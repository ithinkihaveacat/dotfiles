#!/usr/bin/env bash

# Tests: tests/pacioli/
#
# Calls the Gemini API (one request per extraction), so it is slow, costs
# quota, and is mildly non-deterministic. Run manually after changing the
# prompt or schema. Skips automatically when GEMINI_API_KEY is unset.
#
# Fixtures are synthetic (fictional vendors/brands, no real personal data) and
# only exercise format archetypes: Shopify single-brand, in-store till receipt,
# multi-brand department store, marketplace (item in subject), dispatch notice,
# and a return — the last two must classify as non-purchases.

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../../bin/pacioli"
FIX="$DIR/fixtures"

echo "1..11"

# jq drives the assertions on the JSON record.
if ! command -v jq >/dev/null 2>&1; then
  echo "Bail out! jq not found"
  exit 1
fi

# Print the current record as TAP diagnostics (one '# '-prefixed line each).
diag() {
  while IFS= read -r line; do
    printf '# %s\n' "$line"
  done <<<"${REC:-}"
}

# Extract a fixture into $REC; return non-zero if the run failed or produced
# invalid JSON.
extract() {
  REC=$("$BIN" <"$FIX/$1" 2>/dev/null) || return 1
  echo "$REC" | jq -e . >/dev/null 2>&1 || return 1
}

# Test 1: empty stdin is a usage error
if "$BIN" </dev/null >/dev/null 2>&1; then
  echo "not ok 1 - empty stdin should be an error"
else
  echo "ok 1 - empty stdin reported as an error"
fi

# Test 2: --text-only strips full HTML without calling the API
if echo '<html><body><p>Hello&amp;world</p><script>var x=1</script></body></html>' |
  "$BIN" --text-only 2>/dev/null | grep -q "Hello&world"; then
  echo "ok 2 - --text-only strips full HTML and unescapes entities"
else
  echo "not ok 2 - --text-only did not strip full HTML correctly"
fi

# Test 3: short HTML fragments should also strip tags/scripts
FRAGMENT_TEXT=$(printf '<p>Order total</p><script>drop me</script>\n' |
  "$BIN" --text-only 2>/dev/null)
if [[ "$FRAGMENT_TEXT" == "Order total" ]]; then
  echo "ok 3 - --text-only strips short HTML fragments"
else
  echo "not ok 3 - --text-only did not strip short HTML fragments"
  printf '# %s\n' "$FRAGMENT_TEXT"
fi

# Test 4: plain text with comparison symbols should remain plain text
PLAIN_TEXT=$(printf 'Total is 1 < 2 and 3 > 2\n' | "$BIN" --text-only 2>/dev/null)
if [[ "$PLAIN_TEXT" == "Total is 1 < 2 and 3 > 2" ]]; then
  echo "ok 4 - --text-only leaves non-HTML comparison text alone"
else
  echo "not ok 4 - --text-only changed non-HTML comparison text"
  printf '# %s\n' "$PLAIN_TEXT"
fi

if [[ -z "${GEMINI_API_KEY:-}" ]]; then
  for n in 5 6 7 8 9 10 11; do
    echo "ok $n # SKIP GEMINI_API_KEY not set"
  done
  exit 0
fi

# Test 5: Shopify single-brand -> purchase, vendor + brand Thornwood
if extract shopify-single-brand.eml &&
  [[ "$(echo "$REC" | jq -r .is_purchase)" == "true" ]] &&
  echo "$REC" | jq -r .vendor | grep -qi thornwood &&
  echo "$REC" | jq -r '.brands[]' | grep -qi thornwood; then
  echo "ok 5 - shopify single-brand: purchase, vendor + brand Thornwood"
else
  echo "not ok 5 - shopify single-brand extraction wrong"
  diag
fi

# Test 6: in-store receipt -> purchase with multiple line items
if extract instore-receipt.eml &&
  [[ "$(echo "$REC" | jq -r .is_purchase)" == "true" ]] &&
  [[ "$(echo "$REC" | jq -r '.items | length')" -ge 2 ]] &&
  echo "$REC" | jq -r .vendor | grep -qi harborline; then
  echo "ok 6 - in-store receipt: purchase, multiple items, vendor Harborline"
else
  echo "not ok 6 - in-store receipt extraction wrong"
  diag
fi

# Test 7: department store -> multiple distinct brands surfaced
if extract department-multibrand.eml &&
  [[ "$(echo "$REC" | jq -r '.brands | length')" -ge 2 ]] &&
  echo "$REC" | jq -r '.brands[]' | grep -qi vantel; then
  echo "ok 7 - department store: multiple brands incl. Vantel"
else
  echo "not ok 7 - department store brand extraction wrong"
  diag
fi

# Test 8: department store order number captured
if extract department-multibrand.eml &&
  echo "$REC" | jq -r .order_number | grep -q "184903137"; then
  echo "ok 8 - department store: order number captured"
else
  echo "not ok 8 - department store order number missing"
  diag
fi

# Test 9: marketplace with item only in subject still yields the item
if extract marketplace-subject-item.eml &&
  [[ "$(echo "$REC" | jq -r .is_purchase)" == "true" ]] &&
  echo "$REC" | jq -r '.items[].description' | grep -qi sock; then
  echo "ok 9 - marketplace: socks item recovered"
else
  echo "not ok 9 - marketplace item extraction wrong"
  diag
fi

# Test 10: dispatch/shipping notice -> NOT a purchase
if extract dispatch-notice.eml &&
  [[ "$(echo "$REC" | jq -r .is_purchase)" == "false" ]]; then
  echo "ok 10 - dispatch notice classified as non-purchase"
else
  echo "not ok 10 - dispatch notice should be is_purchase=false"
  diag
fi

# Test 11: return/refund -> NOT a purchase
if extract return-confirmation.eml &&
  [[ "$(echo "$REC" | jq -r .is_purchase)" == "false" ]]; then
  echo "ok 11 - return confirmation classified as non-purchase"
else
  echo "not ok 11 - return confirmation should be is_purchase=false"
  diag
fi
