#!/usr/bin/env bash

# Tests: tests/inigo-search/

set -u

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../../skills/interior-design/scripts/inigo-search"

echo "1..8"

# Test 1: --help prints overview and exits 0
OUTPUT=$(mktemp)
trap 'rm -f "$OUTPUT"' EXIT

if "$BIN" --help >"$OUTPUT" 2>&1 &&
  grep -q "Search Inigo property listings" "$OUTPUT" &&
  grep -q "website" "$OUTPUT" &&
  grep -q "sitemap" "$OUTPUT"; then
  echo "ok 1 - --help shows both modes"
else
  echo "not ok 1 - --help missing mode listing"
  sed 's/^/# /' "$OUTPUT"
fi

# Test 2: Bare invocation prints help and exits 0 (cli-tools.md §2.1)
if "$BIN" >"$OUTPUT" 2>&1 &&
  grep -q "website" "$OUTPUT" &&
  grep -q "sitemap" "$OUTPUT"; then
  echo "ok 2 - bare command prints help and exits 0"
else
  echo "not ok 2 - bare command did not print help or exited non-zero"
  sed 's/^/# /' "$OUTPUT"
fi

# Test 3: `help` verb is equivalent to `--help`
HELP_OUT=$("$BIN" --help 2>&1)
HELP_VERB=$("$BIN" help 2>&1)
if [[ "$HELP_OUT" == "$HELP_VERB" ]]; then
  echo "ok 3 - 'help' produces identical output to '--help'"
else
  echo "not ok 3 - 'help' diverges from '--help'"
fi

# Test 4: `website --help` shows website-specific filters
if "$BIN" website --help >"$OUTPUT" 2>&1 &&
  grep -q -- "--price-from" "$OUTPUT" &&
  grep -q -- "--bedrooms" "$OUTPUT" &&
  grep -q -- "--include-featured" "$OUTPUT"; then
  echo "ok 4 - website --help lists website-only filters"
else
  echo "not ok 4 - website --help missing website filters"
  sed 's/^/# /' "$OUTPUT"
fi

# Test 5: `sitemap --help` shows sitemap-specific surface (and not website-only flags)
if "$BIN" sitemap --help >"$OUTPUT" 2>&1 &&
  grep -q -- "--address" "$OUTPUT" &&
  grep -q -- "--json" "$OUTPUT" &&
  ! grep -q -- "--price-from" "$OUTPUT" &&
  ! grep -q -- "--bedrooms" "$OUTPUT"; then
  echo "ok 5 - sitemap --help excludes website-only filters"
else
  echo "not ok 5 - sitemap --help has unexpected/missing flags"
  sed 's/^/# /' "$OUTPUT"
fi

# Test 6: `--active --sold` is rejected (mutual exclusion)
if "$BIN" sitemap --active --sold >"$OUTPUT" 2>&1; then
  echo "not ok 6 - --active --sold should be rejected"
  sed 's/^/# /' "$OUTPUT"
else
  if grep -q "not allowed" "$OUTPUT"; then
    echo "ok 6 - --active --sold mutex enforced"
  else
    echo "not ok 6 - rejected but with unexpected error"
    sed 's/^/# /' "$OUTPUT"
  fi
fi

# Network-dependent tests: probe first, skip individually on failure.
if curl -fsI --max-time 5 -A "Mozilla/5.0" https://www.inigo.com/ >/dev/null 2>&1; then
  NETWORK_OK=1
else
  NETWORK_OK=0
fi

# Test 7: `sitemap --limit 1` returns one inigo.com URL
if [[ $NETWORK_OK -eq 0 ]]; then
  echo "ok 7 - sitemap end-to-end # SKIP network unreachable"
elif "$BIN" sitemap --limit 1 >"$OUTPUT" 2>/dev/null &&
  [[ $(wc -l <"$OUTPUT") -eq 1 ]] &&
  grep -q "^https://www.inigo.com/" "$OUTPUT"; then
  echo "ok 7 - sitemap --limit 1 returns one inigo.com URL"
else
  echo "not ok 7 - sitemap --limit 1 did not return one URL"
  sed 's/^/# /' "$OUTPUT"
fi

# Test 8: `website --active --limit 1` returns one /sales-list/ URL
if [[ $NETWORK_OK -eq 0 ]]; then
  echo "ok 8 - website end-to-end # SKIP network unreachable"
elif "$BIN" website --active --limit 1 >"$OUTPUT" 2>/dev/null &&
  [[ $(wc -l <"$OUTPUT") -eq 1 ]] &&
  grep -q "^https://www.inigo.com/sales-list/" "$OUTPUT"; then
  echo "ok 8 - website --active --limit 1 returns one active listing URL"
else
  echo "not ok 8 - website --active --limit 1 did not return one active URL"
  sed 's/^/# /' "$OUTPUT"
fi
