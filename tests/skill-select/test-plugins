#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "pyyaml",
# ]
# ///
import os
import sys
import tempfile
import importlib.util
from pathlib import Path
from importlib.machinery import SourceFileLoader

# Load skill-select module
test_dir = Path(__file__).resolve().parent
script_path = (
    test_dir.parents[1] / "skills" / "workspace-config" / "scripts" / "skill-select"
)
if not script_path.exists():
    print("1..1")
    print("not ok 1 - skill-select script not found at", script_path)
    sys.exit(1)

loader = SourceFileLoader("skill_select", str(script_path))
spec = importlib.util.spec_from_loader("skill_select", loader)
skill_select = importlib.util.module_from_spec(spec)
try:
    loader.exec_module(skill_select)
except Exception as e:
    print("1..1")
    print(f"not ok 1 - failed to import skill-select: {e}")
    sys.exit(1)

# We have 5 tests
print("1..5")

with tempfile.TemporaryDirectory() as tmpdir:
    tmp_path = Path(tmpdir)

    # Keep an unmutated copy for subprocesses (uv resolves its cache via HOME)
    orig_env = dict(os.environ)

    # Set up mock XDG_CONFIG_HOME
    os.environ["XDG_CONFIG_HOME"] = str(tmp_path)
    config_dir = tmp_path / "skill-select"
    plugins_dir = config_dir / "plugins"
    plugins_dir.mkdir(parents=True, exist_ok=True)

    # Mock home directory for expansion tests
    mock_home = tmp_path / "mock_home"
    mock_home.mkdir()
    os.environ["HOME"] = str(mock_home)

    # Create some dummy local skill directories
    local_skill_dir = mock_home / "local-skill"
    local_skill_dir.mkdir()
    (local_skill_dir / "SKILL.md").write_text(
        "---\nname: local-skill\ndescription: A local skill\n---\nBody"
    )

    corp_skill_dir = mock_home / "corp-skill"
    corp_skill_dir.mkdir()
    (corp_skill_dir / "SKILL.md").write_text(
        "---\nname: corp-skill\ndescription: A corp skill\n---\nBody"
    )

    # ==========================================
    # 1. Test Plugin Loading & Precedence
    # ==========================================
    # Write 50_base.py
    (plugins_dir / "50_base.py").write_text("""
def register(api):
    api.register_skill("conflict-skill", {
        "repo": "dotfiles/conflict",
        "ref": "main"
    })
    api.register_skill("local-skill", {
        "path": "~/local-skill"
    })
""")

    # Write 60_override.py (overrides conflict-skill and adds corp-skill)
    (plugins_dir / "60_override.py").write_text("""
def register(api):
    api.register_skill("conflict-skill", {
        "path": "~/corp-skill"
    })
    api.register_skill("corp-skill", {
        "path": "~/corp-skill"
    })
""")

    catalog = skill_select.load_plugins_catalog()

    # Verify local-skill was loaded and ~ expanded correctly (Test 1)
    expected_local_path = str(local_skill_dir)
    if (
        "local-skill" in catalog
        and catalog["local-skill"].get("path") == expected_local_path
    ):
        print("ok 1 - load_plugins_catalog loads plugins and expands ~ paths")
    else:
        print(
            f"not ok 1 - load_plugins_catalog failed local path: {catalog.get('local-skill')}, expected {expected_local_path}"
        )

    # Verify conflict-skill is overridden by 60_override (Test 2)
    expected_corp_path = str(corp_skill_dir)
    if (
        "conflict-skill" in catalog
        and catalog["conflict-skill"].get("path") == expected_corp_path
    ):
        print("ok 2 - load_plugins_catalog respects alphabetical/numeric precedence")
    else:
        print(
            f"not ok 2 - load_plugins_catalog precedence failed: {catalog.get('conflict-skill')}, expected {expected_corp_path}"
        )

    # ==========================================
    # 2. Test API Validation
    # ==========================================
    api = skill_select.SkillSelectAPI({})
    validation_ok = True

    # Test mixing path and repo
    try:
        api.register_skill(
            "bad-skill", {"path": "/some/path", "repo": "owner/repo", "ref": "main"}
        )
        print("not ok 3 - API failed to reject mixed path and repo")
        validation_ok = False
    except ValueError:
        pass  # Expected

    # Test missing ref for GitHub
    try:
        api.register_skill("bad-skill", {"repo": "owner/repo"})
        print("not ok 3 - API failed to reject missing ref for GitHub")
        validation_ok = False
    except ValueError:
        pass  # Expected

    if validation_ok:
        print("ok 3 - SkillSelectAPI strictly validates schemas")

    # ==========================================
    # 3. Test Resolution (resolve_spec)
    # ==========================================
    try:
        path, name = skill_select.resolve_spec("local-skill", catalog, [])
        if path == local_skill_dir and name == "local-skill":
            print("ok 4 - resolve_spec resolves plugin-defined local entries")
        else:
            print(
                f"not ok 4 - resolve_spec resolved to wrong path: {path}, expected {local_skill_dir}"
            )
    except Exception as e:
        print(f"not ok 4 - resolve_spec failed with exception: {e}")

    # ==========================================
    # 4. Test Template Self-Test
    # ==========================================
    try:
        # Run skill-select --plugin-template via subprocess to capture output.
        # Execute the script directly (its uv shebang supplies its own
        # dependencies) so this test never drifts from skill-select's deps.
        import subprocess

        result = subprocess.run(
            [str(script_path), "--plugin-template"],
            capture_output=True,
            text=True,
            check=True,
            env=orig_env,
        )

        # Write the template output to a new plugin file
        template_plugin = plugins_dir / "90_template_test.py"
        template_plugin.write_text(result.stdout)

        # Reload catalog and verify it loads without throwing exceptions
        # The template registers 'my-local-skill' and 'my-remote-skill'
        test_catalog = skill_select.load_plugins_catalog()

        if "my-local-skill" in test_catalog and "my-remote-skill" in test_catalog:
            print("ok 5 - --plugin-template output is valid and executes successfully")
        else:
            print(
                f"not ok 5 - template plugin failed to register expected skills: {test_catalog.keys()}"
            )
    except subprocess.CalledProcessError as e:
        print(f"not ok 5 - template self-test failed: {e}\n# stderr: {e.stderr}")
    except Exception as e:
        print(f"not ok 5 - template self-test failed with exception: {e}")
