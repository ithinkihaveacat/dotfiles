#!/usr/bin/env bash

set -euo pipefail

# Find script path relative to test
TEST_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT="${TEST_DIR}/../../bin/skill-select"

echo "1..4"

# Test 1: --list enumerates skills without an API key (offline path)
if out=$("${SCRIPT}" --list --search-dirs "${TEST_DIR}/../../skills" 2>/dev/null) &&
	printf '%s' "$out" | grep -q 'skill-select'; then
	echo "ok 1 - --list enumerates skills offline"
else
	echo "not ok 1 - --list did not enumerate skills"
fi

# Test 2: --list --json emits structured output with a path
if "${SCRIPT}" --list --json --search-dirs "${TEST_DIR}/../../skills" 2>/dev/null |
	grep -q '"path"'; then
	echo "ok 2 - --list --json emits structured output"
else
	echo "not ok 2 - --list --json missing structured output"
fi

# Test 3: --help succeeds (exit 0)
if "${SCRIPT}" --help >/dev/null 2>&1; then
	echo "ok 3 - --help exits 0"
else
	echo "not ok 3 - --help failed"
fi

# Test 4: -h is NOT bound to help (reserved per cli-tools.md); must error
if "${SCRIPT}" -h >/dev/null 2>&1; then
	echo "not ok 4 - -h should not be accepted as help"
else
	echo "ok 4 - -h is rejected (not help)"
fi
