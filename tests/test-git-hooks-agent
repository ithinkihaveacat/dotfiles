#!/usr/bin/env bash

# Tests: tests/git-hooks-agent/

set -u

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../bin/git-hooks-agent"
export PATH="$DIR/../bin:$PATH"

# Isolate from the user's/system git config (signing, hooks, templates).
export GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null

echo "1..8"

# Test 1: --help succeeds and documents doctor
if out=$("$BIN" --help 2>&1) && printf '%s' "$out" | grep -q 'doctor'; then
  echo "ok 1 - --help documents doctor"
else
  echo "not ok 1 - --help missing or doesn't mention doctor"
fi

REPO=$(mktemp -d "/tmp/hooks-agent-test.XXXXXX")
trap 'rm -rf "$REPO"' EXIT
git -C "$REPO" init -q

# Test 2: doctor reports the hook missing and exits non-zero before install
if (cd "$REPO" && "$BIN" doctor) >/dev/null 2>&1; then
  echo "not ok 2 - doctor should exit non-zero with no hook installed"
else
  echo "ok 2 - doctor flags a missing hook"
fi

# Test 3: install creates an executable, managed multiplexed hook
if (cd "$REPO" && "$BIN") >/dev/null 2>&1 &&
  [ -x "$REPO/.git/hooks/commit-msg" ] &&
  grep -q "git-hooks-multiplexer" "$REPO/.git/hooks/commit-msg" &&
  [ -x "$REPO/.git/hooks/commit-msg.d/10-agent" ]; then
  echo "ok 3 - install writes a multiplexed agent hook"
else
  echo "not ok 3 - install did not write the expected hook"
fi

# Test 4: doctor now reports ok and exits zero
if (cd "$REPO" && "$BIN" doctor) >/dev/null 2>&1; then
  echo "ok 4 - doctor passes after install"
else
  echo "not ok 4 - doctor failed after install"
fi

# Test 5: all independent commit message errors are reported at once
INVALID_MSG="$REPO/invalid-message"
subject=$(printf 'X%.0s' {1..51})
long_line=$(printf 'x%.0s' {1..73})
printf '%s\n%s\n%s\n%s\n' "$subject" "body starts without a separator" "$long_line" "$long_line" >"$INVALID_MSG"
rc=0
output=$("$REPO/.git/hooks/commit-msg.d/10-agent" "$INVALID_MSG" 2>&1) || rc=$?
if [ "$rc" -eq 0 ]; then
  echo "not ok 5 - invalid message should fail"
elif
  printf '%s\n' "$output" | grep -Fqx "commit-msg: subject must follow 'type(scope): description' format" &&
    printf '%s\n' "$output" | grep -Fqx 'commit-msg: subject is 51 characters (limit: 50)' &&
    printf '%s\n' "$output" | grep -Fqx 'commit-msg: line 2 must be blank (separates subject from body)' &&
    printf '%s\n' "$output" | grep -Fqx 'commit-msg: line 3 is 73 characters (limit: 72)' &&
    printf '%s\n' "$output" | grep -Fqx 'commit-msg: line 4 is 73 characters (limit: 72)'
then
  echo "ok 5 - invalid message reports every formatting error"
else
  echo "not ok 5 - invalid message did not report every formatting error"
fi

# Test 6: a valid message passes without diagnostics
VALID_MSG="$REPO/valid-message"
printf 'feat: validate messages\n\nShort body.\n' >"$VALID_MSG"
if output=$("$REPO/.git/hooks/commit-msg.d/10-agent" "$VALID_MSG" 2>&1) && [ -z "$output" ]; then
  echo "ok 6 - valid message passes"
else
  echo "not ok 6 - valid message should pass"
fi

# Test 7: generated messages retain their format-check exemption
MERGE_MSG="$REPO/merge-message"
printf 'Merge branch invalid formatting that is deliberately long\n' >"$MERGE_MSG"
if output=$("$REPO/.git/hooks/commit-msg.d/10-agent" "$MERGE_MSG" 2>&1) && [ -z "$output" ]; then
  echo "ok 7 - generated message bypasses validation"
else
  echo "not ok 7 - generated message should bypass validation"
fi

# Test 8: doctor flags a foreign (unmanaged) hook
printf '#!/bin/sh\n' >"$REPO/.git/hooks/commit-msg"
if (cd "$REPO" && "$BIN" doctor) >/dev/null 2>&1; then
  echo "not ok 8 - doctor should flag an unmanaged hook"
else
  echo "ok 8 - doctor flags an unmanaged hook"
fi
