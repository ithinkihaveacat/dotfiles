#!/usr/bin/env bash
#
# Tests for socrates CLI argument parsing, help, and exit codes
#
# Does NOT require GEMINI_API_KEY. Tests only the CLI shell behavior.

set -u

SCRIPT_DIR=$(dirname "$0")
ROOT_DIR="$SCRIPT_DIR/../.."
SOCRATES="node $ROOT_DIR/tools/socrates/dist/index.js"

TOTAL_TESTS=16
TEST_NUM=0

echo "1..$TOTAL_TESTS"

pass() {
  TEST_NUM=$((TEST_NUM + 1))
  echo "ok $TEST_NUM - $1"
}

fail() {
  TEST_NUM=$((TEST_NUM + 1))
  echo "not ok $TEST_NUM - $1"
  if [ -n "${2:-}" ]; then
    echo "# $2"
  fi
}

assert_exit_code() {
  local description="$1"
  local expected="$2"
  local actual="$3"
  if [ "$expected" = "$actual" ]; then
    pass "$description"
  else
    fail "$description" "Expected exit code $expected, got $actual"
  fi
}

assert_contains() {
  local description="$1"
  local needle="$2"
  local haystack="$3"
  if echo "$haystack" | grep -qF "$needle"; then
    pass "$description"
  else
    fail "$description" "Expected output to contain: '$needle'"
  fi
}

assert_not_contains() {
  local description="$1"
  local needle="$2"
  local haystack="$3"
  if echo "$haystack" | grep -qF "$needle"; then
    fail "$description" "Expected output NOT to contain: '$needle'"
  else
    pass "$description"
  fi
}

# --- Test: bare command shows help and exits 0 ---

OUTPUT=$($SOCRATES 2>&1)
EXIT_CODE=$?

assert_exit_code "bare command: exits 0" "0" "$EXIT_CODE"
assert_contains "bare command: shows usage" "Usage:" "$OUTPUT"

# --- Test: --help shows help and exits 0 ---

OUTPUT=$($SOCRATES --help 2>&1)
EXIT_CODE=$?

assert_exit_code "--help: exits 0" "0" "$EXIT_CODE"
assert_contains "--help: shows usage" "Usage:" "$OUTPUT"
assert_contains "--help: lists commands" "generate" "$OUTPUT"
assert_contains "--help: shows examples" "Examples:" "$OUTPUT"

# --- Test: unknown command exits non-zero ---

OUTPUT=$($SOCRATES nonexistent 2>&1)
EXIT_CODE=$?

assert_exit_code "unknown command: exits non-zero" "1" "$EXIT_CODE"
assert_contains "unknown command: error message" "unknown command: nonexistent" "$OUTPUT"

# --- Test: missing required arguments ---

OUTPUT=$($SOCRATES status 2>&1)
EXIT_CODE=$?

assert_exit_code "status without db: exits non-zero" "1" "$EXIT_CODE"
assert_contains "status without db: error message" "requires a database path" "$OUTPUT"

OUTPUT=$($SOCRATES answer 2>&1)
EXIT_CODE=$?

assert_exit_code "answer without db: exits non-zero" "1" "$EXIT_CODE"
assert_contains "answer without db: error message" "requires a database path" "$OUTPUT"

OUTPUT=$($SOCRATES delete 2>&1)
EXIT_CODE=$?

assert_exit_code "delete without db: exits non-zero" "1" "$EXIT_CODE"
assert_contains "delete without db: error message" "requires a database path" "$OUTPUT"

# --- Test: --version shows version ---

OUTPUT=$($SOCRATES --version 2>&1)
EXIT_CODE=$?

assert_exit_code "--version: exits 0" "0" "$EXIT_CODE"
assert_contains "--version: shows version string" "socrates" "$OUTPUT"
