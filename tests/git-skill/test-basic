#!/usr/bin/env bash

set -euo pipefail

# Find script path relative to test
TEST_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT="${TEST_DIR}/../../bin/git-skill"

echo "1..13"

# Test 1: catalog runs outside a git work tree
if "${SCRIPT}" catalog >/dev/null 2>&1; then
  echo "ok 1 - catalog runs outside a git work tree"
else
  echo "not ok 1 - catalog failed outside git tree"
fi

# Need a temporary git repo for remaining tests
TMPDIR=$(mktemp -d)
trap 'rm -rf -- "$TMPDIR"' EXIT
cd "$TMPDIR"
git init -q
mkdir -p .claude/skills .agents/skills skills
mkdir -p skills/coding-standards skills/emumanager

# Ensure SKILL_SOURCE_DIRS uses our test skills so we don't resolve against the user's home
export SKILL_SOURCE_DIRS="${TMPDIR}/skills"
export XDG_CONFIG_HOME="${TMPDIR}/.config"
export XDG_CACHE_HOME="${TMPDIR}/.cache"

# Test 2: add multiple skills symlinks into .claude and .agents
if "${SCRIPT}" add coding-standards emumanager >/dev/null 2>&1; then
  if [ -L .claude/skills/coding-standards ] && [ -L .agents/skills/emumanager ]; then
    echo "ok 2 - add multiple skills symlinks into .claude and .agents"
  else
    echo "not ok 2 - add did not create symlinks"
  fi
else
  echo "not ok 2 - add failed"
fi

# Test 3: list returns members with resolved paths
if out=$("${SCRIPT}" list 2>/dev/null) && printf '%s' "$out" | grep -q 'coding-standards'; then
  echo "ok 3 - list returns members with resolved paths"
else
  echo "not ok 3 - list did not return members"
fi

# Test 4: info/exclude contains managed block
if grep -q "coding-standards" .git/info/exclude; then
  echo "ok 4 - info/exclude contains managed block"
else
  echo "not ok 4 - info/exclude missing managed entries"
fi

# Test 5: add bogus-skill-name reports unknown skill
if ! "${SCRIPT}" add bogus-skill-name >/dev/null 2>&1; then
  echo "ok 5 - add bogus-skill-name reports unknown skill"
else
  echo "not ok 5 - add bogus-skill-name succeeded unexpectedly"
fi

# Test 6: remove deletes symlink and exclude entry
if "${SCRIPT}" remove emumanager >/dev/null 2>&1; then
  if [ ! -L .claude/skills/emumanager ] && ! grep -q "emumanager" .git/info/exclude; then
    echo "ok 6 - remove deletes symlink and exclude entry"
  else
    echo "not ok 6 - remove left symlink or exclude entry"
  fi
else
  echo "not ok 6 - remove failed"
fi

# Test 7: clean removes links and managed block
if "${SCRIPT}" clean >/dev/null 2>&1; then
  if [ ! -L .claude/skills/coding-standards ] && ! grep -q "coding-standards" .git/info/exclude; then
    echo "ok 7 - clean removes links and managed block"
  else
    echo "not ok 7 - clean left links or exclude block"
  fi
else
  echo "not ok 7 - clean failed"
fi

# Test 8: resolves names against SKILL_SOURCE_DIRS
mkdir -p custom-skills/test-skill
if SKILL_SOURCE_DIRS="${TMPDIR}/custom-skills" "${SCRIPT}" resolve test-skill >/dev/null 2>&1; then
  echo "ok 8 - resolves names against SKILL_SOURCE_DIRS"
else
  echo "not ok 8 - failed to resolve custom skill"
fi

# Test 9: resolve returns source path; fails on unknown name
if SKILL_SOURCE_DIRS="${TMPDIR}/custom-skills" "${SCRIPT}" resolve test-skill | grep -q 'custom-skills/test-skill'; then
  if ! "${SCRIPT}" resolve nope >/dev/null 2>&1; then
    echo "ok 9 - resolve returns source path; fails on unknown name"
  else
    echo "not ok 9 - resolve succeeded on unknown name"
  fi
else
  echo "not ok 9 - resolve failed to return source path"
fi

# Test 10: add from subdirectory updates top-level exclude
mkdir -p sub
cd sub
if "${SCRIPT}" add coding-standards >/dev/null 2>&1; then
  if grep -q "/.claude/skills/coding-standards" ../.git/info/exclude; then
    echo "ok 10 - add from subdirectory updates top-level exclude"
  else
    echo "not ok 10 - top-level exclude not updated"
  fi
else
  echo "not ok 10 - add from subdirectory failed"
fi
cd ..

# Test 11: update --catalog with empty registry preserves catalog
mkdir -p "${XDG_CACHE_HOME}/skills/catalog/dummy"
touch "${XDG_CACHE_HOME}/skills/catalog/dummy/SKILL.md"
if "${SCRIPT}" update --catalog >/dev/null 2>&1; then
  if [ -d "${XDG_CACHE_HOME}/skills/catalog/dummy" ]; then
    echo "ok 11 - update --catalog with empty registry preserves catalog (GC guard)"
  else
    echo "not ok 11 - update --catalog destroyed unrelated catalog"
  fi
else
  echo "not ok 11 - update --catalog failed"
fi

# Test 12: doctor flags orphaned catalog stub
if "${SCRIPT}" doctor >/dev/null 2>&1; then
  echo "not ok 12 - doctor failed to flag orphan (rc=0)"
else
  echo "ok 12 - doctor flags orphaned catalog stub"
fi

# Test 13: help documents update --catalog
if "${SCRIPT}" help 2>&1 | grep -q '\-\-catalog'; then
  echo "ok 13 - help documents update --catalog"
else
  echo "not ok 13 - help does not document update --catalog"
fi
