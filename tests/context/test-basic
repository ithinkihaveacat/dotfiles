#!/usr/bin/env bash

# Tests: tests/context/

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../../skills/agent-tools/scripts/context"

echo "1..2"

# Test 1: Usage (no args)
OUTPUT=$(mktemp)
trap 'rm -f "$OUTPUT"' EXIT

if ! "$BIN" >"$OUTPUT" 2>&1; then
  if grep -q "usage:" "$OUTPUT" || grep -q "Generate aggregated context" "$OUTPUT"; then
    echo "ok 1 - Usage displayed correctly when no arguments provided"
  else
    echo "not ok 1 - Script failed and usage output missing expected text"
    sed 's/^/# /' "$OUTPUT"
  fi
else
  if grep -q "usage:" "$OUTPUT" || grep -q "Generate aggregated context" "$OUTPUT"; then
    echo "ok 1 - Usage displayed correctly when no arguments provided"
  else
    echo "not ok 1 - Usage output missing expected text"
    sed 's/^/# /' "$OUTPUT"
  fi
fi

# Test 2: Local Directory Support
TMP_DIR=$(mktemp -d)
# We need a new trap to clean up the directory, but we also want to keep the old trap for $OUTPUT if it was still needed?
# Bash traps override each other unless we append, but here we are in a new scope or we can just clean up at the end.
# Let's just clean up at the end of the test or use a single trap.
trap 'rm -f "$OUTPUT"; rm -rf "$TMP_DIR"' EXIT

echo "Hello World" >"$TMP_DIR/file1.txt"
echo "Line 2" >>"$TMP_DIR/file1.txt"
mkdir "$TMP_DIR/subdir"
echo "Subdir file" >"$TMP_DIR/subdir/file2.txt"

if RESPONSE=$("$BIN" "$TMP_DIR"); then
  if echo "$RESPONSE" | grep -q "file1.txt" && echo "$RESPONSE" | grep -q "Hello World" && echo "$RESPONSE" | grep -q "file2.txt" && echo "$RESPONSE" | grep -q "Subdir file"; then
    echo "ok 2 - Local directory packaged correctly"
  else
    echo "not ok 2 - XML output missing expected file content"
    echo "# Response was:"
    # shellcheck disable=SC2001
    echo "$RESPONSE" | sed 's/^/# /'
  fi
else
  echo "not ok 2 - Failed to run context on local directory"
fi
