#!/usr/bin/env bash

set -euo pipefail

# Find script path relative to test
TEST_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT="${TEST_DIR}/../../skills/skill-select/scripts/skill-search"

echo "1..2"

# Test 1: Dry run executes successfully (requires setting env var for test)
if SKILL_SOURCE_DIRS="${TEST_DIR}/../../skills" "${SCRIPT}" --dry-run "test query" >/dev/null; then
	echo "ok 1 - dry run execution"
else
	echo "not ok 1 - dry run execution failed"
	exit 1
fi

# Test 2: Help output
if "${SCRIPT}" --help >/dev/null; then
	echo "ok 2 - help execution"
else
	echo "not ok 2 - help execution failed"
	exit 1
fi
