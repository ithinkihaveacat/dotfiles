#!/usr/bin/env bash

# Tests: tests/markdown-format/

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../../bin/markdown-format"

echo "1..5"

# Test 1: Basic formatting (smoke test)
INPUT=$(mktemp "/tmp/markdown-format.XXXXXX.md")
trap 'rm -f "$INPUT"' EXIT

cat > "$INPUT" << 'EOF'
# Title
Content with  spaces.
EOF

if "$BIN" "$INPUT" >/dev/null 2>&1; then
  echo "ok 1 - Script ran successfully on simple file"
else
  echo "not ok 1 - Script failed on simple file"
fi

# Test 2: Frontmatter preservation
cat > "$INPUT" << 'EOF'
---
name: test
---
# Title
EOF

if "$BIN" "$INPUT" >/dev/null 2>&1; then
  if grep -q "name: test" "$INPUT"; then
    echo "ok 2 - Frontmatter preserved"
  else
    echo "not ok 2 - Frontmatter lost or mangled"
    sed 's/^/# /' "$INPUT"
  fi
else
  echo "not ok 2 - Script failed on file with frontmatter"
fi

# Test 3: Frontmatter wrapping
cat > "$INPUT" << 'EOF'
---
description: >
  This is a very long line in the frontmatter that should be wrapped by the formatter but currently isn't because mdformat doesn't support it natively or we need a plugin.
---
# Title
EOF

if "$BIN" "$INPUT" >/dev/null 2>&1; then
  if grep -q "wrapped by the formatter$" "$INPUT" && grep -q "or we need a plugin.$" "$INPUT"; then
    echo "ok 3 - Frontmatter lines wrapped correctly"
  else
    echo "not ok 3 - Frontmatter lines not wrapped as expected"
    sed 's/^/# /' "$INPUT"
  fi
else
  echo "not ok 3 - Script failed on file needing frontmatter wrapping"
fi

# Test 4: Literal scalar preservation (should NOT wrap)
cat > "$INPUT" << 'EOF'
---
description: |
  This is a very long line in the frontmatter that should NOT be wrapped by the formatter because it is a literal scalar.
---
# Title
EOF

if "$BIN" "$INPUT" >/dev/null 2>&1; then
  if grep -q "should NOT be wrapped by the formatter because it is a literal scalar." "$INPUT"; then
    echo "ok 4 - Literal scalar preserved without wrapping"
  else
    echo "not ok 4 - Literal scalar was wrapped or mangled"
    sed 's/^/# /' "$INPUT"
  fi
else
  echo "not ok 4 - Script failed on file with literal scalar"
fi

# Test 5: Long word handling
cat > "$INPUT" << 'EOF'
---
url: https://www.example.com/this/is/a/very/long/url/that/should/not/be/broken/randomly/even/if/it/exceeds/eighty/characters/limit
---
# Title
EOF

if "$BIN" "$INPUT" >/dev/null 2>&1; then
  if grep -q "https://www.example.com/this/is/a/very/long/url/that/should/not/be/broken/randomly/even/if/it/exceeds/eighty/characters/limit" "$INPUT"; then
    echo "ok 5 - Long word handled without breaking"
  else
    echo "not ok 5 - Long word was broken or mangled"
    sed 's/^/# /' "$INPUT"
  fi
else
  echo "not ok 5 - Script failed on file with long word"
fi
