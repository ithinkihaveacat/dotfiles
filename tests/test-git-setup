#!/usr/bin/env bash

# Tests: tests/git-setup/

set -u

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../bin/git-setup"
export PATH="$DIR/../bin:$PATH"
export SKILL_SOURCE_DIRS="$DIR/../skills"
if [[ -d "/Users/stillers/workspace/corp/skills" ]]; then
  export SKILL_SOURCE_DIRS="$SKILL_SOURCE_DIRS:/Users/stillers/workspace/corp/skills"
fi
if [[ -d "/Users/stillers/workspace/corp/.agents/skills" ]]; then
  export SKILL_SOURCE_DIRS="$SKILL_SOURCE_DIRS:/Users/stillers/workspace/corp/.agents/skills"
fi

# Isolate agent detection so 'permission' steps are deterministic
AGENTS_TMP=$(mktemp -d "/tmp/git-setup-test-agents.XXXXXX")
trap 'rm -rf -- "$AGENTS_TMP"' EXIT

export XDG_CONFIG_HOME="$AGENTS_TMP/config"
mkdir -p "$XDG_CONFIG_HOME/git" "$XDG_CONFIG_HOME/skill/plugins"
cp -R "$DIR/../etc/git/"* "$XDG_CONFIG_HOME/git/"
cp "$DIR/../config/skill/plugins/05_local.py" "$XDG_CONFIG_HOME/skill/plugins/05_local.py"

# Isolate from the user's/system git config (signing, hooks, templates).
export GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null

# Isolate from active user/session skill requirements to ensure deterministic recommendations.
export AGENT_REQUIRED_SKILLS=""
MOCK_HOME="$AGENTS_TMP/mock_home"
mkdir -p "$MOCK_HOME/.claude" "$MOCK_HOME/.gemini/antigravity-cli"
export HOME="$MOCK_HOME"
export AGY_CONFIG_HOME="$AGENTS_TMP/gemini"
export CLAUDE_CONFIG_DIR="$AGENTS_TMP/claude"
export XDG_CACHE_HOME="$AGENTS_TMP/cache"
export UV_CACHE_DIR="${UV_CACHE_DIR:-$MOCK_HOME/.cache/uv}"

# Create a mock agent bin directory and add it to PATH so skill always detects a mock agent
MOCK_BIN="$AGENTS_TMP/bin"
mkdir -p "$MOCK_BIN"
touch "$MOCK_BIN/claude"
chmod +x "$MOCK_BIN/claude"
export PATH="$MOCK_BIN:$PATH"

echo "1..7"

# Test 1: --help succeeds and documents doctor
if out=$("$BIN" --help 2>&1) &&
  printf '%s' "$out" | grep -q 'doctor'; then
  echo "ok 1 - --help documents doctor"
else
  echo "not ok 1 - --help missing or docs absent"
fi

# Test 2: refuses to run outside a git work tree
NONREPO=$(mktemp -d "/tmp/git-setup-test.XXXXXX")
if (cd "$NONREPO" && "$BIN") >/dev/null 2>err; then
  echo "not ok 2 - should have failed outside git work tree"
else
  if grep -q "not inside a git work tree" err; then
    echo "ok 2 - refuses outside git work tree"
  else
    echo "not ok 2 - failed but with unexpected message"
    sed 's/^/# /' err
  fi
fi
rm -f err
rmdir "$NONREPO"

# Test 3: apply mode on a fresh repo
OTHER=$(mktemp -d "/tmp/git-setup-test-other.XXXXXX")
git -C "$OTHER" init -q
export AGENT_REQUIRED_SKILLS="coding-standards"
if out=$(cd "$OTHER" && "$BIN" 2>&1); then
  if [ -x "$OTHER/.git/hooks/commit-msg" ] &&
    [ -L "$OTHER/.claude/skills/coding-standards" ]; then
    echo "ok 3 - git-setup installs hooks and provisions default skills"
  else
    echo "not ok 3 - git-setup missing expected setup"
    printf '%s\n' "$out" | sed 's/^/# /'
  fi
else
  echo "not ok 3 - git-setup failed"
  printf '%s\n' "$out" | sed 's/^/# /'
fi
export AGENT_REQUIRED_SKILLS="" # Clean up
rm -rf "$OTHER"

# Test 4: apply mode on a fresh android repo
ANDROID=$(mktemp -d "/tmp/git-setup-test-android.XXXXXX")
git -C "$ANDROID" init -q
export AGENT_REQUIRED_SKILLS="adb jetpack"
if out=$(cd "$ANDROID" && "$BIN" 2>&1); then
  if [ -L "$ANDROID/.claude/skills/adb" ] &&
    [ -L "$ANDROID/.claude/skills/jetpack" ]; then
    echo "ok 4 - git-setup installs android skills on android repo"
  else
    echo "not ok 4 - git-setup missing expected android setup"
    printf '%s\n' "$out" | sed 's/^/# /'
  fi
else
  echo "not ok 4 - git-setup failed on android repo"
fi
export AGENT_REQUIRED_SKILLS="" # Clean up
rm -rf "$ANDROID"

# Test 5: doctor reports problems (non-zero) on an unconfigured repo. Offline:
# does not call skill suggest.
DOC=$(mktemp -d "/tmp/git-setup-test-doctor.XXXXXX")
git -C "$DOC" init -q
if out=$(cd "$DOC" && "$BIN" doctor 2>&1); then
  echo "not ok 5 - doctor should exit non-zero on unconfigured repo"
  printf '%s\n' "$out" | sed 's/^/# /'
else
  if printf '%s' "$out" | grep -q 'Hooks:'; then
    echo "ok 5 - doctor flags an unconfigured repo"
  else
    echo "not ok 5 - doctor failed but without expected output"
    printf '%s\n' "$out" | sed 's/^/# /'
  fi
fi

# Test 6: after manual setup (hook + one skill, no API call), doctor passes.
export AGENT_REQUIRED_SKILLS="agent-tools"
(cd "$DOC" && git-hooks-agent && skill add agent-tools) >/dev/null 2>&1
if (cd "$DOC" && "$BIN" doctor) >/dev/null 2>&1; then
  echo "ok 6 - doctor passes after hooks and a skill are installed"
else
  echo "not ok 6 - doctor failed on a configured repo"
fi

# Test 7: once an agent appears, doctor flags missing permissions and
# 'permission apply' resolves it (no API call).
mkdir -p "$CLAUDE_CONFIG_DIR"
if (cd "$DOC" && "$BIN" doctor) >/dev/null 2>&1; then
  echo "not ok 7 - doctor should flag missing permission rules"
else
  (cd "$DOC" && permission apply) >/dev/null 2>&1
  if (cd "$DOC" && "$BIN" doctor) >/dev/null 2>&1 &&
    grep -q 'Bash(token-count:\*)' "$DOC/.claude/settings.local.json"; then
    echo "ok 7 - doctor flags missing permissions; permission apply fixes them"
  else
    echo "not ok 7 - permission apply did not satisfy doctor"
  fi
fi
export AGENT_REQUIRED_SKILLS="" # Clean up
rm -rf "$DOC"
