#!/usr/bin/env bash

# Tests: tests/pascal/

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../../bin/pascal"

if [[ -z "${GEMINI_API_KEY:-}" ]]; then
  echo "1..0 # SKIP GEMINI_API_KEY not set"
  exit 0
fi

echo "1..5"

# Test 1: Missing prompt is a usage error (non-zero exit, hint on stderr)
OUTPUT=$(mktemp)
trap 'rm -f "$OUTPUT"' EXIT

if "$BIN" >"$OUTPUT" 2>&1 </dev/null; then
  echo "not ok 1 - Script succeeded with no arguments (expected non-zero exit)"
  sed 's/^/# /' "$OUTPUT"
else
  if grep -q "missing PROMPT argument" "$OUTPUT"; then
    echo "ok 1 - Missing prompt reported as an error"
  else
    echo "not ok 1 - Error output missing expected text"
    sed 's/^/# /' "$OUTPUT"
  fi
fi

# Test 2: Simple Query
QUERY="What is 2 + 2? Answer in one word."
if RESPONSE=$("$BIN" "$QUERY"); then
  if echo "$RESPONSE" | grep -qi "four" || echo "$RESPONSE" | grep -q "4"; then
    echo "ok 2 - Simple query returned correct answer"
  else
    echo "not ok 2 - Simple query returned unexpected answer: $RESPONSE"
  fi
else
  echo "not ok 2 - Simple query failed to execute"
fi

# Test 3: Context Query (stdin context requires a leading '-' argument)
CONTEXT="The secret code is 'bananarama'."
QUERY="What is the secret code?"
if RESPONSE=$(echo "$CONTEXT" | "$BIN" - "$QUERY"); then
  if echo "$RESPONSE" | grep -qi "bananarama"; then
    echo "ok 3 - Context query returned correct answer"
  else
    echo "not ok 3 - Context query returned unexpected answer: $RESPONSE"
  fi
else
  echo "not ok 3 - Context query failed to execute"
fi

# Test 4: Warning on fast piped input (without '-')
echo "secret is xyz" | "$BIN" "What is 2+2?" >/dev/null 2>"$OUTPUT" || true
if grep -q "warning: stdin contains piped input" "$OUTPUT"; then
  echo "ok 4 - Fast piped input warning printed"
else
  echo "not ok 4 - Warning not printed for fast piped input"
  sed 's/^/# /' "$OUTPUT"
fi

# Test 5: Warning on slow piped input (without '-')
( (
  sleep 0.2
  echo "secret is xyz"
) | "$BIN" "What is 2+2?" >/dev/null 2>"$OUTPUT") || true
if grep -q "warning: stdin contains piped input" "$OUTPUT"; then
  echo "ok 5 - Slow piped input warning printed"
else
  echo "not ok 5 - Warning not printed for slow piped input"
  sed 's/^/# /' "$OUTPUT"
fi
