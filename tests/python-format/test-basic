#!/usr/bin/env bash

# Tests: tests/python-format/

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../../bin/python-format"

echo "1..5"

# Setup temporary input file
INPUT=$(mktemp "/tmp/python-format.XXXXXX.py")
trap 'rm -f "$INPUT"' EXIT

# Test 1: Basic formatting (smoke test)
cat > "$INPUT" << 'EOF'
def my_func( a,b ):
    return a+b
EOF

if "$BIN" "$INPUT" >/dev/null 2>&1; then
  # Check if formatting actually applied
  if grep -q "def my_func(a, b):" "$INPUT"; then
    echo "ok 1 - Script ran successfully and formatted file in place"
  else
    echo "not ok 1 - Script did not format file correctly"
    sed 's/^/# /' "$INPUT"
  fi
else
  echo "not ok 1 - Script failed on simple file"
fi

# Test 2: Lint checking with --check (smoke test, should fail on unformatted/bad lint)
cat > "$INPUT" << 'EOF'
import os
def my_func(a, b):
    return a + b
EOF

if ! "$BIN" --check "$INPUT" >/dev/null 2>&1; then
  echo "ok 2 - --check mode exited non-zero on unformatted/lint error file"
else
  echo "not ok 2 - --check mode exited zero on unformatted/lint error file"
fi

# Test 3: Formatting stdin (smoke test)
cat > "$INPUT" << 'EOF'
def other_func(  x  ):
  return x
EOF

OUTPUT=$("$BIN" < "$INPUT" 2>/dev/null)
if [[ "$OUTPUT" == *"def other_func(x):"* ]]; then
  echo "ok 3 - Formatted stdin successfully to stdout"
else
  echo "not ok 3 - Stdin formatting did not produce expected output"
  echo "# Output was: $OUTPUT"
fi

# Test 4: --check option on clean file (should succeed)
# Let's first format the file in place
"$BIN" "$INPUT" >/dev/null 2>&1

if "$BIN" --check "$INPUT" >/dev/null 2>&1; then
  echo "ok 4 - --check mode exited zero on already formatted/clean file"
else
  echo "not ok 4 - --check mode failed on formatted/clean file"
fi

# Test 5: Help option behavior
if "$BIN" --help | grep -q "Usage: python-format"; then
  echo "ok 5 - --help displays correct usage text"
else
  echo "not ok 5 - --help did not display correct usage text"
fi
