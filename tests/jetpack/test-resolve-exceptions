#!/usr/bin/env bash
#
# Tests for bin/jetpack resolve-exceptions subcommand

set -u

# Setup paths
SCRIPT_DIR=$(dirname "$0")
ROOT_DIR="$SCRIPT_DIR/../.."
BIN_JETPACK="$ROOT_DIR/bin/jetpack"

# Total number of tests
TOTAL_TESTS=1
TEST_NUM=0

echo "1..$TOTAL_TESTS"

TEST_NUM=$((TEST_NUM + 1))

if "$BIN_JETPACK" resolve-exceptions androidx.wear:wear STABLE >/dev/null 2>&1; then
	echo "ok $TEST_NUM - resolve-exceptions executes successfully for androidx.wear:wear STABLE"
else
	echo "not ok $TEST_NUM - resolve-exceptions executes successfully for androidx.wear:wear STABLE"
fi
