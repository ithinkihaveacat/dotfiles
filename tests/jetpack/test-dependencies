#!/usr/bin/env bash
#
# Tests for bin/jetpack dependencies subcommand

set -u

# Setup paths
SCRIPT_DIR=$(dirname "$0")
ROOT_DIR="$SCRIPT_DIR/../.."
BIN_JETPACK="$ROOT_DIR/bin/jetpack"

# Total number of tests
TOTAL_TESTS=1
TEST_NUM=0

echo "1..$TOTAL_TESTS"

TEST_NUM=$((TEST_NUM + 1))

# Execute dependencies list check
DEPS_COUNT=$("$BIN_JETPACK" dependencies androidx.wear.tiles:tiles STABLE | wc -l | tr -d ' ')

if [ "$DEPS_COUNT" -gt 0 ]; then
	echo "ok $TEST_NUM - dependencies lists dependencies correctly (found $DEPS_COUNT)"
else
	echo "not ok $TEST_NUM - dependencies lists dependencies correctly (found 0)"
fi
