# See https://direnv.net/ and direnv(1) for more information.

# Ruby - https://github.com/direnv/direnv/wiki/Ruby
#
# System Setup:
#
#   $ ruby-install 3.4 # compiles to $HOME/.local/share/ruby/versions
#
# Activation (in .envrc):
#
#   use ruby 3.4
#   layout ruby # project-local gems in .direnv/ruby (e.g. gem install kamal)
#
# There is no use_ruby in the direnv stdlib (unlike use_node), so it is defined
# below. layout_ruby is provided by the stdlib.

use_ruby() {
  local version=${1:-}
  local prefix=${RUBY_VERSION_PREFIX-ruby-v}
  local search ruby_root

  if [[ -z "${RUBY_VERSIONS:-}" || ! -d "$RUBY_VERSIONS" ]]; then
    log_error "You must specify a \$RUBY_VERSIONS environment variable and a Ruby version!"
    return 1
  fi

  if [[ -z "$version" && -f .ruby-version ]]; then
    version=$(<.ruby-version)
  fi

  version=${version#v}

  if [[ -z "$version" ]]; then
    log_error "I do not know which Ruby version to load (pass one or add a .ruby-version file)."
    return 1
  fi

  search=$(semver_search "$RUBY_VERSIONS" "$prefix" "$version")
  ruby_root="$RUBY_VERSIONS/$prefix$search"

  if [[ ! -d "$ruby_root" ]]; then
    log_error "Unable to find Ruby version ($version) in ($RUBY_VERSIONS)! Install it with: ruby-install $version"
    return 1
  fi

  if [[ ! -x "$ruby_root/bin/ruby" ]]; then
    log_error "Unable to load Ruby binary (ruby) for version ($version)."
    return 1
  fi

  load_prefix "$ruby_root"
  log_status "Successfully loaded Ruby $("$ruby_root/bin/ruby" --version)."
}

# Node - https://github.com/direnv/direnv/wiki/Node
#
# System Setup:
#
#   $ node-install 22 # installs to $HOME/.local/share/node/versions
#
# Activation (in .envrc):
#
#   use node 22
#   layout node # adds node_modules/.bin to PATH
#
# See use_node(), layout_node() in https://github.com/direnv/direnv/blob/master/stdlib.sh

# uv - https://github.com/direnv/direnv/issues/1250#issuecomment-3336516183
#
# Activation (in .envrc):
#
#   layout uv
#   # automatically runs `uv venv` if .venv is missing

layout_uv() {
  if ! has uv; then
    log_error "uv is not installed. Please install it first (see bin/python-install or README.md)."
    return 1
  fi
  [ -d .venv ] || uv venv
  source_env .venv/bin/activate
}

# Agent-assisted Development - Skills & Preflight Gates
#
# Customize the required skills for local agent development on a per-directory
# basis by setting AGENT_REQUIRED_SKILLS in your .envrc file.
#
# Default globally mandated skills (e.g. agent-tools, coding-standards,
# workspace-config, stillers, corp-airlock) can be added to or subtracted from.
#
# Options (in .envrc):
#
#   1. Add a required skill:
#      export AGENT_REQUIRED_SKILLS="$AGENT_REQUIRED_SKILLS my-custom-skill"
#
#   2. Opt-out/Blacklist a globally required skill (case-insensitive, using - or !):
#      export AGENT_REQUIRED_SKILLS="$AGENT_REQUIRED_SKILLS -stillers"
#      export AGENT_REQUIRED_SKILLS="$AGENT_REQUIRED_SKILLS !corp-airlock"
#
# Negated skills are automatically subtracted from the preflight check, and
# 'git-setup' (skill apply) will actively ignore and suppress them during
# bootstrapping, respecting your local repository opt-out.
