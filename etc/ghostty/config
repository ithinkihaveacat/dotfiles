# Full docs:
#
#   - ghostty +show-config --default --docs
#   - https://ghostty.org/docs/config/reference
#
# Problems on remote hosts because TERM=xterm-ghostty? Try
# copying the Ghostty terminal definition to the remote host:
#
#   $ infocmp -x xterm-ghostty | ssh host "mkdir -p ~/.terminfo && tic -x -"
#
# (See the settings `ssh-env` and `ssh-terminfo`, which attempt to
# do this automatically.)

# Bell features - control how the terminal alerts the user
# Options: audio, visual, system, title, border
#   - audio: Plays the file in bell-audio-path
#   - visual: Flashes the screen
#   - system: System alert sound
#   - title: Adds 🔔 to the window title
#   - border: Flashes a border around the surface
# See: src/config/Config.zig (bell-features)
bell-features = system,title

# Command finish notifications
# notify-on-command-finish: Send notification when a command ends.
# Options: never, unfocused, always
# notify-on-command-finish-after: Minimum runtime (e.g., 15s) for notification.
# notify-on-command-finish-action: What to do (bell, notify).
# See: src/config/Config.zig (notify-on-command-finish*)
notify-on-command-finish = unfocused
notify-on-command-finish-after = 15s
notify-on-command-finish-action = notify

# Current theme and font
#theme = Solarized Dark Higher Contrast
theme = Solarized Dark Patched
font-family = Source Code Pro

# Font size in points (supports fractional values like 12.5)
# Default is 13 on macOS, 12 elsewhere.
# On Linux, size is scaled by system DPI and text scaling factors.
# See: src/config/Config.zig (font-size)
font-size = 13

# Font rendering - makes fonts look like Terminal.app on macOS
# Uses CoreText font smoothing to compensate for optical thinning.
# font-thicken-strength: 0-255 (0 is lightest, 255 is heaviest).
# Currently supported on macOS only.
# See: src/config/Config.zig (font-thicken, font-thicken-strength)
font-thicken = true
font-thicken-strength = 230

# Cursor style - appearance of the terminal cursor
# Options: block, bar, underline, block_hollow
# Note: Shell integration may override this at the prompt (unless no-cursor feature is set).
# See: src/config/Config.zig (cursor-style)
cursor-style = bar

# Window padding - space between terminal cells and window edges (in points)
# Can specify two values (e.g., 10,20) for different sides (left,right or top,bottom).
# See: src/config/Config.zig (window-padding-x, window-padding-y)
window-padding-x = 10
window-padding-y = 10

# Balance extra padding between all edges when the viewport is not perfectly
# divisible by the grid cell size.
# See: src/config/Config.zig (window-padding-balance)
window-padding-balance = true

# Initial window size in columns x rows
# Only affects the initial size of new windows. Minimum allowed: 10x4.
# See: src/config/Config.zig (window-width, window-height)
window-width = 130
window-height = 60

# Inherit the working directory from the previously focused window when
# creating a new window. If false, new windows will start in the default
# working directory.
# See: src/config/Config.zig (window-inherit-working-directory)
window-inherit-working-directory = false

# Option key behavior - treat Option as Alt/Meta for terminal apps
# Corresponds to Terminal.app's "Use Option as Meta Key" setting.
# When true, Option sends escape sequences (ESC+key).
# Options: true, false, left, right
# See: src/config/Config.zig (macos-option-as-alt)
macos-option-as-alt = true

# Shell integration - automatic injection of shell scripts
# Options: none, detect, bash, elvish, fish, nushell, zsh
# See: src/config/Config.zig (shell-integration)
shell-integration = none

# macOS app icon style
# Options: official (default), blueprint, chalkboard, microchip, glass,
#          holographic, paper, retro, xray, custom, custom-style
# See: src/config/Config.zig (macos-icon)
macos-icon = retro

# Global keybind for toggling the quick terminal
keybind = global:cmd+,=toggle_quick_terminal

# Quick terminal configuration
# Position options: top, bottom, left, right, center
# Size can be percentages (50%) or pixels (500px).
# For center, primary axis depends on monitor orientation.
# See: src/config/Config.zig (quick-terminal-position, quick-terminal-size)
quick-terminal-position = center
quick-terminal-size = 50%,50%
