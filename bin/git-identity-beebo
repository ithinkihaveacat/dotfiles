#!/usr/bin/env bash
#
# Configure Git identity for personal workspace (Beebo).

set -euo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0")

Configure the local Git repository to use your personal identity
and disable GPG/SSH commit signing (or revert to defaults).

Options:
  --help, -h  Display this help message and exit
EOF
  exit 0
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "$(basename "$0"): error: must be run inside a Git repository" >&2
  exit 1
fi

git config --local user.email "mjs@beebo.org"
git config --local commit.gpgSign false
git config --local --unset user.signingKey 2>/dev/null || true
git config --local --unset gpg.format 2>/dev/null || true

echo "Identity set to Beebo (mjs@beebo.org) with commit signing disabled." >&2
