#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0")

Initializes a new Git repository in the current directory using a template
specifically configured for Node.js projects.

This script sets up a repository with predefined hooks and configurations
from the specified template directory.

Examples:
  # Initialize a Git repository for a Node.js project.
  $(basename "$0")
EOF
  exit 0
}

if [[ "$1" == "--help" ]]; then
  usage
fi

# Template lives alongside the dotfiles tree, two levels up from this script:
# bin/git-hooks-node -> etc/git/templates/node/.
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null && pwd)
git init --template="$SCRIPT_DIR/../etc/git/templates/node"
