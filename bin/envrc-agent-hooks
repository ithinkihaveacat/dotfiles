#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

Creates a .envrc file to set GIT_CONFIG_PARAMETERS for agent hooks.

Options:
  --output FILE  Path to the output file (default: .envrc)
  --help         Display this help message and exit
EOF
  exit 0
}

OUTPUT=".envrc"

while [[ $# -gt 0 ]]; do
  case "$1" in
  --output)
    OUTPUT="$2"
    shift 2
    ;;
  --help)
    usage
    ;;
  *)
    echo "$(basename "$0"): unknown option: $1" >&2
    exit 1
    ;;
  esac
done

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require direnv

cat <<'END' >"$OUTPUT"
export GIT_CONFIG_PARAMETERS="'core.hooksPath=$HOME/.dotfiles/etc/git/templates/agent'"
END

echo "$(basename "$0"): created $OUTPUT"

if [[ "$OUTPUT" == ".envrc" ]]; then
  direnv allow
fi
