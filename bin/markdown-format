#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [FILE...]

Format Markdown files using mdformat.

When FILEs are provided, each file is formatted in place. When no FILE is
provided, reads from standard input and writes to standard output.

Arguments:
  FILE...           Paths to Markdown files to format (optional)

Options:
  -h, --help        Display this help message and exit

Examples:

# Format a file in place
  $(basename "$0") README.md

# Format reading from stdin
  $(basename "$0") < notes.md
EOF
  exit 0
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
fi

if [[ $# -eq 0 && -t 0 ]]; then
  usage
fi

# Parse options
FILES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -*)
      echo "$(basename "$0"): unknown option: $1" >&2
      exit 1
      ;;
    *)
      FILES+=("$1")
      shift
      ;;
  esac
done

format_content() {
  local input_file="$1"
  local output_file="$2"

  # Format with mdformat via uvx
  uvx --with mdformat-gfm mdformat --wrap 80 "$input_file" >/dev/null 2>&1

  if [[ -n "$output_file" ]]; then
    cat "$input_file" >"$output_file"
  fi
}

if [[ ${#FILES[@]} -eq 0 ]]; then
  # Read from stdin, write to stdout
  TMPDIR=$(mktemp -d)
  TMPFILE="$TMPDIR/content.md"
  trap 'rm -rf -- "$TMPDIR"' EXIT
  cat >"$TMPFILE"
  format_content "$TMPFILE"
  cat "$TMPFILE"
else
  # Format files in place
  FAILED=0
  for FILE in "${FILES[@]}"; do
    if [[ ! -f "$FILE" ]]; then
      echo "$(basename "$0"): $FILE: No such file or directory" >&2
      FAILED=1
      continue
    fi
    format_content "$FILE"
    echo "$(basename "$0"): $FILE: formatted"
  done
  exit $FAILED
fi
