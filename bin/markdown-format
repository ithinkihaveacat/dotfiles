#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [FILE...] [OPTIONS]

Format Markdown files using markdownlint-cli2 and prettier.

When FILEs are provided, each file is formatted in place. When no FILE is
provided, reads from standard input and writes to standard output.

Arguments:
  FILE...           Paths to Markdown files to format (optional)

Options:
  -h, --help        Display this help message and exit
  --mdx             Use MDX parser to format text inside HTML-like tags

Note on Tags:
  To ensure text inside custom tags (e.g., <rules>) is formatted correctly,
  you should surround the content with blank lines:

  <rules>

  1. Your list item...

  </rules>

Examples:

# Format a file in place
  $(basename "$0") README.md

# Format using MDX parser for HTML-like tags
  $(basename "$0") --mdx < notes.md
EOF
  exit 0
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
fi

if [[ $# -eq 0 && -t 0 ]]; then
  usage
fi

# Parse options
FILES=()
PRETTIER_PARSER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mdx)
      PRETTIER_PARSER="--parser mdx"
      shift
      ;;
    -*)
      echo "$(basename "$0"): unknown option: $1" >&2
      exit 1
      ;;
    *)
      FILES+=("$1")
      shift
      ;;
  esac
done

# Determine which commands to use
if command -v markdownlint-cli2 >/dev/null 2>&1; then
  MARKDOWNLINT="markdownlint-cli2"
elif command -v npx >/dev/null 2>&1; then
  MARKDOWNLINT="npx -y markdownlint-cli2"
else
  echo "$(basename "$0"): markdownlint-cli2 not found" >&2
  exit 127
fi

if command -v prettier >/dev/null 2>&1; then
  PRETTIER="prettier"
elif command -v npx >/dev/null 2>&1; then
  PRETTIER="npx -y prettier"
else
  echo "$(basename "$0"): prettier not found" >&2
  exit 127
fi

format_content() {
  local input_file="$1"
  local output_file="$2"

  # Fix what can be auto-fixed by the linter
  $MARKDOWNLINT --fix "$input_file" >/dev/null 2>&1

  # Format with prettier
  # shellcheck disable=SC2086
  $PRETTIER --prose-wrap always $PRETTIER_PARSER --write "$input_file" >/dev/null 2>&1

  # Report any remaining lint errors to stderr
  $MARKDOWNLINT "$input_file" >&2 || true

  if [[ -n "$output_file" ]]; then
    cat "$input_file" >"$output_file"
  fi
}

if [[ ${#FILES[@]} -eq 0 ]]; then
  # Read from stdin, write to stdout
  TMPDIR=$(mktemp -d)
  TMPFILE="$TMPDIR/content.md"
  trap 'rm -rf -- "$TMPDIR"' EXIT
  cat >"$TMPFILE"
  format_content "$TMPFILE"
  cat "$TMPFILE"
else
  # Format files in place
  FAILED=0
  for FILE in "${FILES[@]}"; do
    if [[ ! -f "$FILE" ]]; then
      echo "$(basename "$0"): $FILE: No such file or directory" >&2
      FAILED=1
      continue
    fi
    format_content "$FILE"
    echo "$(basename "$0"): $FILE: formatted"
  done
  exit $FAILED
fi
