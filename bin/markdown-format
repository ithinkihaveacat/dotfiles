#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [FILE...]

Format Markdown files using mdformat.

When FILEs are provided, each file is formatted in place. When no FILE is
provided, reads from standard input and writes to standard output.

Arguments:
  FILE...           Paths to Markdown files to format (optional)

Options:
  -h, --help        Display this help message and exit

Examples:

# Format a file in place
  $(basename "$0") README.md

# Format reading from stdin
  $(basename "$0") < notes.md
EOF
  exit 0
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require uvx
require shasum

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
fi

if [[ $# -eq 0 && -t 0 ]]; then
  usage
fi

# Parse options
FILES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -*)
      echo "$(basename "$0"): unknown option: $1" >&2
      exit 1
      ;;
    *)
      FILES+=("$1")
      shift
      ;;
  esac
done

format_content() {
  local input_file="$1"

  # Check if mdformat is installed
  if ! uv tool list | grep -q "^mdformat "; then
    echo "mdformat not found, installing..." >&2
    # We try to install with plugins. If this fails, we'll try to run via uvx anyway
    # but at least the user will see the error.
    if ! uv tool install mdformat --with mdformat-gfm --with mdformat-frontmatter; then
      echo "$(basename "$0"): warning: failed to install mdformat, will try running via uvx" >&2
    fi
  fi

  # Run mdformat. We use --with to ensure plugins are available even if not installed
  # or if running via uvx. If it is installed, uv is smart enough to use the cached env.
  # mdformat edits in-place when passed a file.
  if ! uvx --with mdformat-gfm --with mdformat-frontmatter mdformat --wrap 80 "$input_file"; then
    echo "$(basename "$0"): error: mdformat failed on $input_file" >&2
    return 1
  fi
  return 0
}

if [[ ${#FILES[@]} -eq 0 ]]; then
  # Read from stdin, write to stdout
  TMPDIR=$(mktemp -d)
  TMPFILE="$TMPDIR/content.md"
  trap 'rm -rf -- "$TMPDIR"' EXIT
  cat >"$TMPFILE"
  if format_content "$TMPFILE" >&2; then
    cat "$TMPFILE"
  else
    exit 1
  fi
else
  # Format files in place
  FAILED=0
  for FILE in "${FILES[@]}"; do
    if [[ ! -f "$FILE" ]]; then
      echo "$(basename "$0"): $FILE: No such file or directory" >&2
      FAILED=1
      continue
    fi

    # Track if file changed
    OLD_HASH=$(shasum -a 256 "$FILE" | cut -d' ' -f1)

    if format_content "$FILE" >&2; then
      NEW_HASH=$(shasum -a 256 "$FILE" | cut -d' ' -f1)
      if [[ "$OLD_HASH" != "$NEW_HASH" ]]; then
        echo "$(basename "$0"): $FILE: formatted"
      else
        echo "$(basename "$0"): $FILE: already formatted"
      fi
    else
      FAILED=1
    fi
  done
  exit $FAILED
fi
