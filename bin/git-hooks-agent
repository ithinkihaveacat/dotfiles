#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [--force]

Install git hooks for AI agent workflows into the current repository.

Hooks installed:
  commit-msg   Enforces commit message format; strips Co-Authored-By trailers

The commit-msg hook edits the message in place before the commit is
written. Use git-commit-clean to clean up any existing commits.

Options:
  --force   Overwrite an existing hook not managed by this tool
  --help    Display this help message and exit

Examples:
  cd ~/project && $(basename "$0")
  $(basename "$0") --force
EOF
  exit 0
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "$(basename "$0"): $1 not found" >&2
    exit 127
  }
}

require git

MARKER="git-hooks-agent"
TEMPLATE_DIR="$HOME/.dotfiles/etc/git/templates/agent/hooks"

force=0
for arg in "$@"; do
  case "$arg" in
    --help) usage ;;
    --force) force=1 ;;
    -*)
      echo "$(basename "$0"): unknown option: $arg" >&2
      echo "Try '$(basename "$0") --help' for more information." >&2
      exit 1
      ;;
    *)
      echo "$(basename "$0"): unexpected argument: $arg" >&2
      echo "Try '$(basename "$0") --help' for more information." >&2
      exit 1
      ;;
  esac
done

git_dir=$(git rev-parse --git-dir 2>/dev/null) || {
  echo "$(basename "$0"): not a git repository" >&2
  exit 1
}

hooks_dir="$git_dir/hooks"
mkdir -p "$hooks_dir"

install_hook() {
  local name="$1"
  local src="$TEMPLATE_DIR/$name"
  local dst="$hooks_dir/$name"

  if [ ! -f "$src" ]; then
    echo "$(basename "$0"): hook source not found: $src" >&2
    return 1
  fi

  if [ -f "$dst" ] && ! grep -q "$MARKER" "$dst"; then
    if [ "$force" -eq 0 ]; then
      echo "$(basename "$0"): $dst already exists and is not managed by this tool" >&2
      echo "Inspect it, then use --force to overwrite or chain it manually." >&2
      return 1
    fi
  fi

  cp "$src" "$dst" && chmod +x "$dst"
}

install_hook commit-msg || exit 1
echo "$(basename "$0"): hooks installed in $(git rev-parse --show-toplevel)"
