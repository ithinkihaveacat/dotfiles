#!/usr/bin/env bash

set -euo pipefail

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

usage() {
  cat <<EOF
Usage: $(basename "$0") COMMAND

Launch an interactive AI chat session specialized for a specific command.

Starts Gemini CLI primed with knowledge of the given command, so that
unqualified queries like "how many commits?" are understood in context
(e.g., as a git question when wrapping git). The agent runs commands
directly to answer questions rather than just suggesting them.

For commands located under \$HOME (personal scripts and tools), the
script automatically captures --help output and includes it in the
prompt, giving the AI context for commands it wouldn't otherwise know.

Arguments:
  COMMAND     The command to wrap (must be in PATH and executable)

Options:
  --help      Display this help message and exit

Examples:
  $(basename "$0") git
  $(basename "$0") kubectl
  $(basename "$0") my-custom-script
EOF
  exit 0
}

if [[ "${1:-}" == "--help" ]]; then
  usage
fi

if [[ -z "${1:-}" ]]; then
  echo "$(basename "$0"): missing command operand" >&2
  echo "Try '$(basename "$0") --help' for more information." >&2
  exit 1
fi

require gemini

CMD="$1"
CMD_PATH=$(command -v "$CMD" 2>/dev/null) || true

if [[ -z "$CMD_PATH" ]]; then
  echo "$(basename "$0"): $CMD: command not found" >&2
  exit 1
fi

if [[ ! -x "$CMD_PATH" ]]; then
  echo "$(basename "$0"): $CMD: not executable" >&2
  exit 1
fi

PROMPT="Provide a chat interface to the command \`$CMD\`. Unless explicitly specified otherwise, assume all queries, requests and commands relate or apply to \`$CMD\`. Run commands directly to answer questions rather than just suggesting them."

# For commands under $HOME (personal scripts/tools), include --help
# output so the AI has context for commands it wouldn't otherwise know.
case "$CMD_PATH" in
  "$HOME"/*)
    if HELP_OUTPUT=$("$CMD" --help 2>&1); then
      PROMPT="$PROMPT

Here is the help output for \`$CMD\`:

$HELP_OUTPUT"
    fi
    ;;
esac

exec gemini -i "$PROMPT"
