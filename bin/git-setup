#!/usr/bin/env bash

set -euo pipefail

usage() {
	cat <<EOF
Usage: $(basename "$0") [--force]

Configure the current git repository by installing hooks and provisioning skills.

This command is typically invoked automatically on 'git clone' by the
post-checkout hook from ~/.dotfiles/etc/git/templates/global.

Options:
  --force   Pass --force to git-hooks-agent (overwrite a foreign commit-msg hook)
  --help    Display this help message and exit

Examples:
  $(basename "$0")
  $(basename "$0") --force
EOF
	exit 0
}

require() {
	command -v "$1" >/dev/null 2>&1 || {
		echo "$(basename "$0"): $1 not found" >&2
		exit 127
	}
}

force=0
for arg in "$@"; do
	case "$arg" in
	--help) usage ;;
	--force) force=1 ;;
	-*)
		echo "$(basename "$0"): unknown option: $arg" >&2
		echo "Try '$(basename "$0") --help' for more information." >&2
		exit 1
		;;
	*)
		echo "$(basename "$0"): unexpected argument: $arg" >&2
		echo "Try '$(basename "$0") --help' for more information." >&2
		exit 1
		;;
	esac
done

require git
require git-hooks-agent
require git-skill

if ! inside=$(git rev-parse --is-inside-work-tree 2>/dev/null) || [ "$inside" != "true" ]; then
	echo "$(basename "$0"): not inside a git work tree (run 'git init' to create one)" >&2
	exit 1
fi
if [ "$(git rev-parse --is-bare-repository)" = "true" ]; then
	echo "$(basename "$0"): refusing to run in a bare repository" >&2
	exit 1
fi

root=$(git rev-parse --show-toplevel)
cd "$root"

echo "$(basename "$0"): installing hooks and provisioning skills"

hook_args=()
[ "$force" -eq 1 ] && hook_args+=(--force)

if [ "${#hook_args[@]}" -gt 0 ]; then
	git-hooks-agent "${hook_args[@]}"
else
	git-hooks-agent
fi

git skill apply
