#!/usr/bin/env bash

set -eo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") <command> [skill...]

Manage per-workspace agent skills as untracked symlinks under .claude/skills
and .agents/skills, keeping git quiet via .git/info/exclude. Each command acts
on every destination at once, so they stay in sync. Operates on the current
git repository.

Commands:
  add SPEC...     Add a skill: a local path or a registered topic name
  remove NAME...  Remove a skill this tool added (symlink + ignore entry)
  list            List skills this tool is managing in the current repo
  update SPEC...  Re-fetch registered topics (--all for every managed skill)
  clean           Remove all skills this tool added and its info/exclude block
  topics          List registered topics and their GitHub sources

Aliases:
  rm              Alias for remove

Options:
  --help          Display this help message and exit

Skill specs:
  'add' resolves a SPEC, in order, as:
    path          A local skill directory (absolute, ./relative, or ~/...)
    topic         A registered name (see 'topics'), fetched from GitHub into
                  SKILL_CACHE_DIR and symlinked from there
    name          A directory of that name under SKILL_SOURCE_DIR
  Topics are downloaded once and reused; 'update' re-fetches them. Local skills
  have no upstream, so update skips them.

Registry:
  Topics map a name to a GitHub source. Built-in topics live in this script.
  Add your own (including private/internal repos) without editing it by writing
  lines to ~/.config/skill/registry or ~/.config/skill/registry.d/*:
    <name>  <owner>/<repo>  <ref>  <subpath>
  Later definitions win. ref defaults to main; subpath may be omitted.

Environment:
  SKILL_SOURCE_DIR   Directory searched for skills by name
                     (default: ~/.agents/skills)
  SKILL_CACHE_DIR    Where topic downloads are cached
                     (default: \${XDG_CACHE_HOME:-~/.cache}/agent-skills)

Examples:
  $(basename "$0") add home-assistant-best-practices
  $(basename "$0") add ~/src/my-skill
  $(basename "$0") topics
  $(basename "$0") update home-assistant-best-practices
  $(basename "$0") update --all
  $(basename "$0") list
  $(basename "$0") remove home-assistant-best-practices
  $(basename "$0") clean

Skills are added as symlinks and recorded in .git/info/exclude so git never
reports them. The tool is purely additive: it never touches skills the repo
tracks, and refuses to shadow a tracked skill of the same name.
EOF
  exit 0
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

die() {
  echo >&2 "$(basename "$0"): $1"
  exit 1
}

# Git-style error for subcommands: "skill <subcommand>: <message>".
cmderr() {
  echo >&2 "$(basename "$0") $1: $2"
  exit 1
}

SKILL_SOURCE_DIR="${SKILL_SOURCE_DIR:-$HOME/.agents/skills}"
SKILL_CACHE_DIR="${SKILL_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/agent-skills}"

# Project skill directories to populate, relative to the repo root. Claude Code
# reads .claude/skills; Antigravity reads .agents/skills. A skill is symlinked
# into each, and each link is recorded in info/exclude.
DEST_DIRS=(".claude/skills" ".agents/skills")

MARK_BEGIN="# >>> agent-skills (managed by 'skill') >>>"
MARK_END="# <<< agent-skills (managed by 'skill') <<<"

# Print the skill lines currently recorded in the managed block.
read_managed() {
  [ -f "$EXCLUDE" ] || return 0
  awk -v s="$MARK_BEGIN" -v e="$MARK_END" \
    '$0==s{b=1; next} $0==e{b=0; next} b{print}' "$EXCLUDE"
}

# Rewrite info/exclude: strip the old managed block, then append a fresh one
# built from the arguments (sorted, unique). With no arguments the block is
# removed entirely.
rewrite_block() {
  local tmp
  tmp="$(mktemp)"
  if [ -f "$EXCLUDE" ]; then
    awk -v s="$MARK_BEGIN" -v e="$MARK_END" \
      '$0==s{b=1; next} $0==e{b=0; next} !b{print}' "$EXCLUDE" >"$tmp"
  fi
  if [ "$#" -gt 0 ]; then
    {
      echo "$MARK_BEGIN"
      printf '%s\n' "$@" | sort -u
      echo "$MARK_END"
    } >>"$tmp"
  fi
  mv "$tmp" "$EXCLUDE"
}

contains() {
  local needle="$1"
  shift
  local item
  for item in "$@"; do
    [ "$item" = "$needle" ] && return 0
  done
  return 1
}

# Drop each skills directory (and its parent) if we have left it empty.
prune_dirs() {
  local d
  for d in "${DEST_DIRS[@]}"; do
    rmdir "$d" 2>/dev/null || true
    rmdir "$(dirname "$d")" 2>/dev/null || true
  done
}

# Download a subdirectory of a GitHub repo into the cache. Mirrors bin/context:
# fetch the ref tarball and strip the top-level "<repo>-<ref>/" wrapper. The ref
# may be a branch, tag, or commit. Args: owner repo ref subpath cachedir
fetch_github() {
  local owner="$1" repo="$2" ref="$3" subpath="$4" cachedir="$5"
  require curl
  require tar
  local archive="https://github.com/$owner/$repo/archive/$ref.tar.gz"
  local tmp
  tmp="$(mktemp -d)"
  echo "fetching $archive" >&2
  if ! curl -fsSL --netrc-optional "$archive" | tar -xz -C "$tmp" --strip-components=1; then
    rm -rf "$tmp"
    die "failed to fetch or extract $archive"
  fi
  local src="$tmp"
  [ -n "$subpath" ] && src="$tmp/$subpath"
  if [ ! -d "$src" ]; then
    rm -rf "$tmp"
    die "path not found in $owner/$repo@$ref: ${subpath:-/}"
  fi
  mkdir -p "$(dirname "$cachedir")"
  rm -rf "$cachedir"
  cp -R "$src" "$cachedir"
  rm -rf "$tmp"
}

# Built-in topic registry. Each non-comment line maps a topic name to a GitHub
# source: "<name> <owner>/<repo> <ref> <subpath>". ref defaults to main and
# subpath may be empty. Extend the registry without editing this script (see
# registry_sources).
builtin_registry() {
  cat <<'EOF'
home-assistant-best-practices  homeassistant-ai/skills  main  skills/home-assistant-best-practices
EOF
}

# Emit the built-in registry followed by any plugin registry files, in order.
# Drop "<name> <owner>/<repo> <ref> <subpath>" lines into
# ~/.config/skill/registry or ~/.config/skill/registry.d/* to add topics
# (including private repos); later definitions win.
registry_sources() {
  builtin_registry
  local dir="${XDG_CONFIG_HOME:-$HOME/.config}/skill"
  [ -f "$dir/registry" ] && cat "$dir/registry"
  if [ -d "$dir/registry.d" ]; then
    local f
    for f in "$dir"/registry.d/*; do
      [ -f "$f" ] && cat "$f"
    done
  fi
  return 0
}

# Look up a topic by name. Echoes "<owner>/<repo>\t<ref>\t<subpath>" for the
# last matching definition, or nothing if the name is not registered.
registry_lookup() {
  registry_sources | awk -v want="$1" '
    /^[[:space:]]*#/ { next }
    NF < 2 { next }
    $1 == want { repo = $2; ref = $3; sp = $4 }
    END {
      if (repo != "") {
        if (ref == "") ref = "main"
        printf "%s\t%s\t%s\n", repo, ref, sp
      }
    }
  '
}

# Fetch (or reuse) a registered topic into the cache.
# Sets RESOLVED_SRC, RESOLVED_NAME, RESOLVED_KIND.
resolve_topic() {
  local name="$1" repo="$2" ref="$3" subpath="$4"
  local owner="${repo%%/*}" reponame="${repo#*/}"
  local cachedir="$SKILL_CACHE_DIR/$owner/$reponame/$ref${subpath:+/$subpath}"
  if [ ! -d "$cachedir" ] || [ -z "$(ls -A "$cachedir" 2>/dev/null)" ]; then
    fetch_github "$owner" "$reponame" "$ref" "$subpath" "$cachedir"
  else
    echo "using cached $repo@$ref (run 'skill update $name' to refresh)" >&2
  fi
  RESOLVED_SRC="$cachedir"
  RESOLVED_NAME="$name"
}

# Resolve a skill spec to a source directory to symlink. A spec is a local path,
# a registered topic name, or a name found under SKILL_SOURCE_DIR (in that
# order). Sets RESOLVED_SRC, RESOLVED_NAME, RESOLVED_KIND.
resolve_spec() {
  local arg="$1" entry repo ref subpath
  arg="${arg/#\~/$HOME}" # expand a leading ~ if the user quoted it
  case "$arg" in
    http://* | https://*)
      die "URLs are not accepted; register '$arg' as a topic (see --help)"
      ;;
    /* | ./* | ../*)
      [ -d "$arg" ] || die "skill source not found: $arg"
      RESOLVED_SRC="$arg"
      RESOLVED_NAME="$(basename "$arg")"
      return
      ;;
  esac
  if [[ "$arg" == */* ]]; then
    [ -d "$arg" ] || die "skill source not found: $arg"
    RESOLVED_SRC="$arg"
    RESOLVED_NAME="$(basename "$arg")"
    return
  fi
  entry="$(registry_lookup "$arg")"
  if [ -n "$entry" ]; then
    IFS=$'\t' read -r repo ref subpath <<<"$entry"
    resolve_topic "$arg" "$repo" "$ref" "$subpath"
    return
  fi
  if [ -d "$SKILL_SOURCE_DIR/$arg" ]; then
    RESOLVED_SRC="$SKILL_SOURCE_DIR/$arg"
    RESOLVED_NAME="$arg"
    return
  fi
  die "unknown skill '$arg': not a path, a registered topic, or under $SKILL_SOURCE_DIR"
}

cmd_add() {
  [ "$#" -ge 1 ] || cmderr add "skill name required"
  local managed=()
  local line
  while IFS= read -r line; do
    [ -n "$line" ] && managed+=("$line")
  done < <(read_managed)

  local arg src name d relpath line
  for arg in "$@"; do
    resolve_spec "$arg"
    src="$RESOLVED_SRC"
    name="$RESOLVED_NAME"

    # Reject collisions across every destination before touching any of them.
    for d in "${DEST_DIRS[@]}"; do
      relpath="$d/$name"
      if git ls-files --error-unmatch -- "$relpath" >/dev/null 2>&1; then
        cmderr add "repo already tracks $relpath; refusing to shadow it"
      fi
      if [ -e "$relpath" ] && [ ! -L "$relpath" ]; then
        cmderr add "$relpath exists and is not a symlink; refusing to overwrite"
      fi
    done

    # Link into each destination, flushing the record after each link so the
    # symlinks and info/exclude never disagree even if interrupted mid-skill.
    for d in "${DEST_DIRS[@]}"; do
      relpath="$d/$name"
      line="/$d/$name"
      mkdir -p "$d"
      rm -f "$relpath"
      ln -s "$src" "$relpath"
      contains "$line" "${managed[@]}" || managed+=("$line")
      rewrite_block "${managed[@]}"
    done
    echo "added $name -> $src" >&2
  done
}

cmd_rm() {
  [ "$#" -ge 1 ] || cmderr remove "skill name required"
  local managed=()
  local line
  while IFS= read -r line; do
    [ -n "$line" ] && managed+=("$line")
  done < <(read_managed)

  local arg name d relpath kept item removed
  for arg in "$@"; do
    name="$(basename "$arg")"
    removed=0
    for d in "${DEST_DIRS[@]}"; do
      relpath="$d/$name"
      line="/$d/$name"

      if [ -L "$relpath" ]; then
        rm -f "$relpath"
        removed=1
      elif [ -e "$relpath" ]; then
        cmderr remove "$relpath is not a symlink we manage; leaving it untouched"
      fi

      kept=()
      for item in "${managed[@]}"; do
        [ "$item" = "$line" ] || kept+=("$item")
      done
      managed=("${kept[@]}")
    done

    if [ "$removed" -eq 1 ]; then
      echo "removed $name" >&2
    else
      echo "remove: $name not present; clearing record" >&2
    fi
  done
  rewrite_block "${managed[@]}"
  prune_dirs
}

# List managed skill names, deduplicated across destinations.
cmd_list() {
  local line rel d
  read_managed | while IFS= read -r line; do
    rel="${line#/}"
    for d in "${DEST_DIRS[@]}"; do
      case "$rel" in
        "$d"/*) echo "${rel#"$d"/}" ;;
      esac
    done
  done | sort -u
}

cmd_clean() {
  local managed=()
  local line
  while IFS= read -r line; do
    [ -n "$line" ] && managed+=("$line")
  done < <(read_managed)

  local any_dir=0 d
  for d in "${DEST_DIRS[@]}"; do
    [ -d "$d" ] && any_dir=1
  done
  if [ "${#managed[@]}" -eq 0 ] && [ "$any_dir" -eq 0 ]; then
    echo "clean: nothing to do" >&2
    return 0
  fi

  local relpath removed=0 left=0
  for line in "${managed[@]}"; do
    relpath="${line#/}"
    if [ -L "$relpath" ]; then
      rm -f "$relpath"
      removed=$((removed + 1))
      echo "removed $relpath" >&2
    elif [ -e "$relpath" ]; then
      echo "clean: $relpath is not a symlink; leaving it in place" >&2
      left=$((left + 1))
    fi
  done

  rewrite_block
  prune_dirs
  echo "clean: removed $removed link(s); cleared exclude block" >&2
  [ "$left" -eq 0 ] || echo "clean: $left path(s) left in place (not symlinks)" >&2
}

# Re-fetch registered topics. Local skills have no upstream and are skipped.
cmd_update() {
  local names=()
  if [ "${1:-}" = "--all" ]; then
    local n
    while IFS= read -r n; do
      [ -n "$n" ] && names+=("$n")
    done < <(cmd_list)
  elif [ "$#" -ge 1 ]; then
    names=("$@")
  else
    cmderr update "skill name or --all required"
  fi

  local name entry repo ref subpath owner reponame cachedir relpath target
  for name in "${names[@]}"; do
    relpath="${DEST_DIRS[0]}/$name"
    if [ ! -L "$relpath" ]; then
      echo "update: $name is not currently added; skipping" >&2
      continue
    fi
    target="$(readlink "$relpath")"
    case "$target" in
      "$SKILL_CACHE_DIR"/*) : ;;
      *)
        echo "update: $name is local; nothing to update" >&2
        continue
        ;;
    esac
    entry="$(registry_lookup "$name")"
    if [ -z "$entry" ]; then
      echo "update: $name has no registry entry; cannot refresh" >&2
      continue
    fi
    IFS=$'\t' read -r repo ref subpath <<<"$entry"
    owner="${repo%%/*}"
    reponame="${repo#*/}"
    cachedir="$SKILL_CACHE_DIR/$owner/$reponame/$ref${subpath:+/$subpath}"
    fetch_github "$owner" "$reponame" "$ref" "$subpath" "$cachedir"
    echo "updated $name from $repo@$ref" >&2
  done
}

# List registered topics and their GitHub sources, one "name<TAB>source" per
# line. Needs no git repository.
cmd_topics() {
  registry_sources | awk '
    /^[[:space:]]*#/ { next }
    NF < 2 { next }
    {
      ref = ($3 == "" ? "main" : $3)
      src = $2 "@" ref
      if ($4 != "") src = src "/" $4
      map[$1] = src
    }
    END { for (k in map) printf "%s\t%s\n", k, map[k] }
  ' | sort
}

main() {
  case "${1:-}" in
    "" | --help | help) usage ;;
    topics)
      cmd_topics
      return
      ;;
  esac

  require git

  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null)" ||
    die "not inside a git work tree"
  cd "$root"
  EXCLUDE="$(git rev-parse --git-path info/exclude)"
  mkdir -p "$(dirname "$EXCLUDE")"

  local cmd="$1"
  shift
  case "$cmd" in
    add) cmd_add "$@" ;;
    remove | rm) cmd_rm "$@" ;;
    list) cmd_list "$@" ;;
    update) cmd_update "$@" ;;
    clean) cmd_clean "$@" ;;
    *)
      echo >&2 "$(basename "$0"): unknown command '$cmd'"
      echo >&2 "Try '$(basename "$0") --help' for more information."
      exit 1
      ;;
  esac
}

main "$@"
