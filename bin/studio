#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] [FILE]

Open a file or project in Android Studio.

Options:
  --stable     Use the stable version of Android Studio
  --preview    Use the preview version of Android Studio (default)
  -w, --wait   Wait for the app to exit (blocks)
  --help       Display this help message and exit

Examples:
  $(basename "$0") .
  $(basename "$0") --stable .
  $(basename "$0") --preview .
EOF
  exit 0
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require open

CHANNEL="preview"
WAIT_FLAG=""
STUDIO_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      ;;
    --stable)
      CHANNEL="stable"
      shift
      ;;
    --preview)
      CHANNEL="preview"
      shift
      ;;
    -w | --wait)
      WAIT_FLAG="-W"
      shift
      ;;
    *)
      STUDIO_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ "$CHANNEL" == "stable" ]]; then
  APP_PATH="/Applications/Android Studio.app"
else
  APP_PATH="/Applications/Android Studio Preview.app"
fi

BINARY="$APP_PATH/Contents/MacOS/studio"

if [[ ! -d "$APP_PATH" ]]; then
  echo "$(basename "$0"): $APP_PATH not found" >&2
  exit 1
fi

if [[ ! -x "$BINARY" ]]; then
  echo "$(basename "$0"): $BINARY not found or not executable" >&2
  exit 1
fi

# shellcheck disable=SC2086
open -na "$BINARY" $WAIT_FLAG --args "${STUDIO_ARGS[@]}"
