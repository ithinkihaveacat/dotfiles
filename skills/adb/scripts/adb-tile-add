#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] COMPONENT_NAME

Adds a tile provided by COMPONENT_NAME to the carousel. The script automatically
shows the tile after it has been added (no separate call to adb-tile-show is
needed).

Arguments:
  COMPONENT_NAME  A string composed of the package name and a class in that
                  package, for example:
                  com.example.wear.tiles/com.example.wear.tiles.PreviewTileService

Options:
  --type TYPE     Tile type: FULLSCREEN, LARGE (default), or SMALL. Only applies
                  to tiles supporting the BIND_WIDGET_PROVIDER intent (e.g.,
                  Glance-based tiles).
  --no-show       Do not show the tile after adding it
  --wait          Wait for the tile to be visible (default)
  --no-wait       Do not wait for visibility (return immediately)
  --help          Display this help message and exit

Environment:
  ANDROID_SERIAL  Serial number of device to connect to (see 'adb devices -l').
                  To target a specific device, use:
                    env ANDROID_SERIAL=<serial> $(basename "$0")

Examples:
  $(basename "$0") com.google.android.wearable.shell/.weather.WeatherTileService
  $(basename "$0") --type LARGE com.google.example.wear_widget/.HelloWidgetService
  $(basename "$0") --no-show com.google.example.wear_widget/.HelloWidgetService
EOF
  exit 0
}

if [[ $# -eq 0 ]]; then
  usage
fi

SHOW=true
WAIT=true
TYPE_INT=1 # Default to LARGE

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --no-show)
      SHOW=false
      shift
      ;;
    --wait)
      WAIT=true
      shift
      ;;
    --no-wait)
      WAIT=false
      shift
      ;;
    --type)
      shift
      if [[ -z "$1" ]]; then
        echo "Error: --type requires an argument (FULLSCREEN, LARGE, SMALL)" >&2
        exit 1
      fi
      case "$1" in
        FULLSCREEN) TYPE_INT=0 ;;
        LARGE) TYPE_INT=1 ;;
        SMALL) TYPE_INT=2 ;;
        *)
          echo "Error: Invalid type '$1'. Must be FULLSCREEN, LARGE, or SMALL." >&2
          exit 1
          ;;
      esac
      shift
      ;;
    --help)
      usage
      ;;
    -*)
      echo "Error: Unknown option $1" >&2
      exit 1
      ;;
    *)
      if [[ -z "$COMPONENT_NAME" ]]; then
        COMPONENT_NAME="$1"
      else
        echo "Error: Unexpected argument '$1'" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [ -z "$COMPONENT_NAME" ]; then
  echo "Error: COMPONENT_NAME is required" >&2
  exit 1
fi

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require adb

# Check device availability
if ! adb get-state >/dev/null 2>&1; then
  if [[ -n "$ANDROID_SERIAL" ]]; then
    echo "$(basename "$0"): device '$ANDROID_SERIAL' not available" >&2
  else
    echo "$(basename "$0"): no device connected" >&2
  fi
  exit 1
fi

PACKAGE_NAME="${COMPONENT_NAME%%/*}"

# Check if the package is installed
if ! adb shell pm list packages | grep -q "^package:${PACKAGE_NAME}$"; then
  echo "Error: Package '$PACKAGE_NAME' not found. Is the app installed?" >&2
  exit 1
fi

# -----------------------------------------------------------------------------
# REMOTE COMPOSE VISIBILITY & FAILURE DETECTION
# -----------------------------------------------------------------------------
# Wear Widgets use a remote rendering architecture (Remote Compose).
# The app generates a document and serializes it over a Binder IPC connection.
# SysUI (via ProtoTilesTileRendererImpl) receives, deserializes, and renders it.
#
# Because of this IPC boundary, we cannot rely on app-level logs or just "sleep".
# Failures happen asynchronously AFTER the initial 'add-tile' broadcast.
# We explicitly detect known failure modes to fail fast and prevent false positives:
#
#   1. Binder Overload: Sending large unscaled images exceeds
#      the ~1MB Binder IPC limit. (b/488353353)
#      Result: 'FATAL EXCEPTION' in AndroidRuntime (TransactionTooLargeException)
#
#   2. Unsupported Modifiers: e.g., using alpha or blur effects. (b/473745800)
#      Result: 'Failed to render and attach the tile' in the renderer.
#
#   3. Allowlist Rejection: Package isn't registered for Remote Compose in prod.
#      Result: 'Provider is not allowlisted' in the renderer.
#
#   4. Renderer Timeouts: The provider hung or crashed silently before responding.
#      Result: 'Error getting tile response' in the renderer.
#
# Note: SysUI emits "Visible tile added" when it allocates the container, but
# the renderer might still fail to parse the document milliseconds *after* this.
# Therefore, we monitor for specific failure signatures both
# BEFORE and AFTER the visibility signal using a short grace period.
# -----------------------------------------------------------------------------

LOG_FILE=""
LOG_PID=""
if [ "$WAIT" = true ] && [ "$SHOW" = true ]; then
  LOG_FILE=$(mktemp)
  if [ ! -w "$LOG_FILE" ]; then
    echo "Error: Could not create writable temporary file for logcat monitoring." >&2
    exit 1
  fi

  # Clear buffer to avoid reading old logs from previous runs
  adb logcat -c

  # Monitor relevant tags in the background. We filter specifically for errors
  # from the renderer and runtime to catch async crashes.
  adb logcat -v time SysUI:I ProtoTilesTileRendererImpl:E AndroidRuntime:E "*:S" >"$LOG_FILE" &
  LOG_PID=$!

  # Robust cleanup trap: Handles normal exits, INT (Ctrl+C), and TERM signals.
  trap '
    EXIT_CODE=$?
    [ -n "$LOG_PID" ] && kill "$LOG_PID" 2>/dev/null
    [ -n "$LOG_FILE" ] && rm -f "$LOG_FILE"
    if [ $EXIT_CODE -eq 130 ]; then
       echo -e "\nWarning: Script interrupted by user. Background logcat killed."
    fi
    exit $EXIT_CODE
  ' EXIT INT TERM
fi

# Workaround for a bug: force-stop the package to ensure a fresh bind
adb shell am force-stop "$PACKAGE_NAME"

# Add the tile and capture output
OUTPUT=$(adb shell am broadcast \
  -a com.google.android.wearable.app.DEBUG_SURFACE \
  --es operation add-tile \
  --ecn component "$COMPONENT_NAME" \
  --ei type "$TYPE_INT")

# Check for "Requested tile provider does not exist" error (result=2)
if echo "$OUTPUT" | grep -q "Requested tile provider does not exist"; then
  echo "Error: The requested tile provider does not exist or is disabled."
  echo "This commonly happens with system tiles that cannot be added via this method."
  exit 1
fi

# Extract Index (e.g., from Index=[0])
INDEX=$(echo "$OUTPUT" | grep -o 'Index=\[[0-9]*\]' | sed 's/Index=\[\([0-9]*\)\]/\1/')

if [ -n "$INDEX" ]; then
  echo "Added tile ID: $INDEX"
  if [ "$SHOW" = true ]; then
    adb shell am broadcast \
      -a com.google.android.wearable.app.DEBUG_SYSUI \
      --es operation show-tile \
      --ei index "$INDEX" >/dev/null

    # Wait logic
    if [ "$WAIT" = true ]; then
      echo "Waiting for tile visibility..."
      START_TIME=$(date +%s)
      TIMEOUT=10
      VISIBLE=false

      while true; do
        CURRENT_TIME=$(date +%s)
        ELAPSED=$((CURRENT_TIME - START_TIME))

        # Check if logcat background process died unexpectedly
        if ! kill -0 "$LOG_PID" 2>/dev/null; then
          echo "Error: Background logcat process died unexpectedly. Cannot verify visibility."
          exit 1
        fi

        # Check if device disconnected
        if ! adb get-state >/dev/null 2>&1; then
          echo "Error: Device disconnected during visibility check."
          exit 1
        fi

        if [ $ELAPSED -ge $TIMEOUT ]; then
          echo "Warning: Timeout waiting for tile visibility ($TIMEOUT s)."
          echo "The tile may be visible, but the success log was missed, or it's stuck loading."
          break
        fi

        # Check for Success Signal
        if grep -q "Visible tile added" "$LOG_FILE"; then
          VISIBLE=true
          break
        fi

        # --- Failure Detection (Pre-Visibility) ---
        if grep -q "FATAL EXCEPTION" "$LOG_FILE"; then
          # b/488353353
          echo "Error: Remote Compose App Crash detected!"
          echo "This usually indicates an IPC payload limit was exceeded (TransactionTooLargeException) or a local runtime crash."
          grep -A 5 "FATAL EXCEPTION" "$LOG_FILE"
          exit 1
        fi
        if grep -q "Error getting tile response" "$LOG_FILE"; then
          echo "Error: Renderer timed out getting the tile response."
          echo "The provider may have hung or crashed silently before responding."
          grep "Error getting tile response" "$LOG_FILE"
          exit 1
        fi
        if grep -q "Failed to render and attach the tile" "$LOG_FILE"; then
          # b/473745800
          echo "Error: Renderer failed to parse or attach the document."
          echo "This is typically caused by unsupported Remote Compose modifiers (e.g., alpha, blur)."
          grep -A 2 "Failed to render and attach the tile" "$LOG_FILE"
          exit 1
        fi
        if grep -q "Provider is not allowlisted" "$LOG_FILE"; then
          echo "Error: Provider is not allowlisted for Remote Compose."
          echo "Your applicationId must be registered to run on production builds."
          exit 1
        fi

        sleep 0.2
      done

      if [ "$VISIBLE" = true ]; then
        # Continue monitoring for a short buffer. SysUI says the container is
        # visible, but the renderer might still throw an async parsing exception
        # a few hundred milliseconds later.
        sleep 1.5

        # --- Failure Detection (Post-Visibility Buffer) ---
        if grep -q "FATAL EXCEPTION" "$LOG_FILE"; then
          # b/488353353
          echo "Error: Remote Compose App Crash detected immediately after visibility!"
          echo "This usually indicates an IPC payload limit was exceeded (TransactionTooLargeException)."
          grep -A 5 "FATAL EXCEPTION" "$LOG_FILE"
          exit 1
        fi
        if grep -q "Error getting tile response" "$LOG_FILE"; then
          echo "Error: Renderer timed out getting the tile response after visibility."
          grep "Error getting tile response" "$LOG_FILE"
          exit 1
        fi
        if grep -q "Failed to render and attach the tile" "$LOG_FILE"; then
          # b/473745800
          echo "Error: Renderer rejected the document after visibility."
          echo "This is typically caused by unsupported Remote Compose modifiers (e.g., alpha, blur)."
          grep -A 2 "Failed to render and attach the tile" "$LOG_FILE"
          exit 1
        fi
        echo "Success: Tile is visible."
      fi
    fi
  fi
else
  echo "Failed to parse tile ID from output:"
  echo "$OUTPUT"
  exit 1
fi
