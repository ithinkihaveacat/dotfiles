#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] [FILE]

Records the screen of an adb-connected device. Automatically detects devices
that require raw frame streaming (e.g. Samsung Wear OS watches) and uses ffmpeg
for capture, while defaulting to scrcpy for standard devices.

The screen recording is saved to the specified file, or to a timestamped file
in the current directory if no file is specified. Touches are displayed during
the recording.

Arguments:
  FILE                    The path to save the screen recording to.
                          (defaults to 'adb-screenrecord-YYYYMMDDHHMMSS.mp4')

Options:
  -o, --output FILE       The path to save the screen recording to.
  -t, --duration SECONDS  Max recording duration in seconds.
  --time-limit SECONDS    Alias for --duration.
  --raw                   Force raw frame capture using ffmpeg.
  --no-raw                Disable raw frame capture (force scrcpy).
  -h, --help              Display this help message and exit

Environment:
  ANDROID_SERIAL  Serial number of device to connect to (see 'adb devices -l').
                  To target a specific device, use:
                    env ANDROID_SERIAL=<serial> $(basename "$0")

Examples:
  # Save screen recording to a timestamped file in the current directory
  $(basename "$0")

  # Save screen recording for 10 seconds
  $(basename "$0") --duration 10 /tmp/my-screen-recording.mp4

  # Force raw frame capture on any device
  $(basename "$0") --raw --duration 10 /tmp/my-screen-recording.mp4
EOF
  exit 0
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
fi

OUTPUT_FILE=""
FORCE_RAW=""
DURATION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help | -h)
      usage
      ;;
    -o | --output)
      if [ -z "${2:-}" ]; then
        echo "$(basename "$0"): --output option requires an argument" >&2
        exit 1
      fi
      OUTPUT_FILE="$2"
      shift 2
      ;;
    -t | --duration | --time-limit)
      if [ -z "${2:-}" ]; then
        echo "$(basename "$0"): --duration option requires an argument" >&2
        exit 1
      fi
      DURATION="$2"
      shift 2
      ;;
    --raw)
      FORCE_RAW="1"
      shift
      ;;
    --no-raw)
      FORCE_RAW="0"
      shift
      ;;
    *)
      if [ -z "$OUTPUT_FILE" ]; then
        OUTPUT_FILE="$1"
      fi
      shift
      ;;
  esac
done

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require adb

# Check if device is available and targetable
if ! adb shell true >/dev/null 2>&1; then
  echo "$(basename "$0"): error: no device connected, unauthorized, or multiple devices connected without ANDROID_SERIAL." >&2
  exit 1
fi

MANUFACTURER=$(adb exec-out getprop ro.product.manufacturer 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr -d '\r')
BRAND=$(adb exec-out getprop ro.product.brand 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr -d '\r')
MODEL=$(adb exec-out getprop ro.product.model 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr -d '\r')
USE_RAW=0
if [[ "$FORCE_RAW" == "1" ]]; then
  USE_RAW=1
elif [[ "$FORCE_RAW" == "0" ]]; then
  USE_RAW=0
elif [[ "$MANUFACTURER" == *"samsung"* || "$BRAND" == *"samsung"* || "$MODEL" == *"sm-"* || "$MODEL" == *"samsung"* ]]; then
  USE_RAW=1
fi

if [ -z "$OUTPUT_FILE" ]; then
  OUTPUT_FILE=$(date -u +'adb-screenrecord-%Y%m%d%H%M%S.mp4')
fi

adb exec-out log -p f -t screenrecord "screen recording to $OUTPUT_FILE"

# Wake display and pause briefly to allow SurfaceFlinger to transition from doze/off
# to active, preventing UNASSIGNED_LAYER_STACK errors on sleeping Wear OS displays.
adb exec-out input keyevent KEYCODE_WAKEUP >/dev/null 2>&1 || true
sleep 0.5

SHOW_TOUCHES="adb exec-out settings get system show_touches"
TOUCH_ORIGINAL="$($SHOW_TOUCHES 2>/dev/null || echo 0)"
adb exec-out settings put system show_touches 1 >/dev/null 2>&1 || true

RECORD_PID=""

ensure_faststart() {
  # Skip remux if raw capture already generated faststart headers directly
  if [ "$USE_RAW" -eq 1 ]; then
    return 0
  fi

  if command -v ffmpeg >/dev/null 2>&1 && [ -f "$OUTPUT_FILE" ] && [ -s "$OUTPUT_FILE" ]; then
    local tmp_fast="${OUTPUT_FILE}.fast.mp4"
    if ffmpeg -y -i "$OUTPUT_FILE" -c:v copy -movflags +faststart "$tmp_fast" >/dev/null 2>&1; then
      mv -f "$tmp_fast" "$OUTPUT_FILE"
    else
      rm -f "$tmp_fast"
    fi
  fi
}

cleanup() {
  trap - EXIT INT TERM

  local adb_timeout=()
  if [ -n "$TIMEOUT_CMD" ]; then
    adb_timeout=("$TIMEOUT_CMD" "--foreground" "2s")
  fi

  # Terminate on-device capture/server processes to unblock host ADB sockets;
  # scrcpy blocks in waitpid() for its on-device server, so killing the server
  # allows scrcpy to exit waitpid() and finalize the MP4 header/moov atom.
  if [ "$USE_RAW" -eq 1 ]; then
    "${adb_timeout[@]}" adb shell killall -2 screenrecord >/dev/null 2>&1 || true
  else
    "${adb_timeout[@]}" adb shell pkill -f scrcpy >/dev/null 2>&1 || true
  fi

  # Gracefully terminate host recording process (scrcpy or ffmpeg pipeline) and wait for clean exit
  if [ -n "$RECORD_PID" ] && kill -0 "$RECORD_PID" 2>/dev/null; then
    # In scrcpy mode, send SIGINT to trigger scrcpy_recorder_close().
    # In raw mode, closing on-device screenrecord propagates EOF to ffmpeg naturally;
    # sending SIGINT to ffmpeg concurrently can disrupt its clean EOF trailer flush.
    if [ "$USE_RAW" -eq 0 ]; then
      kill -INT "$RECORD_PID" 2>/dev/null || true
    fi

    local count=0
    while kill -0 "$RECORD_PID" 2>/dev/null && [ $count -lt 30 ]; do
      sleep 0.1
      count=$((count + 1))
    done

    # Allow up to 3 seconds for the recording process to flush MP4 headers before
    # escalating to SIGTERM/SIGKILL, preventing truncated/corrupted MP4 files.
    if kill -0 "$RECORD_PID" 2>/dev/null; then
      kill -TERM "$RECORD_PID" 2>/dev/null || true
      sleep 0.5
      if kill -0 "$RECORD_PID" 2>/dev/null; then
        kill -KILL "$RECORD_PID" 2>/dev/null || true
        wait "$RECORD_PID" 2>/dev/null || true
      fi
    fi
  fi

  "${adb_timeout[@]}" adb exec-out settings put system show_touches "$TOUCH_ORIGINAL" >/dev/null 2>&1 || true
  ensure_faststart
}

trap cleanup EXIT INT TERM

# Note on Wear OS / Raw mode duration handling:
# In raw frames mode (--output-format=raw-frames), Android's native screenrecord
# binary ignores the --time-limit flag and streams frames indefinitely until SIGINT.
# Furthermore, passing -t DURATION to ffmpeg stops ffmpeg from reading stdin after
# DURATION seconds, but leaves the on-device adb exec-out screenrecord binary running
# infinitely in the background holding the pipeline open.
#
# Wrapping raw capture with `timeout --foreground -s INT "${DURATION}s"` sends a SIGINT
# signal directly to adb exec-out upon expiration, cleanly terminating the on-device
# screenrecord binary. This causes ffmpeg to receive EOF on stdin, flush its H.264 video
# encoder, relocate the moov atom for faststart web streaming, and exit cleanly with status 0.
TIMEOUT_WRAPPER=()
TIMEOUT_CMD=""

if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD="timeout"
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_CMD="gtimeout"
fi

if [ -n "$DURATION" ] && [[ "$DURATION" =~ ^[0-9]+$ ]]; then
  if [ -n "$TIMEOUT_CMD" ]; then
    TIMEOUT_WRAPPER=("$TIMEOUT_CMD" "--foreground" "-s" "INT" "${DURATION}s")
  elif [ "$USE_RAW" -eq 1 ]; then
    echo "$(basename "$0"): error: 'timeout' command not found (install coreutils/gtimeout for macOS). Duration limits in raw mode are unsupported without it." >&2
    exit 1
  fi
fi

if [ "$USE_RAW" -eq 1 ]; then
  require ffmpeg
  echo "$(basename "$0"): note: using raw frame capture (ffmpeg) for device $MODEL ($BRAND/$MANUFACTURER)" >&2
  SIZE=$(adb exec-out wm size 2>/dev/null | awk -F': ' 'END{print $2}' | tr -d '\r')
  if [[ ! "$SIZE" =~ ^[0-9]+x[0-9]+$ ]]; then
    SIZE="454x454"
  fi
  BITRATE=70M

  if [ ${#TIMEOUT_WRAPPER[@]} -gt 0 ]; then
    "${TIMEOUT_WRAPPER[@]}" adb exec-out screenrecord --output-format=raw-frames --size "$SIZE" --bit-rate "$BITRATE" - |
      ffmpeg -f rawvideo -vcodec rawvideo -s "$SIZE" -pix_fmt rgb24 -use_wallclock_as_timestamps 1 -vsync 0 -i - -an -c:v libx264 -pix_fmt yuv420p -movflags +faststart -y "$OUTPUT_FILE" &
  else
    adb exec-out screenrecord --output-format=raw-frames --size "$SIZE" --bit-rate "$BITRATE" - |
      ffmpeg -f rawvideo -vcodec rawvideo -s "$SIZE" -pix_fmt rgb24 -use_wallclock_as_timestamps 1 -vsync 0 -i - -an -c:v libx264 -pix_fmt yuv420p -movflags +faststart -y "$OUTPUT_FILE" &
  fi
  RECORD_PID=$!
  wait $RECORD_PID 2>/dev/null || true
elif command -v scrcpy >/dev/null 2>&1; then
  SCRCPY_FLAGS=("--no-audio" "--no-window" "-r" "$OUTPUT_FILE")
  if [ -n "$DURATION" ]; then
    SCRCPY_FLAGS+=("--time-limit=$DURATION")
  fi
  if [ ${#TIMEOUT_WRAPPER[@]} -gt 0 ]; then
    "${TIMEOUT_WRAPPER[@]}" scrcpy "${SCRCPY_FLAGS[@]}" &
  else
    scrcpy "${SCRCPY_FLAGS[@]}" &
  fi
  RECORD_PID=$!
  wait $RECORD_PID 2>/dev/null || true
else
  echo "$(basename "$0"): error: scrcpy not found. Please install scrcpy (e.g. 'brew install scrcpy') for optimal screen recording on non-Samsung devices ($MODEL)." >&2
  exit 1
fi

cleanup
