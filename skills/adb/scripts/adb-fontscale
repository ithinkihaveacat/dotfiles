#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") COMMAND [SCALE]

Get or set the system font scale on an adb-connected Android device.

Commands:
  get         Print the current font scale
  set SCALE   Set the font scale to a preset or numeric value

Scales:
  default     Reset to the default scale (1.0)
  large       Large scale (1.24)
  NUMBER      Any numeric scale factor (e.g. 0.85, 1.5)

Options:
  --help      Display this help message and exit

Environment:
  ANDROID_SERIAL  Serial number of device to connect to (see 'adb devices -l').

Examples:
  $(basename "$0") get
  $(basename "$0") set large
  $(basename "$0") set 1.5
  $(basename "$0") set default
EOF
  exit 0
}

if [[ "$1" == "--help" || "$1" == "-h" || -z "$1" ]]; then
  usage
fi

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require adb

case "$1" in
  get)
    adb exec-out settings get system font_scale
    ;;
  set)
    case "$2" in
      "")
        echo "$(basename "$0") set: missing scale (default, large, or a number)" >&2
        exit 1
        ;;
      default)
        SCALE=1.0
        ;;
      large)
        SCALE=1.24
        ;;
      *)
        if [[ ! "$2" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
          echo "$(basename "$0") set: invalid scale '$2' (expected default, large, or a number)" >&2
          exit 1
        fi
        SCALE="$2"
        ;;
    esac
    adb exec-out settings put system font_scale "$SCALE"
    ;;
  *)
    echo "$(basename "$0"): unknown command '$1'" >&2
    echo "Try '$(basename "$0") --help' for more information." >&2
    exit 1
    ;;
esac
