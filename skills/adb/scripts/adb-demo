#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") COMMAND

Enable or disable demo mode on an adb-connected Android device.

Commands:
  on          Enter demo mode:
                - Enables the SystemUI demo mode
                - Sets the clock to 16:20
                - Shows 4G and full mobile level
                - Sets battery to 100% and unplugged
                - Hides notifications and wifi
                - Enables the "Show touches" setting
                - Sets the screen-off timeout to 30 minutes
                - Blocks heads-up notification popups
                - Enables Do Not Disturb (Priority Only)
  off         Exit demo mode:
                - Disables the SystemUI demo mode
                - Disables the "Show touches" setting
                - Restores the screen-off timeout to 1 minute
                - Restores heads-up notification popups to enabled
                - Disables Do Not Disturb (Zen Mode: Off)

Options:
  --help      Display this help message and exit

Environment:
  ANDROID_SERIAL  Serial number of device to connect to (see 'adb devices -l').

Examples:
  $(basename "$0") on
  $(basename "$0") off
EOF
  exit 0
}

if [[ "$1" == "--help" || -z "$1" ]]; then
  usage
fi

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require adb

# Check if device is available
if [ "$(adb get-state 2>/dev/null)" != "device" ]; then
  echo "$(basename "$0"): error: no device connected" >&2
  exit 1
fi

demo_on() {
  # Abort entire script if any command fails
  # https://stackoverflow.com/a/821419
  set -e
  set -o pipefail

  # Removes dynamic information from the status bar

  adb exec-out settings put global sysui_demo_allowed 1
  adb exec-out am broadcast -a com.android.systemui.demo -e command enter
  adb exec-out am broadcast -a com.android.systemui.demo -e command clock -e hhmm 1620
  adb exec-out am broadcast -a com.android.systemui.demo -e command network -e mobile show -e datatype 4g -e level 4
  adb exec-out am broadcast -a com.android.systemui.demo -e command battery -e level 100 -e plugged false
  adb exec-out am broadcast -a com.android.systemui.demo -e command notifications -e visible false
  adb exec-out am broadcast -a com.android.systemui.demo -e command network -e wifi hide

  # Enables the "Show touches" option

  adb exec-out settings put system show_touches 1

  # Sets the screen-off timeout to 30 minutes (1800000 ms)

  adb exec-out settings put system screen_off_timeout 1800000

  # Blocks heads-up notification popups

  adb exec-out settings put global heads_up_notifications_enabled 0

  # Enables Do Not Disturb (Zen Mode: Priority Only)

  adb exec-out cmd notification set_dnd priority
}

demo_off() {
  # Adds dynamic information from the status bar

  adb exec-out am broadcast -a com.android.systemui.demo -e command exit
  adb exec-out settings put global sysui_demo_allowed 0

  # Disables the "Show touches" option

  adb exec-out settings put system show_touches 0

  # Restores the screen-off timeout to a default of 1 minute (60000 ms)

  adb exec-out settings put system screen_off_timeout 60000

  # Restores heads-up notification popups to enabled

  adb exec-out settings put global heads_up_notifications_enabled 1

  # Disables Do Not Disturb (Zen Mode: Off)

  adb exec-out cmd notification set_dnd off
}

case "$1" in
  on)
    demo_on
    ;;
  off)
    demo_off
    ;;
  *)
    echo "$(basename "$0"): unknown command '$1'" >&2
    echo "Try '$(basename "$0") --help' for more information." >&2
    exit 1
    ;;
esac
