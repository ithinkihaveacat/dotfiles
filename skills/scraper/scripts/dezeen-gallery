#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["playwright"]
# ///
"""Print every gallery image URL from a dezeen.com article.

Default output is one image URL per line on stdout. With --json, emits the
full parsed article payload (title, author, dates, description, tags, body
text and the captioned gallery) for richer pipelines.

Pipe to a downloader to fetch the images:

    dezeen-gallery URL | wget -i - -P dir/
    dezeen-gallery URL | xargs -n1 -P4 curl -sO

Dezeen sits behind Cloudflare bot management, which blocks scripted HTTP
clients (curl and urllib alike) on article detail pages — not by IP or TLS
fingerprint but by detecting automation. So instead of fetching the HTML
ourselves we drive a real Chrome that you launch yourself and read the rendered
DOM over the DevTools protocol; to Cloudflare it looks like an ordinary human
browser (navigator.webdriver is false). Launch one first:

    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \\
        --remote-debugging-port=9222 --user-data-dir=/tmp/chrome-dezeen-profile &

If Cloudflare ever shows a challenge, solve it once in that window — the script
waits for it and the clearance cookie covers the rest of the session. Point the
script at a different endpoint with DEZEEN_CDP_URL. See
references/dezeen-source-structure.md for the site specifics.
"""

import argparse
import html as htmllib
import json
import os
import re
import signal
import sys
import time
import urllib.parse

from playwright.sync_api import Error as PlaywrightError
from playwright.sync_api import sync_playwright

# DevTools endpoint of the user-launched Chrome we drive. A new tab is opened
# per fetch and closed afterwards; the browser process itself is left running.
CDP_URL = os.environ.get("DEZEEN_CDP_URL", "http://127.0.0.1:9222")

# Cloudflare interstitial / managed-challenge titles. When one appears a human
# babysitting the Chrome window solves it once; the resulting cf_clearance
# cookie then covers the rest of the session, so we wait rather than fail.
CHALLENGE_RE = re.compile(r"just a moment|attention required|verify you", re.I)


def launch_hint(prog: str) -> str:
    return (
        f"{prog}: cannot reach a debuggable Chrome at {CDP_URL}.\n\n"
        "This scraper drives a real Chrome you launch yourself, so Cloudflare\n"
        "sees a human browser rather than an automated one. Start one with:\n\n"
        '  "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \\\n'
        "      --remote-debugging-port=9222 \\\n"
        "      --user-data-dir=/tmp/chrome-dezeen-profile &\n\n"
        "then re-run. Override the endpoint with DEZEEN_CDP_URL."
    )


def await_human(page, prog: str, solve_timeout: int) -> None:
    """Block while a Cloudflare challenge is on screen, up to solve_timeout secs.

    Polls the document title; a babysitting human clears the challenge in the
    Chrome window and we continue once the real page loads. On timeout we return
    anyway and let the caller deal with the (challenge) DOM.
    """
    if not CHALLENGE_RE.search(page.title() or ""):
        return
    print(
        f"{prog}: Cloudflare challenge — solve it in the Chrome window "
        f"(waiting up to {solve_timeout}s)…",
        file=sys.stderr,
        flush=True,
    )
    deadline = time.time() + solve_timeout
    while CHALLENGE_RE.search(page.title() or ""):
        if time.time() > deadline:
            return
        time.sleep(2)
    print(f"{prog}: challenge cleared, continuing.", file=sys.stderr, flush=True)


def render(
    url: str,
    prog: str,
    *,
    wait_selector: str | None = None,
    nav_timeout: int = 45000,
    solve_timeout: int = 180,
) -> tuple[int | None, str]:
    """Navigate the connected Chrome to url and return (http_status, html).

    Opens a fresh tab, waits for the DOM, clears any Cloudflare challenge, then
    returns the fully rendered HTML for the regex parsers to consume. Exits with
    a launch hint if no debuggable Chrome is reachable.
    """
    with sync_playwright() as pw:
        try:
            browser = pw.chromium.connect_over_cdp(CDP_URL)
        except Exception:
            sys.exit(launch_hint(prog))
        context = browser.contexts[0] if browser.contexts else browser.new_context()
        page = context.new_page()
        try:
            resp = page.goto(url, wait_until="domcontentloaded", timeout=nav_timeout)
            status = resp.status if resp else None
            await_human(page, prog, solve_timeout)
            if wait_selector:
                try:
                    page.wait_for_selector(wait_selector, timeout=10000)
                except PlaywrightError:
                    pass  # selector may legitimately be absent (e.g. empty page)
            return status, page.content()
        finally:
            try:
                page.close()
            except Exception:
                pass


def fetch(url: str) -> str:
    status, html = render(
        url, "dezeen-gallery", wait_selector="figure[data-lightboximage]"
    )
    if status not in (200, None):
        sys.exit(f"dezeen-gallery: failed to fetch {url} (HTTP {status})")
    return html


def slug_from_url(url: str) -> str:
    """Last non-empty path segment of an article URL.

    Dezeen articles are dated: /YYYY/MM/DD/<slug>/. The slug is the stable key.
    """
    parts = urllib.parse.urlparse(url).path.rstrip("/").split("/")
    return parts[-1] if parts and parts[-1] else url


def _strip_tags(s: str) -> str:
    return htmllib.unescape(re.sub(r"<[^>]+>", "", s)).strip()


def parse_jsonld(html: str) -> dict:
    """Return the NewsArticle JSON-LD block, or {} if absent.

    Dezeen emits several ld+json blocks; the article metadata lives in the one
    whose @type is NewsArticle (sometimes nested in an @graph array).
    """

    def find_news(obj):
        if isinstance(obj, dict):
            t = obj.get("@type")
            if t == "NewsArticle" or (isinstance(t, list) and "NewsArticle" in t):
                return obj
            if "@graph" in obj:
                return find_news(obj["@graph"])
            return None
        if isinstance(obj, list):
            for item in obj:
                hit = find_news(item)
                if hit:
                    return hit
        return None

    for raw in re.findall(
        r'<script type="application/ld\+json"[^>]*>(.*?)</script>', html, re.DOTALL
    ):
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            continue
        hit = find_news(data)
        if hit:
            return hit
    return {}


def parse_authors(ld: dict) -> list[str]:
    authors = []
    raw = ld.get("author")
    if isinstance(raw, dict):
        raw = [raw]
    if isinstance(raw, list):
        for a in raw:
            if isinstance(a, dict) and a.get("name"):
                authors.append(a["name"])
            elif isinstance(a, str):
                authors.append(a)
    if not authors and isinstance(ld.get("creator"), list):
        authors = [c for c in ld["creator"] if isinstance(c, str)]
    return authors


def parse_gallery(html: str) -> list[dict]:
    """Extract the article's gallery as ordered {imageUrl, caption} dicts.

    The genuine gallery images are the only ones carrying a data-lightboximage
    attribute on their <figure> (related-post thumbnails do not). Captions, when
    present, are in a wp-caption-text element inside the same figure. URLs are
    de-duplicated preserving document order.
    """
    images: list[dict] = []
    seen: set[str] = set()
    for url, body in re.findall(
        r'<figure[^>]*data-lightboximage="([^"]+)"[^>]*>(.*?)</figure>',
        html,
        re.DOTALL,
    ):
        url = htmllib.unescape(url)
        if url in seen:
            continue
        seen.add(url)
        cap_m = re.search(r'class="wp-caption-text"[^>]*>(.*?)</', body, re.DOTALL)
        caption = _strip_tags(cap_m.group(1)) if cap_m else None
        images.append({"imageUrl": url, "caption": caption or None})
    return images


def parse_body(html: str) -> str:
    """Best-effort plain-text article body.

    Dezeen's prose paragraphs precede the <div class="article-tags"> block;
    figure captions (wp-caption-text) and related-post blurbs after the tags are
    excluded. This is heuristic — JSON-LD `description` is the reliable summary.
    """
    end = html.find('class="article-tags"')
    region = html[:end] if end != -1 else html
    paras = []
    for m in re.finditer(r"<p\b[^>]*>(.*?)</p>", region, re.DOTALL):
        if "wp-caption-text" in m.group(0)[:80]:
            continue
        text = _strip_tags(m.group(1))
        if len(text) > 40:
            paras.append(text)
    return "\n\n".join(paras)


def parse_article(html: str, url: str) -> tuple[dict, list[str]]:
    ld = parse_jsonld(html)
    gallery = parse_gallery(html)
    payload = {
        "slug": slug_from_url(url),
        "url": url,
        "title": ld.get("headline"),
        "author": parse_authors(ld),
        "datePublished": ld.get("datePublished"),
        "dateModified": ld.get("dateModified"),
        "description": ld.get("description"),
        "section": ld.get("articleSection"),
        "tags": ld.get("keywords") or [],
        "body": parse_body(html),
        "gallery": {"images": gallery},
    }
    urls = [img["imageUrl"] for img in gallery]
    return payload, urls


def main():
    ap = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    ap.add_argument("--help", action="help", help="Show this help message and exit")
    ap.add_argument("url")
    ap.add_argument(
        "--json",
        action="store_true",
        help="Emit the full parsed article payload as JSON instead of URLs",
    )
    args = ap.parse_args()

    html = fetch(args.url)
    payload, urls = parse_article(html, args.url)
    if not urls:
        print("error: could not find gallery images in page", file=sys.stderr)
        sys.exit(1)

    if args.json:
        json.dump(payload, sys.stdout, indent=2, ensure_ascii=False)
        sys.stdout.write("\n")
    else:
        for u in urls:
            print(u)


def _sigterm_handler(signum, frame):
    # Converge SIGTERM with SIGINT so the Playwright driver subprocess is torn
    # down cleanly (the sync_playwright context manager runs on KeyboardInterrupt).
    raise KeyboardInterrupt


if __name__ == "__main__":
    signal.signal(signal.SIGTERM, _sigterm_handler)
    try:
        main()
    except KeyboardInterrupt:
        signal.signal(signal.SIGINT, signal.SIG_IGN)
        signal.signal(signal.SIGTERM, signal.SIG_IGN)
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)
    except BrokenPipeError:
        import os

        devnull = os.open(os.devnull, os.O_WRONLY)
        os.dup2(devnull, sys.stdout.fileno())
        sys.exit(141)
