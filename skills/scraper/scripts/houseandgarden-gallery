#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Print every gallery image URL from a houseandgarden.co.uk article.

Default output is one image URL per line on stdout. With --json, emits a
structured payload (title, author, datePublished, section, tags, body text
and the captioned gallery) for richer pipelines.

Images are served by media.houseandgarden.co.uk with Imgix-style transforms.
This script requests the master-ratio version at 2560px width, which is the
largest available without a fixed crop.

Pipe to a downloader to fetch the images:

    houseandgarden-gallery URL | wget -i - -P dir/
    houseandgarden-gallery URL | xargs -n1 -P4 curl -sO

Slides are identified by their /master/ image transform (see extract_images),
which captures the whole carousel on both page templates H&G serves while
excluding the square recirculation thumbnails and social-card crops.
"""

import argparse
import html as htmllib
import json
import re
import sys
import urllib.request

UA = "Mozilla/5.0 (compatible; houseandgarden-gallery)"


def fetch(url: str) -> str:
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": UA,
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
            "Accept-Language": "en-GB,en;q=0.5",
        },
    )
    with urllib.request.urlopen(req, timeout=30) as r:
        return r.read().decode("utf-8", errors="replace")


def _strip_html(text: str) -> str:
    return re.sub(r"<[^>]+>", "", text or "")


def extract_metadata(html: str) -> dict:
    """Parse article metadata from the NewsArticle JSON-LD block."""
    m = re.search(
        r'<script type="application/ld\+json">(.*?)</script>', html, re.DOTALL
    )
    if not m:
        return {}
    try:
        data = json.loads(m.group(1))
    except json.JSONDecodeError:
        return {}
    if data.get("@type") != "NewsArticle":
        return {}
    authors = [
        a.get("name", "") for a in (data.get("author") or []) if isinstance(a, dict)
    ]
    # Strip [#image: ...] markers embedded in articleBody
    body = re.sub(r"\[#image:[^\]]*\]", "", data.get("articleBody", "")).strip()
    return {
        "title": data.get("headline", ""),
        "author": authors,
        "datePublished": data.get("datePublished", ""),
        "section": data.get("articleSection", ""),
        "body": body,
    }


def extract_tags(html: str) -> list[str]:
    m = re.search(r'<meta name="keywords" content="([^"]*)"', html)
    if not m:
        return []
    return [t.strip() for t in m.group(1).split(",") if t.strip()]


def extract_captions(html: str) -> dict[str, dict]:
    """Build a photo_id → {caption, credit} map from data-item attributes."""
    captions: dict[str, dict] = {}
    for m in re.finditer(r'data-item="(\{[^"]*)"', html):
        try:
            item = json.loads(htmllib.unescape(m.group(1)))
        except (json.JSONDecodeError, ValueError):
            continue
        pid = item.get("id", "")
        img = item.get("image", {})
        if pid:
            captions[pid] = {
                "caption": _strip_html(img.get("caption", "")),
                "credit": img.get("credit", ""),
            }
    return captions


def extract_images(html: str, captions: dict[str, dict]) -> list[dict]:
    """Extract gallery slide images by their master-ratio renderings.

    Each carousel slide is served from media.houseandgarden.co.uk under a
    ``/master/`` transform (the full, uncropped ratio). Recirculation /
    "related" thumbnails and social-card images use fixed-aspect transforms
    (``1:1``, ``16:9``, …) instead, so keying on ``/master/`` isolates the
    gallery cleanly — and across both page templates H&G serves (an older one
    that renders most slides far from any ``GallerySlideWrapper`` marker, and a
    newer one that renders each slide inline). Slides are deduplicated by photo
    id in document order and normalised to the largest master width (2560px).

    Extraction is anchored to the ``src`` / ``srcSet`` HTML attribute (read out
    of its literal-double-quote value). That excludes the entity-encoded
    ``data-item`` JSON — where the same ``/master/`` URLs recur but quotes are
    ``&quot;``, so a raw scan would run past the filename into the JSON — while
    still allowing filenames that legitimately contain ``&amp;`` (e.g. an
    ``H&amp;G`` shoot code). Within an attribute value a single URL ends at
    whitespace (the ``srcSet`` width descriptor) or the value's end.
    """
    images: list[dict] = []
    seen_ids: set[str] = set()
    for attr in re.finditer(r'\b(?:src|src[Ss]et)="([^"]*)"', html):
        for m in re.finditer(
            r"/photos/([a-f0-9]{24})/master/[^/]+/([^/\s,]+)", attr.group(1)
        ):
            pid, fname = m.group(1), m.group(2)
            if pid in seen_ids:
                continue
            seen_ids.add(pid)
            url = (
                f"https://media.houseandgarden.co.uk/photos/{pid}"
                f"/master/w_2560,c_limit/{fname}"
            )
            cap = captions.get(pid, {})
            images.append(
                {
                    "imageUrl": url,
                    "caption": cap.get("caption", ""),
                    "credit": cap.get("credit", ""),
                }
            )
    return images


def parse_gallery(url: str) -> tuple[dict, list[dict]]:
    html = fetch(url)
    meta = extract_metadata(html)
    if not meta:
        print("houseandgarden-gallery: could not find NewsArticle JSON-LD", file=sys.stderr)
        sys.exit(1)
    meta["tags"] = extract_tags(html)
    captions = extract_captions(html)
    images = extract_images(html, captions)
    if not images:
        print("houseandgarden-gallery: no gallery images found", file=sys.stderr)
        sys.exit(1)
    return meta, images


def main():
    ap = argparse.ArgumentParser(
        prog="houseandgarden-gallery",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    ap.add_argument("--help", action="help", help="Show this help message and exit")
    ap.add_argument("url", help="Gallery article URL")
    ap.add_argument(
        "--json",
        action="store_true",
        help="Emit the full parsed article payload as JSON instead of URLs",
    )
    args = ap.parse_args()

    meta, images = parse_gallery(args.url)

    if args.json:
        meta["gallery"] = {"images": images}
        json.dump(meta, sys.stdout, indent=2, ensure_ascii=False)
        sys.stdout.write("\n")
    else:
        for img in images:
            print(img["imageUrl"])


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)
