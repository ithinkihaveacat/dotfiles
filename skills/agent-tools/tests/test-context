#!/usr/bin/env bash

# Tests: tests/context/

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
BIN="$DIR/../scripts/context"

echo "1..5"

# Test 1: Usage (no args)
OUTPUT=$(mktemp)
trap 'rm -f "$OUTPUT"' EXIT

if ! "$BIN" >"$OUTPUT" 2>&1; then
  if grep -q "usage:" "$OUTPUT" || grep -q "Generate aggregated context" "$OUTPUT"; then
    echo "ok 1 - Usage displayed correctly when no arguments provided"
  else
    echo "not ok 1 - Script failed and usage output missing expected text"
    sed 's/^/# /' "$OUTPUT"
  fi
else
  echo "not ok 1 - Script succeeded with no arguments, expected failure"
fi

# Test 2: Local Directory Support (using 'show')
TMP_DIR=$(mktemp -d)
trap 'rm -f "$OUTPUT"; rm -rf "$TMP_DIR"' EXIT

echo "Hello World" >"$TMP_DIR/file1.txt"
echo "Line 2" >>"$TMP_DIR/file1.txt"
mkdir "$TMP_DIR/subdir"
echo "Subdir file" >"$TMP_DIR/subdir/file2.txt"

if RESPONSE=$("$BIN" show "$TMP_DIR"); then
  if echo "$RESPONSE" | grep -q "file1.txt" && echo "$RESPONSE" | grep -q "Hello World" && echo "$RESPONSE" | grep -q "file2.txt" && echo "$RESPONSE" | grep -q "Subdir file"; then
    echo "ok 2 - Local directory packaged correctly using 'show'"
  else
    echo "not ok 2 - XML output missing expected file content"
    echo "# Response was:"
    echo "$RESPONSE" | sed 's/^/# /'
  fi
else
  echo "not ok 2 - Failed to run context show on local directory"
fi

# Test 3: Catalog subcommand
if CATALOG_OUT=$("$BIN" catalog); then
  if echo "$CATALOG_OUT" | grep -q "skills" && echo "$CATALOG_OUT" | grep -q "gemini-api"; then
    echo "ok 3 - Catalog subcommand listed default entries"
  else
    echo "not ok 3 - Catalog output missing expected entries"
    echo "$CATALOG_OUT" | sed 's/^/# /'
  fi
else
  echo "not ok 3 - Catalog subcommand failed"
fi

# Test 4: Template subcommand
if TEMPLATE_OUT=$("$BIN" template); then
  if echo "$TEMPLATE_OUT" | grep -q "api.add_entry" && echo "$TEMPLATE_OUT" | grep -q "my_custom_entry_handler"; then
    echo "ok 4 - Template subcommand output correct template"
  else
    echo "not ok 4 - Template output missing expected content"
    echo "$TEMPLATE_OUT" | sed 's/^/# /'
  fi
else
  echo "not ok 4 - Template subcommand failed"
fi

# Test 5: Invalid subcommand
if ! "$BIN" invalid-command >"$OUTPUT" 2>&1; then
  if grep -q "invalid choice: 'invalid-command'" "$OUTPUT" || grep -q "invalid choice" "$OUTPUT"; then
    echo "ok 5 - Invalid subcommand failed as expected with usage error"
  else
    echo "not ok 5 - Invalid subcommand failed but error message was unexpected"
    sed 's/^/# /' "$OUTPUT"
  fi
else
  echo "not ok 5 - Invalid subcommand succeeded, expected failure"
fi
