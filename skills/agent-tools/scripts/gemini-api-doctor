#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "google-genai",
# ]
# ///

import argparse
import asyncio
import getpass
import os
import sys
import time
import signal
from google import genai
from google.genai import errors as genai_errors

DEFAULT_MODELS = [
    "gemini-3.6-flash",
    "gemini-3.5-flash-lite",
    "gemini-3.1-pro-preview",
]


def get_client():
    key = os.environ.get("GEMINI_API_KEY")
    if not key:
        print(
            "Error: GEMINI_API_KEY environment variable not set",
            file=sys.stderr,
        )
        sys.exit(1)
    return genai.Client(api_key=key)


async def ping_model(client, model):
    start_time = time.perf_counter()
    try:
        # Use asyncio.wait_for for timeout
        await asyncio.wait_for(
            client.aio.models.generate_content(
                model=model,
                contents="Ping",
            ),
            timeout=60.0,
        )
        duration = time.perf_counter() - start_time
        return model, True, "OK", duration
    except asyncio.TimeoutError:
        duration = time.perf_counter() - start_time
        return model, False, "FAILED: Timeout after 60 seconds", duration
    except genai_errors.APIError as e:
        duration = time.perf_counter() - start_time
        return model, False, f"FAILED (HTTP {e.code}): {e.message}", duration
    except Exception as e:
        duration = time.perf_counter() - start_time
        return model, False, f"FAILED: {str(e)}", duration


_signal_received = False


async def main_async():
    global _signal_received
    loop = asyncio.get_running_loop()
    main_task = asyncio.current_task()

    def shutdown_handler():
        global _signal_received
        _signal_received = True
        main_task.cancel()

    # Register handlers
    for sig in (signal.SIGINT, signal.SIGTERM):
        try:
            loop.add_signal_handler(sig, shutdown_handler)
        except NotImplementedError:
            pass

    try:
        parser = argparse.ArgumentParser(
            description="Ping Gemini models to test API key validity. Takes API key from GEMINI_API_KEY environment variable or stdin.",
            add_help=False,
        )
        parser.add_argument(
            "-h", "--help", action="store_true", help="Show this help message and exit"
        )
        parser.add_argument(
            "--model",
            metavar="MODEL",
            help="Ping a single model (equivalent to passing it as a positional argument)",
        )
        parser.add_argument(
            "models",
            nargs="*",
            help="Models to ping. If omitted, uses $GEMINI_MODEL if set, else defaults.",
        )

        # Handle 'help' command as requested by standards
        if len(sys.argv) > 1 and sys.argv[1] == "help":
            parser.print_help()
            sys.exit(0)

        args = parser.parse_args()

        if args.help:
            parser.print_help()
            sys.exit(0)

        # Read API key from stdin if not in environment
        if not os.environ.get("GEMINI_API_KEY"):
            if sys.stdin.isatty():
                key = getpass.getpass("Enter Gemini API Key: ")
            else:
                key = sys.stdin.read().strip()

            if not key:
                print("Error: API Key cannot be empty", file=sys.stderr)
                sys.exit(1)
            os.environ["GEMINI_API_KEY"] = key

        client = get_client()

        models_to_ping = list(args.models)
        if args.model:
            models_to_ping.append(args.model)
        if not models_to_ping:
            env_model = os.environ.get("GEMINI_MODEL")
            models_to_ping = [env_model] if env_model else DEFAULT_MODELS

        print(
            f"gemini-api-doctor: pinging {len(models_to_ping)} models in parallel (60s timeout)...",
            file=sys.stderr,
        )

        tasks = [ping_model(client, model) for model in models_to_ping]

        exit_code = 0
        # Use as_completed to yield results as they complete
        for coro in asyncio.as_completed(tasks):
            model, success, message, duration = await coro
            if success:
                print(f"gemini-api-doctor: {model}: {message} ({duration:.2f}s)")
            else:
                print(
                    f"gemini-api-doctor: {model}: {message} ({duration:.2f}s)",
                    file=sys.stderr,
                )
                exit_code = 1

        sys.exit(exit_code)
    finally:
        # Unregister loop handlers to restore default signal behavior on exit
        for sig in (signal.SIGINT, signal.SIGTERM):
            try:
                loop.remove_signal_handler(sig)
            except Exception:
                pass


def main():
    try:
        asyncio.run(main_async())
    except asyncio.CancelledError:
        if _signal_received:
            try:
                sys.stderr.write("\n")
                sys.stderr.flush()
            except Exception:
                pass
            sys.exit(130)
        else:
            sys.exit(1)
    except KeyboardInterrupt:
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)


if __name__ == "__main__":
    main()
