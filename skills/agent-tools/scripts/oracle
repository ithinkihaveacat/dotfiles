#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "google-genai",
# ]
# [tool.uv.sources]
# google-genai = { index = "pypi" }
# [[tool.uv.index]]
# name = "pypi"
# url = "https://pypi.org/simple"
# ///
"""The Oracle: A high-quality, researched, and authoritative reasoning tool."""

import asyncio
import os
import sys
import datetime
import mimetypes
from pathlib import Path
from google import genai
from google.genai import types

MAX_TEXT_SIZE = 1 * 1024 * 1024  # 1MB
MAX_MEDIA_SIZE = 20 * 1024 * 1024  # 20MB

TEXT_EXTENSIONS = {
    ".txt",
    ".md",
    ".csv",
    ".json",
    ".xml",
    ".html",
    ".css",
    ".js",
    ".ts",
    ".py",
    ".java",
    ".kt",
    ".c",
    ".cpp",
    ".h",
    ".hpp",
    ".rs",
    ".go",
    ".rb",
    ".sh",
    ".bash",
    ".zsh",
    ".fish",
    ".yaml",
    ".yml",
    ".toml",
    ".ini",
    ".gradle",
    ".properties",
    ".bat",
    ".ps1",
    ".sql",
    ".graphql",
    ".graphqls",
}

IGNORED_DIRS = {
    ".git",
    "node_modules",
    "__pycache__",
    "venv",
    ".venv",
    "env",
    ".env",
    ".idea",
    ".vscode",
    "build",
    "dist",
    "out",
    "target",
    ".next",
    ".nuxt",
}


def is_text_file(path: Path) -> bool:
    ext = path.suffix.lower()
    if ext in TEXT_EXTENSIONS:
        return True
    mime, _ = mimetypes.guess_type(path)
    if mime and mime.startswith("text/"):
        return True
    if mime in ["application/json", "application/xml", "application/javascript"]:
        return True
    # For unrecognized files, sniff for null bytes — no nulls means text
    try:
        with open(path, "rb") as f:
            return b"\x00" not in f.read(8192)
    except Exception:
        return False


def usage():
    print(
        f"""\
Usage: {os.path.basename(sys.argv[0])} [OPTIONS] "PROMPT" [FILE_OR_DIR ...]

Consult the Oracle for a very carefully researched and considered answer.
Designed for the highest quality response possible, utilizing deep reasoning
and Google Search grounding.

The Oracle is not a standard, quick-reply AI. It is designed to process massive
amounts of information and synthesize authoritative answers. It has no memory
of previous conversations.

Best Practices for Context:
  To get the most out of the Oracle, you must provide comprehensive context.
  This goes beyond just providing source files. A high-quality prompt should
  also explicitly define:
  - Persona & Audience: Who are you, and who is this answer for?
  - Goals & Intent: What is the ultimate objective of this request?
  - Success Criteria: How will you know the answer is correct or useful?
  - Format & Style: Should the output be a technical spec, an essay, or a report?
  - Constraints: What must the Oracle explicitly avoid doing?
  - Examples: Provide a "few-shot" example of what a good output looks like.
  - Assumptions: Clarify ambiguous terms or state decisions already made.
  - Failed Attempts: If you are stuck, describe what approaches have already
    been tried and why each failed or was rejected (including any error messages
    or constraints). This prevents the Oracle from re-proposing dead ends and
    focuses its reasoning on genuinely novel solutions.

Arguments:
  PROMPT        The specific question or task for the Oracle.
  FILE_OR_DIR   Optional. Files or directories to include as context. Directories
                are recursively walked (ignoring hidden files and standard ignore
                lists like node_modules). Text files are inlined; media files are
                uploaded to the Gemini API (and cleaned up automatically).

Input:
  stdin         Optional. Context or reference material piped into the script.

Options:
  --force       Bypass context size limits (1MB for text, 20MB per media file).
  --maps        Use Google Maps grounding instead of Google Search. (Cannot be combined with --code).
  --code        Enable Code Execution for Python.
  --help        Display this help message and exit.

Environment:
  GEMINI_API_KEY  Required. Your Gemini API key.

Examples:
  cat codebase.md | {os.path.basename(sys.argv[0])} "Propose a refactoring plan"
  {os.path.basename(sys.argv[0])} "Does this code match the spec?" src/ spec.pdf
"""
    )


def main():
    if "--help" in sys.argv:
        usage()
        sys.exit(0)

    force = False
    use_maps = False
    use_code = False
    args = []
    for arg in sys.argv[1:]:
        if arg == "--force":
            force = True
        elif arg == "--maps":
            use_maps = True
        elif arg == "--code":
            use_code = True
        else:
            args.append(arg)

    if not args:
        print(
            f"{os.path.basename(sys.argv[0])}: error: prompt is required",
            file=sys.stderr,
        )
        usage()
        sys.exit(1)

    user_prompt = args[0]
    paths = args[1:]

    text_context = ""
    media_files_to_upload = []
    total_text_size = 0

    # 1. Read stdin
    if not sys.stdin.isatty():
        stdin_content = sys.stdin.read()
        if stdin_content:
            text_context += f'<document path="stdin">\n<![CDATA[\n{stdin_content}\n]]>\n</document>\n'
            total_text_size += len(stdin_content.encode("utf-8"))

    # 2. Gather files
    collected_files = []
    for p in paths:
        path = Path(p)
        if path.is_file():
            collected_files.append(path)
        elif path.is_dir():
            for root, dirs, files in os.walk(path):
                dirs[:] = [
                    d for d in dirs if not d.startswith(".") and d not in IGNORED_DIRS
                ]
                for file in files:
                    if not file.startswith("."):
                        collected_files.append(Path(root) / file)
        else:
            print(f"Warning: path not found: {p}", file=sys.stderr)

    # 3. Categorize and enforce limits
    for path in collected_files:
        size = path.stat().st_size
        if is_text_file(path):
            total_text_size += size
            if total_text_size > MAX_TEXT_SIZE and not force:
                print(
                    "Error: Text context exceeds 1MB threshold. Use --force to bypass.",
                    file=sys.stderr,
                )
                sys.exit(1)
            try:
                content = path.read_text(encoding="utf-8", errors="replace")
                text_context += f'<document path="{path}">\n<![CDATA[\n{content}\n]]>\n</document>\n'
                print(
                    f"{os.path.basename(sys.argv[0])}: inlining {path.name} into context ({size / 1024:.2f} KB)...",
                    file=sys.stderr,
                )
            except Exception as e:
                print(
                    f"{os.path.basename(sys.argv[0])}: warning: failed to read {path}: {e}",
                    file=sys.stderr,
                )
        else:
            mime_type, _ = mimetypes.guess_type(str(path))
            if not mime_type:
                print(
                    f"{os.path.basename(sys.argv[0])}: warning: skipping {path.name}: unknown file type",
                    file=sys.stderr,
                )
                continue
            if size > MAX_MEDIA_SIZE and not force:
                print(
                    f"Error: Media file {path} exceeds 20MB threshold. Use --force to bypass.",
                    file=sys.stderr,
                )
                sys.exit(1)
            media_files_to_upload.append(path)

    if not text_context and not media_files_to_upload:
        print("Warning: No context provided via stdin or files.", file=sys.stderr)

    api_key = os.environ.get("GEMINI_CLI_GEMINI_API_KEY") or os.environ.get(
        "GEMINI_API_KEY"
    )
    if not api_key:
        print(
            f"{os.path.basename(sys.argv[0])}: error: GEMINI_API_KEY environment variable not set",
            file=sys.stderr,
        )
        sys.exit(1)

    client = genai.Client(api_key=api_key)
    model_id = "gemini-3.1-pro-preview"

    now = datetime.datetime.now()
    current_date_str = now.strftime("%A, %d %B %Y")

    system_instruction = f"""You are the Oracle, an elite researcher and strategist known for providing the highest quality, most carefully considered answers possible. You combine deep technical expertise with rigorous reasoning and real-time research.

### Core Mandates

1.  **Highest Quality & Depth:** Your answers must be exhaustive, insightful, and technically precise. Do not settle for surface-level summaries.
2.  **Unwavering Acceptance:** Assume the user's question is correct and well-informed. Do not second-guess the intent, push back against the premise, or suggest the question is misinformed. Answer the question exactly as posed using your best judgment and the provided context.
3.  **Authoritative Voice:** Present information directly as fact. Instead of using weak conversational meta-references (e.g., "The provided text says..." or "According to the documentation..."), use formal, explicit citations (like Markdown footnotes, bracketed references, or direct blockquotes) to attribute information while maintaining a confident tone.
4.  **Markdown Excellence:** Use valid Markdown. Start with a descriptive H1 title. Use lists, tables, and code blocks (preferring Python, then Kotlin, then curl) to enhance clarity.
5.  **Context & Citations:** Prioritize any provided context, assuming it contains highly relevant information. When your answer draws upon this context, use explicit citations (e.g., inlining exact code snippets, quoting transcripts, or citing specific records) to make your response trustworthy and verifiable. Use the Google Search tool to supplement with up-to-date information, especially for technical details or recent developments.

### Contextual Awareness

- **Current Date:** Today is {current_date_str}. It is the year 2026. 
- **Time Sensitivity:** For queries requiring up-to-date information, you MUST use the provided current date when formulating search queries.

### Output Style

- **Verbosity:** High. Provide detailed analysis and comprehensive answers.
- **Tone:** Professional, direct, and authoritative.
- **Directness:** Just answer the question. Skip conversational filler or introductory pleasantries.
"""

    tools_config = []
    if use_maps:
        tools_config.append(types.Tool(google_maps=types.GoogleMaps()))
        tools_str = "maps"
        if use_code:
            print(
                f"{os.path.basename(sys.argv[0])}: warning: --code cannot be combined with --maps, ignoring --code",
                file=sys.stderr,
            )
    else:
        tools_config.append(types.Tool(google_search=types.GoogleSearch()))
        if use_code:
            tools_config.append(types.Tool(code_execution=types.ToolCodeExecution()))
            tools_str = "search+code"
        else:
            tools_str = "search"

    context_parts = []
    if total_text_size > 0:
        context_parts.append(f"{total_text_size / 1024:.2f} KB text")
    if media_files_to_upload:
        context_parts.append(f"{len(media_files_to_upload)} media files")
    context_str = ", ".join(context_parts) if context_parts else "no context"

    print(
        f"{os.path.basename(sys.argv[0])}: {model_id} | {tools_str} | thinking=high | {context_str}",
        file=sys.stderr,
    )

    async def upload_all(paths: list) -> list:
        async def upload_one(path: Path) -> types.File:
            print(
                f"{os.path.basename(sys.argv[0])}: uploading {path.name} ({path.stat().st_size / 1024 / 1024:.2f} MB)...",
                file=sys.stderr,
            )
            mime_type, _ = mimetypes.guess_type(str(path))
            return await client.aio.files.upload(
                file=str(path),
                config=types.UploadFileConfig(mime_type=mime_type),
            )

        return list(await asyncio.gather(*[upload_one(p) for p in paths]))

    uploaded_files = []
    try:
        if media_files_to_upload:
            uploaded_files = asyncio.run(upload_all(media_files_to_upload))

        parts = []
        if text_context:
            parts.append(
                types.Part.from_text(text=f"<context>\n{text_context}\n</context>")
            )
        for uf in uploaded_files:
            parts.append(
                types.Part.from_uri(
                    file_uri=uf.uri,
                    mime_type=uf.mime_type,
                )
            )

        parts.append(types.Part.from_text(text=f"<task>\n{user_prompt}\n</task>"))

        response = client.models.generate_content_stream(
            model=model_id,
            contents=[types.Content(role="user", parts=parts)],
            config=types.GenerateContentConfig(
                system_instruction=system_instruction,
                tools=tools_config,
                thinking_config=types.ThinkingConfig(
                    thinking_level="high", include_thoughts=True
                ),
                temperature=1.0,
            ),
        )

        in_thought = False
        for chunk in response:
            if not chunk.candidates:
                continue
            for part in chunk.candidates[0].content.parts:
                if part.thought:
                    if not in_thought:
                        print(
                            f"\n{os.path.basename(sys.argv[0])}: thinking...\n\033[2m",
                            end="",
                            file=sys.stderr,
                            flush=True,
                        )
                        in_thought = True
                    print(part.text, end="", file=sys.stderr, flush=True)
                elif part.text:
                    if in_thought:
                        print(
                            "\033[0m\n\n", end="", file=sys.stderr, flush=True
                        )  # Dim end
                        in_thought = False
                    print(part.text, end="", flush=True)

        if in_thought:
            print("\033[0m\n", end="", file=sys.stderr, flush=True)
        print()  # Final newline

    except Exception as e:
        print(f"{os.path.basename(sys.argv[0])}: error: {e}", file=sys.stderr)
        sys.exit(1)

    finally:
        for uf in uploaded_files:
            try:
                print(f"Cleaning up {uf.name}...", file=sys.stderr)
                client.files.delete(name=uf.name)
            except Exception as e:
                print(
                    f"{os.path.basename(sys.argv[0])}: warning: failed to delete {uf.name}: {e}",
                    file=sys.stderr,
                )


if __name__ == "__main__":
    main()
