#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "pillow",
#     "pillow-heif",
# ]
# ///
"""Ask Gemini a question about one or more photos.

QUERY is either an @-prefixed built-in or a free-form prompt. Built-ins carry
their own prompt, schema, and tuned defaults (e.g. smaller resize cap for
boolean classification).

  photo-query @people  photo.jpg              # boolean: people prominent?
  photo-query "Is there a fireplace?" *.jpg   # free-form
  photo-query "..." --schema "has_bed bool" *.jpg

Pre-processed WebP bytes are cached at ~/.cache/agent-tools/photo-query/ so
repeated queries against the same images skip EXIF rotation, alpha flatten,
resize, and re-encode.
"""

import argparse
import base64
import hashlib
import io
import json
import os
import sys
import urllib.error
import urllib.request
from dataclasses import dataclass
from pathlib import Path

import pillow_heif
from PIL import Image, ImageOps

pillow_heif.register_heif_opener()


CACHE_FORMAT_VERSION = 1
IMAGE_EXTS = {".jpg", ".jpeg", ".png", ".webp", ".heic", ".heif"}
GEMINI_URL = (
    "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent"
)
DEFAULT_MODEL = "gemini-3.1-flash-lite"
DEFAULT_MAX_SIZE = 768


def cache_dir() -> Path:
    base = os.environ.get("XDG_CACHE_HOME") or str(Path.home() / ".cache")
    d = Path(base) / "agent-tools" / "photo-query"
    d.mkdir(parents=True, exist_ok=True)
    return d


def preprocess(path: Path, max_size: int, use_cache: bool) -> bytes:
    """Return WebP-encoded bytes ready for upload, applying:
    EXIF transpose, alpha flatten on white, thumbnail to max_size."""
    raw = path.read_bytes()
    digest = hashlib.sha256(raw).hexdigest()
    cache_key = f"{digest}-{max_size}-v{CACHE_FORMAT_VERSION}.webp"
    cache_path = cache_dir() / cache_key

    if use_cache and cache_path.exists():
        return cache_path.read_bytes()

    with Image.open(io.BytesIO(raw)) as img:
        img = ImageOps.exif_transpose(img)
        if img.mode in ("RGBA", "LA") or (
            img.mode == "P" and "transparency" in img.info
        ):
            bg = Image.new("RGB", img.size, (255, 255, 255))
            bg.paste(img.convert("RGBA"), mask=img.convert("RGBA").split()[-1])
            img = bg
        else:
            img = img.convert("RGB")
        img.thumbnail((max_size, max_size), Image.Resampling.LANCZOS)
        buf = io.BytesIO()
        img.save(buf, format="WEBP", quality=85, method=4)
        encoded = buf.getvalue()

    if use_cache:
        tmp = cache_path.with_suffix(cache_path.suffix + ".tmp")
        tmp.write_bytes(encoded)
        tmp.rename(cache_path)
    return encoded


def parse_schema_dsl(spec: str) -> dict:
    """Minimal subset of llm.schema_dsl: 'name [type] [: description]'
    fields, comma-separated. Supported types: bool, int, float, str (default)."""
    type_map = {"bool": "boolean", "int": "integer", "float": "number", "str": "string"}
    props, required = {}, []
    for raw_field in spec.split(","):
        field = raw_field.strip()
        if not field:
            continue
        desc = None
        if ":" in field:
            field, desc = (s.strip() for s in field.split(":", 1))
        parts = field.split()
        name = parts[0]
        type_tok = parts[1] if len(parts) > 1 else "str"
        if type_tok not in type_map:
            raise ValueError(f"unknown type {type_tok!r} in schema field {raw_field!r}")
        prop: dict = {"type": type_map[type_tok]}
        if desc:
            prop["description"] = desc
        props[name] = prop
        required.append(name)
    return {"type": "object", "properties": props, "required": required}


def gemini_request(
    api_key: str,
    model: str,
    image_bytes: bytes,
    prompt: str,
    schema: dict | None,
) -> dict:
    payload: dict = {
        "contents": [
            {
                "parts": [
                    {
                        "inlineData": {
                            "mimeType": "image/webp",
                            "data": base64.b64encode(image_bytes).decode("ascii"),
                        }
                    },
                    {"text": prompt},
                ]
            }
        ]
    }
    if schema is not None:
        payload["generationConfig"] = {
            "responseMimeType": "application/json",
            "responseJsonSchema": schema,
        }

    req = urllib.request.Request(
        GEMINI_URL.format(model=model),
        data=json.dumps(payload).encode(),
        headers={"Content-Type": "application/json", "x-goog-api-key": api_key},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            body = json.loads(r.read())
    except urllib.error.HTTPError as e:
        err = e.read().decode("utf-8", errors="replace")
        try:
            msg = json.loads(err).get("error", {}).get("message", err)
        except json.JSONDecodeError:
            msg = err
        raise RuntimeError(f"Gemini API error: {msg}") from None

    if "error" in body:
        raise RuntimeError(f"Gemini API error: {body['error'].get('message', body)}")
    candidates = body.get("candidates") or []
    if not candidates:
        raise RuntimeError(f"no candidates in response: {body}")
    parts = candidates[0].get("content", {}).get("parts") or []
    if not parts:
        raise RuntimeError(f"no parts in response: {body}")
    text = parts[0].get("text", "")
    if schema is None:
        return {"text": text}
    return json.loads(text)


HAS_PEOPLE_PROMPT = """<role>You are an expert photo analyst.</role>
<task>Analyze the provided image and determine if people feature prominently in it.</task>
<instructions>
Return true if people (or partial views like hands, backs of heads, silhouettes, or any visible human body parts) are a significant part of the image. Return false otherwise. Provide the minimal required JSON response.
</instructions>
<examples>
- A landscape with a tiny unrecognizable figure in the distance -> false
- A close-up of a hand holding a phone -> true
- A crowd of silhouettes at a concert -> true
- An empty room with a chair -> false
</examples>"""


@dataclass
class Query:
    prompt: str
    schema: dict | None
    boolean_field: str | None
    max_size: int

    def render_line(self, parsed: dict, path: Path) -> str:
        if self.boolean_field:
            value = "true" if parsed.get(self.boolean_field) else "false"
            return f"{path}\t{value}"
        if self.schema is None:
            return f"{path}\t{parsed['text']}"
        return f"{path}\t{json.dumps(parsed, ensure_ascii=False)}"


BUILTINS: dict[str, Query] = {
    "@people": Query(
        prompt=HAS_PEOPLE_PROMPT,
        schema={
            "type": "object",
            "properties": {
                "has_people": {
                    "type": "boolean",
                    "description": "True if people feature prominently in the photo",
                }
            },
            "required": ["has_people"],
        },
        boolean_field="has_people",
        max_size=384,
    ),
}


def expand_paths(args_paths: list[str], recursive: bool) -> list[Path]:
    out: list[Path] = []
    for p in args_paths:
        path = Path(p)
        if path.is_file():
            out.append(path)
        elif path.is_dir():
            it = path.rglob("*") if recursive else path.iterdir()
            out.extend(
                sorted(c for c in it if c.is_file() and c.suffix.lower() in IMAGE_EXTS)
            )
        else:
            raise FileNotFoundError(p)
    return out


def build_query(args: argparse.Namespace) -> Query:
    raw = args.query
    if raw.startswith("@"):
        if raw not in BUILTINS:
            known = ", ".join(BUILTINS)
            raise SystemExit(f"photo-query: unknown built-in {raw!r} (known: {known})")
        q = BUILTINS[raw]
        if args.schema:
            raise SystemExit(f"photo-query: --schema is not allowed with {raw}")
        max_size = args.max_size if args.max_size is not None else q.max_size
        return Query(
            prompt=q.prompt,
            schema=q.schema,
            boolean_field=q.boolean_field,
            max_size=max_size,
        )

    schema = parse_schema_dsl(args.schema) if args.schema else None
    bool_field = None
    if schema is not None:
        props = schema["properties"]
        bool_fields = [n for n, p in props.items() if p["type"] == "boolean"]
        if len(bool_fields) == 1 and len(props) == 1:
            bool_field = bool_fields[0]
    max_size = args.max_size if args.max_size is not None else DEFAULT_MAX_SIZE
    return Query(prompt=raw, schema=schema, boolean_field=bool_field, max_size=max_size)


def run_query(
    query: Query,
    paths: list[Path],
    model: str,
    use_cache: bool,
    api_key: str,
    verbose: bool,
    filter_field: str | None,
) -> int:
    single_boolean = (
        len(paths) == 1 and query.boolean_field is not None and filter_field is None
    )
    any_error = False
    boolean_result = None

    for path in paths:
        try:
            img_bytes = preprocess(path, query.max_size, use_cache=use_cache)
            parsed = gemini_request(
                api_key, model, img_bytes, query.prompt, query.schema
            )
        except Exception as e:
            print(f"photo-query: {path}: {e}", file=sys.stderr)
            any_error = True
            continue

        if single_boolean:
            assert query.boolean_field is not None
            boolean_result = bool(parsed.get(query.boolean_field))
            if verbose:
                print("true" if boolean_result else "false", file=sys.stderr)
            continue

        if filter_field is not None:
            if parsed.get(filter_field):
                print(path)
            continue

        print(query.render_line(parsed, path))

    if any_error:
        return 2
    if single_boolean:
        return 0 if boolean_result else 1
    return 0


def make_parser() -> argparse.ArgumentParser:
    builtins_list = ", ".join(BUILTINS)
    ap = argparse.ArgumentParser(
        prog="photo-query",
        description="Ask Gemini a question about one or more photos.",
        add_help=False,
    )
    ap.add_argument("--help", action="help", help="Show this help message and exit")
    ap.add_argument(
        "--max-size",
        type=int,
        default=None,
        metavar="N",
        help=(
            f"Longest-edge resize cap, in px (default: {DEFAULT_MAX_SIZE}; "
            "built-ins may use a smaller default)"
        ),
    )
    ap.add_argument(
        "--model",
        default=os.environ.get("GEMINI_MODEL", DEFAULT_MODEL),
        help=(
            f"Gemini model id (default: $GEMINI_MODEL if set, else {DEFAULT_MODEL})"
        ),
    )
    ap.add_argument("--no-cache", action="store_true", help="Bypass the resize cache")
    ap.add_argument(
        "--recursive",
        action="store_true",
        help="Recurse into directory arguments",
    )
    ap.add_argument(
        "--schema",
        help=(
            "llm-style schema_dsl, e.g. 'has_bed bool, count int'. "
            "Not allowed with @ built-ins."
        ),
    )
    ap.add_argument(
        "--filter",
        dest="filter_field",
        help="Print only paths whose boolean FIELD is true",
    )
    ap.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Echo true/false to stderr (single-file boolean mode)",
    )
    ap.add_argument(
        "query",
        metavar="QUERY",
        help=f"@-prefixed built-in ({builtins_list}) or a free-form prompt",
    )
    ap.add_argument("paths", nargs="+", metavar="FILE_OR_DIR")
    return ap


def main() -> int:
    ap = make_parser()
    args = ap.parse_args()

    api_key = os.environ.get("GEMINI_API_KEY", "")
    if not api_key:
        print(
            "photo-query: GEMINI_API_KEY environment variable not set", file=sys.stderr
        )
        return 2

    query = build_query(args)

    if args.filter_field and query.schema is None:
        print(
            "photo-query: --filter requires a schema (built-in or --schema)",
            file=sys.stderr,
        )
        return 2

    paths = expand_paths(args.paths, args.recursive)
    if not paths:
        print("photo-query: no image files found", file=sys.stderr)
        return 2

    return run_query(
        query,
        paths,
        args.model,
        use_cache=not args.no_cache,
        api_key=api_key,
        verbose=args.verbose,
        filter_field=args.filter_field,
    )


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)
