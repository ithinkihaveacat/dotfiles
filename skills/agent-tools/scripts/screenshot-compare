#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "google-genai",
# ]
# [tool.uv.sources]
# google-genai = { index = "pypi" }
# [[tool.uv.index]]
# name = "pypi"
# url = "https://pypi.org/simple"
# ///

import sys
import os
import subprocess
import shutil

from google import genai
from google.genai import types

SCRIPT_NAME = os.path.basename(sys.argv[0])
MODEL = "gemini-3-flash-preview"

DEFAULT_PROMPT = """<role>You are a meticulous UI QA engineer.</role>
<task>Compare these two screenshots with extreme precision. They are expected to show the same UI, but one contains subtle layout, size, or styling variations that may be bugs.</task>
<instructions>
1. Perform a pixel-by-pixel mental comparison.
2. Examine the exact width and height of all containers and shapes.
3. Check the internal padding between text/icons and their containers.
4. Verify the external margins between elements and the screen edges.
5. Assess the precise alignment and centering of all components.
6. Compare font properties including size, weight, style (italic/bold), and color.
7. Look specifically for stretching, shrinking, layout shifts, or text rendering changes.
8. Provide a detailed description of the visual differences. Be specific about container dimensions, colors, font sizes, margins, padding, and layout shifts, noting direction and approximate pixel values where possible.
9. Conclude with a brief summary paragraph of the overall changes (e.g., 'the height of the primary container has been reduced' or 'vertical padding has been increased throughout').
10. If the images are completely different (e.g., they show different apps or entirely different screens), provide a single, concise explanation of why they are not comparable as your entire response.
</instructions>
<constraints>
- Format your entire response as continuous, flowing prose paragraphs. This is required so the output reads as a fluid narrative report.
- Avoid using lists or bullet points.
</constraints>"""


def usage(code=0):
    print(
        f"""Usage: {SCRIPT_NAME} IMAGE1 IMAGE2 [PROMPT]

Compare two screenshots using the Gemini API. Identifies visual differences like
layout shifts, color changes, padding, or text updates.

Arguments:
  IMAGE1      Path to the first screenshot (baseline/before), or '-' for stdin
  IMAGE2      Path to the second screenshot (comparison/after), or '-' for stdin
  PROMPT      Custom prompt for the AI model (optional)

Options:
  --help         Display this help message and exit
  --version      Display version number and exit

Environment:
  GEMINI_API_KEY  Required. Your Gemini API key.

Examples:
  {SCRIPT_NAME} before.png after.png
  {SCRIPT_NAME} v1.png v2.png "Check for font size changes in the header"

Exit Codes:
  0    Success (differences found and described)
  1    General error (API error, usage, missing file, etc.)
  2    Images are identical (no differences to describe)""",
        file=sys.stdout if code == 0 else sys.stderr,
    )
    sys.exit(code)


def error(message, code=1):
    print(f"{SCRIPT_NAME}: {message}", file=sys.stderr)
    sys.exit(code)


def command_exists(cmd):
    return shutil.which(cmd) is not None


def process_image(path):
    try:
        if path == "-":
            input_data = sys.stdin.buffer.read()
            cmd = [
                "magick",
                "-",
                "-background",
                "magenta",
                "-flatten",
                "-define",
                "webp:lossless=true",
                "webp:-",
            ]
        else:
            input_data = None
            cmd = [
                "magick",
                path,
                "-background",
                "magenta",
                "-flatten",
                "-define",
                "webp:lossless=true",
                "webp:-",
            ]

        result = subprocess.run(
            cmd,
            input=input_data,
            capture_output=True,
            check=True,
        )
        return result.stdout
    except subprocess.CalledProcessError as e:
        error(
            f"ImageMagick processing failed: {e.stderr.decode('utf-8', errors='replace')}"
        )
    except Exception as e:
        error(f"Failed to process image: {e}")


def main():
    args = sys.argv[1:]

    if "--help" in args:
        usage(0)
    if "--version" in args:
        print(f"{SCRIPT_NAME} 1.0.0")
        sys.exit(0)

    if len(args) < 2:
        print(f"{SCRIPT_NAME}: missing file operands", file=sys.stderr)
        print(f"Try '{SCRIPT_NAME} --help' for more information.", file=sys.stderr)
        sys.exit(1)

    if not command_exists("magick"):
        error("magick not found (install ImageMagick)")

    image1_path = args[0]
    image2_path = args[1]
    prompt = args[2] if len(args) > 2 else DEFAULT_PROMPT

    if image1_path == "-" and image2_path == "-":
        error("Cannot read both images from stdin")

    if image1_path != "-" and not os.path.isfile(image1_path):
        error(f"{image1_path}: No such file or directory")
    if image2_path != "-" and not os.path.isfile(image2_path):
        error(f"{image2_path}: No such file or directory")

    img1_bytes = process_image(image1_path)
    img2_bytes = process_image(image2_path)

    if img1_bytes == img2_bytes:
        print("The images are identical.")
        print(f"{SCRIPT_NAME}: error: input images are identical", file=sys.stderr)
        sys.exit(2)

    api_key = os.environ.get("GEMINI_CLI_GEMINI_API_KEY") or os.environ.get(
        "GEMINI_API_KEY"
    )
    if not api_key:
        error("GEMINI_API_KEY environment variable not set")
    os.environ["GEMINI_API_KEY"] = api_key

    try:
        client = genai.Client()
        response = client.models.generate_content(
            model=MODEL,
            contents=[
                types.Content(
                    role="user",
                    parts=[
                        types.Part.from_text(text=prompt),
                        types.Part.from_bytes(data=img1_bytes, mime_type="image/webp"),
                        types.Part.from_bytes(data=img2_bytes, mime_type="image/webp"),
                    ],
                )
            ],
        )
        text = response.text
        if not text:
            error("no response text received from API")
        print(text)
    except Exception as e:
        error(f"API error: {e}")


if __name__ == "__main__":
    main()
