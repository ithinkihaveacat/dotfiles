#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") < INPUT_FILE
       echo "text" | $(basename "$0")

Counts the tokens in the text provided via standard input using the Gemini API.

Input:
  stdin       The text to count tokens for.

Options:
  --help         Display this help message and exit
  --model MODEL  Gemini model to use (default: gemini-2.0-flash)

Environment:
  GEMINI_API_KEY  Required. Your Gemini API key.
  GEMINI_MODEL    Optional. Default model if --model is not given.

Exit Codes:
  0    Success (outputs token count)
  1    General error (usage, empty input, API error)
  127  Missing required dependency

Examples:
  echo "The quick brown fox jumps over the lazy dog." | $(basename "$0")
  $(basename "$0") < document.txt
  cat *.md | $(basename "$0")
EOF
  exit 0
}

MODEL="${GEMINI_MODEL:-gemini-2.0-flash}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help | -h)
      usage
      ;;
    --model)
      if [[ $# -lt 2 ]]; then
        echo "$(basename "$0"): --model requires an argument" >&2
        echo "Try '$(basename "$0") --help' for more information." >&2
        exit 1
      fi
      MODEL="$2"
      shift 2
      ;;
    *)
      echo "$(basename "$0"): unknown argument: $1" >&2
      echo "Try '$(basename "$0") --help' for more information." >&2
      exit 1
      ;;
  esac
done

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require curl
require jq
require wc
require tr

# Check for stdin (unconditional read, size checked below)

GEMINI_API_KEY="${GEMINI_API_KEY:-}"
if [[ -z "${GEMINI_API_KEY:-}" ]]; then
  echo "$(basename "$0"): GEMINI_API_KEY environment variable not set" >&2
  exit 1
fi

URL="https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:countTokens"

# Create a temporary file to store input
INPUT_FILE=$(mktemp)
trap 'rm -f "$INPUT_FILE"' EXIT

# Read stdin into the temporary file
cat >"$INPUT_FILE"

# Get the size of the input in bytes and verify it is not empty
INPUT_SIZE=$(wc -c <"$INPUT_FILE" | tr -d '[:space:]')
if [[ "$INPUT_SIZE" -eq 0 ]]; then
  echo "$(basename "$0"): no input provided on stdin" >&2
  echo "Try '$(basename "$0") --help' for more information." >&2
  exit 1
fi

RESPONSE=$(jq -n --rawfile content "$INPUT_FILE" \
  '{
    contents: [{
      parts: [{ text: $content }]
    }]
  }' | curl -s -X POST \
  -H "x-goog-api-key: $GEMINI_API_KEY" \
  -H "Content-Type: application/json" \
  -d @- \
  "${URL}")

# Check for API errors
if echo "$RESPONSE" | jq -e '.error' >/dev/null 2>&1; then
  ERROR_MSG=$(echo "$RESPONSE" | jq -r '.error.message // "Unknown error"')
  echo "$(basename "$0"): API error: $ERROR_MSG" >&2
  exit 1
fi

# Extract and output the token count
TOKEN_COUNT=$(echo "$RESPONSE" | jq -r '.totalTokens // 0')

if [[ -z "$TOKEN_COUNT" || "$TOKEN_COUNT" == "null" ]]; then
  echo "$(basename "$0"): failed to get token count from response" >&2
  echo "$RESPONSE" >&2
  exit 1
fi

echo "size: $INPUT_SIZE, token count: $TOKEN_COUNT"
