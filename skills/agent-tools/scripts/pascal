#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] [-] PROMPT

Asks a question to the Gemini 3 Flash model and prints a short, paragraph-style
response (wrapped to 80 columns).

Arguments:
  -           Read context from stdin and include it with the question.
              Without a leading '-', stdin is ignored.
  PROMPT      The question to ask.

Options:
  --help         Display this help message and exit
  --model MODEL  Gemini model to use (default: gemini-3.5-flash)

Environment:
  GEMINI_API_KEY  Required. Your Gemini API key.
  GEMINI_MODEL    Optional. Default model if --model is not given.

Exit Codes:
  0    Success
  1    General error (usage, API error)
  127  Missing required dependency

Examples:
  $(basename "$0") "What is the capital of Peru?"
  cat article.md | $(basename "$0") - "Summarize this article"
  $(basename "$0") - "Explain this code" < script.sh
EOF
  exit 0
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

MODEL="${GEMINI_MODEL:-gemini-3.5-flash}"
READ_STDIN=false
USER_PROMPT_PARTS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      ;;
    --model)
      if [[ $# -lt 2 ]]; then
        echo "$(basename "$0"): --model requires an argument" >&2
        echo "Try '$(basename "$0") --help' for more information." >&2
        exit 1
      fi
      MODEL="$2"
      shift 2
      ;;
    -)
      READ_STDIN=true
      shift
      ;;
    --)
      shift
      USER_PROMPT_PARTS+=("$@")
      break
      ;;
    -*)
      echo "$(basename "$0"): unknown option: $1" >&2
      echo "Try '$(basename "$0") --help' for more information." >&2
      exit 1
      ;;
    *)
      USER_PROMPT_PARTS+=("$1")
      shift
      ;;
  esac
done

require curl
require jq
require fmt

GEMINI_API_KEY="${GEMINI_API_KEY:-}"
if [[ -z "${GEMINI_API_KEY:-}" ]]; then
  echo "$(basename "$0"): GEMINI_API_KEY environment variable not set" >&2
  exit 1
fi

if [[ ${#USER_PROMPT_PARTS[@]} -lt 1 ]]; then
  echo "$(basename "$0"): missing PROMPT argument" >&2
  echo "Try '$(basename "$0") --help' for more information." >&2
  exit 1
fi

USER_PROMPT="${USER_PROMPT_PARTS[*]}"

if { [ -p /dev/stdin ] || [ -s /dev/stdin ]; } && ! ${READ_STDIN}; then
  echo "$(basename "$0"): warning: stdin contains piped input, but '-' was not specified. Stdin is ignored." >&2
fi

URL="https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent"

# System Instruction
SYSTEM_INSTRUCTION="You are a helpful assistant. Provide a short, direct answer (less than 300 characters) in a single full paragraph. Do not use point form, lists, or markdown formatting (like bold or headers). Just plain text."

# Construct the JSON payload
if $READ_STDIN; then
  # Read stdin into a temp file and use --rawfile to avoid ARG_MAX limits on
  # large inputs (see shell.md "Handling Large Inputs with jq").
  STDIN_FILE=$(mktemp)
  trap 'rm -f "$STDIN_FILE"' EXIT
  cat >"$STDIN_FILE"
  REQUEST_BODY=$(jq -n \
    --arg system_instruction "$SYSTEM_INSTRUCTION" \
    --arg user_prompt "$USER_PROMPT" \
    --rawfile stdin_content "$STDIN_FILE" \
    '{
      system_instruction: {
        parts: [{ text: $system_instruction }]
      },
      contents: [
        {
          role: "user",
          parts: [{ text: ("Context:\n" + $stdin_content + "\n\nQuestion:\n" + $user_prompt) }]
        }
      ],
      generationConfig: {
        temperature: 1.0,
        maxOutputTokens: 2048,
        thinkingConfig: {
          thinkingLevel: "low"
        }
      }
    }')
else
  REQUEST_BODY=$(jq -n \
    --arg system_instruction "$SYSTEM_INSTRUCTION" \
    --arg user_prompt "$USER_PROMPT" \
    '{
      system_instruction: {
        parts: [{ text: $system_instruction }]
      },
      contents: [
        {
          role: "user",
          parts: [{ text: $user_prompt }]
        }
      ],
      generationConfig: {
        temperature: 1.0,
        maxOutputTokens: 2048,
        thinkingConfig: {
          thinkingLevel: "low"
        }
      }
    }')
fi

# Execute the request
RESPONSE=$(echo "${REQUEST_BODY}" | curl -s -X POST \
  -H "x-goog-api-key: $GEMINI_API_KEY" \
  -H "Content-Type: application/json" \
  -d @- \
  "${URL}")

# Check for API errors
if echo "$RESPONSE" | jq -e '.error' >/dev/null 2>&1; then
  ERROR_MSG=$(echo "$RESPONSE" | jq -r '.error.message // "Unknown error"')
  echo "$(basename "$0"): API error: $ERROR_MSG" >&2
  exit 1
fi

# Extract and output the text response
TEXT=$(echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text // empty')

if [[ -z "$TEXT" ]]; then
  # Fallback: sometimes the model might block content or return explicit refusal
  FINISH_REASON=$(echo "$RESPONSE" | jq -r '.candidates[0].finishReason // "UNKNOWN"')
  echo "$(basename "$0"): no response text received (finish reason: $FINISH_REASON)" >&2
  exit 1
fi

# Wrap to 80 chars
echo "$TEXT" | fmt -w 80
