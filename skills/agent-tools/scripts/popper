#!/usr/bin/env -S uv run --script
# Requires uv (https://docs.astral.sh/uv/).
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "uiautomator2",
#   "google-genai",
#   "google-api-core",
#   "pillow",
#   # apkutils is an optional dependency of uiautomator2, needed for installing
#   # its agent APKs onto the device. Must be declared explicitly for uv to
#   # include it.
#   "apkutils",
# ]
# [tool.uv.sources]
# uiautomator2 = { index = "pypi" }
# google-genai = { index = "pypi" }
# apkutils = { index = "pypi" }
# google-api-core = { index = "pypi" }
# pillow = { index = "pypi" }
# [[tool.uv.index]]
# name = "pypi"
# url = "https://pypi.org/simple"
# ///
"""AI-driven semantic UI interaction for Android via ADB."""

import argparse
import os
import sys
import time
import io
import signal
import json
import datetime
import xml.etree.ElementTree as ET
import re

import uiautomator2 as u2
from google import genai
from google.genai import types
from google.genai import errors as genai_errors
from google.api_core import retry


def main():
    if len(sys.argv) == 1:
        sys.argv.append("--help")

    parser = argparse.ArgumentParser(
        description="Interact with Android UIs using an AI agent.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,  # Disable default -h/--help to manually define --help only
        epilog="""
Environment:
  ANDROID_SERIAL  Serial number of device to connect to (see 'adb devices -l').
                  To target a specific device, use:
                    env ANDROID_SERIAL=<serial> popper "accept all permissions"
  GEMINI_API_KEY  Required. Your Gemini API key.
""",
    )
    parser.add_argument(
        "goal",
        type=str,
        nargs="?",
        help="The goal for the AI to achieve (e.g. 'start an exercise')",
    )
    parser.add_argument(
        "--launch",
        type=str,
        metavar="PACKAGE",
        help="Launch the specified app before starting (e.g. com.example.fitness)",
    )
    parser.add_argument(
        "--stay-in-app",
        action="store_true",
        help="Restrict the agent to a single application package for the entire run",
    )
    parser.add_argument(
        "--timeout",
        type=int,
        default=180,
        metavar="SECONDS",
        help="Maximum execution time in seconds (default: 180; exit code 2 on timeout)",
    )
    parser.add_argument(
        "--output-format",
        choices=["text", "stream-json"],
        default="text",
        help="Output format: 'text' (default, human-readable) or 'stream-json' (NDJSON to stdout)",
    )
    parser.add_argument(
        "--screenshots",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Enable/disable screenshot capture and transmission to the model (default: enabled)",
    )
    parser.add_argument(
        "--dump-layout",
        action="store_true",
        help="Dump the UI layout as JSON and exit",
    )
    parser.add_argument(
        "--help",
        action="help",
        default=argparse.SUPPRESS,
        help="show this help message and exit",
    )

    args = parser.parse_args()
    if not args.dump_layout and not args.goal:
        parser.error("the following arguments are required: goal")

    step = 0
    context_usage = {
        "input_limit": 1048576,  # Default fallback
        "prompt_tokens": 0,
        "candidate_tokens": 0,
    }

    def emit(event: dict):
        """Emit a stream-json event to stdout."""
        if args.output_format != "stream-json":
            return
        event["timestamp"] = datetime.datetime.now(datetime.timezone.utc).isoformat()
        print(json.dumps(event, separators=(",", ":")), flush=True)

    def timeout_handler(signum, frame):
        emit(
            {
                "type": "result",
                "success": False,
                "reason": "timeout",
                "steps": step,
                "elapsed_ms": args.timeout * 1000,
            }
        )
        print(
            f"popper: timed out after {args.timeout} seconds",
            file=sys.stderr,
        )
        sys.exit(2)

    if args.timeout:
        if hasattr(signal, "SIGALRM"):
            signal.signal(signal.SIGALRM, timeout_handler)
            signal.alarm(args.timeout)
        else:
            print(
                "popper: --timeout is not supported on this platform (requires SIGALRM)",
                file=sys.stderr,
            )

    api_key = os.environ.get("GEMINI_CLI_GEMINI_API_KEY") or os.environ.get(
        "GEMINI_API_KEY"
    )
    if not api_key:
        print("popper: GEMINI_API_KEY environment variable not set", file=sys.stderr)
        sys.exit(1)
    os.environ["GEMINI_API_KEY"] = api_key

    serial = os.environ.get("ANDROID_SERIAL")
    try:
        # Connect to the device
        if not args.dump_layout:
            print(
                f"[local] Connecting to device {serial if serial else 'default'}",
                file=sys.stderr,
            )
        d = u2.connect(serial)
    except Exception as e:
        print(f"popper: Failed to connect to device: {e}", file=sys.stderr)
        sys.exit(1)

    current_layout_map = {}

    def get_ui_state():
        current_layout_map.clear()
        try:
            res = []
            nodes = [
                n
                for n in ET.fromstring(d.dump_hierarchy()).iter("node")
                if n.get("text") or n.get("content-desc")
            ]
            for idx, n in enumerate(nodes):
                b = [int(x) for x in re.findall(r"\d+", n.get("bounds") or "")]
                if len(b) >= 4:
                    cx, cy = (b[0] + b[2]) // 2, (b[1] + b[3]) // 2
                    element_id = f"{step}:{idx}"
                    current_layout_map[element_id] = (cx, cy)
                    item = {
                        "id": element_id,
                        "text": n.get("text"),
                        "content-desc": n.get("content-desc"),
                        "resource-id": n.get("resource-id").split("/")[-1]
                        if n.get("resource-id")
                        else "",
                        "center": f"[{cx},{cy}]",
                    }
                    res.append({k: v for k, v in item.items() if v})
            return json.dumps(res, ensure_ascii=False)
        except Exception:
            return "[]"

    if args.dump_layout:
        print(get_ui_state())
        sys.exit(0)

    print("[local] Initializing AI", file=sys.stderr)

    # Ensure screen is awake
    try:
        d.screen_on()
        d.shell("wm dismiss-keyguard")
    except Exception as e:
        print(f"[local] Warning: Failed to wake up screen: {e}", file=sys.stderr)

    if args.launch:
        print(f"[local] Launching {args.launch}", file=sys.stderr)
        try:
            d.app_start(args.launch)
            time.sleep(2)  # allow app launch animation to settle
        except Exception as e:
            print(f"popper: failed to launch {args.launch}: {e}", file=sys.stderr)
            sys.exit(1)

    # Note: `app_auto_grant_permissions(pkg)` is intentionally omitted.
    # We want this script to replicate manual UI actions (taps, swipes) as much as possible.

    # Get device metadata to help the agent
    try:
        device_info = d.app_current()
        initial_package = device_info.get("package", "")

        # Try to gather extra hardware context via shell to avoid uiautomator2 info crash
        try:
            size_output = d.shell("wm size").output.strip()
            if "Physical size: " in size_output:
                dims = size_output.replace("Physical size: ", "").split("x")
                if len(dims) == 2:
                    device_info["display_width"] = int(dims[0].strip())
                    device_info["display_height"] = int(dims[1].strip())

            density_output = d.shell("wm density").output.strip()
            if "Physical density: " in density_output:
                density_val = density_output.replace("Physical density: ", "").strip()
                if density_val.isdigit():
                    device_info["display_density"] = int(density_val)

            sdk_output = d.shell("getprop ro.build.version.sdk").output.strip()
            if sdk_output.isdigit():
                device_info["sdk_int"] = int(sdk_output)
        except Exception as e:
            print(
                f"[local] Warning: Could not get extended device info: {e}",
                file=sys.stderr,
            )

        # Determine if it's a watch, tv, auto, or generic mobile device
        characteristics = d.shell("getprop ro.build.characteristics").output.strip()
        device_info["characteristics"] = characteristics
        if "watch" in characteristics:
            device_info["device_type"] = "Wear OS Watch"
        elif "tv" in characteristics:
            device_info["device_type"] = "Android TV"
        elif "automotive" in characteristics:
            device_info["device_type"] = "Android Automotive"
        else:
            device_info["device_type"] = "Android Phone/Tablet"

        print(f"[local] Device Info: {device_info}", file=sys.stderr)
    except Exception as e:
        device_info = {}
        initial_package = ""
        print(f"[local] Warning: Failed to get device info: {e}", file=sys.stderr)
    print(f"[local] Starting package: {initial_package}", file=sys.stderr)

    restricted_package = initial_package if args.stay_in_app else ""
    if args.stay_in_app and not restricted_package:
        print(
            "popper: --stay-in-app requires a current app package; launch an app first or use --launch",
            file=sys.stderr,
        )
        sys.exit(1)

    client = genai.Client()

    try:
        model_info = client.models.get(model="gemini-3-flash-preview")
        context_usage["input_limit"] = model_info.input_token_limit
    except Exception as e:
        print(f"[local] Warning: Failed to fetch model limits: {e}", file=sys.stderr)

    def capture_state_as_parts():
        """Attempts to dump the hierarchy and screenshot. Returns the XML string
        and the screenshot formatted as a FunctionResponsePart.
        """
        xml = get_ui_state()

        img_part = None
        if args.screenshots:
            try:
                img = d.screenshot()
                img_byte_arr = io.BytesIO()
                img.save(img_byte_arr, format="JPEG", quality=85)
                img_bytes = img_byte_arr.getvalue()

                img_part = types.FunctionResponsePart.from_bytes(
                    data=img_bytes, mime_type="image/jpeg"
                )
                img_part.inline_data.display_name = "screenshot.jpg"
            except Exception:
                pass

        return xml, img_part

    # Define UI tools
    def tap_element(
        text: str = None,
        resource_id: str = None,
        description: str = None,
        duration_ms: int = 0,
    ) -> dict:
        """Taps (or long-presses) a UI element. Only provide ONE search criteria.

        Args:
            text: The exact text of the element to tap.
            resource_id: The exact resource-id of the element to tap.
            description: The exact content-desc of the element to tap.
            duration_ms: If greater than 0, performs a long-press (tap and hold)
                         for the specified number of milliseconds.
        """
        criteria = []
        if text:
            criteria.append(f"text='{text}'")
        if resource_id:
            criteria.append(f"resource_id='{resource_id}'")
        if description:
            criteria.append(f"description='{description}'")
        criteria_str = ", ".join(criteria) if criteria else "none provided"
        action = "Tapping"
        if duration_ms > 0:
            action = f"Long-pressing ({duration_ms}ms)"
        print(f"[agent] {action} element ({criteria_str})", file=sys.stderr)

        try:
            if text:
                el = d(text=text)
            elif resource_id:
                el = d(resourceId=resource_id)
            elif description:
                el = d(description=description)
            else:
                return {
                    "status": "error",
                    "message": "Must provide text, resource_id, or description",
                }

            if el.exists:
                if duration_ms > 0:
                    el.long_click(duration=duration_ms / 1000.0)
                else:
                    el.click()
                time.sleep(1.5)
                return {"status": "success"}
            else:
                return {
                    "status": "error",
                    "message": "Element not found. Try scrolling or checking criteria.",
                }
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def tap_by_id(element_id: str) -> dict:
        """Taps the screen at the coordinates of the UI element with the specified ID.

        Args:
            element_id: The ID of the element to tap in 'step:index' format
                (e.g. '1:5').
        """
        print(f"[agent] Tapping by ID: {element_id}", file=sys.stderr)
        if element_id not in current_layout_map:
            try:
                s, _ = map(int, element_id.split(":"))
                if s != step:
                    return {
                        "status": "error",
                        "message": f"ID '{element_id}' belongs to step {s}, but current step is {step}. Use IDs from the current UI state.",
                    }
            except ValueError:
                pass
            return {
                "status": "error",
                "message": f"Element ID '{element_id}' not found in current layout.",
            }

        x, y = current_layout_map[element_id]
        try:
            d.click(x, y)
            time.sleep(1.5)
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def scroll(direction: str) -> dict:
        """Scrolls the screen in the specified direction.

        Args:
            direction: The direction to scroll. MUST be one of: 'forward' (scrolls down to reveal content below), 'backward' (scrolls up to reveal content above), 'left' (scrolls left to reveal the next page), 'right' (scrolls right to reveal the previous page).
        """
        print(f"[agent] Scrolling {direction}", file=sys.stderr)
        try:
            if direction == "forward":
                d.swipe_ext("up")
            elif direction == "backward":
                d.swipe_ext("down")
            elif direction == "left":
                d.swipe_ext("right")
            elif direction == "right":
                d.swipe_ext("left")
            else:
                return {
                    "status": "error",
                    "message": f"Invalid direction '{direction}'. Must be one of: 'forward', 'backward', 'left', 'right'",
                }

            time.sleep(1.5)
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def press_button(button: str, is_long_press: bool = False) -> dict:
        """Presses (or long-presses) a physical device button.

        Args:
            button: The button to press. MUST be one of: 'home', 'back', or 'enter'.
            is_long_press: If True, performs a long-press of the button.
        """
        action = "Long-pressing" if is_long_press else "Pressing"
        print(f"[agent] {action} {button} button", file=sys.stderr)
        try:
            if button not in ["home", "back", "enter"]:
                return {
                    "status": "error",
                    "message": f"Invalid button '{button}'. Must be one of: 'home', 'back', 'enter'",
                }

            if is_long_press:
                d.long_press(button)
            else:
                d.press(button)

            time.sleep(1.5)
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def input_text(
        text_to_type: str,
        text: str = None,
        resource_id: str = None,
        description: str = None,
    ) -> dict:
        """Inputs text into a UI element matching the provided criteria. If criteria are provided, it will tap the element first to focus it. If no criteria are provided, it types into the currently focused element.

        Args:
            text_to_type: The exact text to input into the field.
            text: Optional. The exact text of the element to tap before typing.
            resource_id: Optional. The exact resource-id of the element to tap before typing.
            description: Optional. The exact content-desc of the element to tap before typing.
        """
        criteria = []
        if text:
            criteria.append(f"text='{text}'")
        if resource_id:
            criteria.append(f"resource_id='{resource_id}'")
        if description:
            criteria.append(f"description='{description}'")
        criteria_str = ", ".join(criteria) if criteria else "currently focused element"
        print(
            f"[agent] Inputting text '{text_to_type}' into {criteria_str}",
            file=sys.stderr,
        )

        try:
            if text or resource_id or description:
                if text:
                    el = d(text=text)
                elif resource_id:
                    el = d(resourceId=resource_id)
                else:
                    el = d(description=description)

                if el.exists:
                    el.set_text(text_to_type)
                    time.sleep(1.5)
                    return {"status": "success"}
                else:
                    return {
                        "status": "error",
                        "message": "Element not found. Try scrolling or checking criteria.",
                    }
            else:
                d.send_keys(text_to_type, clear=True)
                time.sleep(1.5)
                return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def open_notification() -> dict:
        """Opens the system notification shade."""
        print("[agent] Opening notification shade", file=sys.stderr)
        try:
            d.open_notification()
            time.sleep(1.5)
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def open_quick_settings() -> dict:
        """Opens the system quick settings panel."""
        print("[agent] Opening quick settings", file=sys.stderr)
        try:
            d.open_quick_settings()
            time.sleep(1.5)
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def observe(delay_ms: int = 0) -> dict:
        """Retrieve the current UI hierarchy without performing any action. Use this
        to wait for the screen to update after a previous action, or to re-examine
        the current state.

        Args:
            delay_ms: Minimum milliseconds to wait before reading the screen.
        """
        if delay_ms > 0:
            time.sleep(delay_ms / 1000.0)
        print(f"[agent] Observing screen (delay={delay_ms}ms)", file=sys.stderr)
        try:
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def tap_coordinates(x: int, y: int, duration_ms: int = 0) -> dict:
        """Taps (or long-presses) the screen at the exact (x, y) pixel coordinates.

        Args:
            x: The horizontal pixel coordinate (0 to display_width).
            y: The vertical pixel coordinate (0 to display_height).
            duration_ms: If greater than 0, performs a long-press (tap and hold)
                         for the specified number of milliseconds.
        """
        msg = f"Tapping coordinates ({x}, {y})"
        if duration_ms > 0:
            msg = f"Long-pressing coordinates ({x}, {y}) for {duration_ms}ms"
        print(f"[agent] {msg}", file=sys.stderr)

        try:
            if duration_ms > 0:
                d.long_click(x, y, duration=duration_ms / 1000.0)
            else:
                d.click(x, y)
            time.sleep(1.5)
            return {"status": "success"}
        except Exception as e:
            return {"status": "error", "message": str(e)}

    def complete_task(success: bool, reason: str) -> dict:
        """Call this when the goal has been definitively achieved or cannot be achieved.

        Args:
            success: True if the goal was achieved, False if it failed.
            reason: Explanation of the outcome.
        """
        print(
            f"[agent] Task marked complete (success={success}, reason={reason})",
            file=sys.stderr,
        )
        return {"success": success, "reason": reason}

    ui_tools = [
        tap_element,
        tap_by_id,
        scroll,
        press_button,
        input_text,
        open_notification,
        open_quick_settings,
        observe,
        tap_coordinates,
        complete_task,
    ]

    tool_map = {fn.__name__: fn for fn in ui_tools}

    # Set up AI context
    if args.stay_in_app and restricted_package:
        cross_app_instruction = (
            f"You MUST stay within the application package '{restricted_package}' "
            "for the entire task. If an action would leave this package, do not "
            "take it. Use complete_task(success=False, ...) instead."
        )
    elif args.launch:
        cross_app_instruction = (
            f"The target application is {args.launch}. "
            "Prefer to accomplish the goal within this app."
        )
    else:
        cross_app_instruction = (
            "You are ALLOWED to cross app boundaries "
            "(e.g. into system settings or other apps) to achieve the goal."
        )

    # The core system instruction template is adapted from the official Google Gemini documentation
    # for agentic workflows: https://ai.google.dev/gemini-api/docs/prompting-strategies#agentic-si-template
    system_instruction = f"""You are a very strong reasoner and planner operating a complex user interface. Use these critical instructions to structure your plans, thoughts, and responses.

Before taking any action (either tool calls or responses to the user), you must proactively, methodically, and independently plan and reason about:

1) Logical dependencies and constraints: Analyze the intended UI action against the following factors. Resolve conflicts in order of importance:
    1.1) Policy-based rules, mandatory prerequisites, and constraints of the interface.
    1.2) Order of operations: Ensure taking a UI action does not prevent a subsequent necessary action.
        1.2.1) The user may request actions in a random order, but you may need to reorder operations to maximize successful completion of the task.
    1.3) Other prerequisites (information and/or actions needed).
    1.4) Explicit user constraints or preferences.

2) Risk assessment: What are the consequences of taking the action? Will the new UI state cause any future issues?

3) Abductive reasoning and hypothesis exploration: At each step, identify the most logical and likely reason for any UI problem or error encountered.
    3.1) Wear OS specific: If you are operating a Wear OS watch and cannot find an expected action button (like Pause, Stop, or Settings), it is highly likely located on an adjacent horizontal page. Use the scroll tool to swipe 'left' or 'right' to discover hidden pages. Paging indicators often do not appear in the XML hierarchy.
    3.2) Visual Fallback: If an element is clearly visible in the screenshot but does not appear in the XML (e.g. game engines, WebViews, icons without descriptions), use the tap_coordinates tool to interact with it visually.

4) Outcome evaluation and adaptability: Does the previous observation require any changes to your plan?

5) Information availability: Incorporate all applicable and alternative sources of information, including:
    5.1) Using available tools and their capabilities.
    5.2) All policies, rules, checklists, and constraints.
    5.3) Previous observations and conversation history.

6) Precision and Grounding: Ensure your reasoning is extremely precise and relevant to each exact ongoing situation.

7) Completeness: Ensure that all requirements, constraints, options, and preferences are exhaustively incorporated into your plan.

8) Persistence and patience: Do not give up unless all the reasoning above is exhausted.
    8.1) Don't be dissuaded by time taken or user frustration.
    8.2) This persistence must be intelligent: On transient errors (e.g. timeout, UI loading), you must retry unless an explicit retry limit (e.g., max 3 tries) has been reached. If such a limit is hit, you must stop. On other errors, you must change your strategy or arguments, not repeat the same failed tool call.

9) Inhibit your response: only take an action after all the above reasoning is completed. Once you've executed a state-changing UI action, you cannot take it back.

When thinking silently: ALWAYS start the thought with a brief (one sentence) recap of the current progress on the task. In particular, consider whether the task is already done.

In quoted strings, the only allowed escape sequences are \\\\, \\n, and \\". Instead of \\\\u escapes, use UTF-8.

---
Device Information:
{device_info}

Constraints:
{cross_app_instruction}
"""

    config = types.GenerateContentConfig(
        tools=ui_tools,
        system_instruction=system_instruction,
        # temperature=1.0 is required by gemini-3-flash-preview. The model was
        # trained at this temperature; lower values degrade output quality.
        temperature=1.0,
        tool_config=types.ToolConfig(
            function_calling_config=types.FunctionCallingConfig(mode="ANY")
        ),
        automatic_function_calling=types.AutomaticFunctionCallingConfig(disable=True),
        thinking_config=types.ThinkingConfig(thinking_level="low"),
    )

    chat = client.chats.create(model="gemini-3-flash-preview", config=config)

    print(f"[goal] {args.goal}", file=sys.stderr)

    # Send the initial UI state and goal to the model
    # For the initial prompt, we must send the raw PIL Image if available.
    initial_xml = get_ui_state()

    try:
        initial_img = d.screenshot()
    except Exception:
        initial_img = None

    prompt = [
        f"""Goal: {args.goal}

Current UI State:
{initial_xml}

Element IDs use 'step:index' format such as '0:12'. When calling tap_by_id,
use IDs from the latest UI state.

What is your first action?"""
    ]
    if initial_img:
        prompt.append(initial_img)

    def should_retry(exception: Exception) -> bool:
        """Retry on rate limits (429) and server errors (500, 503)."""
        if isinstance(exception, genai_errors.APIError):
            if exception.code in (429, 500, 503):
                print(
                    f"[local] Warning: API error {exception.code} ({exception.status}). Retrying with backoff...",
                    file=sys.stderr,
                )
                return True
        return False

    @retry.Retry(
        predicate=should_retry,
        initial=2.0,
        maximum=60.0,
        multiplier=2.0,
        timeout=300.0,
    )
    def send_with_retry(message):
        resp = chat.send_message(message)
        if resp.usage_metadata:
            context_usage["prompt_tokens"] = resp.usage_metadata.prompt_token_count
            context_usage["candidate_tokens"] += (
                resp.usage_metadata.candidates_token_count
            )

            # Print reactive usage to stderr for human readability
            rem_pct = 100 * (
                1.0 - (context_usage["prompt_tokens"] / context_usage["input_limit"])
            )
            print(
                f"[context] Input: {context_usage['prompt_tokens']}/{context_usage['input_limit']} ({rem_pct:.1f}% remaining)",
                file=sys.stderr,
            )
        return resp

    def extract_text(response):
        text_output = ""
        if response.candidates and response.candidates[0].content.parts:
            for part in response.candidates[0].content.parts:
                if part.text:
                    text_output += part.text
        return text_output.strip()

    try:
        session_start = time.perf_counter()

        emit({"type": "start", "goal": args.goal, "device": device_info})
        emit({"type": "hierarchy", "step": 0, "xml": initial_xml})

        response = send_with_retry(prompt)
        task_result = None

        while task_result is None:
            function_calls = []
            if response.candidates and response.candidates[0].content.parts:
                function_calls = [
                    part.function_call
                    for part in response.candidates[0].content.parts
                    if part.function_call
                ]

            if not function_calls:
                text = extract_text(response)
                print(
                    f"[agent] Model responded without tool call: {text}",
                    file=sys.stderr,
                )
                sys.exit(1)

            tool_results = []
            for fc in function_calls:
                step += 1
                fn = tool_map[fc.name]

                step_start = time.perf_counter()

                args_dict = dict(fc.args) if fc.args else {}
                result = fn(**args_dict)

                elapsed_ms = int((time.perf_counter() - step_start) * 1000)
                session_elapsed_ms = int((time.perf_counter() - session_start) * 1000)

                emit(
                    {
                        "type": "step",
                        "step": step,
                        "action": fc.name,
                        "args": args_dict,
                        "status": result.get("status", "success")
                        if isinstance(result, dict)
                        else "success",
                        "elapsed_ms": elapsed_ms,
                    }
                )

                # Check if it is a dictionary (our tools return dicts)
                if isinstance(result, dict):
                    if fc.name == "complete_task":
                        task_result = result

                    # Inject timing so the agent sees it in the function response
                    result["step_elapsed_ms"] = elapsed_ms
                    result["session_elapsed_ms"] = session_elapsed_ms

                    # Capture state for the function response (unless complete)
                    parts_list = []
                    if fc.name != "complete_task":
                        xml_str, img_part = capture_state_as_parts()
                        result["new_ui_hierarchy"] = xml_str
                        emit({"type": "hierarchy", "step": step, "xml": xml_str})

                        if restricted_package:
                            try:
                                current_package = d.app_current().get("package", "")
                            except Exception:
                                current_package = ""

                            if current_package != restricted_package:
                                task_result = {
                                    "success": False,
                                    "reason": (
                                        "Left restricted application package "
                                        f"'{restricted_package}' and entered "
                                        f"'{current_package or 'unknown'}'"
                                    ),
                                }
                                result["status"] = "error"
                                result["message"] = task_result["reason"]

                        if img_part:
                            result["screenshot"] = {"$ref": "screenshot.jpg"}
                            parts_list.append(img_part)

                tool_results.append(
                    types.Part.from_function_response(
                        name=fc.name,
                        response=result,
                        parts=parts_list
                        if "parts_list" in locals() and parts_list
                        else None,
                    )
                )

                if task_result is not None:
                    break

            if task_result is not None:
                break

            response = send_with_retry(tool_results)

        total_elapsed = time.perf_counter() - session_start
        emit(
            {
                "type": "result",
                "success": task_result.get("success", False),
                "reason": task_result.get("reason", ""),
                "steps": step,
                "elapsed_ms": int(total_elapsed * 1000),
                "context": context_usage,
            }
        )

        sys.exit(0 if task_result.get("success") else 1)
    except Exception as e:
        print(
            f"[local] Error communicating with AI or executing UI actions: {e}",
            file=sys.stderr,
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
