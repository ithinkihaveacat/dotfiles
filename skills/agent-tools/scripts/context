            slug = slug[len("docs/") :]
        if slug.endswith(".mdx"):
            slug = slug[:-4]
        published = f"https://agentskills.io/{slug}"

        entry_file(
            file,
            f"https://raw.githubusercontent.com/agentskills/agentskills/main/{rel}",
            published,
        )

    entry_url(
        "https://platform.claude.com/docs/en/agents-and-tools/agent-skills/best-practices.md",
        "https://platform.claude.com/docs/en/agents-and-tools/agent-skills/best-practices",
