#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "requests",
# ]
# ///

import argparse
import json
import os
import sys
import requests
import tempfile
import tarfile
import glob
import re
import hashlib
from datetime import datetime

# Global state
ENTRY_COUNTER = 0
ENTRIES = []

CONTEXT_BASE_DIR = os.path.join(
    os.environ.get("XDG_DATA_HOME", os.path.expanduser("~/.local/share")),
    "context",
)

IGNORED_DIRS = {
    ".git",
    "node_modules",
    "__pycache__",
    "venv",
    ".venv",
    "env",
    ".env",
    ".idea",
    ".vscode",
    "build",
    "dist",
    "out",
    "target",
    ".next",
    ".nuxt",
}


def _emit_entry(display_cmd, content):
    global ENTRY_COUNTER
    ENTRY_COUNTER += 1
    ENTRIES.append(
        {"id": str(ENTRY_COUNTER), "command": display_cmd, "output": content}
    )


def _make_display_cmd(url, web_url=None):
    cmd = f"curl -sfSL '{url}'"
    if web_url:
        cmd += f"  # published to {web_url}"
    return cmd


class ContextAPI:
    def __init__(self, catalog_dict):
        self.catalog = catalog_dict

    def add_entry(self, name, handler, description):
        self.catalog[name] = (handler, description)

    def emit(self, display_cmd, content):
        _emit_entry(display_cmd, content)

    def entry_url(self, fetch_url, web_url=None):
        entry_url(fetch_url, web_url)

    def entry_file(self, local_path, display_url, web_url=None):
        entry_file(local_path, display_url, web_url)


def load_plugins(catalog_dict):
    import importlib.util

    plugins_dir = os.path.expanduser("~/.config/context/plugins")
    if not os.path.isdir(plugins_dir):
        return

    api = ContextAPI(catalog_dict)
    for filename in os.listdir(plugins_dir):
        if filename.endswith(".py"):
            filepath = os.path.join(plugins_dir, filename)
            module_name = f"context_plugin_{filename[:-3]}"
            try:
                spec = importlib.util.spec_from_file_location(module_name, filepath)
                if spec and spec.loader:
                    module = importlib.util.module_from_spec(spec)
                    sys.modules[module_name] = module
                    spec.loader.exec_module(module)
                    if hasattr(module, "register"):
                        module.register(api)
            except Exception as e:
                print(
                    f"context: warning: failed to load plugin {filepath}: {e}",
                    file=sys.stderr,
                )


def _clean_notebook_data(data):
    for cell in data.get("cells", []):
        if cell.get("cell_type") == "code":
            cell["outputs"] = []
            cell["execution_count"] = None
    return data


def entry_url(fetch_url, web_url=None):
    display_cmd = _make_display_cmd(fetch_url, web_url)
    try:
        response = requests.get(fetch_url)
        response.raise_for_status()
        _emit_entry(display_cmd, response.text)
    except Exception as e:
        print(f"context: failed to fetch {fetch_url}: {e}", file=sys.stderr)
        sys.exit(1)


def entry_file(local_path, display_url, web_url=None):
    display_cmd = _make_display_cmd(display_url, web_url)
    try:
        with open(local_path, "r", encoding="utf-8") as f:
            content = f.read()
        _emit_entry(display_cmd, content)
    except Exception as e:
        print(
            f"context: warning: skipping unreadable file: {local_path} ({e})",
            file=sys.stderr,
        )


def fetch(url):
    if not url.startswith("github://"):
        print(f"context: fetch: unsupported URL scheme: {url}", file=sys.stderr)
        sys.exit(1)

    repo_spec = url[len("github://") :]
    branch = "main"
    if "@" in repo_spec:
        repo, branch = repo_spec.split("@")
    else:
        repo = repo_spec

    archive_url = f"https://github.com/{repo}/archive/refs/heads/{branch}.tar.gz"

    print(f"[local] Fetching {archive_url}", file=sys.stderr)
    try:
        response = requests.get(archive_url, stream=True)
        response.raise_for_status()
    except Exception as e:
        print(f"context: fetch: failed to download {archive_url}: {e}", file=sys.stderr)
        sys.exit(1)

    extract_dir = tempfile.mkdtemp(prefix="fetch.")

    with tempfile.NamedTemporaryFile(delete=False) as tmp_file:
        for chunk in response.iter_content(chunk_size=8192):
            tmp_file.write(chunk)
        tmp_file_path = tmp_file.name

    try:
        with tarfile.open(tmp_file_path, "r:gz") as tar:
            members = tar.getmembers()
            if not members:
                print("context: fetch: empty archive", file=sys.stderr)
                sys.exit(1)

            root_dir = members[0].name.split("/")[0]

            for member in members:
                if member.name.startswith(root_dir + "/"):
                    member.name = member.name[len(root_dir) + 1 :]
                    if (
                        member.name
                    ):  # avoid extracting the root dir itself as empty string
                        tar.extract(member, path=extract_dir, filter="data")
    except Exception as e:
        print(f"context: fetch: failed to extract archive: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        os.unlink(tmp_file_path)

    return extract_dir


def handle_url_target(url):
    # Regex to match GitHub URLs
    match = re.match(
        r"https://github\.com/([^/]+)/([^/]+)(/tree/([^/]+)(/(.*))?)?", url
    )
    if not match:
        print(f"context: handle_url_target: invalid GitHub URL: {url}", file=sys.stderr)
        sys.exit(1)

    owner = match.group(1)
    repo = match.group(2)
    branch = match.group(4) or "main"
    path = match.group(6) or ""

    repo_full = f"{owner}/{repo}"

    archive_url = f"https://github.com/{repo_full}/archive/refs/heads/{branch}.tar.gz"

    print(f"[local] Fetching {archive_url}", file=sys.stderr)
    try:
        response = requests.get(archive_url, stream=True)
        response.raise_for_status()
    except Exception as e:
        print(f"context: fetch: failed to download {archive_url}: {e}", file=sys.stderr)
        sys.exit(1)

    extract_dir = tempfile.mkdtemp(prefix="fetch.")

    with tempfile.NamedTemporaryFile(delete=False) as tmp_file:
        for chunk in response.iter_content(chunk_size=8192):
            tmp_file.write(chunk)
        tmp_file_path = tmp_file.name

    try:
        with tarfile.open(tmp_file_path, "r:gz") as tar:
            members = tar.getmembers()
            if not members:
                print("context: fetch: empty archive", file=sys.stderr)
                sys.exit(1)

            root_dir = members[0].name.split("/")[0]

            for member in members:
                if member.name.startswith(root_dir + "/"):
                    member.name = member.name[len(root_dir) + 1 :]
                    if member.name:
                        tar.extract(member, path=extract_dir, filter="data")
    except Exception as e:
        print(f"context: fetch: failed to extract archive: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        os.unlink(tmp_file_path)

    target_dir = os.path.join(extract_dir, path)
    if not os.path.exists(target_dir):
        print(f"context: path not found in repo: {path}", file=sys.stderr)
        sys.exit(1)

    search_pattern = os.path.join(target_dir, "**", "*")
    files = glob.glob(search_pattern, recursive=True)
    files.sort()

    for file in files:
        if os.path.isdir(file):
            continue

        rel_to_extract = os.path.relpath(file, extract_dir)

        display_url = (
            f"https://raw.githubusercontent.com/{repo_full}/{branch}/{rel_to_extract}"
        )
        web_url = f"https://github.com/{repo_full}/blob/{branch}/{rel_to_extract}"

        entry_file(file, display_url, web_url)


def handle_local_dir(directory):
    directory = os.path.abspath(directory)
    if not os.path.exists(directory):
        print(f"context: directory not found: {directory}", file=sys.stderr)
        sys.exit(1)

    print(f"[local] Processing directory {directory}", file=sys.stderr)

    for root, dirs, files in os.walk(directory):
        # Filter directories in-place
        dirs[:] = [d for d in dirs if not d.startswith(".") and d not in IGNORED_DIRS]

        for file in sorted(files):
            if file.startswith("."):
                continue

            file_path = os.path.join(root, file)
            rel_path = os.path.relpath(file_path, directory)

            # Use cat <rel_path> as display_cmd
            display_cmd = f"cat '{rel_path}'"

            try:
                with open(file_path, "r", encoding="utf-8") as f:
                    content = f.read()
                _emit_entry(display_cmd, content)
            except Exception as e:
                print(
                    f"context: warning: skipping unreadable file: {file_path} ({e})",
                    file=sys.stderr,
                )


