    # Script docs
    for doc in ["scripts", "scripts/conditions", "scripts/perform-actions"]:
        path = os.path.join(ha_io, f"source/_docs/{doc}.markdown")
        slug = doc
        published = f"https://www.home-assistant.io/docs/{slug}/"
        entry_file(
            path,
            f"https://raw.githubusercontent.com/home-assistant/home-assistant.io/current/source/_docs/{doc}.markdown",
            published,
        )

    # Configuration and templating docs
    for doc in ["configuration/yaml", "configuration/templating"]:
        path = os.path.join(ha_io, f"source/_docs/{doc}.markdown")
        published = f"https://www.home-assistant.io/docs/{doc}/"
        entry_file(
            path,
            f"https://raw.githubusercontent.com/home-assistant/home-assistant.io/current/source/_docs/{doc}.markdown",
            published,
        )

    # Dashboard docs
    files = []
    for d in ["source/_dashboards", "source/dashboards"]:
        dir_path = os.path.join(ha_io, d)
        if os.path.exists(dir_path):
            for f in os.listdir(dir_path):
                if f.endswith(".markdown"):
                    files.append(os.path.join(dir_path, f))
    files.sort()

    for file in files:
        rel = os.path.relpath(file, ha_io)
        dashboard = os.path.splitext(os.path.basename(file))[0]
        if dashboard == "index":
            published_slug = "dashboards/"
        else:
            published_slug = f"dashboards/{dashboard}/"
        published = f"https://www.home-assistant.io/{published_slug}"
        entry_file(
            file,
            f"https://raw.githubusercontent.com/home-assistant/home-assistant.io/current/{rel}",
            published,
        )

    # REST API and WebSocket API
    apis = [
        "rest.md",
        "websocket.md",
        "supervisor/endpoints.md",
        "supervisor/models.md",
    ]
    for api_file in apis:
        path = os.path.join(dev_docs, "docs/api", api_file)
        slug = os.path.splitext(api_file)[0]
        published = f"https://developers.home-assistant.io/docs/api/{slug}"
        entry_file(
            path,
            f"https://raw.githubusercontent.com/home-assistant/developers.home-assistant/master/docs/api/{api_file}",
            published,
        )

    # Apps documentation
    apps = [
        "communication.md",
        "configuration.md",
        "presentation.md",
        "publishing.md",
        "repository.md",
        "security.md",
        "testing.md",
        "tutorial.md",
    ]
    for apps_file in apps:
        path = os.path.join(dev_docs, "docs/apps", apps_file)
        slug = os.path.splitext(apps_file)[0]
        published = f"https://developers.home-assistant.io/docs/apps/{slug}"
        entry_file(
            path,
            f"https://raw.githubusercontent.com/home-assistant/developers.home-assistant/master/docs/apps/{apps_file}",
            published,
        )

    # Home Assistant AI Skills
    search_pattern = os.path.join(ha_skills, "skills", "**", "*.md")
    files = glob.glob(search_pattern, recursive=True)
    files.extend(
        glob.glob(os.path.join(ha_skills, "skills", "**", "*.markdown"), recursive=True)
    )
    files.sort()

    for file in files:
        rel = os.path.relpath(file, ha_skills)
        entry_file(
            file,
            f"https://raw.githubusercontent.com/homeassistant-ai/skills/main/{rel}",
            f"https://github.com/homeassistant-ai/skills/blob/main/{rel}",
        )


def entry_prompting():
    # Claude platform best practices
    claude_urls = [
        "https://platform.claude.com/docs/en/build-with-claude/prompt-engineering/overview",
        "https://platform.claude.com/docs/en/build-with-claude/prompt-engineering/claude-prompting-best-practices",
        "https://platform.claude.com/docs/en/agents-and-tools/tool-use/overview",
    ]
    for url in claude_urls:
        entry_url(f"{url}.md", url)

    # Google AI / Gemini API docs
    gemini_urls = [
        "https://ai.google.dev/gemini-api/docs/prompting-strategies",
        "https://ai.google.dev/gemini-api/docs/thinking",
        "https://ai.google.dev/gemini-api/docs/files",
        "https://ai.google.dev/gemini-api/docs/text-generation",
    ]
    for url in gemini_urls:
        entry_url(f"{url}.md.txt", url)

    # OpenAI Docs
    openai_slugs = ["guides/prompt-engineering", "guides/text", "guides/reasoning"]
    for slug in openai_slugs:
        entry_url(
            f"https://developers.openai.com/api/docs/{slug}.md",
            f"https://platform.openai.com/docs/{slug}",
        )

    entry_url(
        "https://raw.githubusercontent.com/openai/skills/main/skills/.curated/openai-docs/references/prompting-guide.md",
        "https://github.com/openai/skills/blob/main/skills/.curated/openai-docs/references/prompting-guide.md",
    )

    # OpenAI Cookbook - GPT-5 Prompting Guide
    try:
        cookbook_repo = fetch("github://openai/openai-cookbook")
        nb_path = os.path.join(
            cookbook_repo, "examples/gpt-5/gpt-5_prompting_guide.ipynb"
        )
        with open(nb_path, "r", encoding="utf-8") as f:
            data = json.load(f)

        # Strip outputs to keep it clean
        _clean_notebook_data(data)

        content = json.dumps(data, indent=2)
        display_url = "https://raw.githubusercontent.com/openai/openai-cookbook/main/examples/gpt-5/gpt-5_prompting_guide.ipynb"
        web_url = "https://cookbook.openai.com/examples/gpt-5/gpt-5_prompting_guide"
        display_cmd = f"curl -sfSL '{display_url}' | jq '.cells[] |= if .cell_type == \"code\" then .outputs = [] | .execution_count = null else . end'  # published to {web_url}"
        _emit_entry(display_cmd, content)
    except Exception as e:
        print(
            f"context: failed to fetch/parse OpenAI cookbook: {e}",
            file=sys.stderr,
        )


