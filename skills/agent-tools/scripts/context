def entry_meshtastic():
    repo = fetch("github://meshtastic/meshtastic@master")

    dirs = [
        "docs/getting-started",
        "docs/software/python-cli",
        "docs/hardware/devices",
        "docs/configuration",
    ]

    for dir_name in dirs:
        dir_path = os.path.join(repo, dir_name)
        if os.path.exists(dir_path):
            files = []
            for ext in ["*.md", "*.mdx"]:
                files.extend(
                    glob.glob(os.path.join(dir_path, "**", ext), recursive=True)
                )
            files.sort()

            for file in files:
                rel = os.path.relpath(file, repo)
                slug = rel
                if slug.endswith(".mdx"):
                    slug = slug[:-4]
                elif slug.endswith(".md"):
                    slug = slug[:-3]

                if os.path.basename(slug) == "index":
                    slug = os.path.dirname(slug)

                published = f"https://meshtastic.org/{slug}"

                entry_file(
                    file,
                    f"https://raw.githubusercontent.com/meshtastic/meshtastic/master/{rel}",
                    published,
                )


def cmd_catalog(catalog):
    for t in sorted(catalog.keys()):
        print(t)


def cmd_template():
    print('''"""
Example Plugin for the context script.
Save this file as ~/.config/context/plugins/my_plugin.py
"""
import os

def my_custom_entry_handler(api):
    """
    This function is called when the user requests this catalog entry.
    It should gather files or data and call api.emit(), api.entry_url(),
    or api.entry_file() to add them to the context session.
    """
    
    # 1. Emitting raw text content
    api.emit(
        display_cmd="echo 'Hello World'", 
        content="This is custom content generated by the plugin."
    )

    # 2. Emitting a local file
    # If the file exists, it will be read and added to the context.
    # The 'web_url' is optional but recommended if the file is published online.
    if os.path.exists("/etc/hosts"):
        api.entry_file(
            local_path="/etc/hosts", 
            display_url="cat /etc/hosts",
            web_url="https://example.com/docs/hosts"
        )
        
    # 3. Emitting a remote URL
    # The script will fetch the URL and add its content.
    # api.entry_url(
    #     fetch_url="https://raw.githubusercontent.com/.../README.md",
    #     web_url="https://github.com/.../README.md"
    # )

def register(api):
    """
    This function is automatically called by `bin/context` when the plugin is loaded.
    You must register your entries here using the provided `ContextAPI`.
    """
    api.add_entry(
        name="my-custom-entry",
        handler=lambda: my_custom_entry_handler(api),
        description="A demonstration of a custom plugin entry"
    )
''')


def cmd_show(target, force, catalog):
    cache_dir = os.path.join(
        os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")), "context"
    )

    is_dir_target = False
    is_url_target = False
    cache_file = None
    desc = ""
    func = None

    # 1. Handle Explicit Prefixes (Escape hatches)
    if target.startswith("dir:") or target.startswith("path:"):
        dir_path = target.split(":", 1)[1]
        if not os.path.isdir(dir_path):
            print(f"context: directory not found: {dir_path}", file=sys.stderr)
            sys.exit(1)
        target = dir_path
        desc = f"Local Directory: {target}"
        is_dir_target = True
    elif (
        target.startswith("https://github.com/")
        or target.startswith("github:")
        or target.startswith("http://")
        or target.startswith("github://")
    ):
        url_hash = hashlib.sha256(target.encode("utf-8")).hexdigest()
        cache_file = os.path.join(cache_dir, f"url_{url_hash}.xml")
        desc = f"GitHub URL: {target}"
        is_url_target = True

    # 2. Handle Implicit Resolution
    else:
        is_entry = target in catalog
        is_dir = os.path.isdir(target)

        # Unambiguous path intent (e.g., ./skills or /tmp/skills)
        is_explicit_path = (
            target.startswith((".", "/", "\\")) or ("/" in target) or ("\\" in target)
        )

        if is_explicit_path and is_dir:
            desc = f"Local Directory: {target}"
            is_dir_target = True
        elif is_entry and is_dir:
            print(
                f"context: warning: '{target}' matches both a catalog entry and a local directory.",
                file=sys.stderr,
            )
            print(
                f"context: warning: Resolving as catalog entry. To use the directory, run with 'dir:{target}' or './{target}'",
                file=sys.stderr,
            )
            func, desc = catalog[target]
            cache_file = os.path.join(cache_dir, f"{target}.xml")
        elif is_entry:
            func, desc = catalog[target]
            cache_file = os.path.join(cache_dir, f"{target}.xml")
        elif is_dir:
            desc = f"Local Directory: {target}"
            is_dir_target = True
        else:
            print(
                f"context: error: unknown catalog entry or directory: {target}",
                file=sys.stderr,
            )
            sys.exit(1)

    # Check cache
    use_cache = False
    if cache_file and not force and os.path.exists(cache_file):
        import time

        mtime = os.path.getmtime(cache_file)
        script_mtime = os.path.getmtime(os.path.realpath(__file__))

        if (time.time() - mtime) < 24 * 3600 and mtime > script_mtime:
            use_cache = True

    if use_cache and cache_file:
        with open(cache_file, "r") as f:
            print(f.read(), end="")
        sys.exit(0)

    if is_url_target:
        handle_url_target(target)
    elif is_dir_target:
        handle_local_dir(target)
    else:
        func()

    xml_output = generate_xml(desc)

    # Save to cache
    if cache_file:
        try:
            os.makedirs(cache_dir, exist_ok=True)
            with open(cache_file, "w") as f:
                f.write(xml_output)
        except Exception as e:
            print(f"context: warning: failed to update cache: {e}", file=sys.stderr)

    print(xml_output, end="")


def main():
    # Support 'help' as alias for '--help' and 'help <subcommand>'
    if len(sys.argv) > 1 and sys.argv[1] == "help":
        if len(sys.argv) > 2:
            subcmd = sys.argv[2]
            sys.argv = [sys.argv[0], subcmd, "--help"]
        else:
            sys.argv[1] = "--help"

    catalog = {
        "skills": (
            entry_skills,
            "Agent skills format specification and authoring guide",
        ),
        "gemini-api": (entry_gemini_api, "Gemini API documentation and examples"),
        "mcp-server": (entry_mcp_server, "MCP server documentation and specification"),
        "inkyframe": (entry_inkyframe, "Pimoroni Inky Frame documentation"),
        "rpi": (entry_rpi, "Raspberry Pi documentation"),
        "homeassistant": (
            entry_homeassistant,
            "Home Assistant integration, automation, API and CLI documentation",
        ),
        "prompting": (
            entry_prompting,
            "Prompt engineering guides for Claude, Gemini, and OpenAI",
        ),
        "gemini-sdk-js": (
            entry_gemini_sdk_js,
            "Google Gemini JavaScript SDK codegen instructions",
        ),
        "meshtastic": (entry_meshtastic, "Meshtastic documentation"),
        "gemini-cli": (entry_gemini_cli, "Gemini CLI documentation"),
        "compose-architecture": (
            entry_compose_architecture,
            "Android Compose Architecture documentation",
        ),
        "firebase": (
            entry_firebase,
            "Firebase CLI and hosting documentation",
        ),
    }

    # Construct help description
    load_plugins(catalog)

    description = (
        "Generate aggregated context for a specific catalog entry, "
        "a GitHub URL, or a local directory. Fetches resources (repositories, "
        "files, URLs) and emits them as structured XML for AI agent consumption.\n\n"
        "Catalog Entries:\n"
    )
    for t in sorted(catalog.keys()):
        func, desc = catalog[t]
        description += f"  {t:<22} {desc}\n"

    parser = argparse.ArgumentParser(
        description=description,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="command", help="Subcommands")

    # catalog subcommand
    subparsers.add_parser("catalog", help="List available catalog entries")

    # show subcommand
    show_parser = subparsers.add_parser("show", help="Show context for a target")
    show_parser.add_argument(
        "target", help="Catalog entry name, local directory, or GitHub URL"
    )
    show_parser.add_argument("--force", action="store_true", help="Force cache rebuild")

    # template subcommand
    subparsers.add_parser(
        "template", help="Output a template for creating a Python plugin"
    )

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "catalog":
        cmd_catalog(catalog)
        sys.exit(0)

    if args.command == "template":
        cmd_template()
        sys.exit(0)

    if args.command == "show":
        cmd_show(args.target, args.force, catalog)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)
    except BrokenPipeError:
        # Python flushes standard streams on exit; redirect remaining output
        # to devnull to avoid another BrokenPipeError at shutdown
        import os

        devnull = os.open(os.devnull, os.O_WRONLY)
        os.dup2(devnull, sys.stdout.fileno())
        sys.exit(141)
