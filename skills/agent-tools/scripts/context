def entry_inkyframe():
    inky = fetch("github://pimoroni/inky-frame")
    pico = fetch("github://pimoroni/pimoroni-pico")

    # inky-frame README
    readme = os.path.join(inky, "README.md")
    if os.path.exists(readme):
        entry_file(
            readme,
            "https://raw.githubusercontent.com/pimoroni/inky-frame/main/README.md",
        )

    # inky-frame docs, examples, modules
    for dir_name in ["docs", "examples", "modules"]:
        dir_path = os.path.join(inky, dir_name)
        if os.path.exists(dir_path):
            files = []
            for ext in ["*.md", "*.py"]:
                files.extend(
                    glob.glob(os.path.join(dir_path, "**", ext), recursive=True)
                )
            files.sort()

            for file in files:
                rel = os.path.relpath(file, inky)
                entry_file(
                    file,
                    f"https://raw.githubusercontent.com/pimoroni/inky-frame/main/{rel}",
                )

    # pimoroni-pico picographics
    pico_docs = os.path.join(pico, "micropython/modules/picographics")
    if os.path.exists(pico_docs):
        files = glob.glob(os.path.join(pico_docs, "**", "*.md"), recursive=True)
        files.sort()
        for file in files:
            rel = os.path.relpath(file, pico)
            entry_file(
                file,
                f"https://raw.githubusercontent.com/pimoroni/pimoroni-pico/main/{rel}",
            )

    # pimoroni-pico inky_frame examples
    pico_examples = os.path.join(pico, "micropython/examples/inky_frame")
    if os.path.exists(pico_examples):
        files = []
        for ext in ["*.md", "*.py"]:
            files.extend(
                glob.glob(os.path.join(pico_examples, "**", ext), recursive=True)
            )
        files.sort()
        for file in files:
            rel = os.path.relpath(file, pico)
            entry_file(
                file,
                f"https://raw.githubusercontent.com/pimoroni/pimoroni-pico/main/{rel}",
            )

    # External URLs
    entry_url(
        "https://docs.micropython.org/en/latest/_sources/reference/mpremote.rst.txt"
    )
    entry_url(
        "https://r.jina.ai/https://learn.pimoroni.com/article/getting-started-with-inky-frame",
        "https://learn.pimoroni.com/article/getting-started-with-inky-frame",
    )


def entry_rpi():
    repo = fetch("github://raspberrypi/documentation@master")
    src = os.path.join(repo, "documentation/asciidoc/computers")

    dirs = [
        "config_txt",
        "configuration",
        "getting-started",
        "os",
        "raspberry-pi",
        "remote-access",
    ]

    for dir_name in dirs:
        published = (
            f"https://www.raspberrypi.com/documentation/computers/{dir_name}.html"
        )

        # Index file
        index_file = os.path.join(src, f"{dir_name}.adoc")
        if os.path.exists(index_file):
            entry_file(
                index_file,
                f"https://raw.githubusercontent.com/raspberrypi/documentation/master/documentation/asciidoc/computers/{dir_name}.adoc",
                published,
            )

        # Directory contents
        dir_path = os.path.join(src, dir_name)
        if os.path.exists(dir_path):
            search_pattern = os.path.join(dir_path, "**", "*.adoc")
            files = glob.glob(search_pattern, recursive=True)
            files = [f for f in files if "device-tree.adoc" not in f]
            files.sort()

            for file in files:
                rel = os.path.relpath(file, repo)
                entry_file(
                    file,
                    f"https://raw.githubusercontent.com/raspberrypi/documentation/master/{rel}",
                    published,
                )

    # Standalone file
    software_sources = os.path.join(src, "software-sources.adoc")
    if os.path.exists(software_sources):
        entry_file(
            software_sources,
            "https://raw.githubusercontent.com/raspberrypi/documentation/master/documentation/asciidoc/computers/software-sources.adoc",
            "https://www.raspberrypi.com/documentation/computers/software-sources.html",
        )


