    )

    entry_url(
        "https://raw.githubusercontent.com/anthropics/skills/refs/heads/main/skills/skill-creator/SKILL.md"
    )


def generate_xml(topic_desc, use_toc=True):
    # We build the XML manually or via ET.
    # Since we need to calculate line numbers for TOC, and CDATA blocks are hard to do with ET
    # without third party libraries or hacks (ET escapes < and > inside text even if we want CDATA),
    # it might be easier to generate strings or use a hybrid approach.

    # Let's build the entries strings first to count lines.

    entry_strings = []
    for entry in ENTRIES:
        s = f'<entry id="{entry["id"]}">\n'
        s += f"<command>{entry['command']}</command>\n"
        s += f"<output><![CDATA[{entry['output']}]]></output>\n"
        s += "</entry>\n"
        entry_strings.append(s)

    # Now calculate TOC if needed
    toc_items = []
    if use_toc:
        # We need to know the starting line of entries.
        # Header lines + TOC lines.

        timestamp = datetime.now().strftime("%Y-%m-%dT%H:%M:%S%z")
        header = f"""<shell_session>
<context_summary>
  <generated_at>{timestamp}</generated_at>
  <purpose>
    Topic: {topic_desc}

    This content represents a recorded shell session designed to provide context for an AI agent.
    It aggregates resources (local files, remote URLs, system info) by capturing shell commands
    and their output.
  </purpose>
  <structure>
    The session is organized as a sequence of &lt;entry&gt; elements:
    1. &lt;command&gt;: The command string acting as the data source. (e.g., "cat file.txt" or "curl url")
       Treat this as the source of truth for where the data originated.
    2. &lt;output&gt;: The raw content returned by that command.
  </structure>
  <guidelines>
    - PROVENANCE: The &lt;command&gt; element indicates an approximate source for the data. In some cases
      the actual retrieval method may differ (e.g., fetched from a local cache or extracted archive).
    - SNAPSHOT: Outputs represent a best-effort snapshot at the time this script was run.
    - CITATION: If a &lt;command&gt; contains a "# published to URL" comment, that URL represents the
      canonical, human-readable source for the content. Agents are encouraged to prioritize this
      URL when citing sources or providing links to the user.
  </guidelines>
</context_summary>
"""
        header_lines = header.count("\n")

        toc_lines = (
            len(ENTRIES) + 2
        )  # <table_of_contents> + items + </table_of_contents>

        current_line = header_lines + toc_lines + 1

        for i, entry in enumerate(ENTRIES):
            est = entry_strings[i]
            lines = est.count("\n")
            start = current_line
            end = current_line + lines - 1
            toc_items.append(
                f'  <item id="{entry["id"]}" startLine="{start}" endLine="{end}">{entry["command"]}</item>'
            )
            current_line += lines

    output = []
    output.append(header)
    if use_toc:
        output.append("<table_of_contents>\n")
        for item in toc_items:
            output.append(item + "\n")
        output.append("</table_of_contents>\n")

    for s in entry_strings:
        output.append(s)

    output.append("</shell_session>\n")
    return "".join(output)


def entry_gemini_api():
    repo = fetch("github://google-gemini/cookbook")

    notebooks = [
        "examples/Book_illustration.ipynb",
        "examples/json_capabilities/Entity_Extraction_JSON.ipynb",
        "examples/prompting/Basic_Evaluation.ipynb",
        "examples/prompting/Basic_Information_Extraction.ipynb",
        "quickstarts/Caching.ipynb",
        "quickstarts/Counting_Tokens.ipynb",
        "quickstarts/Error_handling.ipynb",
        "quickstarts/Function_calling.ipynb",
        "quickstarts/Get_Started_Nano_Banana.ipynb",
        "quickstarts/Image_out.ipynb",
        "quickstarts/JSON_mode.ipynb",
        "quickstarts/Safety.ipynb",
        "quickstarts/System_instructions.ipynb",
    ]

    for nb in notebooks:
        nb_path = os.path.join(repo, nb)
        colab = f"https://colab.research.google.com/github/google-gemini/cookbook/blob/main/{nb}"

        try:
            with open(nb_path, "r", encoding="utf-8") as f:
                data = json.load(f)

            _clean_notebook_data(data)

            content = json.dumps(data, indent=2)

            display_url = (
                f"https://raw.githubusercontent.com/google-gemini/cookbook/main/{nb}"
            )
            display_cmd = f"curl -sfSL '{display_url}' | jq '.cells[] |= if .cell_type == \"code\" then .outputs = [] | .execution_count = null else . end'  # published to {colab}"
            _emit_entry(display_cmd, content)
        except Exception as e:
            print(f"context: failed to process notebook {nb}: {e}", file=sys.stderr)

    urls = [
        "https://ai.google.dev/gemini-api/docs/caching.md.txt",
        "https://ai.google.dev/gemini-api/docs/files.md.txt",
        "https://ai.google.dev/gemini-api/docs/function-calling.md.txt",
        "https://ai.google.dev/gemini-api/docs/google-search.md.txt",
        "https://ai.google.dev/gemini-api/docs/imagen.md.txt",
        "https://ai.google.dev/gemini-api/docs/image-generation.md.txt",
        "https://ai.google.dev/gemini-api/docs/image-understanding.md.txt",
        "https://ai.google.dev/gemini-api/docs/interactions.md.txt",
        "https://ai.google.dev/gemini-api/docs/long-context.md.txt",
        "https://ai.google.dev/gemini-api/docs/models.md.txt",
        "https://ai.google.dev/gemini-api/docs/pricing.md.txt",
        "https://ai.google.dev/gemini-api/docs/prompting-strategies.md.txt",
        "https://ai.google.dev/gemini-api/docs/rate-limits.md.txt",
        "https://ai.google.dev/gemini-api/docs/safety-settings.md.txt",
        "https://ai.google.dev/gemini-api/docs/structured-output.md.txt",
        "https://ai.google.dev/gemini-api/docs/text-generation.md.txt",
        "https://ai.google.dev/gemini-api/docs/tokens.md.txt",
        "https://ai.google.dev/gemini-api/docs/troubleshooting.md.txt",
    ]

    for url in urls:
        entry_url(url)


def entry_mcp_server():
    repo = fetch("github://modelcontextprotocol/modelcontextprotocol")

    # Specific doc files
    files = [
        "docs/docs/learn/server-concepts.mdx",
        "docs/docs/learn/architecture.mdx",
        "docs/docs/develop/build-server.mdx",
    ]

    for file in files:
        path = os.path.join(repo, file)
        slug = file[len("docs/docs/") :]
        slug = slug[:-4] if slug.endswith(".mdx") else slug
        published = f"https://modelcontextprotocol.io/docs/{slug}"

        entry_file(
            path,
            f"https://raw.githubusercontent.com/modelcontextprotocol/modelcontextprotocol/main/{file}",
            published,
        )

    # Specification directory
    spec_dir = os.path.join(repo, "docs/specification/2025-11-25")
    search_pattern = os.path.join(spec_dir, "**", "*.mdx")
    spec_files = glob.glob(search_pattern, recursive=True)
    spec_files = [f for f in spec_files if "schema.mdx" not in f]
    spec_files.sort()

    for file in spec_files:
        rel = os.path.relpath(file, repo)
        slug = rel[len("docs/") :]
        slug = slug[:-4] if slug.endswith(".mdx") else slug
        published = f"https://modelcontextprotocol.io/{slug}"

        entry_file(
            file,
            f"https://raw.githubusercontent.com/modelcontextprotocol/modelcontextprotocol/main/{rel}",
            published,
        )


