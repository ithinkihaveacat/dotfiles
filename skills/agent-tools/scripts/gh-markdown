#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "requests",
# ]
# ///

import sys
import requests
import os
from urllib.parse import urlparse

def usage(file=sys.stdout):
    print(f"Usage: {os.path.basename(sys.argv[0])} <url>", file=file)
    print("", file=file)
    print("Fetches GitHub PR details and timeline using GraphQL.", file=file)
    print("Requires GITHUB_API_KEY environment variable.", file=file)
    print("", file=file)
    print("Options:", file=file)
    print("  --help      Display this help message and exit", file=file)
    print("", file=file)
    print("Examples:", file=file)
    print(f"  {os.path.basename(sys.argv[0])} https://github.com/owner/repo/pull/123", file=file)

def parse_github_url(url):
    path_parts = urlparse(url).path.strip("/").split("/")
    if len(path_parts) >= 4 and path_parts[2] == "pull":
        return path_parts[0], path_parts[1], int(path_parts[3])
    raise ValueError("Invalid GitHub PR URL format.")

def main():
    if "-h" in sys.argv:
        print("Error: invalid option '-h'. Use '--help' instead.", file=sys.stderr)
        sys.exit(1)

    if len(sys.argv) < 2:
        print("Error: missing URL argument.", file=sys.stderr)
        usage(file=sys.stderr)
        sys.exit(1)

    if sys.argv[1] in ("--help", "help"):
        usage(file=sys.stdout)
        sys.exit(0)

    url = sys.argv[1]
    
    api_key = os.environ.get("GITHUB_API_KEY")
    if not api_key:
        print("Error: GITHUB_API_KEY environment variable is not set.", file=sys.stderr)
        sys.exit(1)

    try:
        owner, repo, number = parse_github_url(url)
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    headers = {
        "Authorization": f"bearer {api_key}",
        "Content-Type": "application/json",
    }

    # We use the GraphQL API because the GitHub REST API for listing review comments
    # (/pulls/{number}/comments) does not expose the "resolved" status of review threads.
    query = """
    query($owner: String!, $repo: String!, $number: Int!) {
      repository(owner: $owner, name: $repo) {
        pullRequest(number: $number) {
          title
          url
          state
          author { login }
          createdAt
          body
          baseRefName
          headRefName
          labels(first: 100) { nodes { name } }
          
          comments(first: 100) {
            nodes {
              author { login }
              createdAt
              body
            }
          }
          
          reviews(first: 100) {
            nodes {
              author { login }
              state
              submittedAt
              body
            }
          }
          
          reviewThreads(first: 100) {
            nodes {
              isResolved
              path
              comments(first: 100) {
                nodes {
                  author { login }
                  createdAt
                  body
                  line
                  originalLine
                  diffHunk
                }
              }
            }
          }
        }
      }
    }
    """

    variables = {
        "owner": owner,
        "repo": repo,
        "number": number,
    }

    response = requests.post(
        "https://api.github.com/graphql",
        headers=headers,
        json={"query": query, "variables": variables},
    )

    if response.status_code != 200:
        print(f"API error: {response.status_code} - {response.text}", file=sys.stderr)
        sys.exit(1)

    data = response.json()
    
    if "errors" in data:
        print(f"GraphQL errors: {data['errors']}", file=sys.stderr)
        sys.exit(1)

    if "data" in data and data["data"] and "repository" in data["data"] and data["data"]["repository"]:
        pr = data["data"]["repository"]["pullRequest"]
        if not pr:
            print("Error: PR not found in repository", file=sys.stderr)
            sys.exit(1)
    else:
        print("Error: Repository or data missing in response", file=sys.stderr)
        sys.exit(1)

    # Format output
    md = []
    md.append(f"# PR: {pr['title']}")
    md.append(f"**Author:** {(pr.get('author') or {}).get('login', 'Unknown')}")
    md.append(f"**URL:** {pr['url']}")
    md.append(f"**State:** {pr['state'].capitalize()}")
    md.append(f"**Base Branch:** {pr['baseRefName']}")
    md.append(f"**Head Branch:** {pr['headRefName']}")
    
    labels = [label["name"] for label in pr["labels"]["nodes"]]
    md.append(f"**Labels:** {', '.join(labels) if labels else 'None'}")
    md.append(f"**Created:** {pr['createdAt']}")
    md.append("\n## Description\n")
    
    def quote_body(body):
        if not body:
            return ""
        return "\n".join(f"> {line}" for line in body.splitlines())

    md.append(quote_body(pr["body"]) or "*No description provided.*")
    md.append("\n---\n")

    # Combine events for timeline
    timeline = []

    for node in pr["comments"]["nodes"]:
        timeline.append({
            "type": "comment",
            "date": node["createdAt"],
            "data": node
        })

    for node in pr["reviews"]["nodes"]:
        if node["body"] or node["state"] != "COMMENTED":
            timeline.append({
                "type": "review",
                "date": node["submittedAt"] or pr["createdAt"],
                "data": node
            })

    for node in pr["reviewThreads"]["nodes"]:
        if node["comments"]["nodes"]:
            first_comment = node["comments"]["nodes"][0]
            timeline.append({
                "type": "thread",
                "date": first_comment["createdAt"],
                "data": node
            })

    # Sort by date
    timeline.sort(key=lambda x: x["date"])

    # Render timeline
    for item in timeline:
        if item["type"] == "comment":
            c = item["data"]
            author = (c.get("author") or {}).get("login", "Unknown")
            md.append(f"### Comment by {author} on {c['createdAt']}")
            md.append(quote_body(c['body']))
            md.append("\n---\n")
            
        elif item["type"] == "review":
            r = item["data"]
            author = (r.get("author") or {}).get("login", "Unknown")
            state = r["state"].capitalize()
            md.append(f"### Review ({state}) by {author} on {r['submittedAt']}")
            if r["body"]:
                md.append(quote_body(r["body"]))
            md.append("\n---\n")
            
        elif item["type"] == "thread":
            t = item["data"]
            first_comment = t["comments"]["nodes"][0]
            path = t["path"]
            line = first_comment.get("line") or first_comment.get("originalLine") or "Unknown"
            resolved_status = "[RESOLVED] " if t["isResolved"] else ""
            
            md.append(f"### Inline Thread {resolved_status}on `{path}` (Line {line})")
            
            # Show diff hunk from first comment if available
            if first_comment.get("diffHunk"):
                md.append("```diff")
                md.append(first_comment["diffHunk"])
                md.append("```")
                
            for c in t["comments"]["nodes"]:
                author = (c.get("author") or {}).get("login", "Unknown")
                md.append(f"**{author}** ({c['createdAt']}):")
                md.append(quote_body(c["body"]))
                md.append("")
            md.append("\n---\n")

    print("\n".join(md))

if __name__ == "__main__":
    main()
