run_test() {
  local input="$1"
  local expected="$2"

  TEST_NUM=$((TEST_NUM + 1))

  local err_file
  err_file=$(mktemp)

  OUTPUT=$("$BIN_JETPACK" resolve "$input" 2>"$err_file" || true)
  local err_msg
  err_msg=$(cat "$err_file")
  rm -f "$err_file"

  if [ "$OUTPUT" == "$expected" ]; then
    echo "ok $TEST_NUM - $input -> $expected"
  else
    echo "not ok $TEST_NUM - $input -> $expected"
    echo "# Got: $OUTPUT"
    echo "# Expected: $expected"
    if [[ -n "$err_msg" ]]; then
      while IFS= read -r line; do
        echo "# Stderr: $line"
      done <<<"$err_msg"
    fi
  fi
}

