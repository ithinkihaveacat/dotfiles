#!/usr/bin/env bash
#
# Tests for bin/jetpack resolve subcommand

set -u

# Setup paths
SCRIPT_DIR=$(dirname "$0")
ROOT_DIR="$SCRIPT_DIR/.."
BIN_JETPACK="$ROOT_DIR/scripts/jetpack"

# Total number of tests
TOTAL_TESTS=25
TEST_NUM=0

echo "1..$TOTAL_TESTS"

run_test() {
  local input="$1"
  local expected="$2"

  TEST_NUM=$((TEST_NUM + 1))

  # Suppress stderr to avoid cluttering test output on expected resolution failures
  OUTPUT=$("$BIN_JETPACK" resolve "$input" 2>/dev/null || true)

  if [ "$OUTPUT" == "$expected" ]; then
    echo "ok $TEST_NUM - $input -> $expected"
  else
    echo "not ok $TEST_NUM - $input -> $expected"
    echo "# Got: $OUTPUT"
    echo "# Expected: $expected"
  fi
}

# Existing tests
run_test "androidx.glance.wear.GlanceWearWidgetService" "androidx.glance.wear:wear"
run_test "androidx.glance.wear.WearWidgetParams" "androidx.glance.wear:wear"
run_test "androidx.compose.remote.creation.compose.layout.RemoteBox" "androidx.compose.remote:remote-creation-compose"
run_test "androidx.wear.compose.remote.material3.RemoteButton" "androidx.wear.compose.remote:remote-material3"
run_test "androidx.glance.wear.WearWidgetDocument" "androidx.glance.wear:wear"

# Help examples
run_test "androidx.core.splashscreen.SplashScreen" "androidx.core:core-splashscreen"
run_test "androidx.wear.ambient.AmbientLifecycleObserver" "androidx.wear:wear"
run_test "androidx.wear.protolayout.material3.textButton" "androidx.wear.protolayout:protolayout-material3"
run_test "androidx.lifecycle.ViewModel" "androidx.lifecycle:lifecycle-viewmodel"
run_test "androidx.health.services.client.data.ExerciseTrackedStatus" "androidx.health:health-services-client"

run_test "androidx.activity.compose.ComponentActivity" "androidx.activity:activity-compose"
run_test "androidx.compose.foundation.lazy.LazyColumn" "androidx.compose.foundation:foundation"
run_test "androidx.compose.material3.Button" "androidx.compose.material3:material3"
run_test "androidx.compose.ui.unit.Dp" "androidx.compose.ui:ui-unit"
run_test "androidx.lifecycle.compose.LifecycleStartEffect" "androidx.lifecycle:lifecycle-runtime-compose"
