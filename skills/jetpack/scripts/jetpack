#!/usr/bin/env bash
#
# jetpack - Jetpack library utilities
#
# Subcommands:
#   version           Get version for a package (ALPHA/BETA/RC/STABLE/SNAPSHOT)
#   resolve           Convert package name to Maven coordinate
#   source            Download and extract source JARs
#   inspect           Convenience wrapper: resolve + source
#
# Tests: tests/jetpack/

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "$(basename "$0"): requires bash 4.0 or higher (found ${BASH_VERSION})" >&2
  exit 1
fi

SCRIPT_NAME=$(basename "$0")

# =============================================================================
# SHARED CONSTANTS
# =============================================================================

GOOGLE_MAVEN_URL="https://dl.google.com/android/maven2"
SNAPSHOT_REPO_URL="https://androidx.dev/snapshots/latest/artifacts/repository"
SNAPSHOT_BUILD_URL_PREFIX="https://androidx.dev/snapshots/builds"

# =============================================================================
# SHARED HELPERS
# =============================================================================

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

# Verify external dependencies. Deferred until a real command runs so that
# --help (and command-index-sync) work even when dependencies are absent.
check_deps() {
  require curl
  require xmllint
  require jq
  require perl
  require jar
  require gunzip
}

validate_artifact_format() {
  local artifact="$1"
  if [[ ! "$artifact" =~ ^[^:]+:[^:]+$ ]]; then
    echo "$SCRIPT_NAME: invalid artifact format '$artifact' (expected GROUP_ID:ARTIFACT_ID)" >&2
    exit 1
  fi
}

fetch_maven_metadata() {
  local repo_url="$1"
  local group_id="$2"
  local artifact_id="$3"
  local group_id_path
  group_id_path=$(echo "$group_id" | sed 's/\./\//g')

  local metadata_url="$repo_url/$group_id_path/$artifact_id/maven-metadata.xml"

  if ! curl -sSLf "$metadata_url"; then
    echo "$SCRIPT_NAME: artifact '$group_id:$artifact_id' not found at $metadata_url (404)" >&2

    # Suggest alternatives from the local index
    if [[ "$repo_url" == "$GOOGLE_MAVEN_URL" ]]; then
      local suggestions
      # Try searching for artifacts with the same name in other groups (using the new default local search)
      suggestions=$(cmd_search "$artifact_id" 2>/dev/null | grep ":$artifact_id$" | head -n 5 || true)
      if [[ -z "$suggestions" ]]; then
        # Try a broader search if no exact artifact name matches
        suggestions=$(cmd_search "$artifact_id" 2>/dev/null | head -n 3 || true)
      fi

      if [[ -n "$suggestions" ]]; then
        echo "$SCRIPT_NAME: did you mean one of these?" >&2
        # shellcheck disable=SC2001  # sed needed for multiline prefix
        echo "$suggestions" | sed 's/^/  /' >&2
      fi
    fi
    return 1
  fi
}

extract_versions_from_xml() {
  xmllint --xpath "//version/text()" - | tr ' ' '\n' | sort -V
}

# Classify a version string into one of three categories:
#   "symbolic" - ALPHA, BETA, RC, STABLE, LATEST, SNAPSHOT (floating versions)
#   "build_id" - All digits, e.g., 14710011 (pinned snapshot build)
#   "pinned"   - Specific version string, e.g., 1.6.0-alpha01 (pinned release)
classify_version() {
  local version="$1"
  local version_upper
  version_upper=$(echo "$version" | tr '[:lower:]' '[:upper:]')

  case "$version_upper" in
    ALPHA | BETA | RC | STABLE | LATEST | SNAPSHOT)
      echo "symbolic"
      ;;
    *)
      if [[ "$version" =~ ^[0-9]+$ ]]; then
        echo "build_id"
      else
        echo "pinned"
      fi
      ;;
  esac
}

# =============================================================================
# MAIN USAGE
# =============================================================================

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME <command> [arguments]

Jetpack library utilities for working with AndroidX packages.
This tool helps resolve Maven artifacts, finding versions, and downloading
source code for AndroidX libraries, including support for SNAPSHOT builds.

Commands:
  version <artifact> [type] [repo]
                      Get the version string for a Maven artifact.
                      Types: ALPHA, BETA, RC, STABLE, LATEST, SNAPSHOT, or BUILD_ID.
                      Default: STABLE.
  list versions <artifact> [repo]
                      List all versions for a given Maven artifact.
  list dependencies <artifact> [version]
                      List direct Maven dependencies for a given Maven artifact.
  resolve <name>      Convert a fully qualified class name or package prefix to
                      its corresponding Maven artifact (GROUP_ID:ARTIFACT_ID).
                      Uses internal heuristics and an exceptions table.
  search <query> [--force]
                      Search for artifacts by package name (using cached index)
                      or class name (using Android Code Search).
                      Use --force to rebuild the local package index.
  source <artifact>... [version]
                      Download and extract source JARs for one or more Maven artifacts.
                      Supports symbolic versions (e.g. ALPHA) or pinned versions.
                      Handles Kotlin Multiplatform platform sources automatically.
                      Options: --output <dir>, --find <pattern>
  inspect <name> [version]
                      Convenience wrapper that resolves a class name to an artifact
                      and then downloads its source.
Options:
  --help              Display this help message and exit

Environment Variables:
  XDG_CACHE_HOME      Base directory for cache (default: \$HOME/.cache)

Examples:
  # Check the latest stable version
  $SCRIPT_NAME version androidx.wear.tiles:tiles STABLE

  # Check the latest alpha version
  $SCRIPT_NAME version androidx.wear.tiles:tiles ALPHA

  # Resolve a class to its artifact
  $SCRIPT_NAME resolve androidx.core.splashscreen.SplashScreen
  # Output: androidx.core:core-splashscreen

  # Search for libraries related to 'compose'
  $SCRIPT_NAME search androidx.wear.compose

  # Force update the search index
  $SCRIPT_NAME search --force androidx.wear

  # Download source code for the latest SNAPSHOT
  $SCRIPT_NAME source androidx.wear.tiles:tiles SNAPSHOT

  # Inspect source code for a class (downloads and extracts)
  $SCRIPT_NAME inspect androidx.lifecycle.ViewModel

  # List all versions
  $SCRIPT_NAME list versions androidx.wear.tiles:tiles

  # Download specific snapshot build by ID
  $SCRIPT_NAME source androidx.wear.tiles:tiles 14765146
EOF
  exit "${1:-0}"
}

# =============================================================================
# SEARCH SUBCOMMAND
# =============================================================================

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/jetpack"
INDEX_FILE="$CACHE_DIR/androidx-index.json"
MAX_AGE_SECONDS=$((24 * 3600)) # 24 hours

usage_search() {
  cat <<EOF
Usage: $SCRIPT_NAME search [OPTIONS] QUERY

Search for AndroidX artifacts by package name or class name.

Arguments:
  QUERY       Search term (substring match on package, artifact, or class name)

Options:
  --force     Force cache rebuild (ignore existing index)
  --help      Display this help message

Examples:
  $SCRIPT_NAME search androidx.wear.compose
  $SCRIPT_NAME search RemoteImage
  $SCRIPT_NAME search --force androidx.wear  # Rebuild index
EOF
  exit "${1:-0}"
}

is_index_fresh() {
  if [[ ! -f "$INDEX_FILE" ]]; then
    return 1
  fi

  local file_age
  if [[ "$OSTYPE" == "darwin"* ]]; then
    file_age=$(stat -f "%m" "$INDEX_FILE")
  else
    file_age=$(stat -c "%Y" "$INDEX_FILE")
  fi

  local current_time
  current_time=$(date +%s)

  local age=$((current_time - file_age))
  if [[ $age -lt $MAX_AGE_SECONDS ]]; then
    return 0
  else
    return 1
  fi
}

update_index() {
  echo "info: Updating GMaven index..." >&2
  mkdir -p "$CACHE_DIR"
  local index_url="https://dl.google.com/android/studio/gmaven/index/release/v0.1/classes-v0.1.json.gz"

  (
    local tmp_gz tmp_json
    tmp_gz=$(mktemp)
    tmp_json="${tmp_gz}.json"
    trap 'rm -f "$tmp_gz" "$tmp_json"' EXIT

    # Added -f to fail immediately on HTTP errors instead of saving error pages
    if ! curl -sSLf -o "$tmp_gz" "$index_url"; then
      echo "warning: Failed to download GMaven index." >&2
      if [[ -f "$INDEX_FILE" ]]; then
        echo "warning: Using stale cache." >&2
        exit 0
      fi
      exit 1
    fi

    if ! gunzip -c "$tmp_gz" >"$tmp_json"; then
      echo "warning: Failed to decompress GMaven index." >&2
      if [[ -f "$INDEX_FILE" ]]; then
        echo "warning: Using stale cache." >&2
        exit 0
      fi
      exit 1
    fi

    # Atomic swap guarantees cache integrity and prevents race conditions
    mv "$tmp_json" "$INDEX_FILE"
    echo "info: Index updated." >&2
  )
}

search_index() {
  local query="$1"

  if ! is_index_fresh; then
    update_index
  fi

  if [[ ! -f "$INDEX_FILE" ]]; then
    echo "error: Index file not found and update failed." >&2
    return 1
  fi

  # Auto-detect format: array (old) vs object (new with .Index)
  #
  # ARCHITECTURAL NOTE: CLIENT-SIDE KMP REDIRECTION
  # -----------------------------------------------
  # In Kotlin Multiplatform (KMP), a library is split into:
  #   1. A "base" artifact (e.g., `androidx.annotation:annotation`) which is
  #      practically an empty jar containing only Gradle metadata (.module).
  #   2. Platform-specific target artifacts (e.g., `androidx.annotation:annotation-jvm`,
  #      `androidx.annotation:annotation-iosarm64`) which contain the actual class files.
  #
  # Because the base artifact jar is physically empty, the official GMaven indexer
  # assigns an empty class list ("fqcns": []) to the base artifact, and lists the
  # actual classes under the platform-specific target artifacts.
  #
  # In Android Studio (the IDE), this "pure" index is resolved dynamically:
  #   - For projects using older Android Gradle Plugin (AGP < 8.4), the IDE suggests
  #     depending directly on the platform target (e.g., `annotation-jvm`) because
  #     older AGP versions had issues resolving KMP base redirect attributes.
  #   - For projects on AGP 8.4+, the IDE interceptor dynamically redirects the
  #     suggestion to the base artifact (e.g., `annotation`), which Gradle then
  #     resolves to the correct platform target at build time.
  #
  # Since this 'jetpack' CLI tool runs outside Android Studio and lacks project/AGP
  # context, it would normally suggest the platform-specific target (e.g., `annotation-jvm`)
  # when you search for a class like `NonNull`. However, developers almost always
  # want to declare the clean base artifact in their build files (especially in KMP
  # commonMain).
  #
  # To solve this without needing server-side changes to the published index (which
  # must remain "pure" for backward compatibility with older IDEs/AGPs), we implement
  # CLIENT-SIDE KMP REDIRECTION directly in our jq filter:
  #
  # 1. If a search match is found in a platform-specific target (identified by
  #     KMP suffixes like -jvm, -android, -iosarm64, etc.), we strip the suffix
  #     to derive the potential base artifact ID.
  # 2. We then check if the base artifact actually exists in the index.
  # 3. If the base exists, we dynamically redirect the result and return the base
  #    coordinate (e.g., `androidx.annotation:annotation`) instead of the target.
  #
  # WHY WE MUST HARDCODE/FILTER THE KMP SUFFIXES:
  # ---------------------------------------------
  # We cannot blindly redirect any artifact ending with a hyphen. Many Jetpack
  # libraries use hyphens for distinct sub-modules, extensions, or test helpers
  # that are NOT transparent KMP redirects, and must be depended on explicitly.
  # For example:
  #   - `androidx.core:core-ktx` (Kotlin extensions) vs `androidx.core:core` (base)
  #   - `androidx.room:room-compiler` (annotation processor) vs `androidx.room:room` (runtime)
  #   - `androidx.work:work-testing` (test helpers) vs `androidx.work:work` (runtime)
  #
  # If we blindly stripped suffixes, searching for a KTX-specific class would
  # incorrectly redirect to the base library, leaving the developer without the
  # extensions they need. Therefore, we use a strict regex to only target actual
  # KMP platform suffixes (JVM, Android, Desktop, iOS, macOS, Linux, watchOS,
  # tvOS, JS, Wasm).
  #
  # ALGORITHMIC OPTIMIZATION:
  # -------------------------
  # To prevent performance degradation (O(N*M) complexity) from scanning the entire
  # index array for every match during the base-existence check, we pre-compute
  # a lookup dictionary ($artifact_lookup) of all coordinates at the start.
  # This keeps the search running in O(N + M) time, ensuring instant CLI responses
  # even for highly generic queries.
  jq -r --arg q "$query" '
    # 1. Bind DRY regex with exhaustive standard KMP targets (including wasmwasi and Windows mingw)
    "-(jvm|android|desktop|ios[a-z0-9]+|macos[a-z0-9]+|linux[a-z0-9]+|tvos[a-z0-9]+|watchos[a-z0-9]+|js|wasmjs|wasmwasi|mingw[a-z0-9]+)$" as $kmp_regex |
    
    # 2. Normalize query to lowercase for forgiving, case-insensitive searches
    ($q | ascii_downcase) as $query_lower |
    
    .Index as $index |
    ($index | map({key: "\(.groupId):\(.artifactId)", value: true}) | from_entries) as $artifact_lookup |
    
    $index[] | select(
      (.groupId | ascii_downcase | contains($query_lower)) or 
      (.artifactId | ascii_downcase | contains($query_lower)) or 
      (any(.fqcns[]?; ascii_downcase | contains($query_lower)))
    ) |
    .groupId as $group |
    .artifactId as $artifact |
    
    # 3. Apply the DRY regex to both test and sub
    if ($artifact | test($kmp_regex; "i")) then
      ($artifact | sub($kmp_regex; ""; "i")) as $base_artifact |
      if ($artifact_lookup["\($group):\($base_artifact)"]) then
        "\($group):\($base_artifact)"
      else
        "\($group):\($artifact)"
      end
    else
      "\($group):\($artifact)"
    end
  ' "$INDEX_FILE" | sort -u
}

# Code Search (Grimoire API) scraping code removed. The local GMaven class
# index (classes-v0.1.json) is now used by default for all package and class
# searches, making external Code Search network calls obsolete.

cmd_search() {
  local query=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help)
        usage_search
        ;;
      --code)
        echo "$SCRIPT_NAME search: --code (Code Search) is no longer supported." >&2
        echo "The local GMaven class index is now used by default for all searches." >&2
        exit 1
        ;;
      --force)
        rm -f "$INDEX_FILE"
        shift
        ;;
      -*)
        echo "$SCRIPT_NAME search: unknown option: $1" >&2
        exit 1
        ;;
      *)
        if [[ -z "$query" ]]; then
          query="$1"
        else
          echo "$SCRIPT_NAME search: too many arguments" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$query" ]]; then
    usage_search 1 >&2
  fi

  search_index "$query"
}

# =============================================================================
# VERSION SUBCOMMAND
# =============================================================================

usage_version() {
  cat <<EOF
Usage: $SCRIPT_NAME version ARTIFACT [VERSION_TYPE] [REPO_URL]

Get a specific version type for a given Maven artifact.

Arguments:
  ARTIFACT      The Maven artifact (e.g., androidx.wear.tiles:tiles)
  VERSION_TYPE  The version type to retrieve: ALPHA, BETA, RC, STABLE,
                LATEST, or SNAPSHOT (optional, defaults to STABLE)
                OR a build ID integer (e.g. 14765146) for a specific snapshot.
  REPO_URL      The Maven repository URL (optional, defaults to Google Maven)
                For SNAPSHOT, this is ignored and the androidx.dev snapshot
                repo is used.

**About SNAPSHOT builds:** These are bleeding-edge versions of Jetpack
libraries. 'SNAPSHOT' refers to the **latest** available build from
androidx.dev. More info: https://androidx.dev/

Version Types:
  ALPHA    - Latest alpha version (e.g., 1.2.3-alpha04)
  BETA     - Latest beta version (e.g., 1.2.3-beta02)
  RC       - Latest release candidate version (e.g., 1.2.3-rc01)
  STABLE   - Latest stable release (e.g., 1.2.3)
  LATEST   - Latest version of any kind (from maven-metadata.xml)
  SNAPSHOT - Latest snapshot version from androidx.dev
  <BUILD_ID> - Snapshot version from a specific build ID (e.g. 14765146)

Examples:
  $SCRIPT_NAME version androidx.wear.tiles:tiles
  $SCRIPT_NAME version androidx.wear.tiles:tiles ALPHA
  $SCRIPT_NAME version androidx.wear.tiles:tiles SNAPSHOT
  $SCRIPT_NAME version androidx.wear.tiles:tiles 14765146
  $SCRIPT_NAME version com.google.android.horologist:horologist-datalayer \\
    STABLE https://repo1.maven.org/maven2
EOF
  exit "${1:-0}"
}

cmd_version() {
  if [[ "${1:-}" == "--help" ]]; then
    usage_version
  fi

  if [[ $# -lt 1 ]]; then
    usage_version 1 >&2
  fi

  local artifact="$1"
  validate_artifact_format "$artifact"

  # Parse optional arguments
  local version_type repo_url
  local arg2="${2:-}"

  if [[ -n "$arg2" ]]; then
    if [[ "$arg2" =~ ^https?:// ]]; then
      version_type="STABLE"
      repo_url="$arg2"
    elif [[ "$arg2" =~ ^[0-9]+$ ]]; then
      version_type="SNAPSHOT"
      repo_url="${SNAPSHOT_BUILD_URL_PREFIX}/${arg2}/artifacts/repository"
    else
      version_type=$(echo "$arg2" | tr '[:lower:]' '[:upper:]')
      repo_url="${3:-$GOOGLE_MAVEN_URL}"
    fi
  else
    version_type="STABLE"
    repo_url="$GOOGLE_MAVEN_URL"
  fi

  # Validate version type
  case "$version_type" in
    ALPHA | BETA | RC | STABLE | LATEST | SNAPSHOT) ;;
    *)
      echo "$SCRIPT_NAME version: invalid version type '$version_type'" >&2
      echo "Valid types: ALPHA, BETA, RC, STABLE, LATEST, SNAPSHOT, <BUILD_ID>" >&2
      exit 1
      ;;
  esac

  local group_id artifact_id group_id_path
  group_id=$(echo "$artifact" | cut -d: -f1)
  artifact_id=$(echo "$artifact" | cut -d: -f2)
  group_id_path=$(echo "$group_id" | sed 's/\./\//g')

  local version xml_content all_versions

  # Handle SNAPSHOT separately
  if [[ "$version_type" == "SNAPSHOT" ]]; then
    if [[ "$repo_url" == "$GOOGLE_MAVEN_URL" ]]; then
      repo_url="$SNAPSHOT_REPO_URL"
    fi

    if ! xml_content=$(fetch_maven_metadata "$repo_url" "$group_id" "$artifact_id"); then
      echo "$SCRIPT_NAME version: package may not exist in snapshot builds" >&2
      exit 1
    fi

    version=$(echo "$xml_content" | extract_versions_from_xml | grep -E '\-SNAPSHOT$' | tail -n 1)

    if [[ -z "$version" ]]; then
      echo "$SCRIPT_NAME version: no snapshot version found" >&2
      exit 1
    fi

    echo "$version"
    return 0
  fi

  if ! xml_content=$(fetch_maven_metadata "$repo_url" "$group_id" "$artifact_id"); then
    exit 1
  fi

  all_versions=$(echo "$xml_content" | extract_versions_from_xml)

  case "$version_type" in
    ALPHA)
      version=$(echo "$all_versions" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+-alpha[0-9]+$' | tail -n 1)
      if [[ -z "$version" ]]; then
        echo "$SCRIPT_NAME version: no alpha version found" >&2
        exit 1
      fi
      ;;

    BETA)
      version=$(echo "$all_versions" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+-beta[0-9]+$' | tail -n 1)
      if [[ -z "$version" ]]; then
        echo "$SCRIPT_NAME version: no beta version found" >&2
        exit 1
      fi
      ;;

    RC)
      version=$(echo "$all_versions" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+-rc[0-9]+$' | tail -n 1)
      if [[ -z "$version" ]]; then
        echo "$SCRIPT_NAME version: no rc version found" >&2
        exit 1
      fi
      ;;

    STABLE)
      version=$(echo "$all_versions" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | tail -n 1)

      if [[ -z "$version" ]]; then
        # Fallback to latest available version if no stable found
        version=$(echo "$all_versions" | tail -n 1)
        if [[ -z "$version" ]]; then
          echo "$SCRIPT_NAME version: no stable version found" >&2
          exit 1
        fi
        echo "$SCRIPT_NAME version: using prerelease version: $version" >&2
      fi
      ;;

    LATEST)
      version=$(echo "$xml_content" | xmllint --xpath "//versioning/latest/text()" -)

      if [[ -z "$version" ]]; then
        echo "$SCRIPT_NAME version: no latest version found" >&2
        exit 1
      fi
      ;;
  esac

  echo "$version"
}

# =============================================================================
# VERSIONS SUBCOMMAND
# =============================================================================

usage_list() {
  cat <<EOF
Usage: $SCRIPT_NAME list <noun> [arguments]

List information about Jetpack libraries.

Nouns:
  versions            List all versions for a given Maven artifact.
  dependencies        List direct Maven dependencies for a given Maven artifact.

Options:
  --help              Display this help message and exit
EOF
  exit "${1:-0}"
}

usage_versions() {
  cat <<EOF
Usage: $SCRIPT_NAME list versions ARTIFACT [REPO_URL]

List all versions for a given Maven artifact.

Arguments:
  ARTIFACT      The Maven artifact (e.g., androidx.wear.tiles:tiles)
  REPO_URL      The Maven repository URL (optional, defaults to Google Maven)

Examples:
  $SCRIPT_NAME list versions androidx.wear.tiles:tiles
  $SCRIPT_NAME list versions androidx.wear.tiles:tiles https://androidx.dev/snapshots/latest/artifacts/repository
EOF
  exit "${1:-0}"
}

cmd_versions() {
  if [[ "${1:-}" == "--help" ]]; then
    usage_versions
  fi

  if [[ $# -lt 1 ]]; then
    usage_versions 1 >&2
  fi

  local artifact="$1"
  validate_artifact_format "$artifact"

  local repo_url="${2:-$GOOGLE_MAVEN_URL}"
  local group_id artifact_id
  group_id=$(echo "$artifact" | cut -d: -f1)
  artifact_id=$(echo "$artifact" | cut -d: -f2)

  local xml_content
  if ! xml_content=$(fetch_maven_metadata "$repo_url" "$group_id" "$artifact_id"); then
    exit 1
  fi

  echo "$xml_content" | extract_versions_from_xml
}

# =============================================================================
# RESOLVE SUBCOMMAND
# =============================================================================

usage_resolve() {
  cat <<EOF
Usage: $SCRIPT_NAME resolve PACKAGE_NAME

Convert an Android package name to its corresponding Maven artifact.

Arguments:
  PACKAGE_NAME  Fully qualified package/class name
                (e.g., androidx.core.splashscreen.SplashScreen)

Examples:
  $SCRIPT_NAME resolve androidx.core.splashscreen.SplashScreen.Companion.installSplashScreen
  $SCRIPT_NAME resolve androidx.wear.ambient.AmbientLifecycleObserver
  $SCRIPT_NAME resolve androidx.wear.protolayout.material3.textButton
  $SCRIPT_NAME resolve androidx.lifecycle.ViewModel

The command converts AndroidX package names to Maven artifacts using
the cached Google Maven class index. Output format is
GROUP_ID:ARTIFACT_ID (e.g., androidx.core:core-splashscreen).
EOF
  exit "${1:-0}"
}

cmd_resolve() {
  if [[ "${1:-}" == "--help" ]]; then
    usage_resolve
  fi

  if [[ $# -lt 1 ]]; then
    usage_resolve 1 >&2
  fi

  local input="$1"

  # 1. Short-circuit if already a coordinate
  if [[ "$input" == *:* ]]; then
    echo "$input"
    return 0
  fi

  # 2. Ensure index is fresh
  if ! is_index_fresh; then
    update_index >&2
  fi

  if [[ ! -f "$INDEX_FILE" ]]; then
    echo "error: Index file not found and update failed." >&2
    return 1
  fi

  # 3. Pre-compute all fallback query variations to avoid reading the large index file multiple times.
  local temp_query="$input"
  local -a query_targets=()
  local -a prefix_targets=()

  while [[ -n "$temp_query" && "$temp_query" == *.* ]]; do
    local -a all_segments
    local -a pkg_segments=()
    local -a top_class_segments=()
    local in_class=0

    IFS='.' read -ra all_segments <<<"$temp_query"
    for segment in "${all_segments[@]}"; do
      if [[ "$segment" =~ ^[A-Z] ]]; then
        in_class=1
      fi
      if [[ $in_class -eq 0 ]]; then
        pkg_segments+=("$segment")
      fi
    done

    for segment in "${all_segments[@]}"; do
      top_class_segments+=("$segment")
      if [[ "$segment" =~ ^[A-Z] ]]; then
        break
      fi
    done

    local search_target package_prefix=""
    search_target=$(
      IFS='.'
      echo "${top_class_segments[*]}"
    )
    if [[ ${#pkg_segments[@]} -gt 0 ]]; then
      package_prefix=$(
        IFS='.'
        echo "${pkg_segments[*]}"
      )
    fi

    query_targets+=("$search_target")
    prefix_targets+=("$package_prefix")

    temp_query="${temp_query%.*}"
  done

  if [[ ${#query_targets[@]} -eq 0 ]]; then
    echo "$SCRIPT_NAME resolve: could not resolve '$input'" >&2
    return 1
  fi

  # Serialize Bash arrays to JSON arrays
  local q_json p_json
  q_json=$(printf '%s\n' "${query_targets[@]}" | jq -Rn -c '[inputs]')
  p_json=$(printf '%s\n' "${prefix_targets[@]}" | jq -Rn -c '[inputs]')

  # 4. Query the index in a single pass
  local results
  results=$(jq -r --argjson q_arr "$q_json" --argjson p_arr "$p_json" '
    # Helper to check if a prefix is allowed for prefix/fuzzy matching (prevents generic short prefix false positives)
    def is_allowed_prefix(p):
      (p | startswith("androidx.")) or (p | split(".") | length >= 3);

    # Strict KMP regex: Excludes lint, testing, samples
    "-(jvm|android|desktop|ios[a-z0-9]+|macos[a-z0-9]+|linux[a-z0-9]+|tvos[a-z0-9]+|watchos[a-z0-9]+|js|wasmjs|wasmwasi|mingw[a-z0-9]+)$" as $kmp_regex |
    .Index as $index |
    ($index | map({key: "\(.groupId):\(.artifactId)", value: true}) | from_entries) as $artifact_lookup |
    
    $index | map(
      .groupId as $group |
      .artifactId as $artifact |
      
      # For each fallback query variation, compute its match score and take the maximum.
      # i is weighted heavily so that the longest matching query (smallest i) always wins.
      [range(0; $q_arr | length) as $i |
       $q_arr[$i] as $q |
       $p_arr[$i] as $p |
       
       (if any(.fqcns[]?; . == $q) then 3.0
        elif (any(.fqcns[]?; startswith($q + ".")) and is_allowed_prefix($q)) then 2.0
        elif (any(.fqcns[]?; startswith($p + ".")) and is_allowed_prefix($p)) then 1.0
        else 0.0 end) as $class_score |
        
       # Fuzzy fallback score if fqcns are empty
       (if $class_score == 0.0 then
          if ($p | startswith($group + ".")) then
            $p[($group | length) + 1:] as $rem |
            (if (($artifact | gsub("[.-]"; "") | contains($rem | gsub("[.-]"; ""))) and is_allowed_prefix($p)) then 1.0 else 0.0 end)
          elif ($group == $p) then 1.0
          else 0.0 end
        else 0.0 end) as $fuzzy_score |
        
       # Group match tie-breaker bonus:
       # 0.8 if group matches package prefix exactly
       # 0.4 if group is a prefix of package prefix
       (if ($group == $p) then 0.8
        elif ($p | startswith($group + ".")) then 0.4
        else 0.0 end) as $group_bonus |
        
       ($class_score + $fuzzy_score) as $base_score |
       (if $base_score > 0.0 then (((($q_arr | length) - $i) * 10.0) + $base_score + $group_bonus) else 0.0 end)
      ] | (max // 0.0) as $score |
      
      select($score > 0.0) |
      
      # Client-Side KMP Redirection
      (if ($artifact | test($kmp_regex; "i")) then
         ($artifact | sub($kmp_regex; ""; "i")) as $base_artifact |
         if ($artifact_lookup["\($group):\($base_artifact)"]) then "\($group):\($base_artifact)"
         else "\($group):\($artifact)" end
       else "\($group):\($artifact)" end) as $coord |
       
      { coord: $coord, score: $score, len: ($coord | length) }
    ) | 
    # Group by coordinate to remove duplicates
    group_by(.coord) | map(sort_by(-.score) | .[0]) |
    # Sort by Score (Desc), then by Length (Asc)
    sort_by(-.score, .len) | 
    .[0].coord // empty
  ' "$INDEX_FILE")

  if [[ -z "$results" ]]; then
    echo "$SCRIPT_NAME resolve: could not resolve '$input'" >&2
    return 1
  fi

  echo "$results"
}

# =============================================================================
# SOURCE SUBCOMMAND
# =============================================================================

usage_source() {
  cat <<EOF
Usage: $SCRIPT_NAME source [OPTIONS] ARTIFACT... [VERSION] [REPO_URL]

Download and extract source code for one or more Maven artifacts.

Arguments:
  ARTIFACT    One or more Maven artifacts in the format GROUP_ID:ARTIFACT_ID
              (supports brace expansion, e.g., androidx.pkg:{foo,bar})
  VERSION     Version specifier (optional, defaults to STABLE). See below.
  REPO_URL    Maven repository URL
              (optional, default: https://dl.google.com/android/maven2)
              Ignored for SNAPSHOT, build IDs, and pinned snapshot versions.

Version Specifiers:

  There are two categories of version specifiers:

  **Symbolic (floating):** Resolve to the latest matching version at runtime.
  The actual code returned may change over time as new versions are released.

    ALPHA      Latest alpha version (e.g., 1.2.3-alpha04)
    BETA       Latest beta version (e.g., 1.2.3-beta02)
    RC         Latest release candidate (e.g., 1.2.3-rc01)
    STABLE     Latest stable release (e.g., 1.2.3)
    LATEST     Latest version of any kind
    SNAPSHOT   Latest snapshot from androidx.dev

  **Pinned (immutable):** Always resolve to the exact same code, regardless of
  when the command is run. Use these for reproducible builds or to reference
  a specific known-good version.

    <version>  Specific version string (e.g., 1.6.0-alpha01, 2.0.0)
    <build_id> Snapshot build ID from androidx.dev (e.g., 14710011)
               Find build IDs at: https://androidx.dev/snapshots/builds

Options:
  --help        Display this help message
  --output DIR  Specify output directory (default: create temporary directory)

Examples:
  # Symbolic (floating) versions
  $SCRIPT_NAME source androidx.wear.tiles:tiles
  $SCRIPT_NAME source androidx.wear.tiles:tiles ALPHA
  $SCRIPT_NAME source androidx.wear.tiles:tiles SNAPSHOT

  # Pinned (immutable) versions
  $SCRIPT_NAME source androidx.wear.tiles:tiles 1.4.0
  $SCRIPT_NAME source androidx.wear.tiles:tiles 1.5.0-alpha01
  $SCRIPT_NAME source androidx.wear.tiles:tiles 14710011

  # Other options
  $SCRIPT_NAME source androidx.wear.protolayout:protolayout-{expression,material,material3}
  $SCRIPT_NAME source --output /tmp/tiles androidx.wear.tiles:tiles
  pushd "\$($SCRIPT_NAME source androidx.wear.tiles:tiles)"

The command downloads the source JARs, extracts them, and prints the path.
For Kotlin Multiplatform libraries, platform-specific sources are also downloaded.
EOF
  exit "${1:-0}"
}

cmd_source() {
  local output_dir=""
  local find_pattern=""
  local -a remaining_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help)
        usage_source
        ;;
      --output)
        if [[ -z "${2:-}" ]]; then
          echo "$SCRIPT_NAME source: option '--output' requires an argument" >&2
          exit 1
        fi
        output_dir="$2"
        shift 2
        ;;
      --find)
        if [[ -z "${2:-}" ]]; then
          echo "$SCRIPT_NAME source: option '--find' requires an argument" >&2
          exit 1
        fi
        find_pattern="$2"
        shift 2
        ;;
      *)
        remaining_args+=("$1")
        shift
        ;;
    esac
  done
  set -- "${remaining_args[@]}"

  if [[ $# -lt 1 ]]; then
    usage_source
  fi

  # Parse arguments: ARTIFACT... [VERSION] [REPO_URL]
  local repo_url version_string version_string_upper
  local -a artifacts

  if [[ "${!#}" =~ ^https?:// ]]; then
    repo_url="${!#}"
    local last_non_url_arg="${*: -2:1}"
    if [[ ! "$last_non_url_arg" =~ : ]]; then
      version_string="$last_non_url_arg"
      artifacts=("${@:1:$#-2}")
    else
      version_string="STABLE"
      artifacts=("${@:1:$#-1}")
    fi
  else
    repo_url="$GOOGLE_MAVEN_URL"
    local last_arg="${!#}"
    if [[ ! "$last_arg" =~ : ]]; then
      version_string="$last_arg"
      artifacts=("${@:1:$#-1}")
    else
      version_string="STABLE"
      artifacts=("$@")
    fi
  fi

  version_string_upper=$(echo "$version_string" | tr '[:lower:]' '[:upper:]')

  if [[ ${#artifacts[@]} -eq 0 ]]; then
    echo "$SCRIPT_NAME source: no artifacts specified" >&2
    exit 1
  fi

  # Classify the version and set up repository URL accordingly
  local version_class
  version_class=$(classify_version "$version_string")

  if [[ "$version_class" == "build_id" ]]; then
    # Build ID: use specific snapshot build from androidx.dev
    repo_url="$SNAPSHOT_BUILD_URL_PREFIX/$version_string/artifacts/repository"
    echo "info: Using AndroidX snapshot build $version_string" >&2
  elif [[ "$version_string_upper" == "SNAPSHOT" ]]; then
    # SNAPSHOT: use latest snapshot repository
    repo_url="$SNAPSHOT_REPO_URL"
    echo "info: Using AndroidX snapshot repository (latest)" >&2
  fi

  # Validate all artifacts before creating directories
  local group_id artifact_id group_id_path metadata_url
  for artifact in "${artifacts[@]}"; do
    validate_artifact_format "$artifact"

    group_id=$(echo "$artifact" | cut -d: -f1)
    artifact_id=$(echo "$artifact" | cut -d: -f2)
    group_id_path=$(echo "$group_id" | sed 's/\./\//g')
    metadata_url="${repo_url}/${group_id_path}/${artifact_id}/maven-metadata.xml"

    if ! curl -sSLf "$metadata_url" >/dev/null 2>&1; then
      echo "$SCRIPT_NAME source: failed to fetch $metadata_url" >&2
      exit 1
    fi
  done

  # Create output directory
  local build_dir
  if [[ -n "$output_dir" ]]; then
    build_dir="$output_dir"
    mkdir -p "$build_dir"
  else
    build_dir=$(mktemp -d "${TMPDIR:-/tmp}/jetpack.XXXXXXXXXX")
  fi

  # Download and extract each package
  local version="" jar_version snapshot_jar_version
  local source_jar_url source_jar_filename
  local pom_url pom_content platform_artifacts

  for artifact in "${artifacts[@]}"; do
    group_id=$(echo "$artifact" | cut -d: -f1)
    artifact_id=$(echo "$artifact" | cut -d: -f2)
    group_id_path=$(echo "$group_id" | sed 's/\./\//g')

    # Resolve version
    if [[ -z "$version" ]]; then
      if [[ "$version_class" == "symbolic" ]]; then
        # Symbolic version: resolve to actual version number
        version=$(cmd_version "$artifact" "$version_string_upper" "$repo_url")
        echo "info: Resolved $version_string_upper version for ${artifact} to ${version}" >&2
      elif [[ "$version_class" == "build_id" ]]; then
        # Build ID: resolve SNAPSHOT version from that specific build
        version=$(cmd_version "$artifact" "SNAPSHOT" "$repo_url")
        echo "info: Resolved SNAPSHOT version for build $version_string to ${version}" >&2
      else
        # Pinned version: use as-is
        version=$version_string
      fi
    fi

    # For SNAPSHOT versions, resolve the timestamped version
    jar_version="$version"
    if [[ "$version" =~ -SNAPSHOT$ ]]; then
      local version_metadata_url="${repo_url}/${group_id_path}/${artifact_id}/${version}/maven-metadata.xml"
      snapshot_jar_version=$(curl -sSLf "$version_metadata_url" 2>/dev/null |
        xmllint --xpath "//snapshotVersion[classifier='sources' and extension='jar']/value/text()" - 2>/dev/null || true)

      if [[ -n "$snapshot_jar_version" ]]; then
        jar_version="$snapshot_jar_version"
        echo "info: Resolved snapshot JAR version to ${jar_version}" >&2
      else
        echo "$SCRIPT_NAME source: warning: could not resolve timestamped version, trying ${version}" >&2
      fi
    fi

    source_jar_url="${repo_url}/${group_id_path}/${artifact_id}/${version}/${artifact_id}-${jar_version}-sources.jar"
    source_jar_filename="${artifact_id}-${jar_version}-sources.jar"

    echo "info: Downloading ${artifact} version ${version}" >&2
    if ! curl -sSLf -o "${build_dir}/${source_jar_filename}" "${source_jar_url}"; then
      echo "$SCRIPT_NAME source: failed to download $source_jar_url" >&2
      exit 1
    fi

    (
      cd "${build_dir}"
      jar xf "${source_jar_filename}"
      rm "${source_jar_filename}"
    )

    # Check for Kotlin Multiplatform platform-specific sources
    pom_url="${repo_url}/${group_id_path}/${artifact_id}/${version}/${artifact_id}-${jar_version}.pom"
    pom_content=$(curl -sSLf "${pom_url}" 2>/dev/null || true)

    if [[ -n "$pom_content" ]]; then
      platform_artifacts=$(echo "$pom_content" | xmllint --xpath "//*[local-name()='dependency']/*[local-name()='groupId' and text()='${group_id}']/../*[local-name()='artifactId']/text()" - 2>/dev/null | grep "^${artifact_id}-" || true)

      if [[ -n "$platform_artifacts" ]]; then
        echo "info: Detected Kotlin Multiplatform library, downloading platform-specific sources..." >&2
        local platform_artifact platform_jar_version platform_snapshot_jar_version
        local platform_source_jar_url platform_source_jar_filename

        for platform_artifact in $platform_artifacts; do
          platform_jar_version="$version"
          if [[ "$version" =~ -SNAPSHOT$ ]]; then
            local platform_version_metadata_url="${repo_url}/${group_id_path}/${platform_artifact}/${version}/maven-metadata.xml"
            platform_snapshot_jar_version=$(curl -sSLf "$platform_version_metadata_url" 2>/dev/null |
              xmllint --xpath "//snapshotVersion[classifier='sources' and extension='jar']/value/text()" - 2>/dev/null || true)
            if [[ -n "$platform_snapshot_jar_version" ]]; then
              platform_jar_version="$platform_snapshot_jar_version"
            fi
          fi

          platform_source_jar_url="${repo_url}/${group_id_path}/${platform_artifact}/${version}/${platform_artifact}-${platform_jar_version}-sources.jar"
          platform_source_jar_filename="${platform_artifact}-${platform_jar_version}-sources.jar"

          if curl -sSLf -o "${build_dir}/${platform_source_jar_filename}" "${platform_source_jar_url}" 2>/dev/null; then
            echo "info: Downloaded ${platform_artifact} platform sources" >&2
            (
              cd "${build_dir}"
              jar xf "${platform_source_jar_filename}"
              rm "${platform_source_jar_filename}"
            )
          fi
        done
      fi
    fi
  done

  # Clean up META-INF
  rm -rf "${build_dir}/META-INF"

  if [[ -n "$find_pattern" ]]; then
    local -a matches
    # Use array to capture filenames safely (handling spaces, though source files rarely have them)
    mapfile -t matches < <(find "$build_dir" -name "*$find_pattern*" -type f)

    if [[ ${#matches[@]} -eq 0 ]]; then
      echo "error: No files matching '$find_pattern' found in $build_dir" >&2
      exit 1
    elif [[ ${#matches[@]} -eq 1 ]]; then
      cat "${matches[0]}"
    else
      echo "info: Multiple matches found:" >&2
      printf '%s\n' "${matches[@]}"
    fi
  else
    echo "${build_dir}"
  fi
}

# =============================================================================
# INSPECT SUBCOMMAND
# =============================================================================

usage_inspect() {
  cat <<EOF
Usage: $SCRIPT_NAME inspect [OPTIONS] CLASS_NAME [VERSION] [REPO_URL]

Download and inspect source code for a Jetpack class or package.

This is a convenience wrapper that combines resolve and source to map from
a package/class name directly to source code.

Arguments:
  CLASS_NAME  Fully qualified package/class name
              (e.g., androidx.core.splashscreen.SplashScreen)
              OR Maven coordinate (e.g., androidx.wear.tiles:tiles)
  VERSION     Version specifier (optional, defaults to STABLE). See below.
  REPO_URL    Maven repository URL (optional, defaults to Google Maven)
              Ignored for SNAPSHOT, build IDs, and pinned snapshot versions.

Version Specifiers:

  There are two categories of version specifiers:

  **Symbolic (floating):** Resolve to the latest matching version at runtime.
  The actual code returned may change over time as new versions are released.

    ALPHA      Latest alpha version (e.g., 1.2.3-alpha04)
    BETA       Latest beta version (e.g., 1.2.3-beta02)
    RC         Latest release candidate (e.g., 1.2.3-rc01)
    STABLE     Latest stable release (e.g., 1.2.3)
    LATEST     Latest version of any kind
    SNAPSHOT   Latest snapshot from androidx.dev

  **Pinned (immutable):** Always resolve to the exact same code, regardless of
  when the command is run. Use these for reproducible builds or to reference
  a specific known-good version.

    <version>  Specific version string (e.g., 1.6.0-alpha01, 2.0.0)
    <build_id> Snapshot build ID from androidx.dev (e.g., 14710011)
               Find build IDs at: https://androidx.dev/snapshots/builds

Options:
  --help        Display this help message
  --output DIR  Specify output directory (default: create temporary directory)

Examples:
  # Symbolic (floating) versions
  $SCRIPT_NAME inspect androidx.core.splashscreen.SplashScreen
  $SCRIPT_NAME inspect androidx.wear.tiles:tiles
  $SCRIPT_NAME inspect androidx.wear.ambient.AmbientLifecycleObserver ALPHA
  $SCRIPT_NAME inspect androidx.glance.wear.tiles.GlanceTileService SNAPSHOT

  # Pinned (immutable) versions
  $SCRIPT_NAME inspect androidx.lifecycle.ViewModel 2.8.7
  $SCRIPT_NAME inspect androidx.wear.tiles.TileService 1.4.0
  $SCRIPT_NAME inspect androidx.wear.tiles.TileService 14710011

  pushd "\$($SCRIPT_NAME inspect androidx.wear.tiles.TileService)"

For Kotlin Multiplatform libraries, both common and platform-specific sources
are automatically downloaded.
EOF
  exit "${1:-0}"
}

cmd_inspect() {
  local output_dir=""
  local -a remaining_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help)
        usage_inspect
        ;;
      --output)
        if [[ -z "${2:-}" ]]; then
          echo "$SCRIPT_NAME inspect: option '--output' requires an argument" >&2
          exit 1
        fi
        output_dir="$2"
        shift 2
        ;;
      *)
        remaining_args+=("$1")
        shift
        ;;
    esac
  done
  set -- "${remaining_args[@]}"

  if [[ $# -lt 1 ]]; then
    usage_inspect
  fi

  local input="$1"
  local version_type="${2:-STABLE}"
  local repo_url="${3:-}"

  local artifact=""
  local find_target=""

  if [[ "$input" == *:* ]]; then
    # Input is already a coordinate
    artifact="$input"
  else
    # Extract potential class name if input looks like FQCN
    if [[ "$input" =~ \.([A-Z][a-zA-Z0-9]*)$ ]]; then
      find_target="${BASH_REMATCH[1]}"
    elif [[ ! "$input" =~ \. ]]; then
      # Simple class name
      find_target="$input"
    fi

    # Try to resolve or search
    if [[ "$input" =~ \. ]]; then
      # It looks like a FQCN or package
      if resolved=$(cmd_resolve "$input" 2>/dev/null); then
        # Check if this resolved artifact actually exists
        local gid="${resolved%%:*}"
        local aid="${resolved##*:}"
        if fetch_maven_metadata "$GOOGLE_MAVEN_URL" "$gid" "$aid" >/dev/null 2>&1; then
          artifact="$resolved"
        fi
      fi
    fi

    # If resolve failed, didn't apply, or 404'd, try search
    if [[ -z "$artifact" ]]; then
      local search_results
      if search_results=$(cmd_search "$input"); then
        artifact=$(echo "$search_results" | head -n 1)
      fi
    fi
  fi

  if [[ -z "$artifact" ]]; then
    echo "$SCRIPT_NAME inspect: could not resolve or find artifact for '$input'" >&2
    exit 1
  fi

  # Build source arguments
  local -a source_args=()
  if [[ -n "$output_dir" ]]; then
    source_args+=(--output "$output_dir")
  fi

  if [[ -n "$find_target" ]]; then
    # Only append --find if we have a target (simple class name or extracted class name)
    # AND the filename looks like a source file (or we assume .kt/.java will be matched by *target*)
    source_args+=(--find "$find_target")
  fi

  source_args+=("$artifact" "$version_type")
  if [[ -n "$repo_url" ]]; then
    source_args+=("$repo_url")
  fi

  cmd_source "${source_args[@]}"
}

# =============================================================================
# DEPENDENCIES SUBCOMMAND
# =============================================================================

usage_dependencies() {
  cat <<EOF
Usage: $SCRIPT_NAME list dependencies ARTIFACT [VERSION] [REPO_URL]

List direct Maven dependencies for a given artifact.

Arguments:
  ARTIFACT      Maven artifact (e.g., androidx.wear.tiles:tiles)
  VERSION       Version specifier (optional, defaults to STABLE)
  REPO_URL      Repository URL (optional)

Examples:
  $SCRIPT_NAME list dependencies androidx.wear.tiles:tiles
EOF
  exit "${1:-0}"
}

cmd_dependencies() {
  if [[ "${1:-}" == "--help" ]]; then
    usage_dependencies
  fi

  if [[ $# -lt 1 ]]; then
    usage_dependencies
  fi

  local artifact="$1"
  validate_artifact_format "$artifact"

  local version_string="${2:-STABLE}"
  local repo_url="${3:-$GOOGLE_MAVEN_URL}"

  local group_id artifact_id group_id_path
  group_id=$(echo "$artifact" | cut -d: -f1)
  artifact_id=$(echo "$artifact" | cut -d: -f2)
  group_id_path=$(echo "$group_id" | sed 's/\./\//g')

  local version
  version=$(cmd_version "$artifact" "$version_string" "$repo_url")

  local jar_version="$version"
  if [[ "$version" =~ -SNAPSHOT$ ]]; then
    if [[ "$repo_url" == "$GOOGLE_MAVEN_URL" ]]; then
      repo_url="$SNAPSHOT_REPO_URL"
    fi
    local version_metadata_url="${repo_url}/${group_id_path}/${artifact_id}/${version}/maven-metadata.xml"
    local snapshot_jar_version
    snapshot_jar_version=$(curl -sSLf "$version_metadata_url" 2>/dev/null |
      xmllint --xpath "//snapshotVersion[classifier='sources' and extension='jar']/value/text()" - 2>/dev/null || true)
    if [[ -n "$snapshot_jar_version" ]]; then
      jar_version="$snapshot_jar_version"
    fi
  fi

  local pom_url="${repo_url}/${group_id_path}/${artifact_id}/${version}/${artifact_id}-${jar_version}.pom"
  local pom_content
  if ! pom_content=$(curl -sSLf "${pom_url}"); then
    echo "$SCRIPT_NAME dependencies: failed to download $pom_url" >&2
    exit 1
  fi

  local deps
  deps=$(echo "$pom_content" | perl -0777 -ne '
	while (/<dependency>(.*?)<\/dependency>/gs) {
		my $dep = $1;
		my ($g) = $dep =~ /<groupId>([^<]+)<\/groupId>/;
		my ($a) = $dep =~ /<artifactId>([^<]+)<\/artifactId>/;
		my ($v) = $dep =~ /<version>([^<]+)<\/version>/;
		my ($s) = $dep =~ /<scope>([^<]+)<\/scope>/;
		$s ||= "compile";
		if ($g && $a) {
			print "$g:$a:$v ($s)\n";
		}
	}
	' || true)

  if [[ -n "$deps" ]]; then
    echo "$deps"
  fi
}

# =============================================================================
# MAIN DISPATCH
# =============================================================================

if [[ $# -lt 1 ]]; then
  usage 1 >&2
fi

# Help is dependency-free; everything else needs the external tools.
case "$1" in
  help | --help) ;;
  *) check_deps ;;
esac

case "$1" in
  help | --help)
    if [[ -n "${2:-}" ]]; then
      case "$2" in
        version) usage_version ;;
        resolve) usage_resolve ;;
        source) usage_source ;;
        inspect) usage_inspect ;;
        dependencies) usage_dependencies ;;
        *)
          echo "$SCRIPT_NAME: unknown command '$2'" >&2
          usage 1 >&2
          ;;
      esac
    else
      usage
    fi
    ;;
  version)
    shift
    cmd_version "$@"
    ;;
  list)
    shift
    if [[ $# -eq 0 ]]; then
      echo "$SCRIPT_NAME: list requires a sub-command (versions, dependencies)" >&2
      echo "Run '$SCRIPT_NAME list --help' for usage" >&2
      exit 1
    fi
    if [[ "$1" == "--help" ]] || [[ "$1" == "help" ]]; then
      usage_list 0
    fi
    subcmd="$1"
    shift
    case "$subcmd" in
      versions) cmd_versions "$@" ;;
      dependencies) cmd_dependencies "$@" ;;
      *)
        echo "$SCRIPT_NAME: unknown list command '$subcmd'" >&2
        echo "Run '$SCRIPT_NAME list --help' for usage" >&2
        exit 1
        ;;
    esac
    ;;
  resolve)
    shift
    cmd_resolve "$@"
    ;;
  search)
    shift
    cmd_search "$@"
    ;;
  source)
    shift
    cmd_source "$@"
    ;;
  inspect)
    shift
    cmd_inspect "$@"
    ;;
  -*)
    echo "$SCRIPT_NAME: unknown option: $1" >&2
    echo "Run '$SCRIPT_NAME --help' for usage" >&2
    exit 1
    ;;
  *)
    echo "$SCRIPT_NAME: unknown command: $1" >&2
    echo "Run '$SCRIPT_NAME --help' for usage" >&2
    exit 1
    ;;
esac
