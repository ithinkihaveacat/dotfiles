#!/usr/bin/env bash

# jetpack-samples - Extract reference files for inspection
#
# Usage: jetpack-samples ARTIFACT [--output DIR]

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
  echo "$(basename "$0"): requires bash 4.0 or higher (found ${BASH_VERSION})" >&2
  exit 1
fi

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

# Verify external dependencies. Deferred until after the --help check so that
# --help works even when dependencies are absent.
check_deps() {
  require curl
  require jq
}

usage() {
  cat <<EOF
Usage: $(basename "$0") ARTIFACT [OPTIONS]

Extract reference files (samples and integration tests) from the AndroidX 
source repository for inspection.

Arguments:
  ARTIFACT       The Maven coordinate of the Jetpack library (e.g., androidx.compose.remote:remote-creation-compose).

Options:
  --output DIR   Directory where extracted files will be downloaded.
                 If omitted, a temporary directory is used.
  --help         Display this help message and exit

Examples:
  $(basename "$0") androidx.compose.remote:remote-creation-compose
  $(basename "$0") androidx.compose.remote:remote-creation-compose --output ./my-samples
EOF
  exit 0
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
  usage
fi

check_deps

ARTIFACT=""
OUTPUT_DIR=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ -z "${2:-}" ]]; then
        echo "$(basename "$0"): option '--output' requires an argument" >&2
        echo "Try '$(basename "$0") --help' for more information." >&2
        exit 1
      fi
      OUTPUT_DIR="$2"
      shift 2
      ;;
    -*)
      echo "$(basename "$0"): unknown option: $1" >&2
      echo "Try '$(basename "$0") --help' for more information." >&2
      exit 1
      ;;
    *)
      if [[ -z "$ARTIFACT" ]]; then
        ARTIFACT="$1"
      else
        echo "$(basename "$0"): too many arguments" >&2
        echo "Try '$(basename "$0") --help' for more information." >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$ARTIFACT" ]]; then
  echo "$(basename "$0"): missing artifact operand" >&2
  echo "Try '$(basename "$0") --help' for more information." >&2
  exit 1
fi

if [[ ! "$ARTIFACT" =~ ^[^:]+:[^:]+$ ]]; then
  echo "$(basename "$0"): invalid artifact format '$ARTIFACT' (expected GROUP_ID:ARTIFACT_ID)" >&2
  echo "Try '$(basename "$0") --help' for more information." >&2
  exit 1
fi

GROUP_ID=$(echo "$ARTIFACT" | cut -d: -f1)
DERIVED_PATH=$(echo "$GROUP_ID" | sed 's/^androidx\.//' | sed 's/\./\//g')

CLEANUP_ON_FAILURE=false
if [[ -z "$OUTPUT_DIR" ]]; then
  OUTPUT_DIR=$(mktemp -d "${TMPDIR:-/tmp}/jetpack-samples.XXXXXXXXXX")
  CLEANUP_ON_FAILURE=true
fi

mkdir -p "$OUTPUT_DIR"

trap_failure() {
  if [[ "$CLEANUP_ON_FAILURE" == "true" ]]; then
    rm -rf "$OUTPUT_DIR"
  fi
}
trap trap_failure ERR

CURL_RETRY_OPTS=(--retry 5 --retry-delay 4 --retry-all-errors --retry-connrefused)

# Gitiles (the browser behind android.googlesource.com, the same host used
# below to download matched directories) can list a directory's full
# recursive file tree as JSON in a single request, scoped to just the
# derived path. This replaces an older approach that scraped an API key out
# of cs.android.com's HTML to query Google's internal, undocumented Code
# Search backend.
GITILES_URL="https://android.googlesource.com/platform/frameworks/support/+/refs/heads/androidx-main/${DERIVED_PATH}?format=JSON&recursive=1"

if ! RESPONSE=$(curl -sS "${CURL_RETRY_OPTS[@]}" -f "$GITILES_URL"); then
  echo "$(basename "$0"): no files found for path $DERIVED_PATH" >&2
  exit 1
fi

# Gitiles prefixes JSON responses with an anti-XSSI line ()]}'); strip it
# before parsing, then reconstruct each entry's path relative to the repo
# root (the API returns paths relative to the requested directory).
PATHS=$(echo "$RESPONSE" | tail -n +2 | jq -r --arg prefix "$DERIVED_PATH" \
  '.entries[]? | select(.type == "blob") | "\($prefix)/\(.name)"' | sort -u)

if [[ -z "$PATHS" ]]; then
  echo "$(basename "$0"): no files found for path $DERIVED_PATH" >&2
  exit 1
fi

# Extract unique module directories containing a 'src' folder
MODULE_DIRS=$(echo "$PATHS" | grep "/src/" | sed -E 's|/src/.*||' | sort -u)

FOUND_SAMPLES=0
if [[ -n "$MODULE_DIRS" ]]; then
  while IFS= read -r mod_dir; do
    if [[ "$mod_dir" =~ /samples || "$mod_dir" =~ /integration-tests ]]; then
      TARGET_PATH="$OUTPUT_DIR/$mod_dir"
      mkdir -p "$TARGET_PATH"

      echo "info: Downloading optimized archive for $mod_dir..." >&2
      TAR_URL="https://android.googlesource.com/platform/frameworks/support/+archive/refs/heads/androidx-main/${mod_dir}.tar.gz"

      if curl -sSLf "${CURL_RETRY_OPTS[@]}" "$TAR_URL" | tar -xz -C "$TARGET_PATH"; then
        FOUND_SAMPLES=$((FOUND_SAMPLES + 1))
      fi
    fi
  done <<<"$MODULE_DIRS"
fi

if [[ $FOUND_SAMPLES -eq 0 ]]; then
  echo "$(basename "$0"): found files but none matched samples or integration-tests with a 'src' directory" >&2
  exit 1
fi

echo "info: Downloaded $FOUND_SAMPLES modules to $OUTPUT_DIR" >&2
echo "$OUTPUT_DIR"
