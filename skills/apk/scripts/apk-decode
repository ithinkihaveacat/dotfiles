#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] APK_FILE

Decodes an APK file using apktool and outputs the directory path.

This script uses 'apktool d' to decode the APK's resources.
The path to the output directory is printed to standard output.

Arguments:
  APK_FILE          Path to an APK file.

Options:
  -o, --output DIR  The directory to decode the APK into.
                    (defaults to a new temporary directory)
  --help            Display this help message and exit

Examples:
  # Decode an APK into a new temporary directory
  DECODED_PATH=\$($(basename "$0") /path/to/your/app.apk)
  ls "\$DECODED_PATH"

  # Decode an APK into a specific directory
  $(basename "$0") --output /tmp/decoded-apk /path/to/your/app.apk
EOF
  exit 0
}

OUTPUT_DIR=""
OUTPUT_DIR_USER=""

# Manual parsing for --output, compatible with macOS getopt
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      ;;
    -o | --output)
      if [ -z "$2" ]; then
        echo "$(basename "$0"): --output option requires an argument" >&2
        exit 1
      fi
      OUTPUT_DIR="$2"
      OUTPUT_DIR_USER=1
      shift 2
      ;;
    *)
      break # First non-option argument is the APK_FILE
      ;;
  esac
done

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require apktool
require unzip

if [ -z "${1:-}" ]; then
  usage
fi

if [ ! -f "$1" ]; then
  echo "$(basename "$0"): $1: No such file or directory" >&2
  exit 1
fi

if [[ $1 == *.zip ]]; then
  TMPDIR=$(mktemp -d)
  trap 'rm -rf -- "$TMPDIR"' EXIT
  unzip -q -j "$1" '*-base-split.apk' -d "$TMPDIR"
  BASEAPKS=("$TMPDIR"/*-base-split.apk)
  BASEAPK="${BASEAPKS[0]}"
  if [ ! -f "$BASEAPK" ]; then
    echo "$(basename "$0"): *-base-split.apk not found in zip, aborting" >&2
    exit 1
  fi
else
  BASEAPK="$1"
fi

if [ -z "$OUTPUT_DIR" ]; then
  OUTPUT_DIR=$(mktemp -d)
else
  mkdir -p "$OUTPUT_DIR"
fi

# -s to skip source (resources only)
if ! apktool d "$BASEAPK" -f -o "$OUTPUT_DIR" >/dev/null 2>&1; then
  echo "$(basename "$0"): apktool failed to decode $BASEAPK" >&2
  if [ -z "$OUTPUT_DIR_USER" ]; then
    rm -rf "$OUTPUT_DIR"
  fi
  exit 1
fi

echo "$OUTPUT_DIR"
