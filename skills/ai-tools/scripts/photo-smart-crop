#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] <input> <output>

Smart crop images to focus on the primary subject with a specified aspect ratio.

Arguments:
  input        Input image file
  output       Output image file (explicit path)

Options:
  --ratio W:H  Aspect ratio for crop (default: 5:3)
  --help       Display this help message and exit

Processing:
  Uses Gemini API to detect the primary subject (people, food, landscapes, etc.)
  and calculates the maximum possible crop box with the specified aspect ratio,
  centered on the subject. Works with any input orientation (portrait or landscape).

Environment:
  GEMINI_API_KEY  Required. Your Gemini API key.

Exit Codes:
  0    Success (cropped output written)
  1    Error (API error, missing file, invalid arguments)
  2    Rate limited (API returned 429)
  127  Missing required command

Examples:
  $(basename "$0") photo.jpg cropped.jpg
  $(basename "$0") --ratio 16:9 portrait.jpg landscape-16x9.jpg
  $(basename "$0") --ratio 4:3 ~/Photos/family.jpg ./output/family-4x3.jpg
EOF
  exit "${1:-0}"
}

# Parse arguments
ratio="5:3"

if [[ "${1:-}" == "help" ]]; then
  usage 0
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage 0
      ;;
    --ratio)
      if [[ $# -lt 2 ]]; then
        echo "$(basename "$0"): --ratio requires an argument" >&2
        echo "Try '$(basename "$0") --help' for more information." >&2
        exit 1
      fi
      ratio="$2"
      shift 2
      ;;
    -*)
      echo "$(basename "$0"): unknown option: $1" >&2
      echo "Try '$(basename "$0") --help' for more information." >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -ne 2 ]]; then
  echo "$(basename "$0"): missing file operands" >&2
  echo "Try '$(basename "$0") --help' for more information." >&2
  exit 1
fi

INPUT="$1"
OUTPUT="$2"

# Validate ratio format (W:H where both are positive integers)
if ! [[ "$ratio" =~ ^([0-9]+):([0-9]+)$ ]]; then
  echo "$(basename "$0"): invalid ratio format: $ratio (expected W:H, e.g., 5:3)" >&2
  exit 1
fi

ratio_w="${BASH_REMATCH[1]}"
ratio_h="${BASH_REMATCH[2]}"

if [[ "$ratio_w" -eq 0 || "$ratio_h" -eq 0 ]]; then
  echo "$(basename "$0"): ratio components must be positive: $ratio" >&2
  exit 1
fi

if [[ ! -f "$INPUT" ]]; then
  echo "$(basename "$0"): $INPUT: No such file or directory" >&2
  exit 1
fi

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

require curl
require jq
require base64
require magick

GEMINI_API_KEY="${GEMINI_CLI_GEMINI_API_KEY:-${GEMINI_API_KEY:-}}"
if [[ -z "${GEMINI_API_KEY:-}" ]]; then
  echo "$(basename "$0"): GEMINI_API_KEY environment variable not set" >&2
  exit 1
fi

# Get image dimensions AFTER auto-orient to detect true orientation
dimensions=$(magick "$INPUT" -auto-orient -format "%w %h" info:)
img_width=$(echo "$dimensions" | cut -d' ' -f1)
img_height=$(echo "$dimensions" | cut -d' ' -f2)

MODEL="gemini-3-flash-preview"
URL="https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent"

# Convert to HEIF and base64 encode for API
# Using 1024x1024 for better detail retention while staying within reasonable token limits
# base64: macOS uses -b 0, Linux uses -w 0
if base64 --help 2>&1 | grep -q -- '-w'; then
  IMAGE_BASE64=$(magick "$INPUT" -auto-orient -alpha off -resize 1024x1024\> heif:- | base64 -w 0)
else
  IMAGE_BASE64=$(magick "$INPUT" -auto-orient -alpha off -resize 1024x1024\> heif:- | base64 -b 0)
fi

# System Instruction: Defines the core task and constraints
SYSTEM_INSTRUCTION="<role>You are an expert photo editor and compositional analyzer.</role>
<task>Identify the primary subject or key compositional elements in the image and return a bounding box for cropping.</task>
<instructions>
1. DETECT: Identify the primary subject (e.g., people, faces, food, focal points in a landscape).
2. For people, ensure the bounding box centers on their face/head area to preserve identity.
3. For food, objects, or landscapes, isolate the most aesthetically pleasing focal region.
4. CALCULATE BOX: Create a bounding box around this focal region. Keep the box within the image bounds (0-1000 for both dimensions).
5. RETURN: Coordinates in normalized 0-1000 scale as ymin, xmin, ymax, xmax. If there is no specific focal point, return a box covering the central compositional area. Return ONLY the requested JSON.
</instructions>"

USER_PROMPT="Perform the smart crop analysis on this image."

# Build JSON request body
REQUEST_BODY=$(jq -n \
  --arg system_instruction "$SYSTEM_INSTRUCTION" \
  --arg user_prompt "$USER_PROMPT" \
  --arg image "$IMAGE_BASE64" \
  '{
    "system_instruction": {
      "parts": [{ "text": $system_instruction }]
    },
    "contents": [
      {
        "role": "user",
        "parts": [
          {
            "inlineData": {
              "mimeType": "image/heif",
              "data": $image
            }
          },
          {"text": $user_prompt}
        ]
      }
    ],
    "generationConfig": {
      "temperature": 1.0,
      "responseMimeType": "application/json",
      "thinkingConfig": {
        "thinkingLevel": "low"
      },
      "responseJsonSchema": {
        "type": "object",
        "properties": {
          "subject_box": {
            "type": "object",
            "properties": {
              "ymin": {"type": "integer", "description": "Top coordinate (0-1000)"},
              "xmin": {"type": "integer", "description": "Left coordinate (0-1000)"},
              "ymax": {"type": "integer", "description": "Bottom coordinate (0-1000)"},
              "xmax": {"type": "integer", "description": "Right coordinate (0-1000)"}
            },
            "required": ["ymin", "xmin", "ymax", "xmax"]
          }
        },
        "required": ["subject_box"]
      }
    }
  }')

RESPONSE=$(echo "${REQUEST_BODY}" | curl -s -X POST \
  -H "x-goog-api-key: $GEMINI_API_KEY" \
  -H "Content-Type: application/json" \
  -d @- \
  "${URL}")

# Check for API errors
if echo "$RESPONSE" | jq -e '.error' >/dev/null 2>&1; then
  ERROR_CODE=$(echo "$RESPONSE" | jq -r '.error.code // 0')
  ERROR_MSG=$(echo "$RESPONSE" | jq -r '.error.message // "Unknown error"')
  echo "$(basename "$0"): API error: $ERROR_MSG" >&2
  if [[ "$ERROR_CODE" == "429" ]]; then
    exit 2
  fi
  exit 1
fi

# Extract the JSON response text
TEXT=$(echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text // empty')
if [[ -z "$TEXT" ]]; then
  echo "$(basename "$0"): no response text received from API" >&2
  exit 1
fi

# Extract subject box coordinates (normalized 0-1000)
xmin=$(echo "$TEXT" | jq -r '.subject_box.xmin')
ymin=$(echo "$TEXT" | jq -r '.subject_box.ymin')
xmax=$(echo "$TEXT" | jq -r '.subject_box.xmax')
ymax=$(echo "$TEXT" | jq -r '.subject_box.ymax')

# Validate we got numeric values
for val in "$xmin" "$ymin" "$xmax" "$ymax"; do
  if ! [[ "$val" =~ ^[0-9]+$ ]]; then
    echo "$(basename "$0"): invalid subject box coordinates from API" >&2
    exit 1
  fi
done

# Convert normalized coords to pixels FIRST
sub_px_xmin=$((xmin * img_width / 1000))
sub_px_ymin=$((ymin * img_height / 1000))
sub_px_xmax=$((xmax * img_width / 1000))
sub_px_ymax=$((ymax * img_height / 1000))

# Calculate center of the subject
sub_center_x=$(((sub_px_xmin + sub_px_xmax) / 2))
sub_center_y=$(((sub_px_ymin + sub_px_ymax) / 2))

# Calculate maximum possible crop box dimensions for the target aspect ratio
# First, assume the width is the limiting factor (full width)
max_crop_w=$img_width
max_crop_h=$((img_width * ratio_h / ratio_w))

# If the calculated height exceeds the image height, then height is the limiting factor
if [[ $max_crop_h -gt $img_height ]]; then
  max_crop_h=$img_height
  max_crop_w=$((img_height * ratio_w / ratio_h))
fi

# Calculate top-left corner by centering the maximal crop box on the subject
new_xmin=$((sub_center_x - max_crop_w / 2))
new_ymin=$((sub_center_y - max_crop_h / 2))

# Clamp to image boundaries
if [[ $new_xmin -lt 0 ]]; then
  new_xmin=0
fi
if [[ $new_ymin -lt 0 ]]; then
  new_ymin=0
fi

if [[ $((new_xmin + max_crop_w)) -gt $img_width ]]; then
  new_xmin=$((img_width - max_crop_w))
fi
if [[ $((new_ymin + max_crop_h)) -gt $img_height ]]; then
  new_ymin=$((img_height - max_crop_h))
fi

# Final crop dimensions and position
crop_w=$max_crop_w
crop_h=$max_crop_h
px_x1=$new_xmin
px_y1=$new_ymin

# Crop with ImageMagick
if magick "$INPUT" \
  -auto-orient \
  -crop "${crop_w}x${crop_h}+${px_x1}+${px_y1}" \
  +repage \
  "$OUTPUT"; then
  exit 0
else
  echo "$(basename "$0"): failed to crop image" >&2
  exit 1
fi
