#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# ///

import os
import sys
import tempfile
import subprocess
from pathlib import Path

SKILL_SELECT_BIN = str(Path(__file__).resolve().parent / "skill-select")


def die(msg):
    print(f"p4 skill: {msg}", file=sys.stderr)
    sys.exit(1)


def cmderr(cmd, msg):
    print(f"p4 skill {cmd}: {msg}", file=sys.stderr)
    sys.exit(1)


def get_p4_workspace():
    try:
        res = subprocess.run(
            ["p4", "info"],
            capture_output=True,
            text=True,
            check=True,
        )
        client_root = None
        username = None
        for line in res.stdout.splitlines():
            if line.startswith("Client root:"):
                client_root = Path(line.split(":", 1)[1].strip())
            elif line.startswith("User name:"):
                username = line.split(":", 1)[1].strip()

        if not client_root or not username:
            die("could not parse p4 info output")

        return client_root, username
    except FileNotFoundError:
        die("p4 command not found. Are you sure Perforce is installed and in your PATH?")
    except subprocess.CalledProcessError:
        die("not inside a Perforce workspace (p4 info failed)")


def find_main_repo_dir(client_root):
    # Search for a directory at the client root that contains a Bazel-style WORKSPACE file.
    # This dynamically identifies the primary codebase directory.
    for path in client_root.iterdir():
        if path.is_dir() and not path.name.startswith("."):
            if (path / "WORKSPACE").is_file() or (path / "WORKSPACE.bazel").is_file():
                return path
    return None


def get_paths(client_root, username):
    repo_dir = find_main_repo_dir(client_root)
    configs_dir = client_root / "configs"

    if repo_dir and configs_dir.is_dir():
        # Personal config layout convention (centralized)
        dest_dirs = [client_root / "configs" / "users" / username / "_agents" / "skills"]
        state_file = client_root / "configs" / "users" / username / "_agents" / ".p4-skills-managed"
        analyze_dir = repo_dir
        is_personal = True
    else:
        # Standard Perforce convention (local, mirroring git-skill)
        dest_dirs_str = os.environ.get("SKILL_DEST_DIRS", ".claude/skills:.agents/skills")
        dest_dirs = [client_root / d for d in dest_dirs_str.split(":") if d]
        state_file = client_root / ".p4-skills-managed"
        analyze_dir = client_root
        is_personal = False
    return dest_dirs, state_file, analyze_dir, is_personal


def read_managed(state_file):
    if not state_file.is_file():
        return []
    with open(state_file, "r", encoding="utf-8", errors="replace") as f:
        return [line.strip() for line in f if line.strip()]


def write_managed(state_file, managed):
    if not managed:
        if state_file.is_file():
            state_file.unlink()
        return
    state_file.parent.mkdir(parents=True, exist_ok=True)
    with open(state_file, "w", encoding="utf-8") as f:
        for item in sorted(list(set(managed))):
            f.write(item + "\n")


def prune_dirs(dest_dirs):
    for d in dest_dirs:
        try:
            if d.is_dir() and not any(d.iterdir()):
                d.rmdir()
            parent = d.parent
            if parent.is_dir() and not any(parent.iterdir()):
                parent.rmdir()
        except Exception:
            pass


def cmd_add(specs):
    if not specs:
        cmderr("add", "skill name required")
    if len(specs) == 1 and specs[0] == "-":
        specs = sys.stdin.read().split()
        if not specs:
            return

    client_root, username = get_p4_workspace()
    dest_dirs, state_file, _, _ = get_paths(client_root, username)
    managed = read_managed(state_file)

    resolved_skills = []
    for spec in specs:
        res = subprocess.run(
            [SKILL_SELECT_BIN, "--resolve", spec], capture_output=True, text=True
        )
        if res.returncode != 0:
            print(res.stderr, file=sys.stderr, end="")
            sys.exit(res.returncode)

        output = res.stdout.strip()
        if not output:
            continue
        parts = output.split("\t")
        if len(parts) == 2:
            src, name = parts
        else:
            src = parts[0]
            name = Path(src).name

        resolved_skills.append((Path(src), name))

    # Check for conflicts across all destinations
    for src, name in resolved_skills:
        for d in dest_dirs:
            relpath = d / name
            if relpath.exists() and not relpath.is_symlink():
                # Check if tracked by p4
                res = subprocess.run(["p4", "fstat", str(relpath)], capture_output=True, text=True)
                if res.returncode == 0:
                    cmderr(
                        "add",
                        f"workspace already tracks {relpath.relative_to(client_root)}; refusing to shadow it",
                    )
                else:
                    cmderr(
                        "add",
                        f"{relpath} exists and is not a symlink; refusing to overwrite",
                    )

    for src, name in resolved_skills:
        for d in dest_dirs:
            relpath = d / name
            d.mkdir(parents=True, exist_ok=True)
            if relpath.is_symlink() or relpath.exists():
                relpath.unlink()
            relpath.symlink_to(src)

            if name not in managed:
                managed.append(name)
        print(f"added {name} -> {src}", file=sys.stderr)

    write_managed(state_file, managed)


def cmd_remove(names):
    if not names:
        cmderr("remove", "skill name required")

    client_root, username = get_p4_workspace()
    dest_dirs, state_file, _, _ = get_paths(client_root, username)
    managed = read_managed(state_file)

    for arg in names:
        name = os.path.basename(arg)
        removed = False

        for d in dest_dirs:
            relpath = d / name
            if relpath.is_symlink():
                relpath.unlink()
                removed = True
            elif relpath.exists():
                cmderr(
                    "remove",
                    f"{relpath} is not a symlink we manage; leaving it untouched",
                )

        if name in managed:
            managed.remove(name)

        if removed:
            print(f"removed {name}", file=sys.stderr)
        else:
            print(f"remove: {name} not present; clearing record", file=sys.stderr)

    write_managed(state_file, managed)
    prune_dirs(dest_dirs)


def cmd_list():
    client_root, username = get_p4_workspace()
    dest_dirs, state_file, _, _ = get_paths(client_root, username)
    managed = read_managed(state_file)

    home = str(Path.home())

    def clean_p(p):
        s = str(p)
        if s.startswith(home):
            return "~" + s[len(home) :]
        return s

    resolved_skills = []
    for name in sorted(managed):
        target = None
        # Find the resolved link from the first destination that exists
        for d in dest_dirs:
            p = d / name
            if p.is_symlink():
                try:
                    target = clean_p((p.parent / p.readlink()).resolve())
                    break
                except Exception:
                    pass
        resolved_skills.append((name, target))

    if resolved_skills:
        max_len = max(len(name) for name, _ in resolved_skills)
        for name, target in resolved_skills:
            if target:
                print(f"{name.ljust(max_len)} -> {target}")
            else:
                print(name)


def cmd_clean():
    client_root, username = get_p4_workspace()
    dest_dirs, state_file, _, _ = get_paths(client_root, username)
    managed = read_managed(state_file)

    any_dir = any(d.is_dir() for d in dest_dirs)
    if not managed and not any_dir:
        print("clean: nothing to do", file=sys.stderr)
        return

    removed = 0
    left = 0
    for name in managed:
        for d in dest_dirs:
            relpath = d / name
            if relpath.is_symlink():
                relpath.unlink()
                removed += 1
                print(f"removed {relpath.relative_to(client_root)}", file=sys.stderr)
            elif relpath.exists():
                print(
                    f"clean: {relpath.relative_to(client_root)} is not a symlink; leaving it in place",
                    file=sys.stderr,
                )
                left += 1

    write_managed(state_file, [])
    prune_dirs(dest_dirs)
    print(
        f"clean: removed {removed} link(s); cleared managed list",
        file=sys.stderr,
    )
    if left > 0:
        print(
            f"clean: {left} path(s) left in place (not symlinks)",
            file=sys.stderr,
        )


def cmd_update(names):
    if not names:
        cmderr("update", "skill name, --all, or --catalog required")

    if len(names) == 1 and names[0] == "--catalog":
        res = subprocess.run([SKILL_SELECT_BIN, "--update", "--catalog"])
        sys.exit(res.returncode)

    client_root, username = get_p4_workspace()
    _, state_file, _, _ = get_paths(client_root, username)

    if len(names) == 1 and names[0] == "--all":
        names = read_managed(state_file)
        if not names:
            print("update: nothing to do", file=sys.stderr)
            return

    res = subprocess.run([SKILL_SELECT_BIN, "--update"] + names)
    sys.exit(res.returncode)


def cmd_apply(args):
    client_root, username = get_p4_workspace()
    _, _, analyze_dir, _ = get_paths(client_root, username)

    print("p4 skill: determining skills via skill-select...", file=sys.stderr)

    # Analyze the resolved directory
    analyze_dir = analyze_dir

    cmd = [SKILL_SELECT_BIN, str(analyze_dir), "--json"] + args
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode != 0:
        print(res.stderr, file=sys.stderr, end="")
        die("skill-select failed")

    import json

    specs = []
    names = []
    for line in res.stdout.strip().splitlines():
        if not line.strip():
            continue
        try:
            item = json.loads(line)
        except Exception:
            continue

        name = item.get("name")
        path = item.get("path")
        if not name or not path:
            continue

        names.append(name)
        specs.append(path)

    if specs:
        print(f"p4 skill: applying skills: {' '.join(names)}", file=sys.stderr)
        cmd_add(specs)
    else:
        print("p4 skill: no skills recommended by skill-select", file=sys.stderr)


def cmd_suggest(args):
    client_root, username = get_p4_workspace()
    _, _, analyze_dir, _ = get_paths(client_root, username)
    cmd = [SKILL_SELECT_BIN, str(analyze_dir)] + args

    cmd = [SKILL_SELECT_BIN, str(analyze_dir)] + args
    res = subprocess.run(cmd)
    if res.returncode != 0:
        sys.exit(res.returncode)


def usage():
    print(
        """Usage: p4-skill <command> [skill...]

Manage per-workspace agent skills as untracked symlinks in Perforce workspaces.
Supports both centralized personal config and standard Perforce layouts.

Commands:
  apply           Provision skills for this workspace via skill-select (idempotent)
  suggest         Print skill-select recommendations without installing them
  add SPEC...     Add a skill: a local path or a registered catalog entry
  add -           Read skill names from stdin
  remove NAME...  Remove a skill this tool added (alias: rm)
  list            List skills this tool is managing in the current workspace
  update SPEC...  Re-fetch a registered catalog entry; --all for every managed
                  skill, --catalog to refresh the whole metadata index
  clean           Remove all skills this tool added and its managed list
  doctor          Diagnose drift between desired and on-disk skills (read-only)
  catalog         List registered skills and sources
  resolve NAME    Print the source path 'add NAME' would symlink to

Options:
  --help          Display this help message and exit

Note: registry, network, and AI functions are delegated to 'skill-select'."""
    )
    sys.exit(0)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("--help", "help"):
        usage()

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if "--help" in args:
        usage()

    # Pass-through commands to skill-select
    if cmd in ("catalog", "resolve", "doctor"):
        res = subprocess.run([SKILL_SELECT_BIN, f"--{cmd}"] + args)
        sys.exit(res.returncode)

    if cmd == "update":
        cmd_update(args)
    elif cmd == "add":
        cmd_add(args)
    elif cmd in ("remove", "rm"):
        cmd_remove(args)
    elif cmd == "list":
        cmd_list()
    elif cmd == "clean":
        cmd_clean()
    elif cmd == "apply":
        cmd_apply(args)
    elif cmd == "suggest":
        cmd_suggest(args)
    else:
        print(f"p4 skill: unknown command '{cmd}'", file=sys.stderr)
        print("Try 'p4-skill --help' for more information.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
