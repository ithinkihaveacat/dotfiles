#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///

import os
import sys
import tempfile
import subprocess
from pathlib import Path

SKILL_SELECT_BIN = str(Path(__file__).resolve().parent / "skill-select")


def die(msg):
    print(f"skill: {msg}", file=sys.stderr)
    sys.exit(1)


def cmderr(cmd, msg):
    print(f"skill {cmd}: {msg}", file=sys.stderr)
    sys.exit(1)


def prune_dirs(dest_dirs):
    for d in dest_dirs:
        try:
            if d.is_dir() and not any(d.iterdir()):
                d.rmdir()
            parent = d.parent
            if parent.is_dir() and not any(parent.iterdir()):
                parent.rmdir()
        except Exception:
            pass


# ==============================================================================
# Workspace Abstractions
# ==============================================================================


class Workspace:
    """Base class defining the workspace interface."""

    def __init__(self, root):
        self.root = root

    def get_dest_dirs(self) -> list[Path]:
        dest_dirs_str = os.environ.get(
            "SKILL_DEST_DIRS", ".claude/skills:.agents/skills"
        )
        return [self.root / d for d in dest_dirs_str.split(":") if d]

    def get_managed_skills(self) -> list[str]:
        raise NotImplementedError

    def save_managed_skills(self, skills: list[str]):
        raise NotImplementedError

    def check_conflict(self, relpath: Path) -> str | None:
        """Returns an error message if there is a conflict, else None."""
        raise NotImplementedError

    def get_analyze_dir(self) -> Path:
        return self.root


class GitWorkspace(Workspace):
    def __init__(self, root, exclude_file):
        super().__init__(root)
        self.exclude_file = exclude_file
        self.mark_begin = "# >>> skills (managed by 'skill') >>>"
        self.mark_end = "# <<< skills (managed by 'skill') <<<"
        self.legacy_mark_begin = "# >>> skills (managed by 'git-skill') >>>"
        self.legacy_mark_end = "# <<< skills (managed by 'git-skill') <<<"

    @classmethod
    def detect(cls):
        try:
            # Check if we are inside a git repo and get the top-level
            res = subprocess.run(
                ["git", "rev-parse", "--show-toplevel"],
                capture_output=True,
                text=True,
                check=True,
            )
            root = Path(res.stdout.strip())
            # Get the path to the exclude file
            res_ex = subprocess.run(
                ["git", "rev-parse", "--git-path", "info/exclude"],
                capture_output=True,
                text=True,
                check=True,
            )
            exclude_path = Path(res_ex.stdout.strip()).resolve()
            return cls(root, exclude_path)
        except (subprocess.CalledProcessError, FileNotFoundError):
            return None

    def _read_block(self, begin_mark, end_mark):
        if not self.exclude_file.is_file():
            return None
        managed = []
        in_block = False
        with open(self.exclude_file, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line_stripped = line.strip()
                if line_stripped == begin_mark:
                    in_block = True
                    continue
                if line_stripped == end_mark:
                    in_block = False
                    continue
                if in_block and line_stripped:
                    managed.append(line_stripped)
        return managed if (in_block or managed) else None

    def get_managed_skills(self):
        # Try new marker first, then fallback to legacy git-skill marker
        managed = self._read_block(self.mark_begin, self.mark_end)
        if managed is None:
            managed = self._read_block(self.legacy_mark_begin, self.legacy_mark_end)
        if managed is None:
            return []

        # Git exclude stores paths like "/.agents/skills/name". Extract the name.
        skills = set()
        dest_dirs = self.get_dest_dirs()
        for line in managed:
            rel = line.lstrip("/")
            for d in dest_dirs:
                try:
                    rel_d = d.relative_to(self.root)
                    if rel.startswith(str(rel_d) + "/"):
                        skills.add(rel[len(str(rel_d)) + 1 :])
                except ValueError:
                    # d is not relative to root (e.g. if SKILL_DEST_DIRS was customized with absolute paths)
                    pass
        return sorted(list(skills))

    def save_managed_skills(self, skills):
        dest_dirs = self.get_dest_dirs()
        lines = []
        for name in skills:
            for d in dest_dirs:
                try:
                    lines.append(f"/{d.relative_to(self.root)}/{name}")
                except ValueError:
                    # Fallback if dest_dirs are not relative to root
                    lines.append(f"/{d.name}/{name}")

        self.exclude_file.parent.mkdir(parents=True, exist_ok=True)
        other_lines = []
        if self.exclude_file.is_file():
            in_block = False
            with open(self.exclude_file, "r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    line_stripped = line.strip()
                    if line_stripped in (self.mark_begin, self.legacy_mark_begin):
                        in_block = True
                        continue
                    if line_stripped in (self.mark_end, self.legacy_mark_end):
                        in_block = False
                        continue
                    if not in_block:
                        other_lines.append(line)

        temp_fd, temp_path_str = tempfile.mkstemp()
        temp_path = Path(temp_path_str)
        try:
            with os.fdopen(temp_fd, "w", encoding="utf-8") as f:
                for line in other_lines:
                    f.write(line)
                if other_lines and not other_lines[-1].endswith("\n"):
                    f.write("\n")
                if skills:  # Only write block if there are skills
                    f.write(self.mark_begin + "\n")
                    for line in sorted(list(set(lines))):
                        f.write(line + "\n")
                    f.write(self.mark_end + "\n")

            with open(self.exclude_file, "w", encoding="utf-8") as dest:
                with open(temp_path, "r", encoding="utf-8") as src:
                    dest.write(src.read())
        finally:
            temp_path.unlink(missing_ok=True)

    def check_conflict(self, relpath):
        try:
            rel_to_root = relpath.relative_to(self.root)
            res = subprocess.run(
                ["git", "ls-files", "--error-unmatch", "--", str(rel_to_root)],
                cwd=self.root,
                capture_output=True,
                text=True,
            )
            if res.returncode == 0:
                return f"repo already tracks {rel_to_root}; refusing to shadow it"
        except Exception:
            pass
        return None


class P4Workspace(Workspace):
    def __init__(self, root, username):
        super().__init__(root)
        self.username = username
        self._init_paths()

    def _init_paths(self):
        # Search for a directory at the client root that contains a Bazel-style WORKSPACE file.
        self.repo_dir = None
        for path in self.root.iterdir():
            if path.is_dir() and not path.name.startswith("."):
                if (path / "WORKSPACE").is_file() or (
                    path / "WORKSPACE.bazel"
                ).is_file():
                    self.repo_dir = path
                    break

        configs_dir = self.root / "configs"
        if self.repo_dir and configs_dir.is_dir():
            # Personal config layout convention (centralized)
            self.state_file = (
                self.root
                / "configs"
                / "users"
                / self.username
                / "_agents"
                / ".p4-skills-managed"
            )
            self.analyze_dir = self.repo_dir
            self.is_personal = True
        else:
            # Standard Perforce convention (local, mirroring git-skill)
            self.state_file = self.root / ".p4-skills-managed"
            self.analyze_dir = self.root
            self.is_personal = False

    @classmethod
    def detect(cls):
        try:
            res = subprocess.run(
                ["p4", "info"], capture_output=True, text=True, check=True
            )
            client_root = None
            username = None
            for line in res.stdout.splitlines():
                if line.startswith("Client root:"):
                    client_root = Path(line.split(":", 1)[1].strip())
                elif line.startswith("User name:"):
                    username = line.split(":", 1)[1].strip()
            if client_root and username:
                return cls(client_root, username)
        except (subprocess.CalledProcessError, FileNotFoundError):
            return None
        return None

    def get_dest_dirs(self) -> list[Path]:
        if self.is_personal:
            return [
                self.root / "configs" / "users" / self.username / "_agents" / "skills"
            ]
        return super().get_dest_dirs()

    def get_managed_skills(self):
        if not self.state_file.is_file():
            return []
        with open(self.state_file, "r", encoding="utf-8", errors="replace") as f:
            return sorted([line.strip() for line in f if line.strip()])

    def save_managed_skills(self, skills):
        if not skills:
            if self.state_file.is_file():
                self.state_file.unlink()
            return
        self.state_file.parent.mkdir(parents=True, exist_ok=True)
        with open(self.state_file, "w", encoding="utf-8") as f:
            for item in sorted(list(set(skills))):
                f.write(item + "\n")

    def check_conflict(self, relpath):
        if relpath.exists() and not relpath.is_symlink():
            res = subprocess.run(
                ["p4", "fstat", str(relpath)], capture_output=True, text=True
            )
            if res.returncode == 0:
                return f"workspace already tracks {relpath.relative_to(self.root)}; refusing to shadow it"
        return None

    def get_analyze_dir(self):
        return (
            self.repo_dir if (self.is_personal and self.repo_dir) else self.analyze_dir
        )


class VfsWorkspace(Workspace):
    """Support for virtual/mapped workspaces."""

    def __init__(self, root, vfs_root):
        super().__init__(root)
        self.vfs_root = vfs_root
        self.state_file = self.root / ".skills-managed"

    @classmethod
    def detect(cls):
        curr = Path.cwd()
        vfs_root = None
        # Walk up to find the metadata directory
        for p in [curr] + list(curr.parents):
            if (p / ".citc").is_dir():
                vfs_root = p
                break

        if not vfs_root:
            return None

        # Verify workspace type by checking manifest metadata
        manifest_path = vfs_root / ".citc" / "manifest.ascii"
        if not manifest_path.is_file():
            return None

        is_matched = False
        try:
            with open(manifest_path, "r", encoding="utf-8", errors="replace") as f:
                # Read first few KB to find markers
                content = f.read(4096)
                if "cog.use_jj" in content or "devtools_srcfs" in content:
                    is_matched = True
        except Exception:
            pass

        if not is_matched:
            return None

        # Find the repository root.
        # Typically there is one main directory that is not hidden (e.g., 'android').
        repo_dir = None
        try:
            for path in vfs_root.iterdir():
                if path.is_dir() and not path.name.startswith("."):
                    repo_dir = path
                    break
        except Exception:
            pass

        if not repo_dir:
            repo_dir = vfs_root

        return cls(repo_dir, vfs_root)

    def get_managed_skills(self):
        if not self.state_file.is_file():
            return []
        with open(self.state_file, "r", encoding="utf-8", errors="replace") as f:
            return sorted([line.strip() for line in f if line.strip()])

    def save_managed_skills(self, skills):
        if not skills:
            if self.state_file.is_file():
                self.state_file.unlink()
            return
        self.state_file.parent.mkdir(parents=True, exist_ok=True)
        with open(self.state_file, "w", encoding="utf-8") as f:
            for item in sorted(list(set(skills))):
                f.write(item + "\n")

    def check_conflict(self, relpath):
        if relpath.exists() and not relpath.is_symlink():
            return f"{relpath} exists and is not a symlink; refusing to overwrite"
        return None


class DefaultWorkspace(Workspace):
    """Fallback for non-VCS directories."""

    def __init__(self, root):
        super().__init__(root)
        self.state_file = self.root / ".skills-managed"

    def get_managed_skills(self):
        if not self.state_file.is_file():
            return []
        with open(self.state_file, "r", encoding="utf-8", errors="replace") as f:
            return sorted([line.strip() for line in f if line.strip()])

    def save_managed_skills(self, skills):
        if not skills:
            if self.state_file.is_file():
                self.state_file.unlink()
            return
        self.state_file.parent.mkdir(parents=True, exist_ok=True)
        with open(self.state_file, "w", encoding="utf-8") as f:
            for item in sorted(list(set(skills))):
                f.write(item + "\n")

    def check_conflict(self, relpath):
        if relpath.exists() and not relpath.is_symlink():
            return f"{relpath} exists and is not a symlink; refusing to overwrite"
        return None


# ==============================================================================
# Auto-Detection
# ==============================================================================


def get_workspace() -> Workspace:
    ws = GitWorkspace.detect()
    if ws:
        return ws
    ws = P4Workspace.detect()
    if ws:
        return ws
    ws = VfsWorkspace.detect()
    if ws:
        return ws
    return DefaultWorkspace(Path.cwd())


# ==============================================================================
# CLI Command Implementations
# ==============================================================================


def cmd_add(specs):
    if not specs:
        cmderr("add", "skill name required")
    if len(specs) == 1 and specs[0] == "-":
        specs = sys.stdin.read().split()
        if not specs:
            return

    ws = get_workspace()
    managed = ws.get_managed_skills()
    dest_dirs = ws.get_dest_dirs()

    resolved_skills = []
    for spec in specs:
        res = subprocess.run(
            [SKILL_SELECT_BIN, "--resolve", spec], capture_output=True, text=True
        )
        if res.returncode != 0:
            print(res.stderr, file=sys.stderr, end="")
            sys.exit(res.returncode)

        output = res.stdout.strip()
        if not output:
            continue
        parts = output.split("\t")
        if len(parts) == 2:
            src, name = parts
        else:
            src = parts[0]
            name = Path(src).name

        resolved_skills.append((Path(src), name))

    # Check for conflicts across all destinations first
    for src, name in resolved_skills:
        for d in dest_dirs:
            relpath = d / name
            conflict = ws.check_conflict(relpath)
            if conflict:
                cmderr("add", conflict)
            if relpath.exists() and not relpath.is_symlink():
                cmderr(
                    "add",
                    f"{relpath} exists and is not a symlink; refusing to overwrite",
                )

    # Apply symlinks
    for src, name in resolved_skills:
        for d in dest_dirs:
            relpath = d / name
            d.mkdir(parents=True, exist_ok=True)
            if relpath.is_symlink() or relpath.exists():
                relpath.unlink()
            relpath.symlink_to(src)

            if name not in managed:
                managed.append(name)
        print(f"added {name} -> {src}", file=sys.stderr)

    ws.save_managed_skills(managed)


def cmd_remove(names):
    if not names:
        cmderr("remove", "skill name required")

    ws = get_workspace()
    managed = ws.get_managed_skills()
    dest_dirs = ws.get_dest_dirs()

    for arg in names:
        name = os.path.basename(arg)
        removed = False
        for d in dest_dirs:
            relpath = d / name
            if relpath.is_symlink():
                relpath.unlink()
                removed = True
            elif relpath.exists():
                cmderr(
                    "remove",
                    f"{relpath} is not a symlink we manage; leaving it untouched",
                )

        if name in managed:
            managed.remove(name)

        if removed:
            print(f"removed {name}", file=sys.stderr)
        else:
            print(f"remove: {name} not present; clearing record", file=sys.stderr)

    ws.save_managed_skills(managed)
    prune_dirs(dest_dirs)


def cmd_list():
    ws = get_workspace()
    managed = ws.get_managed_skills()
    dest_dirs = ws.get_dest_dirs()

    home = str(Path.home())

    def clean_p(p):
        s = str(p)
        if s.startswith(home):
            return "~" + s[len(home) :]
        return s

    resolved_skills = []
    for name in sorted(managed):
        target = None
        for d in dest_dirs:
            p = d / name
            if p.is_symlink():
                try:
                    target = clean_p((p.parent / p.readlink()).resolve())
                    break
                except Exception:
                    pass
        resolved_skills.append((name, target))

    if resolved_skills:
        max_len = max(len(name) for name, _ in resolved_skills)
        for name, target in resolved_skills:
            if target:
                print(f"{name.ljust(max_len)} -> {target}")
            else:
                print(name)


def cmd_clean():
    ws = get_workspace()
    managed = ws.get_managed_skills()
    dest_dirs = ws.get_dest_dirs()

    any_dir = any(d.is_dir() for d in dest_dirs)
    if not managed and not any_dir:
        print("clean: nothing to do", file=sys.stderr)
        return

    removed = 0
    left = 0
    for name in managed:
        for d in dest_dirs:
            relpath = d / name
            if relpath.is_symlink():
                relpath.unlink()
                removed += 1
                print(f"removed {relpath.relative_to(ws.root)}", file=sys.stderr)
            elif relpath.exists():
                print(
                    f"clean: {relpath.relative_to(ws.root)} is not a symlink; leaving it in place",
                    file=sys.stderr,
                )
                left += 1

    ws.save_managed_skills([])
    prune_dirs(dest_dirs)
    print(f"clean: removed {removed} link(s); cleared managed list", file=sys.stderr)
    if left > 0:
        print(f"clean: {left} path(s) left in place (not symlinks)", file=sys.stderr)


def cmd_update(names):
    if not names:
        cmderr("update", "skill name, --all, or --catalog required")

    if len(names) == 1 and names[0] == "--catalog":
        res = subprocess.run([SKILL_SELECT_BIN, "--update", "--catalog"])
        sys.exit(res.returncode)

    ws = get_workspace()

    if len(names) == 1 and names[0] == "--all":
        names = ws.get_managed_skills()
        if not names:
            print("update: nothing to do", file=sys.stderr)
            return

    res = subprocess.run([SKILL_SELECT_BIN, "--update"] + names)
    sys.exit(res.returncode)


def cmd_apply(args):
    ws = get_workspace()
    analyze_dir = ws.get_analyze_dir()
    print("skill: determining skills via skill-select...", file=sys.stderr)
    cmd = [SKILL_SELECT_BIN, str(analyze_dir), "--json"] + args
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode != 0:
        print(res.stderr, file=sys.stderr, end="")
        die("skill-select failed")

    import json

    specs = []
    names = []
    for line in res.stdout.strip().splitlines():
        if not line.strip():
            continue
        try:
            item = json.loads(line)
        except Exception:
            continue

        name = item.get("name")
        path = item.get("path")
        if not name or not path:
            continue

        names.append(name)
        specs.append(path)

    if specs:
        print(f"skill: applying skills: {' '.join(names)}", file=sys.stderr)
        cmd_add(specs)
    else:
        print("skill: no skills recommended by skill-select", file=sys.stderr)


def cmd_suggest(args):
    ws = get_workspace()
    analyze_dir = ws.get_analyze_dir()
    cmd = [SKILL_SELECT_BIN, str(analyze_dir)] + args
    res = subprocess.run(cmd)
    if res.returncode != 0:
        sys.exit(res.returncode)


def usage():
    print(
        """Usage: skill <command> [skill...]

Manage per-workspace agent skills as untracked symlinks. Automatically detects
whether the current directory is a Git repository, Perforce workspace, or an
unmanaged directory, and applies the appropriate tracking mechanism.

Commands:
  apply           Provision skills for this workspace via skill-select (idempotent)
  suggest         Print skill-select recommendations without installing them
  add SPEC...     Add a skill: a local path or a registered catalog entry
  add -           Read skill names from stdin
  remove NAME...  Remove a skill this tool added (alias: rm)
  list            List skills this tool is managing in the current workspace
  update SPEC...  Re-fetch a registered catalog entry; --all for every managed
                  skill, --catalog to refresh the whole metadata index
  clean           Remove all skills this tool added and clear the tracking record
  doctor          Diagnose drift between desired and on-disk skills (read-only)
  catalog         List registered skills and sources
  resolve NAME    Print the source path 'add NAME' would symlink to

Options:
  --help          Display this help message and exit

Note: registry, network, and AI functions are delegated to 'skill-select'."""
    )
    sys.exit(0)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("--help", "help"):
        usage()

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if "--help" in args:
        usage()

    # Pass-through commands to skill-select
    if cmd in ("catalog", "resolve", "doctor"):
        res = subprocess.run([SKILL_SELECT_BIN, f"--{cmd}"] + args)
        sys.exit(res.returncode)

    if cmd == "update":
        cmd_update(args)
    elif cmd == "add":
        cmd_add(args)
    elif cmd in ("remove", "rm"):
        cmd_remove(args)
    elif cmd == "list":
        cmd_list()
    elif cmd == "clean":
        cmd_clean()
    elif cmd == "apply":
        cmd_apply(args)
    elif cmd == "suggest":
        cmd_suggest(args)
    else:
        print(f"skill: unknown command '{cmd}'", file=sys.stderr)
        print("Try 'skill --help' for more information.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)
