#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///

import os
import sys
import tempfile
import subprocess
from pathlib import Path

SKILL_SELECT_BIN = str(Path(__file__).resolve().parent / "skill-select")


def die(msg):
    print(f"git skill: {msg}", file=sys.stderr)
    sys.exit(1)


def cmderr(cmd, msg):
    print(f"git skill {cmd}: {msg}", file=sys.stderr)
    sys.exit(1)


def get_git_repo():
    try:
        res = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        )
        root = Path(res.stdout.strip())

        res_ex = subprocess.run(
            ["git", "rev-parse", "--git-path", "info/exclude"],
            capture_output=True,
            text=True,
            check=True,
        )
        exclude_path = Path(res_ex.stdout.strip()).resolve()

        return root, exclude_path
    except subprocess.CalledProcessError:
        die("not inside a git work tree (run 'git init' to create one)")


MARK_BEGIN = "# >>> skills (managed by 'git-skill') >>>"
MARK_END = "# <<< skills (managed by 'git-skill') <<<"


def read_managed(exclude_file):
    if not exclude_file.is_file():
        return []
    managed = []
    in_block = False
    with open(exclude_file, "r", encoding="utf-8", errors="replace") as f:
        for line in f:
            line_stripped = line.strip()
            if line_stripped == MARK_BEGIN:
                in_block = True
                continue
            if line_stripped == MARK_END:
                in_block = False
                continue
            if in_block and line_stripped:
                managed.append(line_stripped)
    return managed


def rewrite_block(exclude_file, lines):
    exclude_file.parent.mkdir(parents=True, exist_ok=True)

    other_lines = []
    if exclude_file.is_file():
        in_block = False
        with open(exclude_file, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line_stripped = line.strip()
                if line_stripped == MARK_BEGIN:
                    in_block = True
                    continue
                if line_stripped == MARK_END:
                    in_block = False
                    continue
                if not in_block:
                    other_lines.append(line)

    temp_fd, temp_path_str = tempfile.mkstemp()
    temp_path = Path(temp_path_str)
    try:
        with os.fdopen(temp_fd, "w", encoding="utf-8") as f:
            for line in other_lines:
                f.write(line)
            if other_lines and not other_lines[-1].endswith("\n"):
                f.write("\n")
            if lines:
                f.write(MARK_BEGIN + "\n")
                for line in sorted(list(set(lines))):
                    f.write(line + "\n")
                f.write(MARK_END + "\n")

        with open(exclude_file, "w", encoding="utf-8") as dest:
            with open(temp_path, "r", encoding="utf-8") as src:
                dest.write(src.read())
    finally:
        temp_path.unlink(missing_ok=True)


def cmd_add(specs):
    if not specs:
        cmderr("add", "skill name required")
    if len(specs) == 1 and specs[0] == "-":
        specs = sys.stdin.read().split()
        if not specs:
            return

    root, exclude_file = get_git_repo()
    managed = read_managed(exclude_file)

    resolved_skills = []
    for spec in specs:
        # Resolve the spec (local path, registry name, or SKILL_SOURCE_DIRS entry) via skill-select
        res = subprocess.run(
            [SKILL_SELECT_BIN, "--resolve", spec], capture_output=True, text=True
        )
        if res.returncode != 0:
            print(res.stderr, file=sys.stderr, end="")
            sys.exit(res.returncode)

        output = res.stdout.strip()
        if not output:
            continue
        parts = output.split("\t")
        if len(parts) == 2:
            src, name = parts
        else:
            src = parts[0]
            name = Path(src).name

        resolved_skills.append((Path(src), name))

    dest_dirs_str = os.environ.get("SKILL_DEST_DIRS", ".claude/skills:.agents/skills")
    dest_dirs = [root / d for d in dest_dirs_str.split(":") if d]

    for src, name in resolved_skills:
        for d in dest_dirs:
            relpath = d / name

            try:
                rel_to_root = relpath.relative_to(root)
                res = subprocess.run(
                    [
                        "git",
                        "ls-files",
                        "--error-unmatch",
                        "--",
                        str(rel_to_root),
                    ],
                    cwd=root,
                    capture_output=True,
                    text=True,
                )
                if res.returncode == 0:
                    cmderr(
                        "add",
                        f"repo already tracks {rel_to_root}; refusing to shadow it",
                    )
            except Exception:
                pass

            if relpath.exists() and not relpath.is_symlink():
                cmderr(
                    "add",
                    f"{relpath} exists and is not a symlink; refusing to overwrite",
                )

    for src, name in resolved_skills:
        for d in dest_dirs:
            relpath = d / name
            line = f"/{relpath.relative_to(root)}"

            d.mkdir(parents=True, exist_ok=True)
            if relpath.is_symlink() or relpath.exists():
                relpath.unlink()
            relpath.symlink_to(src)

            if line not in managed:
                managed.append(line)
        print(f"added {name} -> {src}", file=sys.stderr)

    rewrite_block(exclude_file, managed)


def prune_dirs(root):
    dest_dirs_str = os.environ.get("SKILL_DEST_DIRS", ".claude/skills:.agents/skills")
    dest_dirs = [root / d for d in dest_dirs_str.split(":") if d]

    for d in dest_dirs:
        try:
            if d.is_dir() and not any(d.iterdir()):
                d.rmdir()
            parent = d.parent
            if parent.is_dir() and not any(parent.iterdir()):
                parent.rmdir()
        except Exception:
            pass


def cmd_remove(names):
    if not names:
        cmderr("remove", "skill name required")

    root, exclude_file = get_git_repo()
    managed = read_managed(exclude_file)

    dest_dirs_str = os.environ.get("SKILL_DEST_DIRS", ".claude/skills:.agents/skills")
    dest_dirs = [root / d for d in dest_dirs_str.split(":") if d]

    for arg in names:
        name = os.path.basename(arg)
        removed = False
        for d in dest_dirs:
            relpath = d / name
            line = f"/{relpath.relative_to(root)}"

            if relpath.is_symlink():
                relpath.unlink()
                removed = True
            elif relpath.exists():
                cmderr(
                    "remove",
                    f"{relpath} is not a symlink we manage; leaving it untouched",
                )

            if line in managed:
                managed.remove(line)

        if removed:
            print(f"removed {name}", file=sys.stderr)
        else:
            print(f"remove: {name} not present; clearing record", file=sys.stderr)

    rewrite_block(exclude_file, managed)
    prune_dirs(root)


def cmd_list():
    root, exclude_file = get_git_repo()
    managed = read_managed(exclude_file)

    dest_dirs_str = os.environ.get("SKILL_DEST_DIRS", ".claude/skills:.agents/skills")
    dest_dirs_rel = [d for d in dest_dirs_str.split(":") if d]

    skills = set()
    for line in managed:
        rel = line.lstrip("/")
        for d in dest_dirs_rel:
            if rel.startswith(d + "/"):
                skills.add(rel[len(d) + 1 :])

    home = str(Path.home())

    def clean_p(p):
        s = str(p)
        if s.startswith(home):
            return "~" + s[len(home) :]
        return s

    resolved_skills = []
    for s in sorted(list(skills)):
        target = None
        for d in dest_dirs_rel:
            p = root / d / s
            if p.is_symlink():
                try:
                    target = clean_p((p.parent / p.readlink()).resolve())
                    break
                except Exception:
                    pass
        resolved_skills.append((s, target))

    if resolved_skills:
        max_len = max(len(name) for name, _ in resolved_skills)
        for name, target in resolved_skills:
            if target:
                print(f"{name.ljust(max_len)} -> {target}")
            else:
                print(name)


def cmd_clean():
    root, exclude_file = get_git_repo()
    managed = read_managed(exclude_file)

    dest_dirs_str = os.environ.get("SKILL_DEST_DIRS", ".claude/skills:.agents/skills")
    dest_dirs = [root / d for d in dest_dirs_str.split(":") if d]
    any_dir = any(d.is_dir() for d in dest_dirs)

    if not managed and not any_dir:
        print("clean: nothing to do", file=sys.stderr)
        return

    removed = 0
    left = 0
    for line in managed:
        relpath = root / line.lstrip("/")
        if relpath.is_symlink():
            relpath.unlink()
            removed += 1
            print(f"removed {relpath.relative_to(root)}", file=sys.stderr)
        elif relpath.exists():
            print(
                f"clean: {relpath.relative_to(root)} is not a symlink; leaving it in place",
                file=sys.stderr,
            )
            left += 1

    rewrite_block(exclude_file, [])
    prune_dirs(root)
    print(
        f"clean: removed {removed} link(s); cleared exclude block",
        file=sys.stderr,
    )
    if left > 0:
        print(
            f"clean: {left} path(s) left in place (not symlinks)",
            file=sys.stderr,
        )


def cmd_update(names):
    if not names:
        cmderr("update", "skill name, --all, or --catalog required")

    if len(names) == 1 and names[0] == "--catalog":
        res = subprocess.run([SKILL_SELECT_BIN, "--update", "--catalog"])
        sys.exit(res.returncode)

    root, exclude_file = get_git_repo()

    if len(names) == 1 and names[0] == "--all":
        managed = read_managed(exclude_file)
        dest_dirs_str = os.environ.get(
            "SKILL_DEST_DIRS", ".claude/skills:.agents/skills"
        )
        dest_dirs_rel = [d for d in dest_dirs_str.split(":") if d]
        skills = set()
        for line in managed:
            rel = line.lstrip("/")
            for d in dest_dirs_rel:
                if rel.startswith(d + "/"):
                    skills.add(rel[len(d) + 1 :])
        names = sorted(list(skills))
        if not names:
            print("update: nothing to do", file=sys.stderr)
            return

    res = subprocess.run([SKILL_SELECT_BIN, "--update"] + names)
    sys.exit(res.returncode)


def cmd_apply(args):
    root, _ = get_git_repo()
    print("git skill: determining skills via skill-select...", file=sys.stderr)
    cmd = [SKILL_SELECT_BIN, str(root), "--json"] + args
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode != 0:
        print(res.stderr, file=sys.stderr, end="")
        die("skill-select failed")

    import json

    specs = []
    names = []
    for line in res.stdout.strip().splitlines():
        if not line.strip():
            continue
        try:
            item = json.loads(line)
        except Exception:
            continue

        name = item.get("name")
        path = item.get("path")
        if not name or not path:
            continue

        names.append(name)
        specs.append(path)

    if specs:
        print(f"git skill: applying skills: {' '.join(names)}", file=sys.stderr)
        cmd_add(specs)
    else:
        print("git skill: no skills recommended by skill-select", file=sys.stderr)


def cmd_suggest(args):
    root, _ = get_git_repo()
    cmd = [SKILL_SELECT_BIN, str(root)] + args
    res = subprocess.run(cmd)
    if res.returncode != 0:
        sys.exit(res.returncode)


def usage():
    print(
        """Usage: git skill <command> [skill...]

Manage per-workspace agent skills as untracked symlinks under .claude/skills
and .agents/skills, keeping git quiet via .git/info/exclude. Each command acts
on every destination at once, so they stay in sync. Operates on the current
git repository.

Commands:
  apply           Provision skills for this repository via skill-select (idempotent)
  suggest         Print skill-select recommendations without installing them
  add SPEC...     Add a skill: a local path or a registered catalog entry
  add -           Read skill names from stdin
  remove NAME...  Remove a skill this tool added (alias: rm)
  list            List skills this tool is managing in the current repo
  update SPEC...  Re-fetch a registered catalog entry; --all for every managed
                  skill, --catalog to refresh the whole metadata index
  clean           Remove all skills this tool added and its info/exclude block
  doctor          Diagnose drift between desired and on-disk skills (read-only)
  catalog         List registered skills and their sources
  resolve NAME    Print the source path 'add NAME' would symlink to

Options:
  --help          Display this help message and exit

Note: registry, network, and AI functions are delegated to 'skill-select'."""
    )
    sys.exit(0)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("--help", "help"):
        usage()

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if "--help" in args:
        usage()

    # Pass-through commands to skill-select
    if cmd in ("catalog", "resolve", "doctor"):
        res = subprocess.run([SKILL_SELECT_BIN, f"--{cmd}"] + args)
        sys.exit(res.returncode)

    if cmd == "update":
        cmd_update(args)
    elif cmd == "add":
        cmd_add(args)
    elif cmd in ("remove", "rm"):
        cmd_remove(args)
    elif cmd == "list":
        cmd_list()
    elif cmd == "clean":
        cmd_clean()
    elif cmd == "apply":
        cmd_apply(args)
    elif cmd == "suggest":
        cmd_suggest(args)
    else:
        print(f"git skill: unknown command '{cmd}'", file=sys.stderr)
        print("Try 'git skill --help' for more information.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
