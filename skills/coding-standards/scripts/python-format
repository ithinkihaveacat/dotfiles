#!/usr/bin/env bash

# Tests: tests/python-format/

set -euo pipefail

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

# Verify external dependencies. Deferred until after argument parsing so that
# --help works even when dependencies are absent.
check_deps() {
  require uvx
}

SCRIPT_NAME=$(basename "$0")

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME [OPTION] [PATH...]

Format and lint Python files using ruff.

When PATHs are provided, formats and lints files in place. If a directory is
provided, recursively processes all Python files in it.
When no PATH is provided, reads from standard input and writes to standard output.

Arguments:
  PATH...           Paths to Python files or directories to format/lint (optional)

Options:
  --check           Check for lint errors and formatting without making changes
  --help            Display this help message and exit

Examples:

# Format and fix lint errors in a file in place
  $SCRIPT_NAME script.py

# Format and fix lint errors in a directory recursively
  $SCRIPT_NAME src/

# Check a file for issues without modifying it
  $SCRIPT_NAME --check script.py

# Format reading from stdin
  $SCRIPT_NAME < script.py
EOF
}

# Parse options
CHECK_MODE=0
PATHS=()

for arg in "$@"; do
  case "$arg" in
    --help)
      usage
      exit 0
      ;;
    --check)
      CHECK_MODE=1
      ;;
    -*)
      echo "$SCRIPT_NAME: unknown option: $arg" >&2
      exit 1
      ;;
    *)
      PATHS+=("$arg")
      ;;
  esac
done

check_deps

# Check if paths are provided
if [ ${#PATHS[@]} -eq 0 ]; then
  if [ -t 0 ]; then
    usage
    exit 1
  fi

  # Stdin mode
  # Create a temp directory and file to hold stdin content portably
  TMPDIR=$(mktemp -d)
  trap 'rm -rf "$TMPDIR"' EXIT
  TMPFILE="$TMPDIR/python-format.py"

  cat >"$TMPFILE"

  if [ "$CHECK_MODE" -eq 1 ]; then
    # Run silently and redirect outputs to stderr
    uvx ruff check "$TMPFILE" >&2 && uvx ruff format --check "$TMPFILE" >&2
    exit $?
  else
    # Fix and format
    uvx ruff check --fix "$TMPFILE" >&2 && uvx ruff format "$TMPFILE" >&2
    cat "$TMPFILE"
    exit $?
  fi
else
  # Path mode
  # Check if paths exist
  for p in "${PATHS[@]}"; do
    if [ ! -e "$p" ]; then
      echo "$SCRIPT_NAME: $p: No such file or directory" >&2
      exit 1
    fi
  done

  if [ "$CHECK_MODE" -eq 1 ]; then
    echo "Checking lint rules with ruff..." >&2
    uvx ruff check "${PATHS[@]}" || exit 1
    echo "Checking format with ruff..." >&2
    uvx ruff format --check "${PATHS[@]}" || exit 1
  else
    echo "Fixing lint rules with ruff..." >&2
    uvx ruff check --fix "${PATHS[@]}" || exit 1
    echo "Formatting with ruff..." >&2
    uvx ruff format "${PATHS[@]}" || exit 1
  fi
fi
