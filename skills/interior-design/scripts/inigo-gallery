#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Print every gallery image URL from an inigo.com listing.

Default output is one image URL per line on stdout. With --json, emits the
full parsed listing payload (address, price, body text, gallery, etc.) for
richer pipelines.

Pipe to a downloader to fetch the images:

    inigo-gallery URL | wget -i - -P dir/
    inigo-gallery URL | xargs -n1 -P4 curl -sO
"""

import argparse
import json
import re
import sys
import urllib.request

UA = "Mozilla/5.0 (compatible; inigo-gallery)"


def fetch(url: str) -> str:
    req = urllib.request.Request(url, headers={"User-Agent": UA})
    with urllib.request.urlopen(req, timeout=30) as r:
        return r.read().decode("utf-8", errors="replace")


def extract_legacy(html: str):
    """Pages-Router format (pre-2026): __NEXT_DATA__ script tag."""
    m = re.search(
        r'<script id="__NEXT_DATA__" type="application/json">([^<]+)</script>',
        html,
    )
    if not m:
        return None
    data = json.loads(m.group(1))
    page_props = data["props"]["pageProps"]
    gallery = page_props.get("gallery", [])
    urls = [g.get("imageRetina") or g.get("image") for g in gallery]
    return page_props, [u for u in urls if u]


def extract_rsc(html: str):
    """App-Router format (current): self.__next_f.push RSC chunks."""
    for raw in re.findall(r'self\.__next_f\.push\(\[1,"(.*?)"\]\)', html, re.DOTALL):
        decoded = raw.encode("raw_unicode_escape").decode("unicode_escape")
        if '"gallery"' not in decoded:
            continue
        for line in decoded.splitlines():
            if '"gallery"' not in line:
                continue
            try:
                outer = json.loads(re.sub(r"^\d+:", "", line.strip()))
            except json.JSONDecodeError:
                continue
            payload = outer[3] if isinstance(outer, list) and len(outer) > 3 else outer
            listing = payload.get("listing", payload)
            images = listing.get("gallery", {}).get("images", [])
            urls = [img["imageUrl"] for img in images if img.get("imageUrl")]
            if urls:
                return listing, urls
    return None


def main():
    ap = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
    )
    ap.add_argument("--help", action="help", help="Show this help message and exit")
    ap.add_argument("url")
    ap.add_argument(
        "--json",
        action="store_true",
        help="Emit the full parsed listing payload as JSON instead of URLs",
    )
    args = ap.parse_args()

    html = fetch(args.url)
    result = extract_legacy(html) or extract_rsc(html)
    if not result:
        print("error: could not find gallery data in page", file=sys.stderr)
        sys.exit(1)
    payload, urls = result

    if args.json:
        json.dump(payload, sys.stdout, indent=2, ensure_ascii=False)
        sys.stdout.write("\n")
    else:
        for u in urls:
            print(u)


if __name__ == "__main__":
    main()
