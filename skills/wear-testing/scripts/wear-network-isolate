#!/usr/bin/env bash

# If ((BASH_VERSINFO[0] < 4)); then version guard not needed as this script is simple
# and targets standard shell utilities.

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Isolates a connected Wear OS device from the network and phone by 
disabling both Wi-Fi and Bluetooth via ADB. This is useful for testing
offline states and Data Layer message queuing.

Options:
  --restore   Enable Wi-Fi and Bluetooth to restore connectivity
  --help      Display this help message and exit

Examples:
  $(basename "$0")
  $(basename "$0") --restore
EOF
  exit 0
}

require() {
  command -v "$1" >/dev/null 2>&1 || {
    echo >&2 "$(basename "$0"): $1 not found"
    exit 127
  }
}

if [[ "$1" == "--help" ]]; then
  usage
fi

require adb

if [[ "$1" == "--restore" ]]; then
  echo "Restoring connectivity..." >&2
  adb shell svc bluetooth enable
  adb shell svc wifi enable
  echo "Connectivity restored." >&2
  exit 0
fi

echo "Isolating device (disabling Wi-Fi and Bluetooth)..." >&2
adb shell svc bluetooth disable
adb shell svc wifi disable
echo "Device isolated." >&2
