from __future__ import annotations

import json
import os
import re
import shutil
import sys
import time
import tarfile
import tempfile
import subprocess
import urllib.request
from urllib.parse import urlparse
from pathlib import Path


def die(msg):
    print(f"skill: {msg}", file=sys.stderr)
    sys.exit(1)


def cmderr(cmd, msg):
    print(f"skill {cmd}: {msg}", file=sys.stderr)
    sys.exit(1)


def clean_p(p):
    home = str(Path.home())
    s = str(p)
    if s.startswith(home):
        return "~" + s[len(home) :]
    return s


def prune_dirs(dest_dirs):
    for d in dest_dirs:
        try:
            if d.is_dir() and not any(d.iterdir()):
                d.rmdir()
            parent = d.parent
            if parent.is_dir() and not any(parent.iterdir()):
                parent.rmdir()
        except Exception:
            pass


def print_workspace_root(ws, stream=sys.stderr) -> None:
    """Announce the resolved workspace root before a mutating operation.

    The skill-anchor walk (see find_skill_anchor) can bind the workspace to an
    ancestor of the current directory, so symlinks created by 'add'/'apply' (and
    removed by 'remove'/'clean') may land somewhere other than where the command
    was run. Print that resolved location to stderr (it is status, not data) and
    flag the redirect explicitly when the anchor sits above the current
    directory.
    """
    root = ws.root
    cwd = Path.cwd().resolve()
    if root == cwd:
        print(f"skill: workspace root: {clean_p(root)}", file=stream)
    else:
        print(
            f"skill: workspace root: {clean_p(root)} "
            f"(anchor above current directory {clean_p(cwd)})",
            file=stream,
        )


def anchor_subdirs() -> list[str]:
    """The skill destination subpaths that mark a directory as a workspace anchor."""
    if "SKILL_DEST_DIRS" in os.environ:
        return [d for d in os.environ["SKILL_DEST_DIRS"].split(":") if d]
    return list(Workspace.get_supported_configs().keys())


def find_skill_anchor(start: Path, boundary: Path) -> Path:
    """Resolve the workspace anchor the way an agent discovers project skills.

    Agents (Claude, Codex) load skills from the starting directory and every
    parent directory up to the repository root. To keep 'skill' aligned with
    that behavior, we walk from 'start' up to and including 'boundary' (the repo
    root) and bind to the nearest ancestor that already contains a skills
    directory. If none exists yet, we fall back to 'boundary' so a fresh 'apply'
    installs once at the repo root, where an agent launched anywhere below will
    discover it.
    """
    subdirs = anchor_subdirs()
    chain = [start]
    cur = start
    while cur != boundary and boundary in cur.parents:
        cur = cur.parent
        chain.append(cur)
    for d in chain:  # nearest first
        if any((d / sd).is_dir() for sd in subdirs):
            return d
    return boundary


# ==============================================================================
# Workspace Abstractions
# ==============================================================================


class Workspace:
    """Base class defining the workspace interface."""

    def __init__(self, root):
        self.root = root

    @classmethod
    def get_supported_configs(cls) -> dict[str, list[Path]]:
        """Returns a mapping of local destination folders to their global config directories."""
        home = Path.home()
        return {
            ".claude/skills": [home / ".claude"],
            ".agents/skills": [
                home / ".codex",
                home / ".gemini/antigravity-cli",
                home / ".gemini/jetski/cli",
            ],
        }

    def get_dest_dirs(self) -> list[Path]:
        if "SKILL_DEST_DIRS" in os.environ:
            return [
                self.root / d for d in os.environ["SKILL_DEST_DIRS"].split(":") if d
            ]

        dest_dirs = []
        configs = self.get_supported_configs()

        for dest, sources in configs.items():
            if any(src.is_dir() for src in sources) or (self.root / dest).is_dir():
                dest_dirs.append(dest)

        if not dest_dirs:
            home = Path.home()
            all_sources = []
            for sources in configs.values():
                for src in sources:
                    formatted = (
                        f"~/{src.relative_to(home)}"
                        if src.is_relative_to(home)
                        else str(src)
                    )
                    if formatted not in all_sources:
                        all_sources.append(formatted)

            raise RuntimeError(
                f"No supported agent configuration directory ({', '.join(all_sources)}) detected, "
                f"and no existing skill directories found in the workspace."
            )

        return [self.root / d for d in dest_dirs]

    def get_tracked_skills(self) -> list[Path]:
        """Returns a list of VCS-tracked skill paths in the destination directories."""
        tracked = []
        try:
            dest_dirs = self.get_dest_dirs()
        except RuntimeError:
            return []
        for d in dest_dirs:
            if not d.is_dir():
                continue
            for item in d.iterdir():
                if item.name.startswith("."):
                    continue
                if not item.is_symlink() and self.is_tracked(item):
                    tracked.append(item)
        return sorted(tracked, key=lambda p: p.name)

    def get_expected_skills(self) -> list[str]:
        if hasattr(self, "get_managed_skills"):
            return self.get_managed_skills()
        required, _ = get_parsed_skills()
        return required

    def get_actual_skills(self) -> tuple[set[str], list[Path], list[Path]]:
        """Scans destination directories and returns:
        (actual_skills_set, unmanaged_artifacts, dangling_symlinks)
        """
        actual = set()
        unmanaged = []
        dangling = []
        try:
            dest_dirs = self.get_dest_dirs()
        except RuntimeError:
            return actual, unmanaged, dangling

        for d in dest_dirs:
            if not d.is_dir():
                continue
            for item in d.iterdir():
                if item.name.startswith("."):
                    continue
                if item.is_symlink():
                    try:
                        if item.exists():
                            actual.add(item.name)
                        else:
                            dangling.append(item)
                    except OSError as e:
                        raise OSError(
                            e.errno,
                            f"Permission denied accessing skill {item.name}: {e.strerror}",
                            str(item),
                        ) from e
                else:
                    if self.is_tracked(item):
                        continue
                    unmanaged.append(item)
        return actual, unmanaged, dangling

    def check_conflict(self, relpath: Path) -> str | None:
        """Returns an error message if there is a conflict, else None."""
        if relpath.exists() and not relpath.is_symlink():
            return f"{relpath} exists and is not a symlink; refusing to overwrite"
        return None

    def is_tracked(self, path: Path) -> bool:
        """Returns True if the path is tracked by the VCS."""
        return False

    def get_analyze_dir(self) -> Path:
        return self.root

    def doctor_issues(self) -> list[str]:
        """Returns backend-specific findings (read-only)."""
        return []


class FileStateMixin:
    """Stores the managed-skill list as one name per line in self.state_file."""

    def get_managed_skills(self):
        if not self.state_file.is_file():
            return []
        with open(self.state_file, "r", encoding="utf-8", errors="replace") as f:
            return sorted({line.strip() for line in f if line.strip()})

    def save_managed_skills(self, skills):
        skills = sorted(set(skills))
        if not skills:
            if self.state_file.is_file():
                self.state_file.unlink()
            return
        self.state_file.parent.mkdir(parents=True, exist_ok=True)
        with open(self.state_file, "w", encoding="utf-8") as f:
            for item in skills:
                f.write(item + "\n")

    def is_managed(self) -> bool:
        return self.state_file.is_file()


class GitWorkspace(Workspace):
    """Git repositories.

    VCS Cleanliness (CL safety):
    1. Symlinks & Local State: The symlinks in '.claude/skills' or '.agents/skills'
       are automatically appended to '.git/info/exclude'. This is a local-only
       ignore file (not tracked by Git), keeping your 'git status' perfectly clean
       without polluting the repository's shared '.gitignore' file.
    """

    def __init__(self, root, git_root, exclude_file):
        super().__init__(root)
        self.git_root = git_root
        self.exclude_file = exclude_file
        self.mark_begin = "# >>> skills >>>"
        self.mark_end = "# <<< skills <<<"

    @classmethod
    def detect(cls):
        try:
            res = subprocess.run(
                ["git", "rev-parse", "--show-toplevel"],
                capture_output=True,
                text=True,
                check=True,
            )
            git_root = Path(res.stdout.strip()).resolve()
            # Bind to the anchor an agent would discover (cwd up to the repo
            # root), not cwd itself, so 'apply' and 'preflight' agree no matter
            # which depth each is invoked from.
            root = find_skill_anchor(Path.cwd().resolve(), git_root)

            def git_path(rel):
                r = subprocess.run(
                    ["git", "rev-parse", "--git-path", rel],
                    capture_output=True,
                    text=True,
                    check=True,
                )
                return Path(r.stdout.strip()).resolve()

            return cls(root, git_root, git_path("info/exclude"))
        except (subprocess.CalledProcessError, FileNotFoundError):
            return None

    def _read_block(self, begin_mark, end_mark):
        if not self.exclude_file.is_file():
            return None
        managed = []
        in_block = False
        with open(self.exclude_file, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line_stripped = line.strip()
                if line_stripped == begin_mark:
                    in_block = True
                    continue
                if line_stripped == end_mark:
                    in_block = False
                    continue
                if in_block and line_stripped:
                    if not line_stripped.startswith("#"):
                        managed.append(line_stripped)
        return managed if (in_block or managed) else None

    def _names_from_exclude_lines(self, lines):
        # Exclude lines look like "/.agents/skills/name". Extract the name.
        skills = set()
        dest_dirs = self.get_dest_dirs()
        for line in lines:
            rel = line.lstrip("/")
            for d in dest_dirs:
                try:
                    rel_d = d.relative_to(self.git_root)
                    if rel.startswith(str(rel_d) + "/"):
                        skills.add(rel[len(str(rel_d)) + 1 :])
                except ValueError:
                    # d is not relative to git_root
                    pass
        return sorted(skills)

    def _expected_exclude_lines(self, skills):
        lines = set()
        for name in skills:
            for d in self.get_dest_dirs():
                try:
                    lines.add(f"/{d.relative_to(self.git_root)}/{name}")
                except ValueError:
                    # Fallback if dest_dirs are not relative to git_root
                    lines.add(f"/{d.name}/{name}")
        return sorted(lines)

    def _write_exclude_block(self, skills):
        self.exclude_file.parent.mkdir(parents=True, exist_ok=True)
        other_lines = []
        existing_block_lines = []
        if self.exclude_file.is_file():
            in_block = False
            with open(self.exclude_file, "r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    line_stripped = line.strip()
                    if line_stripped == self.mark_begin:
                        in_block = True
                        continue
                    if line_stripped == self.mark_end:
                        in_block = False
                        continue
                    if in_block:
                        if line_stripped and not line_stripped.startswith("#"):
                            existing_block_lines.append(line_stripped)
                    else:
                        other_lines.append(line)

        # Separate existing block lines into ours vs others
        our_rel_dest_dirs = []
        for d in self.get_dest_dirs():
            try:
                our_rel_dest_dirs.append(str(d.relative_to(self.git_root)))
            except ValueError:
                our_rel_dest_dirs.append(d.name)

        preserved_block_lines = []
        for line in existing_block_lines:
            rel = line.lstrip("/")
            is_ours = False
            for rdd in our_rel_dest_dirs:
                if rel.startswith(rdd + "/"):
                    is_ours = True
                    break
            if not is_ours:
                preserved_block_lines.append(line)

        # Generate new lines and combine with preserved lines
        new_lines = self._expected_exclude_lines(skills)
        combined_lines = sorted(set(preserved_block_lines + new_lines))

        # Write to temp file in same directory for atomic replace (concurrency safety)
        temp_fd, temp_path_str = tempfile.mkstemp(dir=str(self.exclude_file.parent))
        temp_path = Path(temp_path_str)
        try:
            with os.fdopen(temp_fd, "w", encoding="utf-8") as f:
                for line in other_lines:
                    f.write(line)
                if other_lines and not other_lines[-1].endswith("\n"):
                    f.write("\n")
                if combined_lines:  # Only write block if there are active lines
                    f.write(self.mark_begin + "\n")
                    f.write("# managed by 'skill'\n")
                    for line in combined_lines:
                        f.write(line + "\n")
                    f.write(self.mark_end + "\n")

            os.replace(temp_path, self.exclude_file)
        except Exception:
            temp_path.unlink(missing_ok=True)
            raise

    def save_exclude_block(self, skills):
        self._write_exclude_block(skills)

    def check_conflict(self, relpath):
        try:
            rel_to_root = relpath.relative_to(self.root)
            res = subprocess.run(
                ["git", "ls-files", "--error-unmatch", "--", str(rel_to_root)],
                cwd=self.root,
                capture_output=True,
                text=True,
            )
            if res.returncode == 0:
                return f"repo already tracks {rel_to_root}; refusing to shadow it"
        except Exception:
            pass
        return None

    def is_tracked(self, path: Path) -> bool:
        """Returns True if the path is tracked by Git (or contains tracked files)."""
        try:
            rel_to_root = path.relative_to(self.root)
            res = subprocess.run(
                ["git", "ls-files", "--error-unmatch", "--", str(rel_to_root)],
                cwd=self.root,
                capture_output=True,
                text=True,
            )
            return res.returncode == 0
        except Exception:
            return False

    def doctor_issues(self):
        issues = []
        actual_skills, _, _ = self.get_actual_skills()

        # Read the block
        block_lines = self._read_block(self.mark_begin, self.mark_end) or []

        # Filter the block lines to only include those belonging to our workspace
        our_rel_dest_dirs = []
        for d in self.get_dest_dirs():
            try:
                our_rel_dest_dirs.append(str(d.relative_to(self.git_root)))
            except ValueError:
                our_rel_dest_dirs.append(d.name)

        our_actual_exclude = []
        for line in block_lines:
            rel = line.lstrip("/")
            for rdd in our_rel_dest_dirs:
                if rel.startswith(rdd + "/"):
                    our_actual_exclude.append(line)
                    break

        if sorted(set(our_actual_exclude)) != self._expected_exclude_lines(
            actual_skills
        ):
            issues.append(
                f"exclude drift  {clean_p(self.exclude_file)} block does not match the actual on-disk skills"
            )
        return issues


class DefaultWorkspace(Workspace):
    """Fallback for non-VCS directories."""

    pass


# ==============================================================================
# Plugins & Auto-Detection
# ==============================================================================


# --- Catalog Caching & Registry Settings ---
CATALOG_TTL = 7 * 24 * 3600  # 7 days
PROVISION_TTL = 8 * 3600  # 8 hours


def get_cache_base() -> Path:
    return (
        Path(
            os.environ.get("SKILL_CACHE_DIR")
            or os.environ.get("XDG_CACHE_HOME")
            or "~/.cache"
        ).expanduser()
        / "skill"
        / "remotes"
    )


def get_catalog_dir() -> Path:
    return get_cache_base().parent / "catalog"


def parse_github_url(url: str) -> tuple[str, str, str | None]:
    parsed = urlparse(url)
    if parsed.netloc != "github.com":
        raise ValueError(
            f"registry: unsupported URL (only github.com is supported): {url}"
        )
    parts = parsed.path.strip("/").split("/")
    if len(parts) < 4 or parts[2] != "tree":
        raise ValueError(f"registry: cannot parse GitHub URL: {url}")
    owner, repo, _, ref = parts[:4]
    subpath = "/".join(parts[4:]) or None
    return f"{owner}/{repo}", ref, subpath


def fetch_github(
    name: str, repo: str, ref: str, subpath: str | None, force: bool = False
) -> str:
    owner, reponame = repo.split("/", 1)
    dest_base = get_cache_base() / owner / reponame / ref
    target_dir = dest_base / subpath if subpath else dest_base
    meta_file = get_catalog_dir() / ".meta" / name

    if not force and target_dir.is_dir() and meta_file.is_file():
        if (time.time() - meta_file.stat().st_mtime) < PROVISION_TTL:
            return str(target_dir)

    url = f"https://github.com/{repo}/archive/{ref}.tar.gz"
    print(f"skill: downloading remote skill '{name}' from GitHub...", file=sys.stderr)

    with tempfile.TemporaryDirectory() as tmpdir:
        tmp_tar = Path(tmpdir) / "archive.tar.gz"
        try:
            req = urllib.request.Request(
                url, headers={"User-Agent": "Antigravity-Skill-Manager/1.0"}
            )
            with (
                urllib.request.urlopen(req, timeout=30) as response,
                open(tmp_tar, "wb") as out_file,
            ):
                out_file.write(response.read())
        except Exception as e:
            die(f"failed to download {url}: {e}")

        try:
            with tarfile.open(tmp_tar, "r:gz") as tar:
                if hasattr(tarfile, "data_filter"):
                    tar.extractall(path=tmpdir, filter="data")
                else:
                    tar.extractall(path=tmpdir)
        except Exception as e:
            die(f"failed to extract archive: {e}")

        extracted_folders = [p for p in Path(tmpdir).iterdir() if p.is_dir()]
        if not extracted_folders:
            die("archive did not contain an extracted folder")
        src_folder = extracted_folders[0]

        dest_base.parent.mkdir(parents=True, exist_ok=True)
        if dest_base.exists():
            import shutil

            shutil.rmtree(dest_base)

        os.rename(src_folder, dest_base)

    meta_file.parent.mkdir(parents=True, exist_ok=True)
    with open(meta_file, "w", encoding="utf-8") as f:
        f.write(str(time.time()))

    src_skill_md = target_dir / "SKILL.md"
    if src_skill_md.is_file():
        catalog_skill_dir = get_catalog_dir() / name
        catalog_skill_dir.mkdir(parents=True, exist_ok=True)
        import shutil

        shutil.copy(src_skill_md, catalog_skill_dir / "SKILL.md")

    return str(target_dir)


def fetch_skill_md(
    name: str, repo: str, ref: str, subpath: str | None, force: bool = False
) -> None:
    catalog_skill_dir = get_catalog_dir() / name
    stub_md = catalog_skill_dir / "SKILL.md"
    meta_file = get_catalog_dir() / ".meta" / name

    if not force and stub_md.is_file() and meta_file.is_file():
        if (time.time() - meta_file.stat().st_mtime) < CATALOG_TTL:
            return

    sub_part = f"/{subpath}" if subpath else ""
    url = f"https://raw.githubusercontent.com/{repo}/{ref}{sub_part}/SKILL.md"
    catalog_skill_dir.mkdir(parents=True, exist_ok=True)
    meta_file.parent.mkdir(parents=True, exist_ok=True)

    try:
        req = urllib.request.Request(
            url, headers={"User-Agent": "Antigravity-Skill-Manager/1.0"}
        )
        with urllib.request.urlopen(req, timeout=15) as response:
            content = response.read().decode("utf-8")
        with open(stub_md, "w", encoding="utf-8") as f:
            f.write(content)
        with open(meta_file, "w", encoding="utf-8") as f:
            f.write(str(time.time()))
    except Exception as e:
        print(
            f"skill: warning: failed to fetch metadata for '{name}': {e}",
            file=sys.stderr,
        )


def load_skill_md_frontmatter(content: str) -> dict:
    """Parses a simple YAML frontmatter block from a SKILL.md file string."""
    meta = {}
    lines = content.strip().splitlines()
    if not lines or lines[0] != "---":
        return meta

    current_key = None
    multiline_val = []

    for line in lines[1:]:
        if line == "---":
            break

        stripped = line.strip()
        if not line.startswith(" ") and ":" in line:
            if current_key and multiline_val:
                meta[current_key] = " ".join(multiline_val).strip().strip("'\"")
                multiline_val = []

            key, val = line.split(":", 1)
            current_key = key.strip()
            val_str = val.strip()

            if val_str in (">", "|", ">-", "|-"):
                multiline_val = []
            else:
                meta[current_key] = val_str.strip().strip("'\"")
                current_key = None
        elif current_key is not None:
            if line.startswith(" ") or not line:
                multiline_val.append(stripped)
            else:
                meta[current_key] = " ".join(multiline_val).strip().strip("'\"")
                current_key = None
                multiline_val = []

    if current_key and multiline_val:
        meta[current_key] = " ".join(multiline_val).strip().strip("'\"")

    return meta


def get_skill_metadata(skill_dir: Path, default_name: str) -> dict:
    """Reads SKILL.md in the given directory and returns its frontmatter metadata."""
    skill_md = skill_dir / "SKILL.md"
    if not skill_md.is_file():
        return {"name": default_name, "description": ""}
    try:
        with open(skill_md, "r", encoding="utf-8", errors="replace") as f:
            content = f.read()
        meta = load_skill_md_frontmatter(content)
        return {
            "name": meta.get("name") or default_name,
            "description": meta.get("description") or "",
        }
    except Exception:
        return {"name": default_name, "description": ""}


def ensure_catalog_index(plugin_catalog, force: bool = False) -> None:
    """Ensures all plugin catalog stubs are downloaded and cached."""
    for name, entry in plugin_catalog.items():
        if name.startswith("local:"):
            continue
        if "repo" in entry and "ref" in entry:
            fetch_skill_md(
                name, entry["repo"], entry["ref"], entry["subpath"], force=force
            )
        elif "path" in entry:
            catalog_dir = get_catalog_dir()
            stub_dir = catalog_dir / name
            stub_md = stub_dir / "SKILL.md"
            src_path = Path(entry["path"]).expanduser()
            src_md = src_path / "SKILL.md"
            if src_md.is_file():
                if not stub_dir.is_dir():
                    stub_dir.mkdir(parents=True, exist_ok=True)
                if not stub_md.is_symlink() and not stub_md.exists():
                    try:
                        stub_md.symlink_to(src_md)
                    except Exception:
                        pass
                elif force or (
                    stub_md.is_symlink() and stub_md.resolve() != src_md.resolve()
                ):
                    stub_md.unlink(missing_ok=True)
                    try:
                        stub_md.symlink_to(src_md)
                    except Exception:
                        pass


class SkillAPI:
    """Unified API surface passed to a plugin's register() function."""

    Workspace = Workspace
    FileStateMixin = FileStateMixin

    def __init__(self):
        self.workspace_classes = []
        self.plugin_catalog = {}
        self.all_registrations = []
        self.load_failures = []

    def register_workspace(self, cls):
        self.workspace_classes.append(cls)

    def register_skill(self, name, spec):
        if isinstance(spec, str):
            if spec.startswith("https://github.com/") or spec.startswith(
                "http://github.com/"
            ):
                repo, ref, subpath = parse_github_url(spec)
                spec = {"repo": repo, "ref": ref, "subpath": subpath}
            else:
                raise ValueError(
                    f"Skill '{name}': string spec must be a GitHub URL, got '{spec}'"
                )

        if not isinstance(spec, dict):
            raise ValueError(
                f"Skill '{name}': spec must be a dictionary or a GitHub URL string, got {type(spec).__name__}"
            )

        spec = dict(spec)

        if "path" in spec:
            if any(k in spec for k in ("repo", "ref", "subpath")):
                raise ValueError(
                    f"Skill '{name}': 'path' cannot be mixed with GitHub parameters."
                )
            spec["path"] = os.path.expanduser(spec["path"])
        elif "repo" in spec and "ref" in spec:
            spec.setdefault("subpath", None)
        else:
            raise ValueError(
                f"Skill '{name}': spec must contain either 'path' or both 'repo' and 'ref'."
            )

        if getattr(self, "current_plugin_file", None):
            spec["plugin_file"] = self.current_plugin_file
        self.plugin_catalog[name] = spec
        self.all_registrations.append((name, spec))


_LOADED_API = None


def get_api() -> SkillAPI:
    global _LOADED_API
    if _LOADED_API is None:
        _LOADED_API = load_plugins()
    return _LOADED_API


def load_plugins() -> SkillAPI:
    import importlib.util

    api = SkillAPI()
    plugins_dir = (
        Path(os.environ.get("XDG_CONFIG_HOME") or "~/.config").expanduser()
        / "skill"
        / "plugins"
    )
    if not plugins_dir.is_dir():
        return api

    for filepath in sorted(plugins_dir.glob("*.py")):
        module_name = f"skill_plugin_{filepath.stem}"
        try:
            spec = importlib.util.spec_from_file_location(module_name, filepath)
            if spec and spec.loader:
                module = importlib.util.module_from_spec(spec)
                sys.modules[module_name] = module
                spec.loader.exec_module(module)
                if hasattr(module, "register"):
                    api.current_plugin_file = filepath.name
                    module.register(api)
                    api.current_plugin_file = None
        except Exception as e:
            api.load_failures.append((filepath.name, str(e)))
            print(
                f"skill: warning: failed to load plugin {filepath}: {e}",
                file=sys.stderr,
            )
            if os.environ.get("SKILL_DEBUG") == "1":
                import traceback

                traceback.print_exc(file=sys.stderr)
    return api


def get_workspace() -> Workspace:
    api = get_api()
    for cls in api.workspace_classes + [GitWorkspace]:
        try:
            ws = cls.detect()
        except Exception as e:
            print(
                f"skill: warning: workspace detector {cls.__name__} failed: {e}",
                file=sys.stderr,
            )
            continue
        if ws:
            return ws
    return DefaultWorkspace(Path.cwd())


# ==============================================================================
# CLI Command Implementations
# ==============================================================================


def resolve_skill_spec(spec: str) -> tuple[Path, str]:
    """Resolves a skill spec/name to its (absolute_source_path, skill_name)."""
    api = get_api()

    # 1. Parse the requested spec for namespace
    req_ns = None
    req_name = spec
    if ":" in spec:
        req_ns, req_name = spec.split(":", 1)

    # We will gather all candidates as dicts: {"path": Path, "namespace": str, "name": str, "full_spec": str}
    candidates = []

    # Scan registered plugins (api.plugin_catalog)
    for key, entry in api.plugin_catalog.items():
        # Parse registered key
        ns = "local"
        short_name = key
        if ":" in key:
            ns, short_name = key.split(":", 1)

        # Check if the short name matches
        if short_name.lower() == req_name.lower():
            if "path" in entry:
                target_path = Path(entry["path"]).expanduser()
                if target_path.is_dir():
                    should_resolve = entry.get("resolve", True)
                    resolved_path = (
                        Path(os.path.realpath(target_path))
                        if should_resolve
                        else target_path
                    )
                    candidates.append(
                        {
                            "path": resolved_path,
                            "namespace": ns,
                            "name": short_name,
                            "full_spec": key,
                            "is_remote": False,
                        }
                    )
            elif "repo" in entry and "ref" in entry:
                candidates.append(
                    {
                        "entry": entry,
                        "namespace": ns,
                        "name": short_name,
                        "full_spec": key,
                        "is_remote": True,
                    }
                )

    # Filter candidates by namespace if one was requested
    if req_ns:
        filtered = [c for c in candidates if c["namespace"].lower() == req_ns.lower()]
        if not filtered:
            raise ValueError(
                f"cannot resolve skill '{spec}': no match in namespace '{req_ns}'"
            )
        candidates = filtered

    # No namespace requested
    if not candidates:
        raise ValueError(f"cannot resolve skill '{spec}'")

    if len(candidates) > 1:
        non_remote = [c for c in candidates if not c.get("is_remote", False)]
        if non_remote:
            candidates = non_remote

    # Now resolve paths for remaining candidates
    unique_candidates = []
    seen_paths = set()
    for c in candidates:
        if c.get("is_remote", False):
            entry = c["entry"]
            try:
                target_dir_str = fetch_github(
                    c["full_spec"], entry["repo"], entry["ref"], entry.get("subpath")
                )
                target_path = Path(target_dir_str)
                if target_path.is_dir():
                    path_obj = Path(os.path.realpath(target_path))
                    if path_obj not in seen_paths:
                        seen_paths.add(path_obj)
                        c["path"] = path_obj
                        unique_candidates.append(c)
            except (Exception, SystemExit):
                # fetch_github() reports fatal errors (network failure, repo
                # not found) via die(), which raises SystemExit rather than a
                # normal exception. Catching only Exception would let that
                # propagate out of resolve_skill_spec() and kill the whole
                # process (including 'skill doctor', which must keep
                # rendering the rest of its checks). die() already printed
                # the underlying error to stderr; treat this candidate as
                # simply unavailable and let resolution fall through to the
                # ordinary "cannot resolve skill" error below.
                pass
        else:
            if c["path"] not in seen_paths:
                seen_paths.add(c["path"])
                unique_candidates.append(c)

    if not unique_candidates:
        raise ValueError(f"cannot resolve skill '{spec}'")

    if len(unique_candidates) == 1:
        return unique_candidates[0]["path"], unique_candidates[0]["name"]

    # Multiple matches found - raise ambiguity error!
    options = ", ".join(c["full_spec"] for c in unique_candidates)
    raise ValueError(
        f"Ambiguous skill spec '{spec}'. Multiple matches found: {options}. "
        f"Please specify the namespace (e.g. {unique_candidates[0]['full_spec']}) to disambiguate."
    )


def rel_to(root: Path, p: Path):
    """Best-effort path relative to root, falling back to the absolute path."""
    try:
        return p.relative_to(root)
    except ValueError:
        return p


# =============================================================================
# Shared reconciliation planner
#
# 'doctor' and 'apply' used to reconstruct "what should be true" independently
# -- each re-derived skill identity, catalog resolution, target matching,
# dangling/extra-symlink state, and the destructive-action safety policy. That
# produced a recurring class of bug: doctor would detect a condition apply's
# separate logic did not handle (or vice versa), so 'skill apply' followed by
# 'skill doctor' would not converge. build_reconcile_plan() is now the single
# definition of the desired-vs-actual comparison: 'doctor' renders it read-only
# and 'apply' executes the permitted actions from the same plan, so the two can
# no longer disagree by construction.
# =============================================================================


class ResolvedSkill:
    """A declared skill spec resolved (or not) against the catalog.

    A read-facing view over resolve_skill_spec(): resolution failures are
    captured as a typed 'error' instead of raising, so doctor and apply share
    one resolution path and neither can crash on a spec the other tolerates.

    (Deliberately a plain class, not a @dataclass: this module is loaded by the
    test suite via SourceFileLoader without registering it in sys.modules, and
    dataclasses' string-annotation handling -- forced by 'from __future__ import
    annotations' -- crashes when it cannot look the module up there.)
    """

    def __init__(self, spec, source_path=None, link_name=None, error=None):
        self.spec = spec  # the declared token, e.g. "coding-standards", "foo:bar"
        self.source_path = source_path  # absolute resolved source directory
        self.link_name = link_name  # canonical symlink basename (source's name)
        self.error = error  # resolution error, None when resolved

    @property
    def resolved(self) -> bool:
        return self.source_path is not None


class DiskEntry:
    """A symlink found in a destination directory."""

    def __init__(self, dest, link_name, path, kind, target, tracked):
        self.dest = dest  # the destination directory containing the link
        self.link_name = link_name  # the symlink's basename
        self.path = path  # dest / link_name
        self.kind = kind  # "live" (target exists) or "dangling" (target missing)
        self.target = target  # absolute symlink target, when readable
        self.tracked = tracked  # whether the link is VCS-tracked


class ReconcilePlan:
    """The desired-vs-actual comparison shared by doctor and apply."""

    def __init__(
        self,
        ws,
        dest_dirs,
        expected_skills,
        resolved,
        expected_targets,
        disk_entries,
        unmanaged,
        missing,
        mismatched,
        extra,
        negated_extra,
        stray_dangling,
        tracked_dangling,
        freshness,
        stale,
        destructive_blocked,
    ):
        self.ws = ws
        self.dest_dirs = dest_dirs  # [] when no agent destination is configured
        self.expected_skills = expected_skills  # declared specs
        self.resolved = resolved  # list[ResolvedSkill], one per declared spec
        self.expected_targets = expected_targets  # abs source Path -> spec
        self.disk_entries = disk_entries  # list[DiskEntry] for every symlink
        self.unmanaged = unmanaged  # non-symlink artifacts in skill dirs
        self.missing = missing  # doctor labels: declared, resolvable, not linked
        self.mismatched = mismatched  # doctor labels: linked to the wrong source
        self.extra = extra  # link basenames present but not declared
        self.negated_extra = negated_extra  # link basenames negated in the env
        self.stray_dangling = stray_dangling  # broken links apply may prune
        self.tracked_dangling = tracked_dangling  # broken links apply won't touch
        self.freshness = freshness  # check_env_freshness() result or None
        self.stale = stale  # environment is a stale cache of .envrc
        self.destructive_blocked = destructive_blocked  # unlink is unsafe now

    @property
    def unresolved(self) -> list:
        return [r for r in self.resolved if not r.resolved]

    @property
    def prune_names(self) -> list:
        """Link basenames apply removes when destructive actions are permitted.

        Both genuinely-extra links and stale negated links are pruned; they are
        reported under different doctor headings but share one remediation.
        """
        return self.extra + self.negated_extra

    def has_fixable_findings(self) -> bool:
        """True when a non-advisory finding remains that apply should have
        resolved. Unresolvable specs and VCS-tracked dangling links are
        advisory (apply cannot fix them), and extra links held back by the
        destructive-action policy are intentionally left in place, so none of
        those count here."""
        if self.missing or self.mismatched or self.stray_dangling:
            return True
        if not self.destructive_blocked and (self.extra or self.negated_extra):
            return True
        return False


def resolve_reconcile_skill(spec: str) -> ResolvedSkill:
    """Resolve one declared spec into a ResolvedSkill, capturing any failure as
    a typed error rather than raising. This is the single resolution entry point
    the planner uses so doctor and apply classify specs identically."""
    try:
        src_path, _name = resolve_skill_spec(spec)
        return ResolvedSkill(
            spec=spec,
            source_path=Path(os.path.abspath(src_path)),
            link_name=src_path.name,
        )
    except Exception as e:
        return ResolvedSkill(spec=spec, error=str(e))


def build_reconcile_plan(ws) -> ReconcilePlan:
    """Compute the single desired-vs-actual comparison for a workspace.

    This is the shared definition of convergence: every fact doctor renders and
    every action apply performs about skill symlinks is derived here, so the two
    commands cannot drift apart.
    """
    expected_skills = ws.get_expected_skills()
    _, negated_skills = get_parsed_skills()
    negated_lower = {n.lower() for n in negated_skills}

    try:
        dest_dirs = ws.get_dest_dirs()
    except RuntimeError:
        dest_dirs = []

    # Resolve declared specs once. link_name is chosen here (the source's
    # basename) so identity is fixed at resolution time rather than rederived
    # from physical basenames at every comparison site.
    resolved = [resolve_reconcile_skill(spec) for spec in expected_skills]
    expected_targets: dict = {}
    for r in resolved:
        if r.resolved:
            expected_targets[r.source_path] = r.spec
    # Link basenames a resolved spec will (re)create via cmd_add. A wrong-target
    # link that cmd_add overwrites in place is a mismatch it re-links, not an
    # extra to prune -- excluding it here is what lets doctor report it under
    # "mismatched" while apply re-links it, instead of the two disagreeing about
    # whether to delete it. Only *resolved* specs count: a link named after an
    # unresolvable spec is still genuinely extra (nothing will recreate it),
    # which is the Test 67 safety case.
    resolved_links = [r.link_name for r in resolved if r.resolved]

    def overwritten_by_add(link_path: Path, dest: Path) -> bool:
        """True when cmd_add's canonical write (dest/<resolved link_name>) hits
        the same on-disk entry as link_path. Compared structurally so the
        filesystem's own case rules decide: a lowercased-name comparison would
        treat a case-variant link ('Good' vs canonical 'good') as the same entry
        on a case-sensitive filesystem, leaving the undeclared link in place
        while the recomputed plan wrongly reports convergence. lstat (not stat)
        avoids following the symlink, so two distinct links to one target are
        not conflated."""
        for ln in resolved_links:
            canonical = dest / ln
            try:
                if os.path.samestat(link_path.lstat(), canonical.lstat()):
                    return True
            except OSError:
                # canonical does not exist yet (cmd_add has not run): only an
                # exact-name write would land on this entry.
                if link_path.name == ln:
                    return True
        return False

    actual_skills, unmanaged, dangling_paths = ws.get_actual_skills()

    # One DiskEntry per symlink on disk -- the single scan both the extra and
    # dangling findings are derived from.
    disk_entries: list = []
    for name in sorted(actual_skills):
        for d in dest_dirs:
            p = d / name
            if not p.is_symlink():
                continue
            try:
                target = os.readlink(p)
                target_abs = Path(os.path.abspath(p.parent / target))
            except OSError:
                target_abs = None
            # 'tracked' is only consulted for dangling entries (to keep
            # checked-in broken links out of the prune set). A live link's
            # tracked state is never read, so skip the per-link 'git ls-files'
            # subprocess that ws.is_tracked() would spawn -- otherwise a
            # workspace with N links across M destinations pays N*M git
            # processes on every plan build (twice per apply, once per
            # preflight), all of it discarded.
            disk_entries.append(DiskEntry(d, name, p, "live", target_abs, False))
    for item in dangling_paths:
        disk_entries.append(
            DiskEntry(
                item.parent, item.name, item, "dangling", None, ws.is_tracked(item)
            )
        )

    stray_dangling = [
        e.path for e in disk_entries if e.kind == "dangling" and not e.tracked
    ]
    tracked_dangling = [
        e.path for e in disk_entries if e.kind == "dangling" and e.tracked
    ]

    # Extra vs. negated classification, from the same disk scan.
    extra: list = []
    negated_extra: list = []
    for e in disk_entries:
        if e.kind != "live" or e.target is None or e.target in expected_targets:
            continue
        s = e.link_name
        if s.lower() in negated_lower:
            if s not in negated_extra:
                negated_extra.append(s)
        elif not overwritten_by_add(e.path, e.dest):
            if s not in extra:
                extra.append(s)

    # Missing / mismatched alignment for resolvable specs. Labels are formatted
    # here so doctor and apply's post-apply verification agree on the finding.
    missing: list = []
    mismatched: list = []
    for r in resolved:
        if not r.resolved:
            continue
        if not dest_dirs:
            missing.append(r.spec)
            continue
        for d in dest_dirs:
            p = d / r.link_name
            if not p.is_symlink():
                label = (
                    f"{r.spec} (missing in {rel_to(ws.root, d)})"
                    if len(dest_dirs) > 1
                    else r.spec
                )
                if label not in missing:
                    missing.append(label)
            else:
                target = os.readlink(p)
                target_abs = Path(os.path.abspath(p.parent / target))
                if target_abs != r.source_path:
                    label = (
                        f"{r.spec} (linked to {clean_p(target_abs)}, expected {clean_p(r.source_path)})"
                        if len(dest_dirs) > 1
                        else f"{r.spec} in {rel_to(ws.root, d)} (linked to {clean_p(target_abs)}, expected {clean_p(r.source_path)})"
                    )
                    if label not in mismatched:
                        mismatched.append(label)

    # Destructive-action policy. Pruning extra links is unsafe when the desired
    # set is untrustworthy: either the environment is a stale cache of .envrc,
    # or a declared spec failed to resolve (so an existing live link for it
    # would look indistinguishable from a genuinely extra one). Neither gates
    # the dangling prune, which is always safe.
    freshness = check_env_freshness(ws)
    stale = freshness is not None and bool(freshness[0] or freshness[1])
    destructive_blocked = stale or any(not r.resolved for r in resolved)

    return ReconcilePlan(
        ws=ws,
        dest_dirs=dest_dirs,
        expected_skills=expected_skills,
        resolved=resolved,
        expected_targets=expected_targets,
        disk_entries=disk_entries,
        unmanaged=unmanaged,
        missing=missing,
        mismatched=mismatched,
        extra=extra,
        negated_extra=negated_extra,
        stray_dangling=stray_dangling,
        tracked_dangling=tracked_dangling,
        freshness=freshness,
        stale=stale,
        destructive_blocked=destructive_blocked,
    )


def is_using_envrc(ws) -> bool:
    """Checks if the workspace is using direnv or has a local .envrc file."""
    return "DIRENV_DIR" in os.environ or (ws.root / ".envrc").is_file()


def cmd_add(specs, is_apply=False):
    if not specs:
        cmderr("add", "skill name required")
    if len(specs) == 1 and specs[0] == "-":
        specs = sys.stdin.read().split()
        if not specs:
            return

    ws = get_workspace()
    try:
        dest_dirs = ws.get_dest_dirs()
    except RuntimeError as e:
        cmderr("add", str(e))

    if not is_apply:
        print_workspace_root(ws)

    resolved_skills = []
    has_errors = False
    for spec in specs:
        try:
            src_path, name = resolve_skill_spec(spec)
            resolved_skills.append((src_path, name))
        except Exception as e:
            print(f"skill: error: failed to resolve '{spec}': {e}", file=sys.stderr)
            has_errors = True
            continue

    # Check for conflicts across all destinations first
    for src, name in resolved_skills:
        for d in dest_dirs:
            # UNIQUENESS CONSTRAINT:
            # We create the symlink using the target directory's basename (src.name)
            # rather than the registered name (which can be anything, e.g., wear-vcs).
            # This decouples the namespacing/lookup name from the actual symlink,
            # but implies that all installed skills in a workspace must have unique
            # directory basenames to avoid name collisions in .agents/skills/.
            link_name = src.name
            relpath = d / link_name
            conflict = ws.check_conflict(relpath)
            if conflict:
                cmderr("add", conflict)
            if relpath.exists() and not relpath.is_symlink():
                cmderr(
                    "add",
                    f"{relpath} exists and is not a symlink; refusing to overwrite",
                )

    # Apply symlinks
    for src, name in resolved_skills:
        for d in dest_dirs:
            link_name = src.name
            relpath = d / link_name
            d.mkdir(parents=True, exist_ok=True)

            # Atomic symlink replacement (concurrency-safe swap)
            tmp_link = relpath.with_name(f".{relpath.name}.tmp-{os.getpid()}")
            tmp_link.unlink(missing_ok=True)
            try:
                tmp_link.symlink_to(src)
                os.replace(tmp_link, relpath)
            except Exception:
                tmp_link.unlink(missing_ok=True)
                raise
        print(f"added {name} -> {src}", file=sys.stderr)

    if resolved_skills and not is_apply:
        names = " ".join(name for _, name in resolved_skills)
        if is_using_envrc(ws):
            print(
                f"skill: note: to make this permanent, run: envrc add skills {names}",
                file=sys.stderr,
            )
        else:
            print(
                f"skill: note: to make this permanent, add '{names}' to the AGENT_REQUIRED_SKILLS environment variable",
                file=sys.stderr,
            )

    # Re-sync exclude block for the active set of skills on disk
    actual_skills, _, _ = ws.get_actual_skills()
    if hasattr(ws, "save_exclude_block"):
        ws.save_exclude_block(actual_skills)
    if hasattr(ws, "save_managed_skills"):
        ws.save_managed_skills(list(actual_skills))

    if has_errors:
        if is_apply:
            return False
        sys.exit(1)
    return True


def cmd_remove(names, announce=True):
    if not names:
        cmderr("remove", "skill name required")

    ws = get_workspace()
    try:
        dest_dirs = ws.get_dest_dirs()
    except RuntimeError as e:
        cmderr("remove", str(e))

    if announce:
        print_workspace_root(ws)

    for arg in names:
        # Try to resolve to find the physical target's basename
        link_name = arg
        try:
            src, _ = resolve_skill_spec(arg)
            link_name = src.name
        except Exception:
            # Fallback to direct name if it cannot be resolved (e.g. if plugin is disabled)
            link_name = os.path.basename(arg)

        removed = False
        for d in dest_dirs:
            relpath = d / link_name
            if ws.is_tracked(relpath):
                continue
            if relpath.is_symlink() or relpath.exists():
                relpath.unlink(missing_ok=True)
                removed = True

        if removed:
            print(f"removed {link_name}", file=sys.stderr)
        else:
            print(f"remove: {link_name} not present; clearing record", file=sys.stderr)

    # Re-sync exclude block
    actual_skills, _, _ = ws.get_actual_skills()
    if hasattr(ws, "save_exclude_block"):
        ws.save_exclude_block(actual_skills)
    if hasattr(ws, "save_managed_skills"):
        ws.save_managed_skills(list(actual_skills))
    prune_dirs(dest_dirs)


def resolve_installed(ws):
    """Returns [(name, resolved_target_path_or_None)] for active skills."""
    try:
        dest_dirs = ws.get_dest_dirs()
    except RuntimeError:
        return []
    actual_skills, _, _ = ws.get_actual_skills()
    resolved = []
    for name in sorted(actual_skills):
        target = None
        for d in dest_dirs:
            p = d / name
            if p.is_symlink():
                try:
                    candidate = (p.parent / p.readlink()).resolve()
                    if candidate.exists():
                        target = candidate
                        break
                except Exception:
                    pass
        resolved.append((name, target))
    return resolved


def cmd_list(args):
    as_json = "--json" in args
    ws = get_workspace()
    resolved_skills = resolve_installed(ws)

    if as_json:
        print(
            json.dumps(
                [
                    {"name": name, "path": str(target) if target else None}
                    for name, target in resolved_skills
                ]
            )
        )
        return

    if resolved_skills:
        max_len = max(len(name) for name, _ in resolved_skills)
        for name, target in resolved_skills:
            if target:
                print(f"{name.ljust(max_len)} -> {clean_p(target)}")
            else:
                print(name)


def cmd_clean():
    ws = get_workspace()
    try:
        dest_dirs = ws.get_dest_dirs()
    except RuntimeError as e:
        cmderr("clean", str(e))

    print_workspace_root(ws)

    actual_skills, _, _ = ws.get_actual_skills()

    any_dir = any(d.is_dir() for d in dest_dirs)
    if not actual_skills and not any_dir:
        print("clean: nothing to do", file=sys.stderr)
        return

    removed = 0
    left = 0
    for name in actual_skills:
        for d in dest_dirs:
            relpath = d / name
            if relpath.is_symlink():
                relpath.unlink(missing_ok=True)
                removed += 1
                print(f"removed {relpath.relative_to(ws.root)}", file=sys.stderr)
            elif relpath.exists():
                print(
                    f"clean: {relpath.relative_to(ws.root)} is not a symlink; leaving it in place",
                    file=sys.stderr,
                )
                left += 1

    if hasattr(ws, "save_exclude_block"):
        ws.save_exclude_block([])
    if hasattr(ws, "save_managed_skills"):
        ws.save_managed_skills([])
    prune_dirs(dest_dirs)
    print(f"clean: removed {removed} link(s); cleared git excludes", file=sys.stderr)
    if left > 0:
        print(f"clean: {left} path(s) left in place (not symlinks)", file=sys.stderr)


def cmd_update(names):
    if not names:
        cmderr("update", "skill name, --all, or --catalog required")

    api = get_api()

    def update_catalog_entry(name, entry):
        if "repo" in entry:
            fetch_github(
                name, entry["repo"], entry["ref"], entry["subpath"], force=True
            )
        elif entry.get("generated"):
            print(
                f"skill update: '{name}' is generated; refreshed by plugin loader",
                file=sys.stderr,
            )
        else:
            print(
                f"skill update: '{name}' is a local skill; nothing to update",
                file=sys.stderr,
            )

    if len(names) == 1 and names[0] == "--catalog":
        print("skill: refreshing catalog metadata index...", file=sys.stderr)
        ensure_catalog_index(api.plugin_catalog, force=True)
        print("catalog: metadata index updated", file=sys.stderr)
        return

    if len(names) == 1 and names[0] == "--all":
        # Update all registered plugins in the catalog
        for name, entry in api.plugin_catalog.items():
            update_catalog_entry(name, entry)
        return

    # Update specific skill names
    for name in names:
        if name in api.plugin_catalog:
            update_catalog_entry(name, api.plugin_catalog[name])
        else:
            print(f"skill update: unknown skill '{name}'", file=sys.stderr)


def parse_skill_tokens(tokens):
    """
    Folds a list of skill tokens ('name', '-name', '!name') into
    (required_set, negated_set) — the same mini-language AGENT_REQUIRED_SKILLS
    uses, applied to any token source.
    """
    required_set = []
    negated_set = []
    for spec in tokens:
        if spec.startswith("-") or spec.startswith("!"):
            clean_name = spec[1:]
            negated_set.append(clean_name.lower())
            required_set = [
                req for req in required_set if req.lower() != clean_name.lower()
            ]
        else:
            if spec not in required_set:
                required_set.append(spec)
    return required_set, negated_set


def get_parsed_skills():
    """
    Parses AGENT_REQUIRED_SKILLS from environment.
    Returns a tuple: (required_set, negated_set)
    """
    return parse_skill_tokens(os.environ.get("AGENT_REQUIRED_SKILLS", "").split())


ENVRC_SKILLS_MARK_BEGIN = "# >>> envrc managed block: skills >>>"
ENVRC_SKILLS_MARK_END = "# <<< envrc managed block: skills <<<"
ENVRC_LEGACY_EXPORT_RE = re.compile(
    r'^export\s+AGENT_REQUIRED_SKILLS="\$AGENT_REQUIRED_SKILLS([^"]*)"$'
)


def read_envrc_declared_skills(ws):
    """Statically read the skill tokens declared in the workspace's .envrc
    managed skills block (written by 'envrc'), without executing any shell.

    Returns the token list, or None when there is nothing trustworthy to read:
    no .envrc, no managed block, or block content the parser does not
    recognize. The freshness check built on this is advisory, so it must never
    guess.
    """
    envrc = ws.root / ".envrc"
    if not envrc.is_file():
        return None
    try:
        lines = envrc.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return None
    in_block = False
    found = False
    tokens = []
    for line in lines:
        stripped = line.strip()
        if stripped == ENVRC_SKILLS_MARK_BEGIN:
            in_block = True
            found = True
            continue
        if stripped == ENVRC_SKILLS_MARK_END:
            in_block = False
            continue
        if not in_block or not stripped or stripped.startswith("#"):
            continue
        if stripped == "skills" or stripped.startswith("skills "):
            tokens.extend(stripped.split()[1:])
            continue
        m = ENVRC_LEGACY_EXPORT_RE.match(stripped)
        if m:
            tokens.extend(m.group(1).split())
            continue
        return None
    if not found:
        return None
    return tokens


def check_env_freshness(ws):
    """Compare the skills declared in .envrc's managed block against the
    inherited AGENT_REQUIRED_SKILLS (the source of truth skill acts on).

    Returns None when there is nothing to compare, else a tuple
    (declared_but_missing, negated_but_still_present): names the block adds
    that the environment does not reflect, and names the block negates that
    the environment still contains. Either being non-empty means the
    environment is a stale cache of the .envrc (direnv has not reloaded yet).

    The detection is deliberately one-directional: the reverse (a name in the
    environment that the block no longer mentions) is unjudgeable, because the
    base layer (global defaults) cannot be observed separately. The result is
    advisory only — callers may warn or decline destructive work, but must
    never merge it into the desired set.
    """
    tokens = read_envrc_declared_skills(ws)
    if tokens is None:
        return None
    decl_required, decl_negated = parse_skill_tokens(tokens)
    env_required, _ = get_parsed_skills()
    env_lower = {r.lower() for r in env_required}
    missing = [d for d in decl_required if d.lower() not in env_lower]
    stale_negated = []
    for n in decl_negated:
        if n in env_lower and n not in stale_negated:
            stale_negated.append(n)
    return missing, stale_negated


def cmd_apply(args):
    ws = get_workspace()
    print_workspace_root(ws)

    # One shared comparison drives the whole command: doctor renders this same
    # plan read-only, so any condition doctor reports is one apply acts on here.
    plan = build_reconcile_plan(ws)
    expected_skills = plan.expected_skills

    # Prune dangling symlinks (their target no longer exists) unconditionally,
    # even when AGENT_REQUIRED_SKILLS is empty: a broken link is never a
    # legitimate desired state regardless of what (if anything) is declared, so
    # this must not be gated behind having something to reconcile against. It
    # also needs no freshness interlock like the extra-symlink prune below:
    # resolve_skill_spec only ever returns paths that exist, so a broken link
    # can never coincide with a legitimately expected-but-not-yet-declared
    # target. VCS-tracked broken links are checked-in content, not stray install
    # artifacts, so the plan keeps them out of stray_dangling.
    for item in plan.stray_dangling:
        print(
            f"skill: pruning dangling symlink: '{rel_to(ws.root, item)}'",
            file=sys.stderr,
        )
        item.unlink(missing_ok=True)

    if not expected_skills:
        print(
            "skill: AGENT_REQUIRED_SKILLS is empty. No skills to apply.",
            file=sys.stderr,
        )
        print(
            "To discover recommended skills for this workspace, run 'skill suggest'.",
            file=sys.stderr,
        )
        return

    print(
        f"skill: synchronizing workspace skills to match AGENT_REQUIRED_SKILLS: {' '.join(expected_skills)}",
        file=sys.stderr,
    )

    # Deterministic Local Sync:
    # 1. Resolve and add/symlink all expected skills
    add_ok = cmd_add(expected_skills, is_apply=True)

    # 2. Prune any actual symlinks on disk that are NOT expected target paths.
    if not plan.dest_dirs:
        sys.exit(0 if add_ok else 1)

    extra_skills = plan.prune_names
    unresolved_specs = [r.spec for r in plan.unresolved]

    # cmd_add() re-resolves every spec, so add_ok is a fresher signal than the
    # plan built before it: if a source vanished or a resolver changed between
    # plan-build and the add, add_ok is False even though the plan's
    # destructive_blocked (computed from the earlier resolution) is not. The
    # "any unresolved desired spec blocks destructive actions" policy must honor
    # that fresher signal -- otherwise pruning would delete links using a stale
    # desired set on the same run that add is about to fail on.
    if extra_skills:
        if plan.destructive_blocked or not add_ok:
            # Freshness interlock: when .envrc declares changes the environment
            # does not reflect yet, or a declared spec cannot be resolved, the
            # desired set we are about to enforce is untrustworthy. Do less, not
            # different: skip the destructive prune and tell the human how to
            # recover. (Adding symlinks above is harmless and proceeds
            # regardless.)
            if plan.stale:
                fresh_missing, fresh_negated = plan.freshness
                reasons = []
                if fresh_missing:
                    reasons.append(
                        f".envrc declares {', '.join(repr(s) for s in fresh_missing)} "
                        "not reflected in AGENT_REQUIRED_SKILLS"
                    )
                if fresh_negated:
                    reasons.append(
                        f".envrc negates {', '.join(repr(s) for s in fresh_negated)} "
                        "still present in AGENT_REQUIRED_SKILLS"
                    )
                print(
                    f"skill: environment looks stale for this workspace: {'; '.join(reasons)}",
                    file=sys.stderr,
                )
            if unresolved_specs:
                # A spec that fails to resolve is missing from expected_targets
                # entirely, so any existing live link that happens to share its
                # name would otherwise look indistinguishable from a genuinely
                # extra symlink and get deleted. The desired set is incomplete,
                # not wrong, so treat pruning as unsafe until it resolves.
                print(
                    "skill: cannot fully resolve the desired skill set: "
                    f"{', '.join(repr(s) for s in unresolved_specs)} failed to "
                    "resolve against the catalog",
                    file=sys.stderr,
                )
            print(
                f"skill: not pruning {len(extra_skills)} extra symlink(s) while the "
                + (
                    "environment is stale; run 'direnv reload' (or start a new "
                    "prompt), then re-run 'skill apply'"
                    if plan.stale
                    else "desired set is incomplete; fix the unresolvable "
                    "declaration(s) above, then re-run 'skill apply'"
                ),
                file=sys.stderr,
            )
        else:
            for s in extra_skills:
                print(
                    f"skill: pruning extra symlink not in AGENT_REQUIRED_SKILLS: '{s}'",
                    file=sys.stderr,
                )
            names = " ".join(extra_skills)
            if is_using_envrc(ws):
                print(
                    f"skill: to keep any of them, run: envrc add skills {names}",
                    file=sys.stderr,
                )
            else:
                print(
                    f"skill: to keep any of them, add '{names}' to the AGENT_REQUIRED_SKILLS environment variable",
                    file=sys.stderr,
                )
            cmd_remove(extra_skills, announce=False)

    if not add_ok:
        sys.exit(1)

    # Convergence interlock: recompute the plan from the now-mutated disk state
    # and fail if any apply-fixable finding survives. Because doctor renders
    # this same plan, a clean recomputation here is what guarantees the property
    # "apply, then doctor, clears every fixable finding" -- rather than trusting
    # each finding was handled by a matching branch above. Advisory findings
    # (unresolvable specs, tracked dangling links) and extra links intentionally
    # held back by the destructive-action policy do not count.
    if build_reconcile_plan(ws).has_fixable_findings():
        sys.exit(1)


def cmd_preflight(caller_label):
    # AGENT_PREFLIGHT_SKIP is the documented name; _agent_preflight_skip is
    # the legacy spelling, honored indefinitely for old configs.
    if os.environ.get("AGENT_PREFLIGHT_SKIP") or os.environ.get(
        "_agent_preflight_skip"
    ):
        print(
            f"{caller_label}: skill check skipped (AGENT_PREFLIGHT_SKIP set)",
            file=sys.stderr,
        )
        sys.exit(0)

    ws = get_workspace()

    # Retrieve destinations (errors out if no agent is detected)
    try:
        ws.get_dest_dirs()
    except RuntimeError as e:
        print(f"{caller_label}: error in {ws.root}: {e}", file=sys.stderr)
        sys.exit(1)

    is_healthy = cmd_doctor(
        verbose=False, check_catalog=False, stream=sys.stderr, errors_only=True
    )
    if not is_healthy:
        print(
            f"{caller_label}: error: preflight check failed in workspace: {ws.root}",
            file=sys.stderr,
        )
        print(
            f"{caller_label}: to launch anyway: AGENT_PREFLIGHT_SKIP=1 {caller_label}",
            file=sys.stderr,
        )
        sys.exit(1)
    sys.exit(0)


def cmd_resolve(name):
    try:
        src_path, _ = resolve_skill_spec(name)
        print(src_path)
    except Exception as e:
        die(str(e))


def cmd_info(name):
    try:
        src_path, actual_name = resolve_skill_spec(name)
    except Exception as e:
        die(str(e))

    if not src_path.is_dir():
        die(f"resolved path '{src_path}' is not a directory")

    # Get description from metadata helper
    metadata = get_skill_metadata(src_path, actual_name)
    description = (
        metadata.get("description") or "No description found in SKILL.md frontmatter."
    )

    # Gather file metadata (reinstated from history)
    dir_stats = {}
    total_size = 0
    total_files = 0
    root_files = 0
    root_size = 0

    for item in src_path.iterdir():
        if item.is_file():
            if item.name.startswith("."):
                continue
            try:
                sz = item.stat().st_size
                root_files += 1
                root_size += sz
                total_files += 1
                total_size += sz
            except Exception:
                pass
        elif item.is_dir():
            if item.name.startswith(".") or item.name == "__pycache__":
                continue
            files_count = 0
            dir_size = 0
            for root, dirs, files in os.walk(item):
                dirs[:] = [
                    d for d in dirs if not d.startswith(".") and d != "__pycache__"
                ]
                for f in files:
                    if f.startswith("."):
                        continue
                    fpath = Path(root) / f
                    try:
                        sz = fpath.stat().st_size
                        files_count += 1
                        dir_size += sz
                    except Exception:
                        pass
            if files_count > 0:
                dir_stats[item.name] = (files_count, dir_size)
                total_files += files_count
                total_size += dir_size

    if root_files > 0:
        dir_stats["(root)"] = (root_files, root_size)

    def format_size(size_bytes):
        if size_bytes < 1024:
            return f"{size_bytes} B"
        elif size_bytes < 1024 * 1024:
            return f"{size_bytes / 1024:.1f} KB"
        else:
            return f"{size_bytes / (1024 * 1024):.1f} MB"

    print(f"Skill: {actual_name}")
    print(f"Path:  {clean_p(src_path)}")
    print()
    print("Description:")
    import textwrap

    wrapped_desc = textwrap.fill(
        description, width=80, initial_indent="  ", subsequent_indent="  "
    )
    print(wrapped_desc)
    print()
    print("Metadata:")
    print(f"  Total Size:  {format_size(total_size)} ({total_files} files)")
    if dir_stats:
        print("  Structure:")
        sorted_dirs = sorted([d for d in dir_stats.keys() if d != "(root)"])
        if "(root)" in dir_stats:
            sorted_dirs.insert(0, "(root)")
        for d in sorted_dirs:
            count, size = dir_stats[d]
            d_label = d if d == "(root)" else f"{d}/"
            print(f"    {d_label:<15} : {count:>2} files ({format_size(size)})")


def get_common_dir_prefix(sources: list[str]) -> str | None:
    if not sources:
        return None
    split_sources = [s.split("/") for s in sources]
    if len(split_sources) == 1:
        common = split_sources[0][:-1]
    else:
        common = []
        for parts in zip(*split_sources):
            if len(set(parts)) == 1:
                common.append(parts[0])
            else:
                break
    if len(common) <= 1:
        return None
    prefix = "/".join(common)
    return prefix if prefix else None


def print_catalog(skills_info: list[dict], term_width: int) -> None:
    if not skills_info:
        return

    namespaces: dict[str, list[dict]] = {}
    for s in sorted(skills_info, key=lambda x: x["name"]):
        ns = s.get("namespace") or (
            s["name"].split(":")[0] if ":" in s["name"] else "default"
        )
        namespaces.setdefault(ns, []).append(s)

    def ns_order(ns: str) -> tuple[int, str]:
        if ns == "local":
            return (0, ns)
        elif ns == "remote":
            return (2, ns)
        else:
            return (1, ns)

    sorted_ns = sorted(namespaces.keys(), key=ns_order)

    for idx, ns in enumerate(sorted_ns):
        skills = namespaces[ns]
        prefix = get_common_dir_prefix([s["source"] for s in skills])

        plugin_files = sorted({s["plugin"] for s in skills if s.get("plugin")})
        plugin_str = f"via {', '.join(plugin_files)}" if plugin_files else ""

        info_parts = [p for p in (prefix, plugin_str) if p]
        info_str = f" ({', '.join(info_parts)})" if info_parts else ""

        if idx > 0:
            print("")
        print(f"{ns}{info_str}:" if ns else f"default{info_str}:")
        indent = "  "

        rows = []
        for s in skills:
            src = s["source"]
            if prefix and src.startswith(prefix + "/"):
                disp_src = src[len(prefix) + 1 :]
            else:
                disp_src = src
            rows.append((s["name"], disp_src))

        fit_names = [
            name
            for name, disp_src in rows
            if len(indent) + len(name) + 4 + len(disp_src) <= term_width
            and len(name) <= 45
        ]
        if fit_names:
            max_len = max(len(name) for name in fit_names)
        else:
            max_len = max(len(name) for name, _ in rows)

        for name, disp_src in rows:
            total_w = len(indent) + max_len + 4 + len(disp_src)
            if len(name) <= max_len and total_w <= term_width:
                print(f"{indent}{name.ljust(max_len)} -> {disp_src}")
            else:
                print(f"{indent}{name}")
                if len(indent) + max_len + 4 + len(disp_src) <= term_width:
                    arrow_indent = max_len
                else:
                    arrow_indent = 2
                print(f"{indent}{''.ljust(arrow_indent)} -> {disp_src}")


def cmd_catalog(as_json=False):
    api = get_api()
    ensure_catalog_index(api.plugin_catalog)

    skills_info = []

    # Scan all registered plugin skills
    for name, entry in api.all_registrations:
        ns = name.split(":")[0] if ":" in name else "default"
        if "path" in entry:
            meta = get_skill_metadata(Path(entry["path"]), name)
            obj = {
                "name": name,
                "description": meta["description"],
                "source": clean_p(entry["path"]),
                "namespace": ns,
            }
            if entry.get("plugin_file"):
                obj["plugin"] = entry["plugin_file"]
            skills_info.append(obj)
        elif "repo" in entry:
            stub_dir = get_catalog_dir() / name
            meta = get_skill_metadata(stub_dir, name)
            subpath = entry.get("subpath")
            src_str = (
                f"github.com/{entry['repo']}/{subpath}@{entry['ref']}"
                if subpath
                else f"github.com/{entry['repo']}@{entry['ref']}"
            )
            obj = {
                "name": name,
                "description": meta["description"],
                "source": src_str,
                "namespace": ns,
            }
            if entry.get("plugin_file"):
                obj["plugin"] = entry["plugin_file"]
            skills_info.append(obj)

    # Deduplicate identical target paths within the same group/type
    deduped_info = []
    seen_group_sources = set()
    for s in skills_info:
        key = (s["namespace"], s["source"])
        if key in seen_group_sources:
            continue
        seen_group_sources.add(key)
        deduped_info.append(s)
    skills_info = deduped_info

    # Detect naming conflicts (same name across distinct targets)
    name_counts = {}
    for s in skills_info:
        name_counts[s["name"]] = name_counts.get(s["name"], 0) + 1
    for s in skills_info:
        if name_counts[s["name"]] > 1 and "(! CONFLICT)" not in s["name"]:
            s["name"] = f"{s['name']} (! CONFLICT)"

    if as_json:
        for s in sorted(skills_info, key=lambda x: x["name"]):
            print(json.dumps(s))
    else:
        term_width = shutil.get_terminal_size((80, 24)).columns
        print_catalog(skills_info, term_width)


def cmd_suggest(args):
    # Lazy import of heavyweight LLM dependencies
    try:
        from google import genai
        from google.genai import types
    except ImportError:
        die(
            "The 'google-genai' package is required for suggestions. Please install it."
        )

    # Separate flags from positional arguments (preserving '-' as a positional)
    flags = [a for a in args if a.startswith("-") and a != "-"]
    positional_args = [a for a in args if not a.startswith("-") or a == "-"]

    # Detect explicit stdin request ("-")
    read_stdin = False
    if "-" in positional_args:
        read_stdin = True
        positional_args.remove("-")

    target_dir = Path.cwd()
    positional_prompt = None

    if positional_args:
        # Smart Positional Parsing:
        # Check if the first argument is a directory on disk.
        first_arg_path = Path(positional_args[0]).expanduser()
        if first_arg_path.is_dir():
            target_dir = first_arg_path.resolve()
            if len(positional_args) > 1:
                positional_prompt = " ".join(positional_args[1:])
        else:
            # If not a directory, treat the entire list as the prompt.
            positional_prompt = " ".join(positional_args)

    if not target_dir.is_dir():
        die(f"target directory '{target_dir}' does not exist")

    # Read from stdin if explicitly requested
    stdin_prompt = None
    if read_stdin:
        print("skill: reading task prompt from stdin...", file=sys.stderr)
        try:
            stdin_prompt = sys.stdin.read().strip()
        except Exception as e:
            die(f"failed to read from stdin: {e}")

    # Combine prompts if both are present
    prompt_context = None
    if positional_prompt and stdin_prompt:
        prompt_context = f"{positional_prompt}\n\nAdditional Context:\n{stdin_prompt}"
    elif positional_prompt:
        prompt_context = positional_prompt
    elif stdin_prompt:
        prompt_context = stdin_prompt

    print("skill: scanning workspace to compile recommendations...", file=sys.stderr)

    api = get_api()
    ensure_catalog_index(api.plugin_catalog)

    available_skills = []
    for name, entry in api.plugin_catalog.items():
        if any(s["name"] == name for s in available_skills):
            continue
        if "path" in entry:
            meta = get_skill_metadata(Path(entry["path"]), name)
            available_skills.append({"name": name, "description": meta["description"]})
        elif "repo" in entry:
            stub_dir = get_catalog_dir() / name
            meta = get_skill_metadata(stub_dir, name)
            available_skills.append({"name": name, "description": meta["description"]})

    if not available_skills:
        print(
            "skill suggest: no available skills found in catalog or paths",
            file=sys.stderr,
        )
        return

    # Gather directory info (context) to feed into prompt
    repo_files = []
    for root, dirs, files in os.walk(target_dir):
        dirs[:] = [d for d in dirs if not d.startswith(".")]
        depth = len(Path(root).relative_to(target_dir).parts)
        if depth > 3:
            continue
        for file in files:
            if file.startswith("."):
                continue
            repo_files.append(str(Path(root).relative_to(target_dir) / file))
            if len(repo_files) > 150:
                break
        if len(repo_files) > 150:
            break

    readme_content = ""
    for readme_name in ("README.md", "README.txt", "README"):
        readme_path = target_dir / readme_name
        if readme_path.is_file():
            try:
                with open(readme_path, "r", encoding="utf-8", errors="replace") as f:
                    readme_content = f.read(1500)
                break
            except Exception:
                pass

    repo_context = "FILES:\n" + "\n".join(repo_files[:100])
    if readme_content:
        repo_context += f"\n\nREADME EXCERPT:\n{readme_content}"

    system_instruction = """
You are a development environment orchestrator.
Your goal is to recommend the best agent "skills" to activate for the given project directory and task.
You will be provided with:
1. The available skills (name and description).
2. The user's task or context (optional).
3. Information about the target directory (e.g. file structure, README).

Recommend exactly the skills that are directly relevant. Err on the side of caution: if a skill is clearly relevant to the tech stack or task, include it. If it is completely irrelevant, do not include it.

Your response must be ONLY a valid JSON array of objects.
Each object must have:
- "name": the EXACT name of the skill
- "reason": a brief 1-sentence explanation of why it is relevant

Return an empty array [] if no skills apply.
"""

    prompt = f"""
AVAILABLE SKILLS:
{available_skills}
"""

    if prompt_context:
        prompt += f"""
USER CONTEXT / TASK:
{prompt_context}
"""

    prompt += f"""
TARGET DIRECTORY INFO:
{repo_context}
"""

    model_name = os.environ.get("GEMINI_MODEL", "gemini-3.5-flash")
    client = genai.Client()
    try:
        response = client.models.generate_content(
            model=model_name,
            contents=prompt,
            config=types.GenerateContentConfig(
                system_instruction=system_instruction,
                temperature=0.0,
                response_mime_type="application/json",
            ),
        )
    except Exception as e:
        die(f"Error calling Gemini API: {e}")

    try:
        results = json.loads(response.text)
    except Exception as e:
        die(f"Could not parse JSON response from LLM: {e}\n{response.text}")

    if not isinstance(results, list):
        die(f"Expected JSON array, got: {type(results)}\n{response.text}")

    as_json = "--json" in sys.argv or "--json" in flags
    if as_json:
        for s in results:
            print(json.dumps(s))
    else:
        print("\nRecommended Skills for this Workspace:", file=sys.stderr)
        if not results:
            print("  (None recommended)", file=sys.stderr)
        for s in results:
            print(f"  * {s['name'].ljust(20)} - {s['reason']}", file=sys.stderr)
        print("\nTo install a recommendation, run: skill add <name>", file=sys.stderr)


def colorize(text: str, color_name: str, enabled: bool = True) -> str:
    """Applies ANSI terminal styling to text if enabled."""
    if not enabled:
        return text
    codes = {
        "green": "\033[32m",
        "yellow": "\033[33m",
        "red": "\033[31m",
        "bold": "\033[1m",
        "reset": "\033[0m",
    }
    return f"{codes.get(color_name, '')}{text}{codes['reset']}"


def cmd_doctor(
    verbose: bool = False,
    check_catalog: bool = False,
    stream=sys.stderr,
    errors_only: bool = False,
) -> bool:
    """Diagnoses the health of the workspace, skill configuration, and catalog.

    Returns True if healthy, False otherwise. By default (a full 'doctor' audit)
    both WARNING and ERROR findings count as unhealthy. With errors_only=True
    (the 'preflight' launch gate) only ERROR-severity findings fail; WARNING
    findings are suppressed from the report and do not block agent launch.
    """
    ws = get_workspace()
    use_color = stream.isatty() if hasattr(stream, "isatty") else False

    # The single desired-vs-actual comparison. 'apply' executes this same plan;
    # 'doctor' only renders it, so the two cannot disagree about what should be
    # true (missing/extra/mismatched/dangling and the destructive-action policy
    # are all defined once, in build_reconcile_plan).
    plan = build_reconcile_plan(ws)
    expected_skills = plan.expected_skills
    unmanaged = plan.unmanaged

    def rel(p):
        try:
            return p.relative_to(ws.root)
        except ValueError:
            return p

    dest_dirs = []
    dest_err = None
    try:
        dest_dirs = ws.get_dest_dirs()
    except RuntimeError as e:
        dest_err = str(e)

    checks = []

    # Check 1: Workspace Detection
    # The workspace root is the most critical path in the report: every skill
    # symlink and exclude entry is relative to it, and the anchor walk can
    # resolve it above the current directory. Lead with it and label it plainly.
    ws_type = "Git repository" if isinstance(ws, GitWorkspace) else "Non-VCS directory"
    cwd = Path.cwd().resolve()
    ws_details = [f"Root: {clean_p(ws.root)}"]
    if ws.root != cwd:
        ws_details.append(f"Anchor resolved above current directory {clean_p(cwd)}")
    checks.append(
        {
            "name": "Workspace",
            "status": "OK",
            "summary": ws_type,
            "details": ws_details,
        }
    )

    # Check 1b: Plugin Load Failures
    # A plugin that raises during import/register() currently drops out
    # silently: get_api() only prints a one-line stderr warning, so a
    # "healthy" catalog can be silently missing that plugin's skills. Surface
    # the failures here so they show up as drift instead of scrolling past.
    load_failures = get_api().load_failures
    if load_failures:
        checks.append(
            {
                "name": "Plugin Loading",
                "status": "ERROR",
                "summary": f"Found {len(load_failures)} plugin(s) that failed to load",
                "details": ["Failed to load:"]
                + [f"  - {name}: {error}" for name, error in load_failures],
            }
        )
    else:
        checks.append(
            {
                "name": "Plugin Loading",
                "status": "OK",
                "summary": "All plugins loaded successfully",
                "details": [],
            }
        )

    # Check 2: Agent Configuration
    if dest_err:
        checks.append(
            {
                "name": "Agent Configuration",
                "status": "ERROR",
                "summary": "No active agent configuration detected",
                "details": [dest_err],
            }
        )
    else:
        dest_desc = ", ".join(clean_p(d) for d in dest_dirs)
        checks.append(
            {
                "name": "Agent Configuration",
                "status": "OK",
                "summary": f"Found active destination(s): {dest_desc}",
                "details": [],
            }
        )

    # Check 3: Required Skills (Alignment).
    # All alignment facts come from the shared plan. 'apply' fixes exactly the
    # conditions surfaced here: 'missing' (link creation), 'mismatched_target'
    # (re-link), and 'extra'/'negated_extra' (prune, subject to the plan's
    # destructive-action policy). 'unresolvable' specs fail the same catalog
    # lookup apply performs, so they are kept out of 'missing' -- apply cannot
    # fix them, and reporting them as missing would send the user into a loop
    # that never converges.
    missing = plan.missing
    unresolvable = [r.spec for r in plan.unresolved]
    unresolvable_errors = {r.spec: r.error for r in plan.unresolved}
    mismatched_target = plan.mismatched
    extra = plan.extra
    negated_extra = plan.negated_extra

    skill_details = []
    if missing:
        skill_details.append("Missing skills (declared but not linked on disk):")
        for s in missing:
            skill_details.append(f"  - {s}")
    if unresolvable:
        # This bucket also catches ambiguous specs (multiple catalog matches,
        # fixed by qualifying the namespace) and remote-fetch failures, not
        # only "no match at all" -- unresolvable_errors carries the specific
        # reason for each, so the header stays deliberately generic.
        skill_details.append("Unresolvable skills (declared but cannot be resolved):")
        for s in unresolvable:
            skill_details.append(f"  - {s} ({unresolvable_errors[s]})")
    if mismatched_target:
        skill_details.append(
            "Mismatched symlink targets (linked on disk but pointing to unexpected source):"
        )
        for s in mismatched_target:
            skill_details.append(f"  - {s}")
    if negated_extra:
        skill_details.append(
            "Stale excluded skills (linked on disk but explicitly negated in env):"
        )
        for s in negated_extra:
            skill_details.append(f"  - {s}")
    if extra:
        skill_details.append("Extra skills (linked on disk but not declared):")
        for s in extra:
            skill_details.append(f"  - {s}")

    if missing or unresolvable or mismatched_target or extra or negated_extra:
        parts = []
        if missing:
            parts.append(f"{len(missing)} missing")
        if unresolvable:
            parts.append(f"{len(unresolvable)} unresolvable")
        if mismatched_target:
            parts.append(f"{len(mismatched_target)} mismatched target")
        num_extra = len(extra) + len(negated_extra)
        if num_extra:
            parts.append(f"{num_extra} extra/stale")
        summary_str = ", ".join(parts)
        checks.append(
            {
                "name": "Required Skills",
                "status": "ERROR",
                "summary": f"Mismatched skill configuration ({summary_str})",
                "details": skill_details,
            }
        )
    else:
        checks.append(
            {
                "name": "Required Skills",
                "status": "OK",
                "summary": f"All {len(expected_skills)} expected skills are correctly installed and symlinked",
                "details": [],
            }
        )

    # Check 3c: Skill Conflicts (advisory)
    api = get_api()
    local_name_paths = {}
    for name, spec in api.all_registrations:
        if name.startswith("local:") and "path" in spec:
            sname = name.split(":", 1)[1]
            realpath = Path(os.path.realpath(spec["path"]))
            local_name_paths.setdefault(sname, set()).add(realpath)

    conflict_details = []
    for sname, paths in sorted(local_name_paths.items()):
        if len(paths) > 1:
            path_strs = ", ".join(clean_p(p) for p in sorted(paths))
            conflict_details.append(
                f"  - '{sname}' found in multiple distinct paths: {path_strs}"
            )

    if conflict_details:
        checks.append(
            {
                "name": "Skill Conflicts",
                "status": "WARNING",
                "summary": f"Found {len(conflict_details)} local skill name conflict(s)",
                "details": ["Conflicting skill names across SKILL_SOURCE_DIRS:"]
                + conflict_details,
            }
        )
    else:
        checks.append(
            {
                "name": "Skill Conflicts",
                "status": "OK",
                "summary": "No conflicting skill names across SKILL_SOURCE_DIRS",
                "details": [],
            }
        )

    # Check 3b: Environment Freshness (advisory).
    # Compares the .envrc managed skills block (the recording) against
    # AGENT_REQUIRED_SKILLS (the truth skill acts on). Only rendered when the
    # workspace has a readable block; WARNING severity so it fails 'doctor'
    # (a full audit) but never blocks 'preflight' (the launch gate).
    freshness = plan.freshness
    fresh_missing = []
    fresh_negated = []
    if freshness is not None:
        fresh_missing, fresh_negated = freshness
        fresh_details = []
        if fresh_missing:
            fresh_details.append(
                "Declared in .envrc but not reflected in the environment:"
            )
            fresh_details += [f"  - {s}" for s in fresh_missing]
        if fresh_negated:
            fresh_details.append(
                "Negated in .envrc but still present in the environment:"
            )
            fresh_details += [f"  - {s}" for s in fresh_negated]
        if fresh_details:
            checks.append(
                {
                    "name": "Environment Freshness",
                    "status": "WARNING",
                    "summary": "AGENT_REQUIRED_SKILLS does not reflect this workspace's .envrc (stale environment?)",
                    "details": fresh_details,
                }
            )
        else:
            checks.append(
                {
                    "name": "Environment Freshness",
                    "status": "OK",
                    "summary": "The environment reflects .envrc's skills declaration",
                    "details": [],
                }
            )

    # Check 4: Symlink Health
    # 'apply' intentionally never touches a VCS-tracked dangling symlink (it
    # is checked-in content, not a stray install artifact), so recommending
    # 'skill apply' for one would send the user in a loop that never
    # converges -- the plan splits stray from tracked so this check and apply's
    # prune agree on which links apply may remove.
    tracked_dangling = plan.tracked_dangling
    stray_dangling = plan.stray_dangling
    if stray_dangling or tracked_dangling:
        dangling_details = []
        if stray_dangling:
            dangling_details.append("Dangling symlinks:")
            dangling_details += [f"  - {rel(item)}" for item in stray_dangling]
        if tracked_dangling:
            dangling_details.append(
                "VCS-tracked dangling symlinks (not touched by 'skill apply'; "
                "fix or remove the checked-in symlink itself):"
            )
            dangling_details += [f"  - {rel(item)}" for item in tracked_dangling]
        checks.append(
            {
                "name": "Symlink Health",
                "status": "ERROR",
                "summary": f"Found {len(stray_dangling) + len(tracked_dangling)} broken or dangling symlink(s)",
                "details": dangling_details,
            }
        )
    else:
        checks.append(
            {
                "name": "Symlink Health",
                "status": "OK",
                "summary": "No dangling or broken symlinks detected",
                "details": [],
            }
        )

    # Check 5: Directory Cleanliness
    if unmanaged:
        checks.append(
            {
                "name": "Directory Cleanliness",
                "status": "ERROR",
                "summary": f"Found {len(unmanaged)} unmanaged file(s) or directory/directories in skill folders",
                "details": ["Unmanaged artifacts (should be moved or deleted):"]
                + [f"  - {rel(item)}" for item in unmanaged],
            }
        )
    else:
        checks.append(
            {
                "name": "Directory Cleanliness",
                "status": "OK",
                "summary": "No unmanaged files or directories in skill folders",
                "details": [],
            }
        )

    # Check 5b: VCS-Managed Skills (Informational)
    tracked_skills = ws.get_tracked_skills()
    if tracked_skills:
        checks.append(
            {
                "name": "VCS-Managed Skills",
                "status": "OK",
                "summary": f"Found {len(tracked_skills)} skill(s) committed to the repository",
                "details": [f"  - {rel(item)}" for item in tracked_skills],
            }
        )

    # Check 6: Orphaned Directories
    home = Path.home()
    orphaned = []
    configs = ws.get_supported_configs()

    for dest, sources in configs.items():
        if (ws.root / dest).is_dir() and not any(src.is_dir() for src in sources):
            formatted_sources = [
                f"~/{src.relative_to(home)}" if src.is_relative_to(home) else str(src)
                for src in sources
            ]
            if len(formatted_sources) == 1:
                msg = f"local folder exists, but {formatted_sources[0]} config directory does not exist"
            else:
                msg = f"local folder exists, but none of the config directories ({', '.join(formatted_sources)}) exist"
            orphaned.append((dest, msg))

    if orphaned:
        checks.append(
            {
                "name": "Orphaned Directories",
                "status": "WARNING",
                "summary": f"Found {len(orphaned)} orphaned skill directory/directories",
                "details": ["Orphaned folders:"]
                + [f"  - {path} ({reason})" for path, reason in orphaned],
            }
        )
    else:
        checks.append(
            {
                "name": "Orphaned Directories",
                "status": "OK",
                "summary": "No orphaned skill directories detected",
                "details": [],
            }
        )

    # Check 7: Workspace Exclusions (Git-specific)
    backend_issues = ws.doctor_issues()
    if backend_issues:
        checks.append(
            {
                "name": "Workspace Exclusions",
                "status": "ERROR",
                "summary": "Exclude configuration drift detected",
                "details": ["Exclude drift issues:"]
                + [f"  - {issue}" for issue in backend_issues],
            }
        )
    elif isinstance(ws, GitWorkspace):
        checks.append(
            {
                "name": "Workspace Exclusions",
                "status": "OK",
                "summary": f"{clean_p(ws.exclude_file)} is fully synchronized",
                "details": [],
            }
        )

    # Catalog-specific checks
    unresolvable_local = False
    catalog_index_issues = []
    catalog_stale_issues = []
    plugin_path_issues = []

    if check_catalog:
        api = get_api()
        catalog_dir = get_catalog_dir()
        meta_dir = catalog_dir / ".meta"

        for name, entry in api.plugin_catalog.items():
            if name.startswith("local:"):
                continue
            stub_md = catalog_dir / name / "SKILL.md"
            meta = meta_dir / name

            if "path" in entry:
                target_path = Path(entry["path"]).expanduser()
                if not target_path.is_dir():
                    plugin_path_issues.append(
                        f"  - {name} (path does not exist: {clean_p(target_path)})"
                    )
                    unresolvable_local = True
                    continue

            if not stub_md.is_file():
                catalog_index_issues.append(f"  - {name} (missing {clean_p(stub_md)})")
            elif meta.is_file():
                if (time.time() - meta.stat().st_mtime) > CATALOG_TTL:
                    catalog_stale_issues.append(
                        f"  - {name} (stale metadata {clean_p(meta)})"
                    )

        # Check 8: Plugin Local Paths
        if plugin_path_issues:
            checks.append(
                {
                    "name": "Plugin Local Paths",
                    "status": "ERROR",
                    "summary": f"Found {len(plugin_path_issues)} missing plugin-defined local path(s)",
                    "details": ["Missing plugin paths:"] + plugin_path_issues,
                }
            )
        else:
            checks.append(
                {
                    "name": "Plugin Local Paths",
                    "status": "OK",
                    "summary": "All plugin-defined local paths exist",
                    "details": [],
                }
            )

        # Check 9: Catalog Cache
        catalog_details = []
        if catalog_index_issues:
            catalog_details.append("Missing from catalog index:")
            for issue in catalog_index_issues:
                catalog_details.append(f"  {issue}")
        if catalog_stale_issues:
            catalog_details.append("Stale catalog indexes:")
            for issue in catalog_stale_issues:
                catalog_details.append(f"  {issue}")

        if catalog_index_issues or catalog_stale_issues:
            status = "ERROR" if catalog_index_issues else "WARNING"
            checks.append(
                {
                    "name": "Catalog Cache",
                    "status": status,
                    "summary": f"Catalog cache issues detected in {clean_p(catalog_dir)} ({len(catalog_index_issues)} missing, {len(catalog_stale_issues)} stale)",
                    "details": catalog_details,
                }
            )
        else:
            checks.append(
                {
                    "name": "Catalog Cache",
                    "status": "OK",
                    "summary": f"All remote catalog stubs are indexed and fresh in {clean_p(catalog_dir)}",
                    "details": [],
                }
            )

    # Render checks.
    #
    # 'doctor' is a full audit: every non-OK check (WARNING or ERROR) is a
    # finding and makes the command exit non-zero. 'preflight' passes
    # errors_only=True as a launch gate: only ERROR-severity checks block an
    # agent from starting, so a WARNING-only workspace renders nothing and
    # passes. A check is rendered only when it is "visible".
    def is_visible(check):
        if verbose:
            return True
        if check["status"] == "ERROR":
            return True
        if check["status"] == "WARNING":
            return not errors_only
        return False

    fail = any(
        (c["status"] == "ERROR") if errors_only else (c["status"] != "OK")
        for c in checks
    )

    def format_status(status):
        if status == "OK":
            tag, color_name = "[OK]   ", "green"
        elif status == "WARNING":
            tag, color_name = "[WARN] ", "yellow"
        else:
            tag, color_name = "[ERROR]", "red"
        return colorize(tag, color_name, use_color)

    # Per-finding remediation, attached to the check it belongs to so fixes
    # never scroll away from the finding that prompted them (emumanager style).
    generic_sync = "To resolve: run 'git-setup' or 'skill apply' to synchronize and repair your configuration."
    for check in checks:
        if check["status"] == "OK":
            continue
        name = check["name"]
        if name == "Environment Freshness":
            check["details"].append(
                "To resolve: reload this workspace's environment so AGENT_REQUIRED_SKILLS picks up .envrc:"
            )
            check["details"].append(
                "  direnv reload   # or start a new prompt, then re-run 'skill apply'"
            )
        elif name == "Required Skills":
            if missing or mismatched_target or extra or negated_extra:
                check["details"].append(generic_sync)
            if unresolvable:
                check["details"].append(
                    "To resolve: 'skill apply' cannot fix this -- these "
                    "spec(s) fail the same catalog lookup doctor just "
                    "performed (see the reason next to each above: fix the "
                    "catalog registration, qualify an ambiguous name with "
                    "its namespace, or remove the unresolvable "
                    "declaration(s)):"
                )
                if is_using_envrc(ws):
                    check["details"].append(
                        f"  envrc remove skills {' '.join(unresolvable)}"
                    )
                else:
                    check["details"].append(
                        "  # remove them from the AGENT_REQUIRED_SKILLS environment variable"
                    )
            if extra:
                if is_using_envrc(ws):
                    check["details"].append(
                        "Add the extra skill(s) to your required skills (updates .envrc):"
                    )
                    check["details"].append(f"  envrc add skills {' '.join(extra)}")
                else:
                    check["details"].append(
                        "Add the extra skill(s) to the AGENT_REQUIRED_SKILLS environment variable:"
                    )
                    check["details"].append(
                        f'  export AGENT_REQUIRED_SKILLS="$AGENT_REQUIRED_SKILLS {" ".join(extra)}"'
                    )
                check["details"].append("Or remove the local symlink(s):")
                check["details"].append(f"  skill remove {' '.join(extra)}")
            if negated_extra:
                check["details"].append("Remove the excluded symlink(s) manually:")
                check["details"].append(f"  skill remove {' '.join(negated_extra)}")
        elif name == "Symlink Health":
            if stray_dangling:
                check["details"].append(generic_sync)
            if tracked_dangling:
                check["details"].append(
                    "To resolve: 'skill apply' will not remove a VCS-tracked "
                    "symlink -- fix its target or delete it from the repository:"
                )
                check["details"].append(
                    "  rm "
                    + " ".join(str(rel(item)) for item in tracked_dangling)
                    + "   # then 'git rm --cached' if already staged/committed"
                )
        elif name == "Workspace Exclusions":
            check["details"].append(generic_sync)
        elif name == "Directory Cleanliness":
            check["details"].append(
                "To resolve: manually delete or move the unmanaged files/directories out of the skill folders."
            )
        elif name == "Orphaned Directories":
            rm_cmds = " && ".join(f"rm -rf {path}" for path, _ in orphaned)
            check["details"].append(
                "To resolve: delete the orphaned directory/directories if you no longer use those agents:"
            )
            check["details"].append(f"  {rm_cmds}")
        elif name == "Plugin Loading":
            check["details"].append(
                "To resolve: fix or remove the failing plugin file(s) listed above "
                "(rerun with SKILL_DEBUG=1 for a full traceback)."
            )
        elif name == "Plugin Local Paths":
            check["details"].append(
                "To resolve: fix the missing local paths for your plugins in your configuration."
            )
        elif name == "Catalog Cache" and not unresolvable_local:
            check["details"].append(
                "To resolve: run 'skill update --catalog' to repair the catalog cache."
            )

    for check in checks:
        if is_visible(check):
            print(
                f"{format_status(check['status'])} {check['name']}: {check['summary']}",
                file=stream,
            )
            if check["details"]:
                for line in check["details"]:
                    print(f"    {line}", file=stream)

    if fail:
        return False

    if verbose:
        print(
            colorize(
                "\n✔ Workspace is healthy and skills are fully synchronized!",
                "green",
                use_color,
            ),
            file=stream,
        )
    return True


def cmd_doctor_all():
    """Canonical entrypoint for the 'skill doctor' command.

    Runs both local and catalog diagnostics, printing to stdout with verbose reporting.
    """
    healthy = cmd_doctor(verbose=True, check_catalog=True, stream=sys.stdout)
    sys.exit(0 if healthy else 1)


def usage():
    print(
        """Usage: skill <command> [skill...]

Manage per-workspace agent skills as untracked symlinks. Automatically detects
which agent is installed on PATH and applies symlinks and local git ignores:
  - Claude          -> .claude/skills
  - Codex/Agy/Jetski -> .agents/skills

Commands:
  apply           Synchronize workspace symlinks to match AGENT_REQUIRED_SKILLS
  suggest [DIR] [-] [PROMPT] Print advisory LLM skill recommendations guided by an
                          optional task prompt (pass '-' to read from stdin)
                          (requires google-genai)
  add SPEC...     Add a skill: a local path or a plugin-provided catalog entry
  add -           Read skill names from stdin
  remove NAME...  Remove a skill and clean its exclude entry (alias: rm)
  list [--json]   List active skills on disk in the current workspace
  update SPEC...  Re-fetch a plugin-provided catalog entry; --all for every active
                  skill, --catalog to refresh the whole metadata index
  clean           Remove all skills and clear git excludes
  doctor          Diagnose mismatch between desired and on-disk skills (read-only)
  preflight LABEL Verify required skills and workspace health before agent launch
  catalog         List plugin-provided skills and sources
  resolve NAME    Print the source path 'add NAME' would symlink to
  show/info NAME  Show details and metadata of a skill

Options:
  --help             Display this help message and exit
  --plugin-template  Output a template/documentation for creating a Workspace plugin"""
    )
    sys.exit(0)


def main():
    if "--plugin-template" in sys.argv:
        print('''"""
Example Plugin for the skill script.
Save this file as ~/.config/skill/plugins/my_plugin.py

register() runs on every skill invocation. Keep it fast and
side-effect-free: no network calls, subprocesses, or filesystem writes.

If the plugin encounters a fatal environment error (e.g., missing corporate
credentials/mounts) and must abort execution immediately, print a clean
error message to stderr and call sys.exit(1).
"""

def register(api):
    """
    This function is automatically called by `skill` when the plugin is loaded.
    You must register your custom Workspace classes here using the provided `SkillAPI`.
    """

    class MyCustomWorkspace(api.Workspace):
        """Custom workspace implementation."""

        @classmethod
        def detect(cls):
            """Detect if the current directory is of this workspace type.

            Return an instance of MyCustomWorkspace if detected, else None.
            """
            return None

        def get_expected_skills(self) -> list[str]:
            return []
''')
        sys.exit(0)

    if len(sys.argv) < 2 or sys.argv[1] in ("--help", "-h", "help"):
        usage()

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if "--help" in args or "-h" in args:
        usage()

    if cmd == "doctor":
        cmd_doctor_all()
    elif cmd == "catalog":
        as_json = "--json" in args
        cmd_catalog(as_json=as_json)
    elif cmd == "resolve":
        if not args:
            cmderr("resolve", "skill name required")
        cmd_resolve(args[0])
    elif cmd in ("info", "show"):
        if not args:
            cmderr(cmd, "skill name required")
        cmd_info(args[0])
    elif cmd == "update":
        cmd_update(args)
    elif cmd == "add":
        cmd_add(args)
    elif cmd in ("remove", "rm"):
        cmd_remove(args)
    elif cmd == "list":
        cmd_list(args)
    elif cmd == "clean":
        cmd_clean()
    elif cmd == "apply":
        cmd_apply(args)
    elif cmd == "suggest":
        cmd_suggest(args)
    elif cmd == "preflight":
        caller_label = args[0] if args else "agent"
        cmd_preflight(caller_label)
    else:
        print(f"skill: unknown command '{cmd}'", file=sys.stderr)
        print("Try 'skill --help' for more information.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)
    except Exception as e:
        if os.environ.get("SKILL_DEBUG") == "1":
            import traceback

            traceback.print_exc(file=sys.stderr)
        else:
            print(f"skill: error: {e}", file=sys.stderr)
        sys.exit(1)
