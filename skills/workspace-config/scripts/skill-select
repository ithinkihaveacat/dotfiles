#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "google-genai",
#   "pyyaml",
#   "requests",
# ]
# ///

import os
import sys
import time
import shutil
import argparse
import tempfile
import tarfile
import subprocess
import yaml
from pathlib import Path
from urllib.parse import urlparse

# --- MOVED REGISTRY & NETWORK CODE ---

# Catalog index stub (SKILL.md) freshness: how long a discovered metadata stub
# is trusted before re-fetching during 'suggest'/'apply'.
CATALOG_TTL = 7 * 24 * 3600  # 7 days
# Full-repo freshness on provision: how old a cached repo may be before 'apply'
# force-refreshes it while adding a registry skill to a workspace.
PROVISION_TTL = 8 * 3600  # 8 hours


def get_cache_base():
    return (
        Path(
            os.environ.get("SKILL_SELECT_CACHE_DIR")
            or os.environ.get("XDG_CACHE_HOME")
            or "~/.cache"
        ).expanduser()
        / "skill-select"
    )


def get_catalog_dir():
    return get_cache_base() / "catalog"


def parse_github_url(url):
    """Parse a GitHub tree URL into (repo, ref, subpath).

    Accepts: https://github.com/{owner}/{repo}/tree/{ref}[/{subpath}]
    """
    parsed = urlparse(url)
    if parsed.netloc != "github.com":
        raise ValueError(
            f"registry: unsupported URL (only github.com is supported): {url}"
        )
    parts = parsed.path.strip("/").split("/")
    if len(parts) < 4 or parts[2] != "tree":
        raise ValueError(f"registry: cannot parse GitHub URL: {url}")
    owner, repo, _, ref = parts[:4]
    subpath = "/".join(parts[4:]) or None
    return f"{owner}/{repo}", ref, subpath


class SkillSelectAPI:
    """API surface passed to a plugin's register() function."""

    def __init__(self, plugin_catalog):
        self.plugin_catalog = plugin_catalog

    def register_skill(self, name, spec):
        """Register a skill in the catalog.

        spec must be:
        - A dict with 'path' (local path, automatically ~ expanded)
        - OR a dict with 'repo' and 'ref' (GitHub, with optional 'subpath')
        - OR a GitHub URL string (e.g. 'https://github.com/owner/repo/tree/ref/subpath')
        """
        if isinstance(spec, str):
            if spec.startswith("https://github.com/") or spec.startswith(
                "http://github.com/"
            ):
                repo, ref, subpath = parse_github_url(spec)
                spec = {"repo": repo, "ref": ref, "subpath": subpath}
            else:
                raise ValueError(
                    f"Skill '{name}': string spec must be a GitHub URL, got '{spec}'"
                )

        if not isinstance(spec, dict):
            raise ValueError(
                f"Skill '{name}': spec must be a dictionary or a GitHub URL string, got {type(spec).__name__}"
            )
        # Copy so registration never mutates (or aliases) the plugin's dict
        spec = dict(spec)

        if "path" in spec:
            if any(k in spec for k in ("repo", "ref", "subpath")):
                raise ValueError(
                    f"Skill '{name}': 'path' cannot be mixed with GitHub parameters."
                )
            # Normalize path (expand ~) immediately at registration time
            spec["path"] = os.path.expanduser(spec["path"])
        elif "repo" in spec and "ref" in spec:
            spec.setdefault("subpath", None)
        else:
            raise ValueError(
                f"Skill '{name}': spec must contain either 'path' or both 'repo' and 'ref'."
            )

        self.plugin_catalog[name] = spec


def load_plugins(plugin_catalog):
    import importlib.util

    plugins_dir = (
        Path(os.environ.get("XDG_CONFIG_HOME") or "~/.config").expanduser()
        / "skill-select"
        / "plugins"
    )
    if not plugins_dir.is_dir():
        return

    api = SkillSelectAPI(plugin_catalog)

    for filepath in sorted(plugins_dir.glob("*.py")):
        module_name = f"skill_select_plugin_{filepath.stem}"
        try:
            spec = importlib.util.spec_from_file_location(module_name, filepath)
            if spec and spec.loader:
                module = importlib.util.module_from_spec(spec)
                sys.modules[module_name] = module
                spec.loader.exec_module(module)
                if hasattr(module, "register"):
                    module.register(api)
        except Exception as e:
            print(
                f"skill-select: warning: failed to load plugin {filepath}: {e}",
                file=sys.stderr,
            )
            if os.environ.get("SKILL_SELECT_DEBUG") == "1":
                import traceback

                traceback.print_exc(file=sys.stderr)


def load_plugins_catalog():
    plugin_catalog = {}
    load_plugins(plugin_catalog)
    return plugin_catalog


def _atomic_replace_dir(src, dest):
    """Install src as dest atomically, swapping within dest's parent directory.

    Uses sibling temp names (not '.with_suffix', which mangles refs containing
    dots) and os.replace (which cannot overwrite a non-empty directory) by
    moving any existing dest aside first. Both renames stay within one
    directory, so they are atomic and safe under concurrent fetches.
    """
    dest.parent.mkdir(parents=True, exist_ok=True)
    tmp = dest.parent / f"{dest.name}.tmp-{os.getpid()}"
    if tmp.exists():
        shutil.rmtree(tmp)
    try:
        shutil.copytree(src, tmp, symlinks=True)
        if dest.exists():
            trash = dest.parent / f"{dest.name}.old-{os.getpid()}"
            if trash.exists():
                shutil.rmtree(trash)
            os.replace(dest, trash)
            os.replace(tmp, dest)
            shutil.rmtree(trash, ignore_errors=True)
        else:
            os.replace(tmp, dest)
    finally:
        if tmp.exists():
            shutil.rmtree(tmp, ignore_errors=True)


def fetch_github(name, repo, ref, subpath, force=False):
    import requests

    owner, reponame = repo.split("/", 1)
    cache_base = get_cache_base()
    cachedir = cache_base / owner / reponame / ref
    if subpath:
        cachedir = cachedir / subpath

    have_cache = cachedir.is_dir() and any(cachedir.iterdir())
    if not force and have_cache:
        print(
            f"using cached {repo}@{ref} (run 'skill update {name}' to refresh)",
            file=sys.stderr,
        )
        return cachedir

    archive_url = f"https://github.com/{owner}/{reponame}/archive/{ref}.tar.gz"
    print(f"fetching {archive_url}", file=sys.stderr)
    try:
        r = requests.get(archive_url, stream=True)
        r.raise_for_status()
    except requests.exceptions.RequestException as e:
        # Offline / network failure: fall back to an existing cache so already
        # provisioned skills keep working; only fail if nothing is cached.
        if have_cache:
            print(f"skill: {archive_url}: {e}; using stale cache", file=sys.stderr)
            return cachedir
        die(f"failed to fetch {archive_url}: {e}")

    with tempfile.TemporaryDirectory() as tmpdir:
        tmp_path = Path(tmpdir)
        tar_path = tmp_path / "archive.tar.gz"
        with open(tar_path, "wb") as f:
            for chunk in r.iter_content(chunk_size=8192):
                f.write(chunk)

        try:
            with tarfile.open(tar_path, "r:gz") as tar:
                # Avoid DeprecationWarning on Python 3.12+ by using the 'data' filter.
                # We use hasattr to remain compatible with older Python 3.11 releases.
                if hasattr(tarfile, "data_filter"):
                    tar.extractall(path=tmp_path, filter="data")
                else:
                    tar.extractall(path=tmp_path)
        except Exception as e:
            die(f"failed to extract archive: {e}")

        subdirs = [
            x for x in tmp_path.iterdir() if x.is_dir() and x.name != "archive.tar.gz"
        ]
        if not subdirs:
            die("extracted archive is empty")
        wrapper_dir = subdirs[0]

        src_dir = wrapper_dir
        if subpath:
            src_dir = wrapper_dir / subpath
            if not src_dir.is_dir():
                die(f"path not found in {owner}/{reponame}@{ref}: {subpath}")

        _atomic_replace_dir(src_dir, cachedir)

    return cachedir


def fetch_skill_md(name, repo, ref, subpath, force=False):
    """Fetch only SKILL.md for a registry entry into a lightweight catalog stub.

    This is the metadata-only discovery path: it lets skill-select see and rank
    a registry skill without downloading the whole repository. The full repo is
    materialized lazily on 'add'/provision via fetch_github. Returns the stub
    directory, or None if SKILL.md could not be obtained and no stub exists.
    """
    import requests

    owner, reponame = repo.split("/", 1)
    catalog_dir = get_catalog_dir()
    stub = catalog_dir / name
    meta_dir = catalog_dir / ".meta"
    meta = meta_dir / name
    stub_md = stub / "SKILL.md"

    if not force and meta.is_file() and stub_md.is_file():
        if (time.time() - meta.stat().st_mtime) < CATALOG_TTL:
            return stub

    sub = f"{subpath}/" if subpath else ""
    url = f"https://raw.githubusercontent.com/{owner}/{reponame}/{ref}/{sub}SKILL.md"
    try:
        r = requests.get(url)
        r.raise_for_status()
        content = r.content
    except requests.exceptions.RequestException as e:
        # Degrade gracefully: keep any existing stub when offline, and skip
        # (never die) so one bad entry does not break discovery of the rest.
        if stub_md.is_file():
            return stub
        print(f"skill: {url}: {e}; skipping {name}", file=sys.stderr)
        return None

    stub.mkdir(parents=True, exist_ok=True)
    tmp = stub / f".SKILL.md.tmp-{os.getpid()}"
    try:
        tmp.write_bytes(content)
        os.replace(tmp, stub_md)
    finally:
        if tmp.exists():
            tmp.unlink()
    meta_dir.mkdir(parents=True, exist_ok=True)
    meta.touch()
    return stub


def ensure_catalog_index(plugin_catalog, force=False) -> bool:
    """Populate/refresh the catalog/ index of metadata stubs for plugin-defined skills.

    Fetches only SKILL.md per entry (fast, offline-friendly cold start), then
    garbage-collects stubs whose names are no longer defined. Returns early
    when the catalog is empty so a missing/unreadable config never triggers a
    destructive GC of an otherwise-populated catalog.
    """
    if not plugin_catalog:
        return True

    catalog_dir = get_catalog_dir()
    meta_dir = catalog_dir / ".meta"
    total = len(plugin_catalog)
    has_errors = False
    for i, name in enumerate(sorted(plugin_catalog), 1):
        entry = plugin_catalog[name]

        if "path" in entry:
            # Local entry: symlink the directory into catalog
            target_path = Path(entry["path"]).resolve()
            if not target_path.is_dir():
                print(
                    f"skill-select: error: local path for {name} does not exist: {target_path}",
                    file=sys.stderr,
                )
                has_errors = True
                continue

            stub_dir = catalog_dir / name
            if not stub_dir.is_symlink() or os.readlink(stub_dir) != str(target_path):
                if stub_dir.exists() or stub_dir.is_symlink():
                    if stub_dir.is_symlink():
                        stub_dir.unlink()
                    else:
                        shutil.rmtree(stub_dir)
                stub_dir.parent.mkdir(parents=True, exist_ok=True)
                stub_dir.symlink_to(target_path)
            continue

        meta = meta_dir / name
        stub_md = catalog_dir / name / "SKILL.md"
        fresh = (
            not force
            and meta.is_file()
            and stub_md.is_file()
            and (time.time() - meta.stat().st_mtime) < CATALOG_TTL
        )
        if fresh:
            continue
        print(f"skill-select: [{i}/{total}] indexing {name}...", file=sys.stderr)
        res = fetch_skill_md(
            name, entry["repo"], entry["ref"], entry["subpath"], force=force
        )
        if res is None:
            has_errors = True

    # Garbage-collect orphaned stubs (plugin_catalog is non-empty here, so this cannot
    # wipe a catalog just because a config file went missing).
    if catalog_dir.is_dir():
        for item in catalog_dir.iterdir():
            if item.name.startswith("."):
                continue
            if item.name in plugin_catalog:
                continue
            if item.is_symlink() or not item.is_dir():
                item.unlink()
            else:
                shutil.rmtree(item, ignore_errors=True)
            stale_meta = meta_dir / item.name
            if stale_meta.exists():
                stale_meta.unlink()

    return not has_errors


def provision_plugin_skill(name, entry):
    """Ensure a plugin-provided skill's full repo is cached and fresh before adding.

    Force-refreshes when the cache is missing or older than PROVISION_TTL so a
    just-added skill reflects a recent upstream, then leaves fetch_github's own
    reuse to make the subsequent 'add' a cache hit.
    """
    cache_base = get_cache_base()
    owner, reponame = entry["repo"].split("/", 1)
    cachedir = cache_base / owner / reponame / entry["ref"]
    if entry["subpath"]:
        cachedir = cachedir / entry["subpath"]
    stale = (
        not cachedir.is_dir()
        or not any(cachedir.iterdir())
        or (time.time() - cachedir.stat().st_mtime) > PROVISION_TTL
    )
    fetch_github(name, entry["repo"], entry["ref"], entry["subpath"], force=stale)


def resolve_spec(spec, plugin_catalog, source_dirs):
    expanded_spec = os.path.expanduser(spec)

    # 1. Local path check
    if (
        expanded_spec.startswith("/")
        or expanded_spec.startswith("./")
        or expanded_spec.startswith("../")
        or "/" in expanded_spec
    ):
        path = Path(expanded_spec).resolve()
        if not path.is_dir():
            die(f"skill source not found: {spec}")
        return path, path.name

    # 2. Plugin catalog check
    if spec in plugin_catalog:
        entry = plugin_catalog[spec]
        if "path" in entry:
            path = Path(entry["path"]).resolve()
            if not path.is_dir():
                die(
                    f"skill source not found: {entry['path']} (defined by plugin as {spec})"
                )
            return path, spec
        else:
            repo = entry["repo"]
            ref = entry["ref"]
            subpath = entry["subpath"]
            src = fetch_github(spec, repo, ref, subpath)
            return src, spec

    # 3. SKILL_SOURCE_DIRS check
    for d in source_dirs:
        if not d:
            continue
        path = Path(d) / spec
        if path.is_dir():
            return path, spec

    die(
        f"unknown skill '{spec}': not a path, a plugin-provided catalog entry, or under any of SKILL_SOURCE_DIRS ({':'.join(source_dirs)})"
    )


def cmd_update(names, plugin_catalog):
    if not names:
        die("update requires a skill name or 'catalog'")

    if len(names) == 1 and names[0] in ("--catalog", "catalog"):
        ensure_catalog_index(plugin_catalog, force=True)
        print("update: refreshed catalog index", file=sys.stderr)
        return

    cache_base = get_cache_base()

    for name in names:
        if name in plugin_catalog:
            entry = plugin_catalog[name]
            if "path" in entry:
                print(
                    f"update: {name} is a local skill; nothing to update",
                    file=sys.stderr,
                )
                continue
            fetch_skill_md(
                name, entry["repo"], entry["ref"], entry["subpath"], force=True
            )
            owner, reponame = entry["repo"].split("/", 1)
            cachedir = cache_base / owner / reponame / entry["ref"]
            if entry["subpath"]:
                cachedir = cachedir / entry["subpath"]
            if cachedir.is_dir() and any(cachedir.iterdir()):
                fetch_github(
                    name, entry["repo"], entry["ref"], entry["subpath"], force=True
                )
            print(
                f"updated {name} from {entry['repo']}@{entry['ref']}", file=sys.stderr
            )
        else:
            print(
                f"update: {name} is not defined by any plugin; cannot refresh",
                file=sys.stderr,
            )


def cmd_resolve(name, plugin_catalog, source_dirs):
    try:
        path, actual_name = resolve_spec(name, plugin_catalog, source_dirs)
        print(f"{path}\t{actual_name}")
    except SystemExit:
        sys.exit(1)


def cmd_catalog(plugin_catalog, source_dirs, as_json=False):
    import json as _json
    from collections import defaultdict

    grouped = defaultdict(list)
    home = str(Path.home())

    def clean_p(p):
        s = str(p)
        if s.startswith(home):
            return "~" + s[len(home) :]
        return s

    # Map cleaned source dirs to their index for sorting
    source_order = {}
    order_idx = 0
    for d in source_dirs:
        if d:
            resolved = clean_p(Path(d).resolve())
            if resolved not in source_order:
                source_order[resolved] = order_idx
                order_idx += 1

    # 1. Plugin catalog entries
    for name in plugin_catalog:
        entry = plugin_catalog[name]
        if "path" in entry:
            grouped["Plugins"].append((name, entry["path"]))
        else:
            repo = entry["repo"]
            ref = entry["ref"]
            subpath = entry["subpath"]

            url = f"https://github.com/{repo}/tree/{ref}"
            if subpath:
                url += f"/{subpath}"
            # Group all plugin items under "Plugins" showing their full URL
            grouped["Plugins"].append((name, url))

    # 2. Local catalog entries under source_dirs
    for d in source_dirs:
        if not d:
            continue
        path = Path(d)
        if path.is_dir():
            resolved_parent = str(path.resolve())
            group_key = clean_p(resolved_parent)
            for item in path.iterdir():
                if item.is_dir() and not item.name.startswith("."):
                    target = None
                    if item.is_symlink():
                        target = clean_p(item.resolve())
                    elif resolved_parent == str(get_catalog_dir().resolve()):
                        if item.name in plugin_catalog:
                            entry = plugin_catalog[item.name]
                            if "repo" in entry:
                                repo = entry["repo"]
                                ref = entry["ref"]
                                subpath = entry["subpath"]
                                url = f"https://github.com/{repo}/tree/{ref}"
                                if subpath:
                                    url += f"/{subpath}"
                                target = url
                    # Remove it from plugin_catalog if it was there to avoid duplicates
                    for grp in list(grouped.keys()):
                        grouped[grp] = [x for x in grouped[grp] if x[0] != item.name]
                    grouped[group_key].append((item.name, target))

    # Clean up empty groups
    for grp in list(grouped.keys()):
        if not grouped[grp]:
            del grouped[grp]

    def sort_key(grp):
        if grp == "Plugins":
            return (2, grp)
        if grp in source_order:
            return (0, source_order[grp])
        return (1, grp)

    if as_json:
        entries = []
        for grp in sorted(grouped.keys(), key=sort_key):
            for name, target in sorted(grouped[grp], key=lambda x: x[0]):
                entries.append({"name": name, "source": grp, "target": target})
        print(_json.dumps(entries))
        return

    # Display output grouped by source path/prefix
    first = True
    for grp in sorted(grouped.keys(), key=sort_key):
        if not first:
            print()
        first = False
        print(f"{grp}:")
        items = sorted(grouped[grp], key=lambda x: x[0])
        has_targets = [x for x in items if x[1]]
        max_len = max(len(name) for name, _ in has_targets) if has_targets else 0
        for name, target in items:
            if target:
                print(f"  {name.ljust(max_len)} -> {target}")
            else:
                print(f"  {name}")


def cmd_doctor(plugin_catalog):
    catalog_dir = get_catalog_dir()
    meta_dir = catalog_dir / ".meta"
    issues = []
    unresolvable_local = False
    for name in sorted(plugin_catalog):
        entry = plugin_catalog[name]
        stub_md = catalog_dir / name / "SKILL.md"
        meta = meta_dir / name

        if "path" in entry:
            target_path = Path(entry["path"]).resolve()
            if not target_path.is_dir():
                issues.append(
                    f"  error        {name} (plugin-provided path does not exist: {target_path})"
                )
                unresolvable_local = True
                continue

        if not stub_md.is_file():
            issues.append(
                f"  missing      {name} (plugin-defined but not indexed in catalog)"
            )
        elif meta.is_file() and (time.time() - meta.stat().st_mtime) > CATALOG_TTL:
            issues.append(f"  stale        {name} (catalog index is stale)")

    if catalog_dir.is_dir():
        for item in sorted(catalog_dir.iterdir()):
            if item.name.startswith("."):
                continue
            if item.name not in plugin_catalog:
                issues.append(
                    f"  orphan       {item.name} (in catalog cache but not defined by any plugin)"
                )

    if issues:
        print()
        print("Catalog:")
        for line in sorted(issues):
            print(line)
        if unresolvable_local:
            print("                (fix missing local paths first)")
        else:
            print("                skill-select repair")
        sys.exit(1)
    sys.exit(0)


def cmd_repair(plugin_catalog):
    if not ensure_catalog_index(plugin_catalog, force=False):
        print("repair: error: failed to heal some catalog entries", file=sys.stderr)
        sys.exit(1)
    print("repair: healed catalog index", file=sys.stderr)


def load_skill_md(path: Path, default_name: str | None = None) -> dict | None:
    """Reads SKILL.md and extracts frontmatter and content."""
    skill_md = path / "SKILL.md"
    if not skill_md.is_file():
        return None
    try:
        content = skill_md.read_text(encoding="utf-8", errors="replace")
        # Parse YAML frontmatter
        if content.startswith("---"):
            parts = content.split("---", 2)
            if len(parts) >= 3:
                frontmatter = yaml.safe_load(parts[1])
                body = parts[2].strip()
                return {
                    "name": frontmatter.get("name", default_name or path.name),
                    "description": frontmatter.get("description", ""),
                    "path": str(path),
                    "content": body,
                }
        return {
            "name": default_name or path.name,
            "description": "",
            "path": str(path),
            "content": content,
        }
    except Exception as e:
        print(
            f"skill-select: warning: failed to read skill at {path}: {e}",
            file=sys.stderr,
        )
        return None


def gather_skills(search_dirs: list[Path]) -> list[dict]:
    """Finds all skills in the given directories, resolving symlinks to avoid duplicates.

    Collapses skills with the same name, preserving the first one encountered
    to respect search directory precedence (e.g. preferring active/source skills
    over catalog stubs). Prints a detailed warning to stderr when duplicates are
    found, indicating their paths and sources.
    """
    skills_by_name = {}
    seen_paths = set()
    for d in search_dirs:
        expanded_d = Path(os.path.expanduser(str(d))).resolve()
        if not expanded_d.is_dir():
            continue
        source_name = clean_p(expanded_d)
        # Search for SKILL.md in subdirectories
        for item in expanded_d.iterdir():
            if item.is_dir() and not item.name.startswith("."):
                try:
                    resolved_item = item.resolve()
                except Exception:
                    continue
                if resolved_item in seen_paths:
                    continue
                seen_paths.add(resolved_item)
                skill_data = load_skill_md(resolved_item, default_name=item.name)
                if skill_data:
                    skill_data["source"] = source_name
                    name = skill_data["name"]
                    if name not in skills_by_name:
                        skills_by_name[name] = skill_data
                    else:
                        existing = skills_by_name[name]
                        if existing["path"] != skill_data["path"]:
                            print(
                                f"skill-select: warning: duplicate skill '{name}' found.\n"
                                f"  Keeping:  {existing['path']} (from {existing['source']})\n"
                                f"  Ignoring: {skill_data['path']} (from {skill_data['source']})",
                                file=sys.stderr,
                            )
    return list(skills_by_name.values())


def gather_context(target_dir: Path) -> str:
    """Gathers files and .gitignore contents for query context."""
    context = ""
    # 1. Try to get git files if inside a repo
    try:
        res = subprocess.run(
            ["git", "ls-files", "--cached", "--others", "--exclude-standard"],
            cwd=target_dir,
            capture_output=True,
            text=True,
            check=True,
        )
        files = res.stdout.splitlines()
        context += "Tracked Files (first 50):\n" + "\n".join(files[:50]) + "\n"
    except Exception:
        # Fallback to local files
        try:
            items = [
                str(p.relative_to(target_dir))
                for p in target_dir.iterdir()
                if not p.name.startswith(".")
            ]
            context += "Files in current directory:\n" + "\n".join(items[:30]) + "\n"
        except Exception as e:
            context += f"Could not list directory: {e}\n"

    # 2. Try to get .gitignore
    gitignore = target_dir / ".gitignore"
    if gitignore.is_file():
        try:
            content = gitignore.read_text(encoding="utf-8", errors="replace")
            # Clip to 1KB
            if len(content) > 1024:
                content = content[:1024] + "\n... [TRUNCATED]"
            context += f"\n.gitignore content:\n{content}\n"
        except Exception:
            pass

    # 3. Try to get README.* and AGENTS.md contents
    try:
        important_files = []
        for p in target_dir.iterdir():
            if not p.is_file():
                continue
            name_lower = p.name.lower()
            if (
                name_lower.startswith("readme.")
                or name_lower == "readme"
                or name_lower == "agents.md"
            ):
                important_files.append(p)

        # Sort by name to make the context deterministic
        important_files.sort(key=lambda x: x.name.lower())

        for p in important_files:
            try:
                content = p.read_text(encoding="utf-8", errors="replace")
                # Clip to 10KB
                if len(content) > 10000:
                    content = content[:10000] + "\n... [TRUNCATED]"
                context += f"\n=== File: {p.name} ===\n{content}\n"
            except Exception:
                pass
    except Exception:
        pass

    return context


def clean_p(p):
    home = str(Path.home())
    s = str(p)
    if s.startswith(home):
        return "~" + s[len(home) :]
    return s


def resolve_selection(results, skills):
    """Rewrite model-selected items to the authoritative skill we discovered.

    Matches each selection to a gathered skill by path first (the model is shown
    real paths and normally echoes them), then by unique name. The emitted
    'name' and 'path' come from the gathered catalog, never the model, so a
    hallucinated or renamed entry cannot reach a consumer like 'skill apply'.
    Unmatched selections are dropped with a warning.
    """
    by_path = {}
    by_name = {}
    for s in skills:
        by_path[str(Path(s["path"]).resolve())] = s
        by_name.setdefault(s["name"], []).append(s)

    resolved = []
    for item in results:
        match = None
        path = item.get("path", "")
        if path:
            match = by_path.get(str(Path(os.path.expanduser(path)).resolve()))
        if match is None:
            candidates = by_name.get(item.get("name", ""), [])
            if len(candidates) == 1:
                match = candidates[0]
        if match is None:
            print(
                f"skill-select: warning: dropping unrecognized selection "
                f"{item.get('name', '?')!r} ({path or 'no path'})",
                file=sys.stderr,
            )
            continue
        resolved.append(
            {
                "name": match["name"],
                "path": match["path"],
                "reason": item.get("reason", ""),
            }
        )
    return resolved


def die(msg):
    print(f"skill-select: {msg}", file=sys.stderr)
    sys.exit(1)


PLUGIN_TEMPLATE = '''"""
Example Plugin for skill-select.
Save this file as ~/.config/skill-select/plugins/my_plugin.py

register() runs on every skill-select invocation. Keep it fast and
side-effect-free: no network calls, subprocesses, or filesystem writes.
"""

def register(api):
    """
    This function is automatically called by `skill-select` when the plugin is loaded.
    You can register your custom skills here using the provided `SkillSelectAPI`.
    """

    # 1. Register a local skill (paths starting with ~ are automatically expanded)
    api.register_skill("my-local-skill", {
        "path": "~/workspace/my-local-skill"
    })

    # 2. Register a GitHub skill
    api.register_skill("my-remote-skill", {
        "repo": "owner/repo",
        "ref": "main",          # Branch, tag, or commit SHA
        "subpath": "skills/my"  # Optional subdirectory within the repo
    })
'''


def usage():
    print("""Usage: skill-select <command> [arguments]

Discover and recommend agent skills, and maintain the catalog of
plugin-provided skills. Plumbing for the higher-level 'skill' tool.

Commands:
  suggest [DIR]   Recommend skills for DIR via the Gemini API (default: cwd)
  catalog         List every available skill and its source
  resolve NAME    Print the source path for a skill
  update NAME...  Re-fetch plugin-provided catalog entries; 'update catalog'
                  refreshes the whole metadata index
  doctor          Diagnose drift in the catalog index (read-only)
  repair          Repair the catalog index (heal missing stubs)

Options:
  --context TEXT       Self-contained context to guide selection (suggest)
  --search-dirs DIRS   Colon-separated skill search directories, overriding
                       SKILL_SOURCE_DIRS (suggest, catalog, resolve)
  --json               Emit structured output (suggest, catalog)
  --help               Display this help message and exit
  --plugin-template    Output a template for creating a skill-select plugin""")
    sys.exit(0)


def compute_search_paths(search_dirs=None):
    """Resolve skill search paths from --search-dirs, SKILL_SOURCE_DIRS, or the
    built-in defaults (which also include the plugin catalog index)."""
    if search_dirs:
        return [Path(p) for p in search_dirs.split(":")]
    env_dirs = os.environ.get("SKILL_SOURCE_DIRS")
    if env_dirs:
        search_paths = [Path(p) for p in env_dirs.split(":")]
    else:
        home = Path.home()
        search_paths = [
            home / ".dotfiles/skills",
            home / ".private/skills",
            home / ".corp/skills",
        ]
    search_paths.append(get_catalog_dir())
    return search_paths


# Pre-subcommand spellings, kept only to point callers at the new syntax.
LEGACY_FLAGS = {
    "--catalog": "catalog",
    "--list": "catalog",
    "--update": "update",
    "--doctor": "doctor",
    "--resolve": "resolve",
    "--repair": "repair",
}


def main():
    argv = sys.argv[1:]

    if "--plugin-template" in argv:
        print(PLUGIN_TEMPLATE)
        sys.exit(0)

    # Help handling: bare invocation, 'help', '--help' anywhere.
    if not argv or argv[0] in ("--help", "help"):
        usage()

    cmd = argv[0]
    args = argv[1:]

    if "--help" in args:
        usage()

    if cmd in LEGACY_FLAGS:
        print(
            f"skill-select: '{cmd}' is now a subcommand: use 'skill-select {LEGACY_FLAGS[cmd]}'",
            file=sys.stderr,
        )
        sys.exit(1)

    plugin_catalog = load_plugins_catalog()

    if cmd == "repair":
        cmd_repair(plugin_catalog)
        sys.exit(0)

    if cmd == "update":
        cmd_update(args, plugin_catalog)
        sys.exit(0)

    if cmd == "doctor":
        cmd_doctor(plugin_catalog)  # exits with its own status

    if cmd in ("catalog", "list"):  # 'list' is a hidden legacy alias
        parser = argparse.ArgumentParser(prog="skill-select catalog", add_help=False)
        parser.add_argument("--json", action="store_true")
        parser.add_argument("--search-dirs")
        opts = parser.parse_args(args)
        source_dirs = [str(p) for p in compute_search_paths(opts.search_dirs)]
        cmd_catalog(plugin_catalog, source_dirs, as_json=opts.json)
        sys.exit(0)

    if cmd == "resolve":
        parser = argparse.ArgumentParser(prog="skill-select resolve", add_help=False)
        parser.add_argument("name")
        parser.add_argument("--search-dirs")
        opts = parser.parse_args(args)
        source_dirs = [str(p) for p in compute_search_paths(opts.search_dirs)]
        cmd_resolve(opts.name, plugin_catalog, source_dirs)
        sys.exit(0)

    if cmd == "suggest":
        parser = argparse.ArgumentParser(prog="skill-select suggest", add_help=False)
        parser.add_argument("dir", nargs="?", default=".")
        parser.add_argument("--context")
        parser.add_argument("--search-dirs")
        parser.add_argument("--json", action="store_true")
        opts = parser.parse_args(args)
        cmd_suggest(opts, plugin_catalog)
        sys.exit(0)

    hint = ""
    if Path(cmd).is_dir():
        hint = " (directory analysis is now 'skill-select suggest DIR')"
    print(f"skill-select: unknown command '{cmd}'{hint}", file=sys.stderr)
    print("Try 'skill-select --help' for more information.", file=sys.stderr)
    sys.exit(1)


def cmd_suggest(args, plugin_catalog):
    search_paths = compute_search_paths(args.search_dirs)

    if not search_paths:
        print(
            "skill-select: Error: No search paths configured. Please set SKILL_SOURCE_DIRS.",
            file=sys.stderr,
        )
        sys.exit(1)

    # Auto-heal the metadata index (TTL-cached) before discovery
    ensure_catalog_index(plugin_catalog)

    skills = gather_skills(search_paths)

    if not skills:
        print("skill-select: No skills found in search paths.", file=sys.stderr)
        sys.exit(0)

    target_dir = Path(args.dir).resolve()
    if not target_dir.is_dir():
        print(
            f"skill-select: Error: target directory '{target_dir}' does not exist.",
            file=sys.stderr,
        )
        sys.exit(1)

    if args.context:
        context_text = args.context
    else:
        context_text = "Standard workspace directory."

    repo_context = gather_context(target_dir)

    try:
        from google import genai
        from google.genai import types
    except ImportError:
        print(
            "skill-select: Error: The 'google-genai' package is required.",
            file=sys.stderr,
        )
        sys.exit(1)

    system_instruction = """
You are a development environment orchestrator.
Your goal is to recommend the best agent "skills" to activate for the given project directory and task.
You will be provided with:
1. The available skills (name and description).
2. The user's goal/context.
3. Information about the target directory (e.g. files, gitignore, READMEs).

Recommend exactly the skills that are directly relevant. Err on the side of caution: if a skill is clearly relevant to the tech stack or task, include it. If it is completely irrelevant, do not include it.

Your response must be ONLY a valid JSON array of objects.
Each object must have:
- "name": the EXACT name of the skill
- "reason": a brief 1-sentence explanation of why it is relevant

Return an empty array [] if no skills apply.
"""

    prompt = f"""
AVAILABLE SKILLS:
{skills}

USER CONTEXT/GOAL:
{context_text}

TARGET DIRECTORY INFO:
{repo_context}
"""

    model_name = os.environ.get("GEMINI_MODEL", "gemini-3.5-flash")
    client = genai.Client()
    try:
        response = client.models.generate_content(
            model=model_name,
            contents=prompt,
            config=types.GenerateContentConfig(
                system_instruction=system_instruction,
                temperature=0.0,
                response_mime_type="application/json",
            ),
        )
    except Exception as e:
        print(f"skill-select: Error calling Gemini API: {e}", file=sys.stderr)
        sys.exit(1)
    import json

    try:
        results = json.loads(response.text)
    except json.JSONDecodeError as e:
        print(
            f"skill-select: Error: Could not parse JSON response: {e}\n{response.text}",
            file=sys.stderr,
        )
        sys.exit(1)

    if not isinstance(results, list):
        print(
            f"skill-select: Error: Expected a JSON array, got: {type(results)}\n{response.text}",
            file=sys.stderr,
        )
        sys.exit(1)

    resolved = resolve_selection(results, skills)

    # Provision plugin skills and update paths to the fully cloned repositories
    for item in resolved:
        name = item["name"]
        if name in plugin_catalog and "repo" in plugin_catalog[name]:
            provision_plugin_skill(name, plugin_catalog[name])
            entry = plugin_catalog[name]
            owner, reponame = entry["repo"].split("/", 1)
            cachedir = get_cache_base() / owner / reponame / entry["ref"]
            if entry["subpath"]:
                cachedir = cachedir / entry["subpath"]
            item["path"] = str(cachedir)

    if args.json:
        for item in resolved:
            print(json.dumps(item))
    else:
        for item in resolved:
            print(item["name"])


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        try:
            sys.stderr.write("\n")
            sys.stderr.flush()
        except Exception:
            pass
        sys.exit(130)
