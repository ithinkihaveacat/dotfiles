EOF
NOPLUGIN_DIR="${TMPDIR}/noplugin"
mkdir -p "$NOPLUGIN_DIR"
cd "$NOPLUGIN_DIR"
if out=$("${SCRIPT}" add coding-standards 2>&1); then
