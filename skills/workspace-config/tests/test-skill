mkdir -p .claude/skills .agents/skills
cat_out=$(SKILL_SOURCE_DIRS="${CAT_CONF_DIR}/dir1:${CAT_CONF_DIR}/dir2" "${SCRIPT}" catalog 2>/dev/null) || true
