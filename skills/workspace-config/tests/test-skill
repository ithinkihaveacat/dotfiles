fi

# Test 59: catalog and doctor flag conflicting skill names across distinct targets
CAT_CONF_DIR="${TMPDIR}/cat-conf"
mkdir -p "${CAT_CONF_DIR}/dir1/conf-skill" "${CAT_CONF_DIR}/dir2/conf-skill"
echo -e "---\nname: conf-skill\n---" >"${CAT_CONF_DIR}/dir1/conf-skill/SKILL.md"
echo -e "---\nname: conf-skill\n---" >"${CAT_CONF_DIR}/dir2/conf-skill/SKILL.md"
