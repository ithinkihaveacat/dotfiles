# ==============================================================================
# PART 6: Doctor & Preflight UI / Output Tests
# ==============================================================================

UI_TEST_DIR="${TMPDIR}/ui-test"
mkdir -p "$UI_TEST_DIR"
cd "$UI_TEST_DIR"
git init -q
mkdir -p .claude/skills .agents/skills

# Set up a healthy environment with 1 skill
export SKILL_SOURCE_DIRS="${TMPDIR}/sources"
