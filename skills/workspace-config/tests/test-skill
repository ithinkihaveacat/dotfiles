#!/usr/bin/env bash

set -euo pipefail

# Find script path relative to test
TEST_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT="${TEST_DIR}/../scripts/skill"

echo "1..53"

# Need a temporary directory for workspace simulations
TMPDIR=$(mktemp -d)
TMPDIR=$(python3 -c "import pathlib; print(pathlib.Path('${TMPDIR}').resolve())")
MOCK_BIN_DIR=$(mktemp -d)
MOCK_HOME="${TMPDIR}/mock_home"
mkdir -p "$MOCK_HOME/.claude" "$MOCK_HOME/.gemini/antigravity-cli"
trap 'rm -rf -- "$TMPDIR" "$MOCK_BIN_DIR"' EXIT

# Create mock executables so skill detects both Claude and Codex paths by default in tests
touch "$MOCK_BIN_DIR/claude" "$MOCK_BIN_DIR/codex"
chmod +x "$MOCK_BIN_DIR/claude" "$MOCK_BIN_DIR/codex"

# Create source skills in a central location
mkdir -p "${TMPDIR}/sources/coding-standards" "${TMPDIR}/sources/emumanager" "${TMPDIR}/sources/test-skill"
# Add dummy SKILL.md to sources so they are valid skills
echo -e "---\nname: coding-standards\ndescription: Rules for coding standards\n---\nbody" >"${TMPDIR}/sources/coding-standards/SKILL.md"
echo -e "---\nname: emumanager\ndescription: Manage emulators\n---\nbody" >"${TMPDIR}/sources/emumanager/SKILL.md"
echo -e "---\nname: test-skill\ndescription: Test skill\n---\nbody" >"${TMPDIR}/sources/test-skill/SKILL.md"

# Set up common environment
# Isolate from the user's/system git config (signing, hooks, templates).
export HOME="$MOCK_HOME"
export GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null
export SKILL_SOURCE_DIRS="${TMPDIR}/sources"
export XDG_CONFIG_HOME="${TMPDIR}/.config"
export XDG_CACHE_HOME="${TMPDIR}/.cache"
export UV_CACHE_DIR="${UV_CACHE_DIR:-$MOCK_HOME/.cache/uv}"
# Ensure p4 is not found by default during Git/Unmanaged tests
export PATH="$MOCK_BIN_DIR:$PATH"

# Write a dummy p4 that fails, to ensure we don't accidentally detect P4
cat <<'EOF' >"$MOCK_BIN_DIR/p4"
#!/usr/bin/env bash
exit 1
EOF
chmod +x "$MOCK_BIN_DIR/p4"

# ==============================================================================
# PART 1: Unmanaged (Default) Workspace Mode
# ==============================================================================
UNMANAGED_DIR="${TMPDIR}/unmanaged"
mkdir -p "$UNMANAGED_DIR"
cd "$UNMANAGED_DIR"

# Test 1: catalog runs
if "${SCRIPT}" catalog >/dev/null 2>&1; then
  echo "ok 1 - [Unmanaged] catalog runs"
else
  echo "not ok 1 - [Unmanaged] catalog failed"
fi

# Test 2: add multiple skills
if "${SCRIPT}" add coding-standards emumanager >/dev/null 2>&1; then
  if [ -L .claude/skills/coding-standards ] && [ -L .agents/skills/emumanager ]; then
    echo "ok 2 - [Unmanaged] add multiple skills"
  else
    echo "not ok 2 - [Unmanaged] add did not create symlinks"
  fi
else
  echo "not ok 2 - [Unmanaged] add failed"
fi

# Test 3: list returns members
if out=$("${SCRIPT}" list 2>/dev/null) && printf '%s' "$out" | grep -q 'coding-standards'; then
  echo "ok 3 - [Unmanaged] list returns members"
else
  echo "not ok 3 - [Unmanaged] list failed"
fi

# Test 4: state file .skills-managed NOT created (stateless model)
if [ ! -f .skills-managed ]; then
  echo "ok 4 - [Unmanaged] state file not created (stateless model)"
else
  echo "not ok 4 - [Unmanaged] state file was created unexpectedly"
fi

# Test 5: clean removes links and does not leave state file
if "${SCRIPT}" clean >/dev/null 2>&1; then
  if [ ! -d .claude ] && [ ! -d .agents ] && [ ! -f .skills-managed ]; then
    echo "ok 5 - [Unmanaged] clean removes links successfully"
  else
    echo "not ok 5 - [Unmanaged] clean left files"
  fi
else
  echo "not ok 5 - [Unmanaged] clean failed"
fi

# ==============================================================================
# PART 2: Git Workspace Mode
# ==============================================================================
GIT_DIR="${TMPDIR}/git_repo"
mkdir -p "$GIT_DIR"
cd "$GIT_DIR"
git init -q
mkdir -p .claude/skills .agents/skills

# Test 6: add multiple skills
if "${SCRIPT}" add coding-standards emumanager >/dev/null 2>&1; then
  if [ -L .claude/skills/coding-standards ] && [ -L .agents/skills/emumanager ]; then
    echo "ok 6 - [Git] add multiple skills"
  else
    echo "not ok 6 - [Git] add did not create symlinks"
  fi
else
  echo "not ok 6 - [Git] add failed"
fi

# Test 7: authoritative state file .git/info/skills NOT created (stateless model)
if [ ! -f .git/info/skills ]; then
  echo "ok 7 - [Git] state file .git/info/skills not created"
else
  echo "not ok 7 - [Git] state file .git/info/skills was created unexpectedly"
fi

# Test 8: info/exclude contains regenerated managed block
if [ -f .git/info/exclude ] && grep -q "managed by 'skill'" .git/info/exclude &&
  grep -q '/.claude/skills/coding-standards' .git/info/exclude; then
  echo "ok 8 - [Git] info/exclude contains managed block"
else
  echo "not ok 8 - [Git] info/exclude missing managed entries"
fi

# Test 9: list --json emits names and resolved paths
if out=$("${SCRIPT}" list --json 2>/dev/null) &&
  printf '%s' "$out" | grep -q '"name": *"coding-standards"' &&
  printf '%s' "$out" | grep -q '"path": *"'; then
  echo "ok 9 - [Git] list --json emits names and paths"
else
  echo "not ok 9 - [Git] list --json failed: $out"
fi

# Test 10: exclude block is regenerable: corrupt it, doctor flags, apply fixes
export AGENT_REQUIRED_SKILLS="coding-standards emumanager"
sed '/skills/d' .git/info/exclude >.git/info/exclude.tmp && mv .git/info/exclude.tmp .git/info/exclude
if "${SCRIPT}" doctor >/dev/null 2>&1; then
  echo "not ok 10 - [Git] doctor should flag exclude drift"
else
  if "${SCRIPT}" apply >/dev/null 2>&1 &&
    grep -q '/.claude/skills/coding-standards' .git/info/exclude &&
    "${SCRIPT}" doctor >/dev/null 2>&1; then
    echo "ok 10 - [Git] doctor flags exclude drift; apply regenerates it"
  else
    echo "not ok 10 - [Git] apply did not restore exclude block"
  fi
fi
export AGENT_REQUIRED_SKILLS="" # Clean up

# Test 11: remove deletes symlink and exclude entry
if "${SCRIPT}" remove emumanager >/dev/null 2>&1; then
  if [ ! -L .agents/skills/emumanager ] && ! grep -q "emumanager" .git/info/exclude &&
    [ ! -f .git/info/skills ]; then
    echo "ok 11 - [Git] remove deletes symlink and exclude entry"
  else
    echo "not ok 11 - [Git] remove left symlink or exclude entry"
  fi
else
  echo "not ok 11 - [Git] remove failed"
fi

# Test 12: clean removes links and exclude block
if "${SCRIPT}" clean >/dev/null 2>&1; then
  if [ ! -L .claude/skills/coding-standards ] && [ ! -f .git/info/skills ] &&
    ! grep -q "coding-standards" .git/info/exclude; then
    echo "ok 12 - [Git] clean removes links and exclude block"
  else
    echo "not ok 12 - [Git] clean left links or exclude block"
  fi
else
  echo "not ok 12 - [Git] clean failed"
fi

# Test 13: from a subdirectory with no local skills dir, 'add' binds to the
# anchor an agent would discover (the repo root), installs there rather than
# scattering a skills dir into the subdirectory, and a 'preflight' run from the
# subdirectory agrees with that install (the apply<->preflight composability
# the cwd-as-root regression broke).
mkdir -p sub
cd sub
export AGENT_REQUIRED_SKILLS="coding-standards"
if "${SCRIPT}" add coding-standards >/dev/null 2>&1; then
  if [ -L ../.claude/skills/coding-standards ] && [ -L ../.agents/skills/coding-standards ] &&
    [ ! -e .claude/skills/coding-standards ] && [ ! -e .agents/skills/coding-standards ] &&
    grep -q "/.claude/skills/coding-standards" ../.git/info/exclude &&
    grep -q "/.agents/skills/coding-standards" ../.git/info/exclude &&
    "${SCRIPT}" preflight claude >/dev/null 2>&1 &&
    [ ! -f ../.git/info/skills ]; then
    echo "ok 13 - [Git] subdirectory add binds to repo-root anchor; preflight agrees"
  else
    echo "not ok 13 - [Git] subdirectory anchor/exclude/preflight mismatch"
  fi
else
  echo "not ok 13 - [Git] add from subdirectory failed"
fi
export AGENT_REQUIRED_SKILLS=""
cd ..
"${SCRIPT}" clean >/dev/null 2>&1 || true

# Test 14: legacy migration (skipped in stateless model)
echo "ok 14 - [Git] legacy exclude-block state migration skipped # SKIP"

# ==============================================================================
# PART 3: Perforce Workspace Mode (standard layout)
# ==============================================================================
# Re-mock p4 command to succeed and return simulated workspace info
cat <<'EOF' >"$MOCK_BIN_DIR/p4"
#!/usr/bin/env bash
if [ "$1" = "info" ]; then
  echo "User name: testuser"
  echo "Client root: $MOCK_CLIENT_ROOT"
  exit 0
