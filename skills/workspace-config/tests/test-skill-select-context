#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "google-genai",
#     "pyyaml",
# ]
# ///
import sys
import tempfile
import importlib.util
from pathlib import Path

from importlib.machinery import SourceFileLoader

# Load skill-select module
test_dir = Path(__file__).resolve().parent
script_path = test_dir.parents[0] / "scripts" / "skill-select"
if not script_path.exists():
    print("1..1")
    print("not ok 1 - skill-select script not found at", script_path)
    sys.exit(1)

loader = SourceFileLoader("skill_select", str(script_path))
spec = importlib.util.spec_from_loader("skill_select", loader)
skill_select = importlib.util.module_from_spec(spec)
try:
    loader.exec_module(skill_select)
except Exception as e:
    print("1..1")
    print(f"not ok 1 - failed to import skill-select: {e}")
    sys.exit(1)

print("1..4")

with tempfile.TemporaryDirectory() as tmpdir:
    tmp_path = Path(tmpdir)

    # Test 1: Empty directory context
    ctx = skill_select.gather_context(tmp_path)
    print("ok 1 - gather_context runs on empty directory")

    # Test 2: .gitignore truncation
    gitignore_file = tmp_path / ".gitignore"
    gitignore_file.write_text("a\n" * 1500)  # 3000 bytes
    ctx = skill_select.gather_context(tmp_path)
    if "[TRUNCATED]" in ctx and ".gitignore content" in ctx:
        print("ok 2 - .gitignore is truncated correctly")
    else:
        print("not ok 2 - .gitignore truncation failed")

    # Test 3: README.* gathering
    readme_file = tmp_path / "README.md"
    readme_file.write_text(
        "This is a README file.\n" + "hello\n" * 2000
    )  # > 10000 chars
    ctx = skill_select.gather_context(tmp_path)
    if (
        "=== File: README.md ===" in ctx
        and "[TRUNCATED]" in ctx
        and "This is a README file." in ctx
    ):
        print("ok 3 - README.md is gathered and truncated to 10KB")
    else:
        print("not ok 3 - README.md gathering failed")

    # Test 4: AGENTS.md gathering
    agents_file = tmp_path / "AGENTS.md"
    agents_file.write_text("This is an AGENTS file.")
    ctx = skill_select.gather_context(tmp_path)
    if "=== File: AGENTS.md ===" in ctx and "This is an AGENTS file." in ctx:
        print("ok 4 - AGENTS.md is gathered successfully")
    else:
        print("not ok 4 - AGENTS.md gathering failed")
